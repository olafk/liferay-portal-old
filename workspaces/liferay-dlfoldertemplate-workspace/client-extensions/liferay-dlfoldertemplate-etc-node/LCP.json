{
	"cpu": 1,
	"env": {
		"COM_LIFERAY_LXC_DXP_DOMAINS": "liferay:8080",
		"COM_LIFERAY_LXC_DXP_MAIN_DOMAIN": "liferay:8080",
		"COM_LIFERAY_LXC_DXP_SERVER_PROTOCOL": "http",
		"LIFERAY_DLFOLDERTEMPLATE_ETC_NODE_OAUTH_APPLICATION_SERVER_OAUTH2_HEADLESS_SERVER_CLIENT_ID": "",
		"LIFERAY_DLFOLDERTEMPLATE_ETC_NODE_OAUTH_APPLICATION_SERVER_OAUTH2_HEADLESS_SERVER_CLIENT_SECRET": "",
		"LIFERAY_DLFOLDERTEMPLATE_ETC_NODE_OAUTH_APPLICATION_USER_AGENT_OAUTH2_USER_AGENT_CLIENT_ID": "",
		"LIFERAY_ROUTES_CLIENT_EXTENSION": "/etc/liferay/lxc/ext-init-metadata",
		"LIFERAY_ROUTES_DXP": "/etc/liferay/lxc/dxp-metadata"
	},
	"environments": {
		"infra": {
			"deploy": false
		}
	},
	"id": "liferaydlfoldertemplateetcnode",
	"kind": "Deployment",
	"livenessProbe": {
		"httpGet": {
			"path": "/ready",
			"port": 8050
		}
	},
	"loadBalancer": {
		"targetPort": 8050
	},
	"memory": 512,
	"ports": [
		{
			"external": true,
			"port": 8050
		}
	],
	"readinessProbe": {
		"httpGet": {
			"path": "/ready",
			"port": 8050
		}
	},
	"scale": 1
}
