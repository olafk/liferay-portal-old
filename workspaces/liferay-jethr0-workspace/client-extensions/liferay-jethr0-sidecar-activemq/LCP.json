{
	"cpu": 1.0,
	"env": {
		"ANONYMOUS_LOGIN": "false",
		"ARTEMIS_CLUSTER_PASSWORD": "artemis-cluster",
		"ARTEMIS_CLUSTER_SLAVE": "false",
		"ARTEMIS_CLUSTER_USER": "artemis-cluster",
		"ARTEMIS_PASSWORD": "artemis",
		"ARTEMIS_USER": "artemis"
	},
	"id": "__PROJECT_ID__",
	"kind": "Deployment",
	"livenessProbe": {
		"httpGet": {
			"path": "/",
			"port": 8161
		}
	},
	"memory": 1024,
	"ports": [
		{
			"external": true,
			"port": 8161,
			"protocol": "TCP",
			"targetPort": 8161
		},
		{
			"external": true,
			"port": 61616,
			"protocol": "TCP",
			"targetPort": 61616
		}
	],
	"readinessProbe": {
		"httpGet": {
			"path": "/",
			"port": 8161
		}
	},
	"scale": 1,
	"volumes": {
		"activemqdata": "/opt/activemq/data"
	}
}