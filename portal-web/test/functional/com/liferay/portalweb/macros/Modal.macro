definition {

	@summary = "Default summary"
	macro gotoNavTab(navTab = null) {
		var key_tab = ${navTab};

		if (IsElementNotPresent(locator1 = "Modal#ACTIVE_TAB_LINK")) {
			Click(locator1 = "Modal#TAB_LINK");
		}

		AssertElementPresent(locator1 = "Modal#ACTIVE_TAB_LINK");
	}

	@summary = "Default summary"
	macro publish(warningMessage = null, action = null) {
		if (!(isSet(index))) {
			var index = 1;
		}

		AssertTextEquals(
			index = ${index},
			locator1 = "Modal#BODY_MESSAGE",
			value1 = ${warningMessage});

		if (${action} == "Cancel") {
			Click(
				key_text = "Cancel",
				locator1 = "Modal#MODAL_FOOTER_BUTTON");
		}
		else if (${action} == "Continue") {
			Click(
				key_text = "Continue",
				locator1 = "Modal#MODAL_FOOTER_BUTTON");

			Alert.viewSuccessMessage();
		}
		else {
			Click(
				key_text = "Publish",
				locator1 = "Modal#MODAL_FOOTER_BUTTON");

			Alert.viewSuccessMessage();
		}
	}

	@summary = "Default summary"
	macro save() {
		Click(
			key_text = "Save",
			locator1 = "Modal#MODAL_FOOTER_BUTTON");

		Alert.viewSuccessMessage();
	}

}