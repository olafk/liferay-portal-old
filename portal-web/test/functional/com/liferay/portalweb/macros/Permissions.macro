	@summary = "Default summary"
	macro setUpSiteTeamRoleLoginUserPG(userEmailAddressVariation = null, teamName = null, userEmailAddress = null, siteName = null, userFirstName = null, teamDescription = null, userLoginEmailAddress = null, userLastName = null, userScreenName = null, userMiddleName = null, userGender = null, userLoginFullName = null, userNameIsNotFound = null, userBirthday = null) {
		JSONUser.addUser(
			userBirthday = ${userBirthday},
			userEmailAddress = ${userEmailAddress},
			userEmailAddressVariation = ${userEmailAddressVariation},
			userFirstName = ${userFirstName},
			userGender = ${userGender},
			userLastName = ${userLastName},
			userMiddleName = ${userMiddleName},
			userScreenName = ${userScreenName});

		JSONUser.setFirstPassword(
			agreeToTermsAndAnswerReminderQuery = "true",
			requireReset = "false",
			userEmailAddress = ${userEmailAddress});

		HeadlessSite.addSite(siteName = ${siteName});

		JSONGroup.assignUserToGroup(
			groupName = ${siteName},
			userEmailAddress = ${userEmailAddress});

		JSONTeam.addTeam(
			siteName = ${siteName},
			teamDescription = ${teamDescription},
			teamName = ${teamName});

		PagesAdmin.openPagesAdmin(siteURLKey = ${siteName});

		ProductMenu.gotoPortlet(
			category = "People",
			portlet = "Teams");

		Team.assignMembersCP(
			siteName = ${siteName},
			teamName = ${teamName},
			userFirstName = ${userFirstName},
			userLastName = ${userLastName},
			userNameIsNotFound = ${userNameIsNotFound},
			userScreenName = ${userScreenName});

		User.logoutAndLoginPG(
			userLoginEmailAddress = ${userLoginEmailAddress},
			userLoginFullName = ${userLoginFullName});
	}

}