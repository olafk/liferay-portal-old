			locator1 = "LexiconList#LIST_ENTRY_ELLIPSIS");

		ClickNoError(
			key_menuItem = "Delete",
			locator1 = "MenuItem#DROPDOWN_MENU_ITEM");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro moveToRecycleBinDraftCP(entryTitle = null) {
