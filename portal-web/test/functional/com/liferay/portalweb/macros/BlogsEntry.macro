		SelectFrameTop(value1 = "relative=top");

		AssertVisible(
			key_coverImageName = ${coverImageName},
			locator1 = "BlogsEntry#ENTRY_COVER_IMAGE_UNPUBLISHED");
	}

	@summary = "Default summary"
