	@summary = "Default summary"
	macro scheduleBlogEntry() {
		Panel.expandPanel(panel = "Configuration");

		var displayDate = DateUtil.getFormattedCurrentDate("MM/dd/yyyy");

		echo("## * displayDate: ${displayDate}");

		Type(
			locator1 = "TextInput#DISPLAY_DATE",
			value1 = ${displayDate});

		var displayTime = DateUtil.getDateOffsetByMinutes(2, "hh:mm a");

		var displayTime = StringUtil.removeSpaces(${displayTime});

		Type.sendKeys(
			locator1 = "TextInput#DISPLAY_DATE_TIME",
			value1 = ${displayTime});
	}

	@summary = "Default summary"
	macro searchCP(position = null, entryTitle = null, entryContent = null, entrySearchTerm = null) {
		var key_entryContent = ${entryContent};
		var key_entryTitle = ${entryTitle};

		AssertElementPresent(locator1 = "Blogs#SEARCH_KEYWORDS");

		Type(
			locator1 = "Blogs#SEARCH_KEYWORDS",
			value1 = ${entrySearchTerm});

		KeyPress(
			locator1 = "Blogs#SEARCH_KEYWORDS",
			value1 = "\RETURN");

		WaitForLiferayEvent.initializeLiferayEventLog();

		Blogs.viewEntryTitle(
			entryTitle = ${entryTitle},
			position = ${position});

		if (isSet(relevance)) {
			ManagementBar.viewFilterAndOrderSelectedItem(menuItem = "Relevance");
		}
	}

	@summary = "Default summary"
	macro searchNoCP(entryTitle = null, entryContent = null, entrySearchTerm = null) {
		var key_entryContent = ${entryContent};
		var key_entryTitle = ${entryTitle};

		AssertElementPresent(locator1 = "Blogs#SEARCH_KEYWORDS");

		Type(
			locator1 = "Blogs#SEARCH_KEYWORDS",
			value1 = ${entrySearchTerm});

		KeyPress(
			locator1 = "Blogs#SEARCH_KEYWORDS",
			value1 = "\RETURN");

		WaitForLiferayEvent.initializeLiferayEventLog();

		AssertTextEquals.assertPartialText(
			locator1 = "Message#EMPTY_INFO",
			value1 = "No entries were found.");

		Blogs.viewEntryNotPresent(entryTitle = ${entryTitle});
	}

	@summary = "Default summary"
