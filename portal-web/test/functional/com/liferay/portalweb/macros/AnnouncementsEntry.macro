definition {

	@summary = "Default summary"
	macro addEntryWithFutureDate(distributionScope = null, entryURL = null, minutesAdjustmentValue = null, entryTitle = null, entryContent = null) {
		AssertClick(
			locator1 = "Button#ADD_ANNOUNCEMENT",
			value1 = "Add Announcement");

		AssertElementPresent(locator1 = "TextInput#TITLE");

		Type(
			locator1 = "TextInput#TITLE",
			value1 = ${entryTitle});

		SelectFrame.selectFrameNoLoading(locator1 = "CKEditor#BODY_FIELD_IFRAME");

		KeyPress(
			locator1 = "CKEditor#BODY",
			value1 = ${entryContent});

		SelectFrame(value1 = "relative=top");

		Panel.expandPanel(panel = "Configuration");

		Select(
			locator1 = "AnnouncementsManageEntries#DISTRIBUTION_SCOPE_SELECT",
			value1 = ${distributionScope});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${entryURL});

		ScrollWebElementIntoView(locator1 = "Button#SAVE");

		Uncheck(locator1 = "Checkbox#DISPLAY_IMMEDIATELY");

		var displayDateDay = DateUtil.getCurrentDate();
		var displayDateMonth = DateUtil.getCurrentMonth();
		var displayDateYear = DateUtil.getCurrentYear();

		var displayDate = "${displayDateMonth}/${displayDateDay}/${displayDateYear}";

		Type(
			locator1 = "TextInput#DISPLAY_DATE",
			value1 = ${displayDate});

		var displayTime = DateUtil.getDateOffsetByMinutes(${minutesAdjustmentValue}, "hh:mm a");

		echo("display Time: ${displayTime}");

		var displayTime = StringUtil.removeSpaces(${displayTime});

		Type.sendKeys(
			locator1 = "TextInput#DISPLAY_DATE_TIME",
			value1 = ${displayTime});

		Button.clickSave();
	}

	@summary = "Default summary"
	macro addPG(distributionScope = null, entryURL = null, priority = null, entryTitle = null, entryContent = null, expirationDate = null) {
		AssertClick(
			locator1 = "Button#ADD_ANNOUNCEMENT",
			value1 = "Add Announcement");

		AssertElementPresent(locator1 = "TextInput#TITLE");

		Type(
			locator1 = "TextInput#TITLE",
			value1 = ${entryTitle});

		CKEditor.addContent(content = ${entryContent});

		Panel.expandPanel(panel = "Configuration");

		Select(
			locator1 = "AnnouncementsManageEntries#DISTRIBUTION_SCOPE_SELECT",
			value1 = ${distributionScope});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${entryURL});

		if (isSet(priority)) {
			Select(
				locator1 = "Announcements#PRIORITY_SELECT",
				value1 = ${priority});
		}

		if (isSet(expirationDate)) {
			ScrollWebElementIntoView(locator1 = "Button#SAVE");

			Type(
				locator1 = "TextInput#EXPIRATION_DATE",
				value1 = ${expirationDate});

			Button.clickSave();
		}

		if (isSet(pastDate)) {
			Alert.viewRequestFailedToComplete();
		}
		else {
			PortletEntry.save();
		}
	}

	@summary = "Default summary"
	macro deletePG(entryTitle = null) {
		AssertTextEquals(
			key_entryTitle = ${entryTitle},
			locator1 = "Announcements#CARD_VIEW_ENTRY_TITLE",
			value1 = ${entryTitle});

		Click.waitForMenuToggleJSClick(locator1 = "Announcements#CARD_VIEW_ENTRY_VERTICAL_ELLIPSIS");

		MenuItem.clickNoError(menuItem = "Delete");

		AssertConfirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");
	}

	@summary = "Default summary"
	macro editPG(entryContentEdit = null, distributionScope = null, entryTitleEdit = null, entryTitle = null, entryContent = null, entryURLEdit = null) {
		var key_distributionScope = ${distributionScope};
		var key_entryTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "Announcements#CARD_VIEW_ENTRY_TITLE",
			value1 = ${entryTitle});

		AssertTextEquals(
			locator1 = "Announcements#CARD_VIEW_ENTRY_SCOPE",
			value1 = ${distributionScope});

		AssertTextEquals(
			key_entryContent = ${entryContent},
			locator1 = "Announcements#CARD_VIEW_ENTRY_CONTENT",
			value1 = ${entryContent});

		Click.waitForMenuToggleJSClick(locator1 = "Announcements#CARD_VIEW_ENTRY_VERTICAL_ELLIPSIS");

		WaitForLiferayEvent.initializeLiferayEventLog();

		MenuItem.click(menuItem = "Edit");

		AssertTextEquals(
			locator1 = "TextInput#TITLE",
			value1 = ${entryTitle});

		Type(
			locator1 = "TextInput#TITLE",
			value1 = ${entryTitleEdit});

		SelectFrame.selectFrameNoLoading(locator1 = "CKEditor#BODY_FIELD_IFRAME");

		Type(
			locator1 = "CKEditor#BODY",
			value1 = ${entryContentEdit});

		SelectFrame(value1 = "relative=top");

		Panel.expandPanel(panel = "Configuration");

		Type(
			locator1 = "TextInput#URL",
			value1 = ${entryURLEdit});

		Button.clickSave();
	}

	@summary = "Default summary"
	macro markAsReadPG(tabName = null, siteURLKey = null, entryContent = null, layoutName = null) {
		var key_entryContent = ${entryContent};

		AnnouncementsNavigator.openToEntriesTab(
			layoutName = ${layoutName},
			siteURLKey = ${siteURLKey},
			tabName = ${tabName});

		AssertVisible(locator1 = "Announcements#CARD_VIEW_ENTRY_VERTICAL_ELLIPSIS");

		Click.waitForMenuToggleJSClick(locator1 = "Announcements#CARD_VIEW_ENTRY_VERTICAL_ELLIPSIS");

		MenuItem.clickNoError(menuItem = "Mark as Read");

		AssertElementNotPresent(locator1 = "Announcements#CARD_VIEW_ENTRY_CONTENT");
	}

	@summary = "Default summary"
	macro tearDownCP() {
		AnnouncementsNavigator.opentoAdmin(
			groupName = "Guest",
			siteURLKey = "guest");

		while (IsElementNotPresent(locator1 = "Message#EMPTY_INFO")) {
			PortletEntry.selectAll();

			ClickNoError(locator1 = "Icon#DELETE");

			AssertConfirm(value1 = "Are you sure you want to delete the selected entries? They will be deleted immediately.");
		}

		AssertTextEquals.assertPartialText(
			locator1 = "Message#EMPTY_INFO",
			value1 = "No entries were found.");
	}

	@summary = "Default summary"
	macro viewList(distributionScope = null, entryTitle = null) {
		var key_entryTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "Blogs#ENTRY_TABLE_TITLE",
			value1 = ${entryTitle});

		AssertTextEquals(
			locator1 = "Blogs#ENTRY_TABLE_AUTHOR",
			value1 = ${distributionScope});
	}

	@summary = "Default summary"
	macro viewNoAdmin() {
		AssertTextEquals(
			locator1 = "Message#NO_ENTRIES",
			value1 = "No entries were found.");
	}

	@summary = "Default summary"
	macro viewNoPG(entryTitle = null) {
		var key_entryTitle = ${entryTitle};

		AssertTextNotPresent(
			locator1 = "Announcements#CARD_VIEW_ENTRY_TITLE",
			value1 = ${entryTitle});
	}

	@summary = "Default summary"
	macro viewPG(distributionScope = null, priority = null, entryTitle = null, entryContent = null) {
		var key_distributionScope = ${distributionScope};
		var key_entryTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "Announcements#CARD_VIEW_ENTRY_TITLE",
			value1 = ${entryTitle});

		AssertTextEquals(
			locator1 = "Announcements#CARD_VIEW_ENTRY_SCOPE",
			value1 = ${distributionScope});

		if (isSet(priority)) {
			AssertTextEquals(
				locator1 = "Announcements#PRIORITY_IMPORTANT",
				value1 = ${priority});
		}

		var key_entryContent = ${entryContent};

		AssertTextEquals(
			locator1 = "Announcements#CARD_VIEW_ENTRY_CONTENT",
			value1 = ${entryContent});
	}

	@summary = "Default summary"
	macro viewReadPG(distributionScope = null, announcementType = null, entryTitle = null, entryContent = null) {
		Click(
			locator1 = "Announcements#NAVIGATION_ENTRIES_READ",
			value1 = "Read");

		AnnouncementsEntry.viewPG(
			announcementType = ${announcementType},
			distributionScope = ${distributionScope},
			entryContent = ${entryContent},
			entryTitle = ${entryTitle},
			key_distributionScope = ${distributionScope},
			key_entryTitle = ${entryTitle});
	}

}