definition {

	@summary = "Default summary"
	macro assertColumnNotPresent(key_field = null) {
		AssertElementNotPresent(
			key_field = ${key_field},
			locator1 = "FrontendDataSet#TABLE_ITEM_COLUMN");
	}

	@summary = "Default summary"
	macro assertColumnPresent(key_field = null) {
		AssertElementPresent(
			key_field = ${key_field},
			locator1 = "FrontendDataSet#TABLE_ITEM_COLUMN");
	}

	@summary = "Default summary"
	macro assertCustomViewName(key_nameCustomView = null) {
		AssertElementPresent(
			locator1 = "FrontendDataSet#SELECT_CUSTOM_VIEW",
			value1 = ${key_nameCustomView});
	}

	@summary = "Default summary"
	macro assertFilterSummaryLabel(key_filter = null) {
		AssertElementPresent(
			locator1 = "FrontendDataSet#FILTER_SUMMARY_LABEL",
			value1 = ${key_filter});
	}

	@summary = "Default summary"
	macro assertMenuItem(key_menuItem = null) {
		AssertElementPresent(
			key_itemName = ${key_menuItem},
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW");
	}

	@summary = "Default summary"
	macro changeCustomView(key_itemName = null) {
		Click(locator1 = "FrontendDataSet#SELECT_CUSTOM_VIEW");

		Click(
			key_optionName = ${key_itemName},
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW");
	}

	@summary = "Default summary"
	macro compareValue(key_columnIndex = null, key_valueIndex2 = null, key_valueIndex1 = null) {
		var dataSetValue1 = FrontendDataSetCustomView.getValueByPosition(
			columnIndex = ${key_columnIndex},
			valueIndex = ${key_valueIndex1});
		var dataSetValue2 = FrontendDataSetCustomView.getValueByPosition(
			columnIndex = ${key_columnIndex},
			valueIndex = ${key_valueIndex2});

		TestUtils.isGreaterThan(
			actual = ${dataSetValue1},
			expected = ${dataSetValue2});
	}

	@summary = "Default summary"
	macro createNewView(entryName = null) {
		Click(locator1 = "FrontendDataSet#SELECT_OPTION_HEADER");

		Click(
			key_itemName = "Save View As...",
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW");

		Type(
			locator1 = "FrontendDataSet#INPUT_CUSTOM_VIEW_NAME",
			value1 = ${entryName});

		Click(
			key_name = "Save",
			locator1 = "Button#GENERAL_BUTTON_MODAL_FOOTER");
	}

	@summary = "Default summary"
	macro deleteView() {
		Click(locator1 = "FrontendDataSet#SELECT_OPTION_HEADER");

		Click(
			key_itemName = "Delete View",
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW");

		AssertTextEquals(
			locator1 = "Modal#BODY",
			value1 = "Are you sure you want to delete this? It will be deleted immediately.");

		Click(
			key_text = "Delete",
			locator1 = "Modal#MODAL_FOOTER_BUTTON");
	}

	@summary = "Default summary"
	macro editCurrentViewName(entryName = null) {
		Click(locator1 = "FrontendDataSet#SELECT_OPTION_HEADER");

		Click(
			key_itemName = "Rename View",
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW");

		Type(
			locator1 = "FrontendDataSet#INPUT_CUSTOM_VIEW_NAME",
			value1 = ${entryName});

		Click(
			key_name = "Save",
			locator1 = "Button#GENERAL_BUTTON_MODAL_FOOTER");
	}

	@summary = "Default summary"
	macro getValueByPosition(valueIndex = null, columnIndex = null) {
		var key_columnIndex = ${columnIndex};
		var key_valueIndex = ${valueIndex};
		var dataSetValue = selenium.getText("FrontendDataSet#TABLE_CELL");

		return ${dataSetValue};
	}

	@summary = "Default summary"
	macro saveCustomView() {
		Click(locator1 = "FrontendDataSet#SELECT_OPTION_HEADER");

		Click(
			key_itemName = "Save View",
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW");
	}

	@summary = "Default summary"
	macro saveViewAs(entryName = null) {
		Click(locator1 = "FrontendDataSet#SELECT_CUSTOM_VIEW");

		Click(
			key_itemName = "Save View As",
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW");

		Type(
			locator1 = "FrontendDataSet#INPUT_CUSTOM_VIEW_NAME",
			value1 = ${entryName});

		Click(
			key_name = "Save",
			locator1 = "Button#GENERAL_BUTTON_MODAL_FOOTER");
	}

	@summary = "Default summary"
	macro selectColumn(key_itemName = null) {
		Click(
			ariaLabel = "Open Fields Menu",
			locator1 = "Button#ANY_WITH_ARIA_LABEL");

		Click(
			key_itemName = ${key_itemName},
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW");
	}

	@summary = "Default summary"
	macro selectView(key_itemName = null) {
		Click(
			locator1 = "FrontendDataSet#SELECT_OPTION_CUSTOM_VIEW",
			value1 = ${key_itemName});
	}

	@summary = "Default summary"
	macro verifyCustomView(key_nameCustomView = null) {
		VerifyElementPresent(
			locator1 = "FrontendDataSet#SELECT_CUSTOM_VIEW",
			value1 = ${key_nameCustomView});
	}

	@summary = "Default summary"
	macro verifyFilterSummaryLabel(key_filter = null) {
		VerifyElementPresent(
			locator1 = "FrontendDataSet#FILTER_SUMMARY_LABEL",
			value1 = ${key_filter});
	}

	@summary = "Default summary"
	macro viewNoColumn(key_field = null) {
		AssertElementNotPresent(
			key_field = ${key_field},
			locator1 = "FrontendDataSet#TABLE_ITEM_COLUMN");
	}

}