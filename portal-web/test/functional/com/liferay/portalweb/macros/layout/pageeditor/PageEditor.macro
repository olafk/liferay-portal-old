	}

	@summary = "Default summary"
	macro viewCommentReply(commentReply = null, user = null) {
		if (isSet(fromNotifications)) {
			AssertTextEquals(
				key_commentReply = ${commentReply},
				locator1 = "PageEditor#FRAGMENT_SIDEBAR_REPLY_COMMENTS_ENTRY_HIGHLIGHTED",
