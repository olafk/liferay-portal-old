	@description = "This is a use case for LPS-147329."
	@priority = 3
	test ViewOOTBElementsLocalization {
		task ("Assert the title and description of an OOTB Element within the Blueprint query builder add element sidebar are not using language keys") {
			Blueprints.openBlueprintsAdmin();

			Blueprints.createBlueprint(title = "Test Blueprint");

			Blueprints.addElement(element = "Limit Search to PDF files");

			AssertTextNotEquals.assertNotPartialMatch(
				key_element = "Limit Search to PDF files",
				locator1 = "Blueprints#BLUEPRINTS_ADD_ELEMENTS_SIDEBAR_ELEMENT_DESCRIPTION",
				value1 = "limit-search-to-pdf-files-description");
		}

		task ("Assert the title and description of an OOTB Element instance within the Blueprint query builder are not using language keys") {
			AssertElementNotPresent(
				key_element = "limit-search-to-pdf-files",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT");

			AssertElementNotPresent(
				key_element = "limit-search-to-pdf-files-description.",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT");

			PortletEntry.save();
		}

		task ("Assert the title and description of an OOTB Element JSON Configuration are using language keys") {
			Navigator.gotoNavItem(navItem = "Elements");

			Blueprints.gotoElement(element = "Limit Search to PDF files");

			AssertTextEquals.assertPartialText(
				locator1 = "Blueprints#CODE_MIRROR_EDITOR",
				value1 = "limit-search-to-pdf-files");

			AssertTextEquals.assertPartialText(
				locator1 = "Blueprints#CODE_MIRROR_EDITOR",
				value1 = "limit-search-to-pdf-files-description");
		}

		Navigator.gotoBack();

		task ("Assert the title and description of an OOTB Element on the Elements admin page is translated when using Hungarian locale") {
			Navigator.ensureLocaleURL(locale = "hu");

			Blueprints.viewEntryTitle(title = "A keress korltozsa PDF-fjlokra");

			Blueprints.viewEntryDescription(
				description = "A keress korltozsa a mimeType mezben meghatrozott PDF-fjlokra.",
				title = "A keress korltozsa PDF-fjlokra");
		}

		task ("Assert the title and description of an OOTB Element within the Blueprint query builder add element sidebar is translated when using Hungarian locale") {
			Blueprints.openBlueprintsAdmin();

			Blueprints.gotoBlueprint(title = "Test Blueprint");

			Blueprints.searchAddElementsSidebar(element = "keress");

			AssertElementPresent(
				key_element = "A keress korltozsa PDF-fjlokra",
				locator1 = "Blueprints#BLUEPRINTS_ADD_ELEMENTS_SIDEBAR_ELEMENT_NAME");

			AssertTextEquals.assertPartialText(
				key_element = "A keress korltozsa PDF-fjlokra",
				locator1 = "Blueprints#BLUEPRINTS_ADD_ELEMENTS_SIDEBAR_ELEMENT_DESCRIPTION",
				value1 = "A keress korltozsa a mimeType mezben meghatrozott PDF-fjlokra");
		}

		task ("Assert the title and description of an added OOTB Element instance within the Blueprint query builder is translated when using Hungarian locale") {
			AssertElementPresent(
				key_element = "A keress korltozsa PDF-fjlokra",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT");

			AssertElementPresent(
				key_element = "A keress korltozsa a mimeType mezben meghatrozott PDF-fjlokra.",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT");
		}
	}

