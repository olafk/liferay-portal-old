		SelectWindow(value1 = "Search Blueprints Configuration Reference - Liferay Learn");

		Close.closeAndSelectWindow(value1 = "Edit Blueprint - ${siteName}");

		Click(
			key_linkContext = "Override the default search highlight configuration",
			key_linkText = "Learn more",
			locator1 = "Blueprints#DOC_LINK_GENERIC");

		SelectWindow(value1 = "Search Blueprints Configuration Reference - Liferay Learn");

		Close.closeAndSelectWindow(value1 = "Edit Blueprint - ${siteName}");

		Click(
			key_linkContext = "Add sorts to those already present in the search request",
			key_linkText = "Learn more",
			locator1 = "Blueprints#DOC_LINK_GENERIC");

		SelectWindow(value1 = "Search Blueprints Configuration Reference - Liferay Learn");

		Close.closeAndSelectWindow(value1 = "Edit Blueprint - ${siteName}");

		Click(
			key_linkContext = "Declare new template variables from search context attributes",
			key_linkText = "Learn more",
			locator1 = "Blueprints#DOC_LINK_GENERIC");

		SelectWindow(value1 = "Search Blueprints Configuration Reference - Liferay Learn");

		Close.closeAndSelectWindow(value1 = "Edit Blueprint - ${siteName}");

		Click(
			key_linkContext = "Add source includes and excludes as search request parameters",
			key_linkText = "Learn more",
			locator1 = "Blueprints#DOC_LINK_GENERIC");

		SelectWindow(value1 = "Search Blueprints Configuration Reference - Liferay Learn");

		Close.closeAndSelectWindow(value1 = "Edit Blueprint - ${siteName}");

		ClickNoError(
			key_text = "Cancel",
			locator1 = "Link#ANY");

		Blueprints.gotoElement(element = "Text Match Over Multiple Fields");

		Click(locator1 = "Blueprints#INFO_BUTTON");

		Click(
