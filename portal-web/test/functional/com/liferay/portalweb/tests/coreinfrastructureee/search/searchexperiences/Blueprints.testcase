	@priority = 3
	test ViewElementLocalizationWithinElementsAdmin {
		Blueprints.openBlueprintsAdmin();

		Navigator.gotoNavItem(navItem = "Elements");

		Click(locator1 = "Button#PLUS");

		PortletEntry.inputTitle(title = "Title in English");

		PortletEntry.inputDescription(description = "Description in English");

		Button.click(button = "Create");

		Click(
			ariaLabel = "Edit Title",
			locator1 = "Blueprints#BLUEPRINTS_EDIT_PAGE_HEADER_TITLE");

		Blueprints.setTitleAndDescriptionLocalization(
			currentLocale = "en-US",
			description = "Descripcin en Espaol",
			locale = "es-ES",
			title = "Ttulo en Espaol");

		Button.clickDone();

		var elementSourceJson = '''
{
	"description_i18n": {
		"en_US": "Description in English",
		"es_ES": "Descripcin en Espaol",
		"de_DE": "Beschreibung auf Deutsch"
	},
	"elementDefinition": {
		"category": "custom",
		"configuration": {},
		"icon": "custom-field"
	},
	"title_i18n": {
		"en_US": "Title in English",
		"es_ES": "Ttulo en Espaol",
		"de_DE": "Titel auf Deutsch"
	},
	"type": 0
}
		''';

		Type.typeCodeMirrorEditorNoError(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = ${elementSourceJson});

		WaitForElementPresent(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = "de_DE&quot: &quotTitel auf Deutsch");

		AssertTextEquals.assertPartialText(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = "\"es_ES\": \"Ttulo en Espaol\"");

		AssertTextEquals.assertPartialText(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = "\"es_ES\": \"Descripcin en Espaol\"");

		Click(
			ariaLabel = "Edit Title",
			locator1 = "Blueprints#BLUEPRINTS_EDIT_PAGE_HEADER_TITLE");

		Blueprints.viewTitleAndDescriptionLocalization(
			currentLocale = "en-US",
			description = "Beschreibung auf Deutsch",
			locale = "de-DE",
			title = "Titel auf Deutsch");

		PortletEntry.save();

		Blueprints.viewEntryTitle(title = "Title in English");

		Blueprints.viewEntryDescription(
			description = "Description in English",
			title = "Title in English");

		Blueprints.gotoEntry(title = "Title in English");

		Click(locator1 = "Button#PREVIEW");

		AssertElementPresent(
			key_text = "Title in English",
			locator1 = "Blueprints#ELEMENT_EDIT_PAGE_PREVIEW_TEXT");

		AssertElementPresent(
			key_text = "Description in English",
			locator1 = "Blueprints#ELEMENT_EDIT_PAGE_PREVIEW_TEXT");

		Navigator.gotoBack();

		Navigator.ensureLocaleURL(locale = "es");

		Blueprints.viewEntryTitle(title = "Ttulo en Espaol");

		Navigator.gotoNavItem(navItem = "Elementos");

		Blueprints.viewEntryDescription(
			description = "Descripcin en Espaol",
			title = "Ttulo en Espaol");

		Blueprints.openBlueprintsAdmin(locale = "de");

		Navigator.gotoNavItem(navItem = "Elemente");

		Blueprints.viewEntryTitle(title = "Titel auf Deutsch");

		Blueprints.viewEntryDescription(
			description = "Beschreibung auf Deutsch",
			title = "Titel auf Deutsch");

		Blueprints.gotoEntry(title = "Titel auf Deutsch");

		Click(locator1 = "//button[contains(.,'Vorschau')]");

		AssertElementPresent(
			key_text = "Titel auf Deutsch",
			locator1 = "Blueprints#ELEMENT_EDIT_PAGE_PREVIEW_TEXT");

		AssertElementPresent(
			key_text = "Beschreibung auf Deutsch",
			locator1 = "Blueprints#ELEMENT_EDIT_PAGE_PREVIEW_TEXT");
	}

