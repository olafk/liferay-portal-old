	@priority = 3
	test ViewQueryBuilderAssetCategorySingleSelectField {
		JSONCategory.addVocabulary(
			groupName = "Guest",
			title = "Test Vocabulary");

		var categoryId = JSONCategory.addCategory(
			groupName = "Guest",
			title = "Test Category",
			vocabularyName = "Test Vocabulary");

		var categoryERC = JSONCategory.getCategoryFieldValueById(
			categoryId = ${categoryId},
			fieldName = "externalReferenceCode");

		Blueprints.openBlueprintsAdmin();

		var elementSourceJson = '''
	{
	"description_i18n": {},
	"elementDefinition": {
		"category": "conditional",
		"configuration": {
			"queryConfiguration": {
				"queryEntries": [
					{
						"clauses": [
							{
								"context": "query",
								"occur": "filter",
								"query": {
									"bool": {
										"must_not": [
											{
												"terms": {
													"groupAssetCategoryExternalReferenceCode": "${configuration.group_asset_category_external_reference_code}"
												}
											}
										]
									}
								}
							}
						]
					}
				]
			}
		},
		"icon": "hidden",
		"uiConfiguration": {
			"fieldSets": [
				{
					"fields": [
						{
							"label": "Asset Category External Reference Codes",
							"name": "group_asset_category_external_reference_code",
							"type": "text"
						}
					]
				}
			]
		}
	},
	"title_i18n": {
		"en_US": "Test Element"
	}
	}
		''';

		Blueprints.createElement(
			elementSourceJson = ${elementSourceJson},
			title = "Test Element");

		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Test Element");

		Type(
			key_elementName = "Test Element",
			key_fieldLabel = "Asset Category External Reference Codes",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = "Test Category");

		Click(
			key_assetCategory = "Test Category (ERC: ${categoryERC})",
			locator1 = "Blueprints#BLUEPRINTS_ASSET_CATEGORY_FIELD_AUTOCOMPLETE_DROPDOWN_ITEM");

		Blueprints.selectAddedElementMenuItem(
			element = "Test Element",
			menuItem = "View Element JSON");

		AssertVisible(
			key_jsonText = ${categoryERC},
			locator1 = "Blueprints#BLUEPRINTS_EDIT_PAGE_VIEW_ELEMENT_JSON_TEXT");

		Click(locator1 = "Modal#CLOSE_BUTTON");

		Type(
			key_elementName = "Test Element",
			key_fieldLabel = "Asset Category External Reference Codes",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = "");

		Button.clickSave();

		FormPortlet.viewValidationErrorMessage(validationErrorMessage = "This field is required.");

		Alert.viewErrorMessage(errorMessage = "Unable to save due to invalid or missing configuration values.");

		Button.clickSelect();

		var siteName = TestCase.getSiteName();

		Select(
			locator1 = "Select#ANY_ID",
			selectId = "selectSite",
			value1 = ${siteName});

		Click(
			key_treeItem = "Test Vocabulary",
			locator1 = "Blueprints#BLUEPRINTS_ASSET_CATEGORY_TREE_VIEW_ITEM");

		Click.clickAtNotVisible(
			key_treeItem = "Test Category (ERC: ${categoryERC})",
			locator1 = "Blueprints#BLUEPRINTS_ASSET_CATEGORY_TREE_VIEW_ITEM_SELECT");

		Blueprints.selectAddedElementMenuItem(
			element = "Test Element",
			menuItem = "View Element JSON");

		AssertVisible(
			key_jsonText = ${categoryERC},
			locator1 = "Blueprints#BLUEPRINTS_EDIT_PAGE_VIEW_ELEMENT_JSON_TEXT");

		PortletEntry.save();

		AssertElementNotPresent(locator1 = "Message#ERROR");
	}

	@priority = 3
	test ViewQueryBuilderFieldValidation {
		Blueprints.openBlueprintsAdmin();

		var elementSourceJson = '''
{
	"elementDefinition": {
		"configuration": {},
		"uiConfiguration": {
			"fieldSets": [
				{
					"fields": [
						{
							"fieldMappings": [
								{
									"field": "localized_title",
									"locale": "hu_HU"
								}
							],
							"label": "Fields",
							"name": "fields",
							"type": "fieldMappingList"
						},
						{
							"defaultValue": 1,
							"label": "Boost",
							"name": "boost",
							"type": "number"
						}
					]
				}
			]
		}
	},
	"title_i18n": {
		"en_US": "Test Element"
	}
}
		''';

		Blueprints.createElement(
			elementSourceJson = ${elementSourceJson},
			title = "Test Element");

		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Test Element");

		Click(
			key_field = "localized_title",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_MAPPING_DELETE_BUTTON");

		Button.clickSave();

		Alert.viewRequiredField();

		Alert.viewErrorMessage(errorMessage = "Unable to save due to invalid or missing configuration values.");

		Click(locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_MAPPING_ADD_BUTTON");

		Type(
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_MAPPING_FIELD",
			value1 = "title");

		KeyPress(
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_MAPPING_FIELD",
			value1 = "\ESCAPE");

		Type(
			key_elementName = "Test Element",
			key_fieldLabel = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = "");

		Alert.viewRequiredField();

		Type(
			key_elementName = "Test Element",
			key_fieldLabel = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = 1);

		AssertElementNotPresent(locator1 = "TextInput#REQUIRED_ALERT");

		PortletEntry.save();

		AssertElementNotPresent(locator1 = "TextInput#REQUIRED_ALERT");

		Blueprints.gotoElement(element = "Test Element");

		var elementSourceJson = '''
{
	"elementDefinition": {
		"configuration": {},
		"uiConfiguration": {
			"fieldSets": [
				{
					"fields": [
						{
							"fieldMappings": [
								{
									"field": "localized_title",
									"locale": "hu_HU"
								}
							],
							"label": "Fields",
							"name": "fields",
							"type": "fieldMappingList",
							"typeOptions": {
								"required": false
							}
						},
						{
							"defaultValue": 1,
							"label": "Boost",
							"name": "boost",
							"type": "number",
							"typeOptions": {
								"required": false
							}
						}
					]
				}
			]
		}
	},
	"title_i18n": {
		"en_US": "Test Element"
	}
}
		''';

		Type.typeCodeMirrorEditorNoError(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = ${elementSourceJson});

		PortletEntry.save();

		Blueprints.openBlueprintsAdmin();

		Blueprints.gotoBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Test Element");

		AssertTextEquals.assertPartialText(
			key_elementName = "Test Element",
			key_fieldName = "Fields",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_LABEL",
			value1 = "Optional");

		AssertTextEquals.assertPartialText(
			key_elementName = "Test Element",
			key_fieldName = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_LABEL",
			value1 = "Optional");

		Type(
			key_elementName = "Test Element",
			key_fieldLabel = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = "");

		Click(
			key_field = "localized_title",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_MAPPING_DELETE_BUTTON");

		AssertElementNotPresent(locator1 = "TextInput#REQUIRED_ALERT");

		PortletEntry.save();

		AssertElementNotPresent(locator1 = "TextInput#REQUIRED_ALERT");

		AssertElementNotPresent(locator1 = "Message#ERROR_1");
	}

