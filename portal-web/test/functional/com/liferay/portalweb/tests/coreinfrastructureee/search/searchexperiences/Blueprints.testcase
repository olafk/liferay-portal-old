			key_linkText = "Learn more",
			locator1 = "Blueprints#DOC_LINK_GENERIC");

		SelectWindow(value1 = "Creating Elements - Liferay Learn");

		Close.closeAndSelectWindow(value1 = "View Element - ${siteName}");

		SearchPage.addWidgets(searchPortletList = "Blueprints Options");

