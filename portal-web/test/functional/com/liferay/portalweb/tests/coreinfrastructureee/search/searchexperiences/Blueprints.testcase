	@priority = 3
	test PaginateElementsAdmin {
		Blueprints.openBlueprintsAdmin();

		Navigator.gotoNavItem(navItem = "Elements");

		var paginationResults = selenium.getText("Pagination#RESULTS");

		echo(${paginationResults});

		var totalElements = StringUtil.extractLast(${paginationResults}, "of ");

		var totalElements = StringUtil.extractFirst(${totalElements}, " ");

		Pagination.changePagination(itemsPerPage = "4 Items");

		Pagination.viewResults(results = "Showing 1 to 4 of ${totalElements} entries.");

		AssertElementPresent(
			key_index = 4,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		AssertElementNotPresent(
			key_index = 5,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		Click(locator1 = "Blueprints#PAGINATION_NEXT_LINK");

		Pagination.viewResults(results = "Showing 5 to 8 of ${totalElements} entries.");

		AssertElementPresent(
			key_index = 4,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		AssertElementNotPresent(
			key_index = 5,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		Click(locator1 = "Blueprints#PAGINATION_PREVIOUS_LINK");

		Pagination.viewResults(results = "Showing 1 to 4 of ${totalElements} entries.");

		AssertElementPresent(
			key_index = 4,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		AssertElementNotPresent(
			key_index = 5,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		Click(
			key_pageNumber = 3,
			locator1 = "Pagination#ANY_PAGE");

		Pagination.viewResults(results = "Showing 9 to 12 of ${totalElements} entries.");

		AssertElementPresent(
			key_index = 4,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		AssertElementNotPresent(
			key_index = 5,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		Click(
			key_pageNumber = 1,
			locator1 = "Pagination#ANY_PAGE");

		Pagination.viewResults(results = "Showing 1 to 4 of ${totalElements} entries.");

		AssertElementPresent(
			key_index = 4,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		AssertElementNotPresent(
			key_index = 5,
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");

		Pagination.changePagination(itemsPerPage = "60 Items");

		Pagination.viewResults(results = "Showing 1 to ${totalElements} of ${totalElements} entries.");

		AssertElementPresent(
			key_index = ${totalElements},
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_NTH_ENTRY");
	}

