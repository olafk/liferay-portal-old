	@priority = 3
	test ViewMappedAssetInBlueprintCollectionProvider {
		property custom.properties = "feature.flag.LPS-129412=true${line.separator}feature.flag.LPS-193551=true";

		task ("Create a test structure and a few sample web contents with the structure") {
			WebContentNavigator.openWebContentAdmin(siteURLKey = "guest");

			NavItem.gotoStructures();

			WebContentStructures.addCP(structureName = "Test Structure");

			DEBuilder.addField(
				fieldLabel = "Custom Title",
				fieldName = "Text");

			DEBuilder.addField(
				fieldLabel = "Custom Content",
				fieldName = "Rich Text");

			WebContentStructures.saveCP();

			WebContentNavigator.openWebContentAdmin(siteURLKey = "guest");

			for (var count : list "1,2,3") {
				WebContentNavigator.gotoAddWithStructureCP(structureName = "Test Structure");

				WebContent.addWithStructureCP(
					structureName = "Test Structure",
					webContentRichText = "Some HTML ${count}",
					webContentRichTextFieldLabel = "Custom Content",
					webContentText = "Test Web Content ${count}",
					webContentTextFieldLabel = "Custom Title",
					webContentTitle = "Test Web Content ${count}");

				PortletEntry.publish();
			}
		}

		task ("Create a blueprint and configure to only search for Web Content Articles") {
			Blueprints.openBlueprintsAdmin();

			Blueprints.createBlueprint(title = "Test Blueprint");

			Navigator.gotoNavNested(navNested = "Query Settings");

			Check.checkNotVisible(
				locator1 = "Radio#ANY",
				radioLabel = "Selected Types");

			Button.click(button = "Select Asset Types");

			Check.checkNotVisible(
				key_assetType = "Web Content Article",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX");

			Button.clickDone();
		}

		task ("Fetch the ddmStructureKey of the created test structure") {
			Navigator.gotoNavTab(navTab = "Configuration");

			var customJson = '''
	{
		"source": {
			"fetchSource": true
		}
	}
		''';

			Type.typeCodeMirrorEditorNoError(
				key_configurationField = "Advanced Configuration",
				locator1 = "Blueprints#BLUEPRINTS_CONFIGURATION_EDITOR",
				value1 = ${customJson});

			Navigator.gotoNavTab(navTab = "Query Builder");

			Blueprints.searchBlueprintsPreview(searchTerm = "Test Web Content 1");

			Click(locator1 = "Blueprints#BLUEPRINTS_PREVIEW_EXPAND_RESULT_BUTTON");

			var ddmStructureKey = selenium.getText("//div[contains(@class,'preview-results-list')]//*[contains(@class,'row')]//*[contains(.,'ddmStructureKey')]/following-sibling::div");
		}

		task ("Add a Filter by Exact Terms Mtach element to the blueprint with the ddmStructureKey") {
			Click(
				ariaLabel = "Add Query Element",
				locator1 = "Button#ANY_WITH_ARIA_LABEL");

			Blueprints.addElement(element = "Filter by Exact Terms Match");

			Type(
				key_elementName = "Filter by Exact Terms Match",
				key_fieldLabel = "Field",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
				value1 = "ddmStructureKey");

			Type(
				key_elementName = "Filter by Exact Terms Match",
				key_fieldLabel = "Values",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
				value1 = ${ddmStructureKey});
		}

		task ("Assert in the preview sidebar that the test web contents appear as the only results") {
			Blueprints.searchBlueprintsPreview(searchTerm = "");

			Click(locator1 = "Blueprints#BLUEPRINTS_PREVIEW_EXPAND_RESULT_BUTTON");

			AssertElementPresent(
				key_resultTitle = "Test Web Content 1",
				locator1 = "Blueprints#BLUEPRINTS_PREVIEW_SEARCH_RESULT_TITLE");

			AssertElementPresent(
				key_resultTitle = "Test Web Content 2",
				locator1 = "Blueprints#BLUEPRINTS_PREVIEW_SEARCH_RESULT_TITLE");

			AssertElementPresent(
				key_resultTitle = "Test Web Content 3",
				locator1 = "Blueprints#BLUEPRINTS_PREVIEW_SEARCH_RESULT_TITLE");

			AssertElementPresent(
				key_resultTotal = "3 Results",
				locator1 = "Blueprints#BLUEPRINTS_PREVIEW_SEARCH_RESULT_TOTAL_HITS");

			PortletEntry.save();
		}

		task ("Create a test content page with a collection display fragment") {
			JSONLayout.addPublicLayout(
				groupName = "Guest",
				layoutName = "Test Content Page",
				type = "content");

			JSONLayout.publishLayout(
				groupName = "Guest",
				layoutName = "Test Content Page");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Content Page",
				siteName = "Guest");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Collection Display");
		}

		task ("Select the collection provider for 'Web Content Article - Test Structure'") {
			PageEditor.clickConfigurableField(
				fragmentName = "Collection Display",
				index = 1);

			PageEditor.gotoTab(tabName = "Browser");

			AssertVisible(
				key_sidebarButton = "Browser",
				locator1 = "PageEditor#FRAGMENT_SIDEBAR_TITLE");

			Navigator.gotoNavTab(navTab = "General");

			Click(
				key_fieldLabel = "Collection",
				key_text = "plus",
				locator1 = "Icon#ANY_ITEM_SELECTOR");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			NavItem.click(navItem = "Collection Providers");

			ManagementBar.setFilterAndOrder(filterBy = "Web Content Article");

			LexiconCard.clickCard(card = "Test Blueprint");

			SelectFrameTop();

			PageEditor.waitForAutoSave();
		}

		task ("Add Heading and HTML fragment to collection display and map them to Custom Title and Content respectively") {
			PageEditor.addFragmentToCollectionDisplay(
				collectionName = "Basic Components",
				entryTitle = "Test Web Content 1",
				fragmentName = "Heading");

			PageEditorMapping.mapEditableTextToField(
				field = "Custom Title",
				fragmentName = "Heading",
				id = "element-text");

			PageEditor.addFragmentToCollectionDisplay(
				collectionName = "Basic Components",
				fragmentName = "HTML",
				targetFragmentName = "Heading");

			PageEditorMapping.gotoEditableFieldMapping(
				fragmentName = "HTML",
				id = "element-html");

			Select(
				key_fieldLabel = "Field",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Custom Content");
		}

		task ("Publish and assert that only the sample test structure contents are shown") {
			PageEditor.publish();

			for (var count : list "1,2,3") {
				AssertElementPresent(
					key_text = "Test Web Content ${count}",
					locator1 = "PageEditor#COLLECTION_ITEM_CONTENT");

				AssertElementPresent(
					key_text = "Some HTML ${count}",
					locator1 = "PageEditor#COLLECTION_ITEM_CONTENT");
			}
		}
	}

