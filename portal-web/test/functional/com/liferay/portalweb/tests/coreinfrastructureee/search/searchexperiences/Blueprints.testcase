	@description = "This is a use case for LPS-134492."
	@priority = 3
	test ViewBlueprintTitleAndDescriptionLocalization {
		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(
			description = "Description in English",
			title = "Title in English");

		Click(
			ariaLabel = "Edit Title",
			locator1 = "Blueprints#BLUEPRINTS_EDIT_PAGE_HEADER_TITLE");

		Blueprints.setTitleAndDescriptionLocalization(
			currentLocale = "en-US",
			description = "Descripcin en Espanol",
			locale = "es-ES",
			title = "Ttulo en Espaol");

		Blueprints.setTitleAndDescriptionLocalization(
			currentLocale = "es-ES",
			description = "Beschreibung auf Deutsch",
			locale = "de-DE",
			title = "Titel auf Deutsch");

		Button.clickDone();

		PortletEntry.save();

		Blueprints.openBlueprintsAdmin(locale = "es");

		AssertTextEquals(
			key_entryTitle = "Ttulo en Espaol",
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_ENTRY_DESCRIPTION",
			value1 = "Descripcin en Espanol");

		Blueprints.openBlueprintsAdmin(locale = "de");

		AssertTextEquals(
			key_entryTitle = "Titel auf Deutsch",
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_ENTRY_DESCRIPTION",
			value1 = "Beschreibung auf Deutsch");

		Blueprints.openBlueprintsAdmin(locale = "en");

		AssertTextEquals(
			key_entryTitle = "Title in English",
			locator1 = "Blueprints#BLUEPRINTS_ADMIN_ENTRY_DESCRIPTION",
			value1 = "Description in English");
	}

	@priority = 3
	test ViewClauseContributorsFilterAndSort {
		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Navigator.gotoNavNested(navNested = "Query Settings");

		Check.checkNotVisible(
			locator1 = "Radio#ANY",
			radioLabel = "Customize");

		Button.click(button = "Customize Contributors");

		Uncheck.uncheckToggleSwitch(
			key_contributorClass = "AssetCategoryKeywordQueryContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ON_OFF_TOGGLE");

		Type(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "AccountEntryModelPreFilterContributor");

		KeyPress(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "\RETURN");

		Uncheck.uncheckToggleSwitch(
			key_contributorClass = "AccountEntryModelPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ON_OFF_TOGGLE");

		Type(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "AssetCategoryIdsQueryPreFilterContributor");

		KeyPress(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "\RETURN");

		Uncheck.uncheckToggleSwitch(
			key_contributorClass = "AssetCategoryIdsQueryPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ON_OFF_TOGGLE");

		Type(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "AssetEntryModelPreFilterContributor");

		KeyPress(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "\RETURN");

		Uncheck.uncheckToggleSwitch(
			key_contributorClass = "AssetEntryModelPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ON_OFF_TOGGLE");

		Type(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "");

		KeyPress(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "\RETURN");

		Button.click(button = "Filter");

		MenuItem.click(menuItem = "Inactive");

		AssertElementPresent(
			key_contributorClass = "AssetCategoryKeywordQueryContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementPresent(
			key_contributorClass = "AccountEntryModelPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementPresent(
			key_contributorClass = "AssetCategoryIdsQueryPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_TOGGLE_ENABLED");

		Button.click(button = "Clear");

		AssertElementPresent(locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_TOGGLE_ENABLED");

		AssertElementPresent(locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_TOGGLE_DISABLED");

		Button.click(button = "Filter");

		MenuItem.click(menuItem = "Active");

		AssertElementPresent(locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_TOGGLE_ENABLED");

		AssertElementNotPresent(locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_TOGGLE_DISABLED");

		Button.click(button = "Filter");

		Click(
			key_menuItem = "KeywordQueryContributor",
			locator1 = "MenuItem#DROPDOWN_MENU_ITEM");

		AssertElementPresent(
			key_contributorClass = "KeywordQueryContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(
			key_contributorClass = "ModelPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(
			key_contributorClass = "QueryPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		Button.click(button = "Filter");

		Click(
			key_menuItem = "ModelPreFilterContributor",
			locator1 = "MenuItem#DROPDOWN_MENU_ITEM");

		AssertElementPresent(
			key_contributorClass = "ModelPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(
			key_contributorClass = "KeywordQueryContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(
			key_contributorClass = "QueryPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		Button.click(button = "Filter");

		Click(
			key_menuItem = "QueryPreFilterContributor",
			locator1 = "MenuItem#DROPDOWN_MENU_ITEM");

		AssertElementPresent(
			key_contributorClass = "QueryPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(
			key_contributorClass = "KeywordQueryContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(
			key_contributorClass = "ModelPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		Click(
			key_filter = "QueryPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_CLEAR_FILTER_BUTTON");

		AssertElementPresent(
			key_contributorClass = "KeywordQueryContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementPresent(
			key_contributorClass = "ModelPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementPresent(
			key_contributorClass = "QueryPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		Button.click(button = "Filter");

		MenuItem.click(menuItem = "Inactive");

		Button.click(button = "Filter");

		Click(
			key_menuItem = "KeywordQueryContributor",
			locator1 = "MenuItem#DROPDOWN_MENU_ITEM");

		AssertElementPresent(
			key_contributorClass = "AssetCategoryKeywordQueryContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(
			key_contributorClass = "AccountEntryModelPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		AssertElementNotPresent(
			key_contributorClass = "AssetCategoryIdsQueryPreFilterContributor",
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_ITEM");

		Button.click(button = "Clear");

		AssertTextEquals.assertPartialText(
			key_index = 1,
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_NTH_ITEM",
			value1 = "Account Entry Keyword Query Contributor");

		Click.clickNoMouseOver(locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SORT_BUTTON");

		AssertTextEquals.assertPartialText(
			key_index = 1,
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_NTH_ITEM",
			value1 = "User Keyword Query Contributor");
	}

	@priority = 3
	test ViewClauseContributorsUI {
		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Navigator.gotoNavNested(navNested = "Query Settings");

