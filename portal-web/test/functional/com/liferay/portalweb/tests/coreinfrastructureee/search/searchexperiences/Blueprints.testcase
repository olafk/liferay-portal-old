		Type(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "AssetCategoryKeywordQueryContributor");

		KeyPress(
			locator1 = "Blueprints#BLUEPRINTS_CLAUSE_CONTRIBUTOR_SEARCH_BAR",
			value1 = "\RETURN");

		AssertElementPresent(
			key_contributorClass = "AssetCategoryKeywordQueryContributor",
