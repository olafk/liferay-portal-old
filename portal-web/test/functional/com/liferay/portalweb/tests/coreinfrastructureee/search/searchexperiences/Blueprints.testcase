	@description = "This is a use case for LPS-177882. Can apply blueprint to blueprint options widget in a non-root portal context."
	@priority = 4
	test ApplyBlueprintViaBlueprintsOptionsInNonRootContext {
		property portal.context = "liferay";
		property search.environment.suite.exclude = "true";
		property skip.clean-app-server-deploy-dir = "true";
		property test.assert.warning.exceptions = "true";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";

		JSONBlog.addEntry(
			entryContent = "",
			entryTitle = "apple apple apple");

		JSONWebcontent.addWebContent(
			content = "apple",
			groupName = "Guest",
			title = "WC Title");

		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Asset Type");

		Blueprints.configureElementDropdown(
			dropdownName = "Asset Type",
			option = "Web Content Article");

		Type(
			key_elementName = "Boost Asset Type",
			key_fieldLabel = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = 1000);

		PortletEntry.save();

		SearchPage.openSearchPage();

		Blueprints.applyBlueprintViaOptionsWidget(blueprintTitle = "Test Blueprint");

		SearchPage.searchWidget(searchTerm = "apple");

		SearchResults.viewSearchResultsSpecificOrder(resultsList = "WC Title,apple apple apple");
	}

	@priority = 3
	test ApplyBlueprintWithOOTBElement {
		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Asset Type");

		Blueprints.configureElementDropdown(
			dropdownName = "Asset Type",
			option = "Web Content Article");

		Type(
			key_elementName = "Boost Asset Type",
			key_fieldLabel = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = 1000);

		PortletEntry.save();

		SearchPage.openSearchPage();

		JSONWebcontent.addWebContent(
			content = "Liferay",
			groupName = "Guest",
			title = "Liferay Web Content");

		JSONBlog.addEntry(
			entryContent = "Liferay Liferay",
			entryTitle = "Liferay Blogs Entry");

		SearchPage.searchEmbedded(searchTerm = "liferay");

		SearchResults.viewSearchResultsSpecificOrder(resultsList = "Liferay Blogs Entry,Liferay Web Content");

		Blueprints.applyBlueprintViaOptionsWidget(blueprintTitle = "Test Blueprint");

		SearchPage.searchEmbedded(searchTerm = "liferay");

		SearchResults.viewSearchResultsSpecificOrder(resultsList = "Liferay Web Content,Liferay Blogs Entry");
	}

	@description = "This is a use case for LPS-147264."
	@priority = 3
	test ApplyUserCustomFieldVariableToCustomElement {
		JSONWebcontent.addWebContent(
			content = "",
			groupName = "Guest",
			title = "Employee eyes only");

		CustomFields.openCustomFieldAdmin();

		CustomFields.addCP(
			customFieldName = "Employee",
			customFieldType = "True / False",
			resourceName = "User");

		JSONUser.addUser(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		User.openUsersAdmin();

		UserNavigator.gotoUser(userScreenName = "usersn");

		Select(
			locator1 = "Select#SELECT_ID",
			selectFieldId = "employee",
			value1 = "False");

		PortletEntry.save();

		Blueprints.openBlueprintsAdmin();

		var elementSourceJson = '''
{
  "elementDefinition": {
    "configuration": {
      "queryConfiguration": {
        "queryEntries": [
          {
            "clauses": [
              {
                "context": "query",
                "occur": "filter",
                "query": {
                  "bool": {
                    "must_not": [
                      {
                        "match": {
                          "title_${context.language_id}": {
                            "query": "employee"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            ],
            "condition": {
              "equals": {
                "parameterName": "user.custom.field.employee",
                "value": false
              }
            }
          }
        ]
      }
    }
  },
  "title_i18n": {
    "en_US": "Test Element"
  }
}
		''';

		Blueprints.createElement(
			elementSourceJson = ${elementSourceJson},
			title = "Test Element");

		Blueprints.gotoElement(element = "Test Element");

		Click(
			key_item = "user",
			locator1 = "Blueprints#ELEMENTS_EDIT_PAGE_PREDEFINED_VARIABLES_SIDEBAR_ITEM");

		AssertElementPresent(
			key_item = "Employee",
			locator1 = "Blueprints#ELEMENTS_EDIT_PAGE_PREDEFINED_VARIABLES_SIDEBAR_ITEM");

		PortletEntry.save();

		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Test Element");

		PortletEntry.save();

		SearchPage.openSearchPage();

		Blueprints.applyBlueprintViaOptionsWidget(blueprintTitle = "Test Blueprint");

		SearchPage.searchEmbedded(searchTerm = "Employee");

		SearchResults.viewSearchResults(
			searchAssetTitle = "Employee eyes only",
			searchAssetType = "Web Content Article");

		User.logoutAndLoginPG(
			userLoginEmailAddress = "userea@liferay.com",
			userLoginFullName = "userfn userln");

		SearchPage.searchEmbedded(searchTerm = "Employee");

		SearchResults.viewSearchResultNotPresent(
			searchAssetTitle = "Employee eyes only",
			searchAssetType = "Web Content Article");
	}

	@description = "This is a use case for LPS-151209."
	@priority = 3
	test AssertBlueprintsPreviewResultsPresentWithSkippedElement {
		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Proximity");

		Type(
			key_elementName = "Boost Proximity",
			key_fieldLabel = "Field",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = "accountEntryId");

		Blueprints.searchBlueprintsPreview(searchTerm = "test");

		Alert.viewWarningSpecific(key_warningMessage = "Element skippedInvalid element instance at: 0");

		AssertElementPresent(
			key_resultTitle = "Test Test",
			locator1 = "Blueprints#BLUEPRINTS_PREVIEW_SEARCH_RESULT_TITLE");
	}

	@priority = 3
	test AssertBlueprintStillAppliedAfterRename {
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";

		JSONWebcontent.addWebContent(
			content = "apple apple apple",
			groupName = "Guest",
			title = "WC Shorter");

		JSONWebcontent.addWebContent(
			content = "apple adding more content to this article",
			groupName = "Guest",
			title = "WC Longer");

		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Longer Contents");

		Type(
			key_elementName = "Boost Longer Contents",
			key_fieldLabel = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = 1000);

		PortletEntry.save();

		SearchPage.openSearchPage();

		Blueprints.applyBlueprintViaOptionsWidget(blueprintTitle = "Test Blueprint");

		SearchPage.searchEmbedded(searchTerm = "apple");

		SearchResults.viewSearchResultsSpecificOrder(resultsList = "WC Longer,WC Shorter");

		Blueprints.openBlueprintsAdmin();

		Blueprints.gotoBlueprint(title = "Test Blueprint");

		Click(locator1 = "Blueprints#BLUEPRINTS_EDIT_PAGE_HEADER_TITLE");

		PortletEntry.inputTitle(title = "Edited Blueprint");

		Button.clickDone();

		PortletEntry.save();

		SearchPage.openSearchPage();

		SearchPage.searchEmbedded(searchTerm = "apple");

		SearchResults.viewSearchResultsSpecificOrder(resultsList = "WC Longer,WC Shorter");
	}

	@description = "This is a use case for LPS-136868."
	@priority = 3
	test AssertCommerceItemsSearchableViaPreview {
		CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.searchBlueprintsPreview(searchTerm = "Brake Pads");

		AssertElementPresent(
			key_resultTitle = "Brake Pads",
			locator1 = "Blueprints#BLUEPRINTS_PREVIEW_SEARCH_RESULT_TITLE");
	}

	@priority = 3
	test AssertDisabledQueryElementNotAppliedToSearch {
		JSONWebcontent.addWebContent(
			content = "",
			groupName = "Guest",
			title = "apple apple apple");

		var webContentserviceContext = '''{"assetTagNames": ["apple"]}''';

		JSONWebcontent.addWebContent(
			content = "",
			groupName = "Guest",
			serviceContext = ${webContentserviceContext},
			title = "gala");

		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Tags Match");

		Type(
			key_elementName = "Boost Tags Match",
			key_fieldLabel = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = 3000);

		PortletEntry.save();

		SearchPage.openSearchPage();

		Blueprints.applyBlueprintViaOptionsWidget(blueprintTitle = "Test Blueprint");

		SearchPage.searchEmbedded(searchTerm = "apple");

		SearchResults.viewSearchResultsSpecificOrder(resultsList = "gala,apple apple apple");

		Blueprints.openBlueprintsAdmin();

		Blueprints.gotoBlueprint(title = "Test Blueprint");

		Uncheck.uncheckToggleSwitch(
			key_elementName = "Boost Tags Match",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_ENABLE_DISABLE_TOGGLE");

		PortletEntry.save();

		SearchPage.openSearchPage();

		SearchPage.searchEmbedded(searchTerm = "apple");

		SearchResults.viewSearchResultsSpecificOrder(resultsList = "apple apple apple,gala");
	}

	@description = "This is a use case for LPS-185939 - Federated search requests should inherit parent request's search context properties."
	@priority = 3
	test AssertFederatedSearchRequestsInheritParentRequestsSearchContextProperties {
		property custom.properties = "jsonws.web.service.paths.excludes=";

		task ("Add a user and assign it the Administrator role") {
			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.setFirstPassword(
				agreeToTermsAndAnswerReminderQuery = "true",
				requireReset = "false",
				userEmailAddress = "userea@liferay.com");

			JSONRole.assignRoleToUser(
				roleTitle = "Administrator",
				userEmailAddress = "userea@liferay.com");
		}

		task ("Create a Web Contents Article as the new user") {
			JSONWebcontent.addWebContent(
				content = "Test",
				groupName = "Guest",
				title = "WC WebContent Title",
				userEmailAddress = "userea@liferay.com",
				userPassword = PropsUtil.get("default.admin.password"));
		}

		task ("Create Blueprint with the element Limit Search to My Contents") {
			Blueprints.openBlueprintsAdmin();

			Blueprints.createBlueprint(title = "Test Blueprint");

			Blueprints.addElement(element = "Limit Search to My Contents");

			PortletEntry.save();
		}

		task ("Create a Content Page with Search widgets") {
			SearchPage.openSearchPage();

			SearchPage.configureEmbeddedSearchBar(
				federatedSearchKey = "key",
				searchScope = "Everything");

			SearchResults.configureSearchResults(federatedSearchKey = "key");

			SearchPage.configureSearchOptions(
				allowEmptySearches = "true",
				federatedSearchKey = "key");

			Blueprints.applyBlueprintViaOptionsWidget(blueprintTitle = "Test Blueprint");

			Blueprints.configureFederatedSearchKeyForOptionsWidget(federatedSearchKey = "key");
		}

		task ("As the new user, assert the Web Content Article shows up, but not the OOTB Documents") {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "userea@liferay.com",
				userLoginFullName = "userfn userln");

			SearchPage.openSearchPage();

			SearchResults.viewSearchResults(
				searchAssetTitle = "WC WebContent Title",
				searchAssetType = "Web Content Article");

			SearchResults.viewMultipleSearchResultsNotPresent(noResultsList = "astronaut.png,earth.png,moon.png");
		}
	}

	@description = "This is a use case for LPS-192211."
	@priority = 3
	test AssertGlobalCategoryVisibleInHideContentAssetCategory {
		task ("Add a global vocabulary and with a category") {
			JSONCategory.addVocabulary(
				groupName = "Global",
				title = "Test Vocabulary");

			var categoryID = JSONCategory.addCategory(
				groupName = "Global",
				title = "Test Category",
				vocabularyName = "Test Vocabulary");

			var categoryERC = JSONCategory.getCategoryFieldValueById(
				categoryId = ${categoryID},
				fieldName = "externalReferenceCode");
		}

		task ("Create a blueprint and add the 'Hide Contents in a Category' element") {
			Blueprints.openBlueprintsAdmin();

			Blueprints.createBlueprint(title = "Test Blueprint");

			Blueprints.addElementViaDescription(
				element = "Hide contents in the given category.",
				searchTerm = "Hide Contents in a Category");
		}

		task ("Assert that the global category is present when searching in the text field") {
			Type(
				key_elementName = "Hide Contents in a Category",
				key_fieldLabel = "Asset Category External Reference Codes",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
				value1 = "Test");

			AssertElementPresent(
				key_assetCategory = "Test Category (ERC: ${categoryERC})",
				locator1 = "Blueprints#BLUEPRINTS_ASSET_CATEGORY_FIELD_AUTOCOMPLETE_DROPDOWN_ITEM");
		}

		task ("Assert that the global category is present when opening the select modal frame") {
			Click(locator1 = "Button#SELECT");

			SelectFrameTop();

			Click(
				key_dropdownName = "Select Site",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_GENERIC_DROPDOWN");

			Click.clickNoMouseOver(
				key_dropdownName = "Select Site",
				key_option = "Global",
				locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_GENERIC_DROPDOWN_OPTION");

			Click(
				key_treeItem = "Test Vocabulary",
				locator1 = "Blueprints#BLUEPRINTS_ASSET_CATEGORY_TREE_VIEW_ITEM");

			AssertElementPresent(
				key_treeItem = "Test Category (ERC: ${categoryERC})",
				locator1 = "Blueprints#BLUEPRINTS_ASSET_CATEGORY_TREE_VIEW_ITEM_CHECKBOX");
		}
	}

	@priority = 3
	test AssertLocalizedFieldsAddLocaleDropdown {
		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Filter by Exact Terms Match");

		Type(
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_MAPPING_FIELD",
			value1 = "local");

		Click(
			key_optionName = "localized_title",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_MAPPING_GLOBAL_ICON_OPTION");

		AssertElementPresent(locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_FIELD_MAPPING_LOCALE_DROPDOWN");
	}

	@description = "This is a use case for LPS-144359."
	@priority = 3
	test AssertNoBlueprintsPreviewResultsDueToEmptyRequiredFields {
		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Asset Type");

		Blueprints.searchBlueprintsPreview(searchTerm = "test");

		Alert.viewErrorMessage(errorMessage = "The configuration has missing or invalid values.");

		AssertElementNotPresent(
			key_resultTitle = "",
			locator1 = "Blueprints#BLUEPRINTS_PREVIEW_SEARCH_RESULT_TITLE");

		Alert.viewRequiredField();
	}

	@priority = 3
	test AssertNonAdminsCannotAccessBlueprintsPortlet {
		JSONUser.addUser(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		User.logoutAndLoginPG(
			userLoginEmailAddress = "userea@liferay.com",
			userLoginFullName = "userfn userln");

		AssertElementNotPresent(locator1 = "ControlMenu#APPLICATIONS_MENU_ICON");

		Blueprints.openBlueprintsAdmin();

		Portlet.viewNoPermissionPG();
	}

	@description = "This is a use case for LPS-132856."
	@priority = 3
	test AssertTitleAndDescriptionNoXSS {
		Blueprints.openBlueprintsAdmin();

		Click(locator1 = "Button#PLUS");

		PortletEntry.inputTitle(title = "<script>alert(123);</script>");

		PortletEntry.inputDescription(description = "<script>alert(123);</script>");

		PortletEntry.create();

		AssertAlertNotPresent();

		PortletEntry.save();

		AssertAlertNotPresent();

		SearchPage.openSearchPage();

		Blueprints.applyBlueprintViaOptionsWidget(blueprintTitle = "<script>alert(123);</script>");

		Refresh();

		AssertAlertNotPresent();
	}

	@priority = 3
	test AssertUsingCopiedElementJSONWithinCustomElement {
		JSONBlog.addEntry(
			entryContent = "",
			entryTitle = "apple apple apple");

		JSONWebcontent.addWebContent(
			content = "apple",
			groupName = "Guest",
			title = "WC Title");

		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Asset Type");

		Blueprints.configureElementDropdown(
			dropdownName = "Asset Type",
			option = "Web Content Article");

		Type(
			key_elementName = "Boost Asset Type",
			key_fieldLabel = "Boost",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT_INPUT_FIELD",
			value1 = 1000);

		Blueprints.selectAddedElementMenuItem(
			element = "Boost Asset Type",
			menuItem = "View Element JSON");

		SelectFrameTop();

		Click(locator1 = "Link#DOWNLOAD");

		Alert.viewSuccessMessage();

		var outputDir = PropsUtil.get("output.dir.name");

		var fileContent = FileUtil.read("${outputDir}/sxpElement.json");

		var customElementJson = StringUtil.replace(${fileContent}, "boost-asset-type", "Boost Results of Web Content Articles");

		Click(locator1 = "Modal#CLOSE_BUTTON");

		ClickNoError(
			key_text = "Cancel",
			locator1 = "Link#ANY");

		Confirm(value1 = "null");

		Blueprints.createElement(
			elementSourceJson = ${customElementJson},
			title = "Test Element");

		Navigator.gotoNavItem(navItem = "Blueprints");

		Blueprints.gotoBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Results of Web Content Articles");

		PortletEntry.save();

		SearchPage.openSearchPage();

		Blueprints.applyBlueprintViaOptionsWidget(blueprintTitle = "Test Blueprint");

		SearchPage.searchEmbedded(searchTerm = "apple");

		SearchResults.viewSearchResultsSpecificOrder(resultsList = "WC Title,apple apple apple");
	}

