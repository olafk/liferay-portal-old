	@priority = 3
	test ViewSelectedAssetTypesUI {
		property custom.properties = "feature.flag.LPD-35013=true";

		task ("Create a test blueprint and navigate to the 'Query Settings' tab") {
			Blueprints.openBlueprintsAdmin();

			Blueprints.createBlueprint(title = "Test Blueprint");

			Navigator.gotoNavNested(navNested = "Query Settings");
		}

		task ("Open the 'Select Types' modal") {
			Check.checkNotVisible(
				locator1 = "Radio#ANY",
				radioLabel = "Selected Types");

			Button.click(button = "Select Asset Types");
		}

		task ("Check the select all checkbox and assert the 'Select All' button doesn't appear") {
			Check.checkNotVisible(locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECT_ALL_CHECKBOX");

			AssertElementNotPresent(locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECT_REMAINING");
		}

		task ("Assert at least one asset type is checked and no unchecked asset types are present") {
			AssertChecked.assertCheckedNotVisible(
				key_assetType = "Blogs Entry",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX");

			AssertElementNotPresent(locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX_UNCHECKED");
		}

		task ("Uncheck the select all checkbox and assert no checked asset type is present") {
			Uncheck.uncheckNotVisible(locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECT_ALL_CHECKBOX");

			AssertElementNotPresent(locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX_CHECKED");
		}

		task ("Assert the 'Select All' button appears when at least one, but not all asset types are checked") {
			Check.checkNotVisible(
				key_assetType = "Web Content Article",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX");

			Click(locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECT_REMAINING");
		}

		task ("Assert clicking the 'Select All' button causes the rest of the remaining unchecked asset types to become checked") {
			AssertElementNotPresent(locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX_UNCHECKED");
		}

		task ("Save the modal and assert at least one of the checked asset types appears on the main page") {
			Button.clickDone();

			AssertElementPresent(
				key_assetType = "Web Content Article",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECTED");
		}

		task ("Click the remove button for one of the asset types and assert that is removed from the main page") {
			Click(
				key_assetType = "Wiki Page",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_REMOVE_SELECTED");

			AssertElementNotPresent(
				key_assetType = "Wiki Page",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECTED");
		}

		task ("Assert the removed asset type is also immediately removed from the 'Select Types' modal. This covers the bug in LPS-179782.") {
			Button.click(button = "Select Asset Types");

			AssertNotChecked.assertNotCheckedNotVisible(
				key_assetType = "Wiki Page",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX");
		}

		task ("Save the blueprint, open it again, and navigate back to the 'Query Settings' tab") {
			PortletEntry.save();

			Blueprints.gotoBlueprint(title = "Test Blueprint");

			Navigator.gotoNavNested(navNested = "Query Settings");
		}

		task ("Assert that at least one asset type is selected on the main page") {
			AssertElementPresent(
				key_assetType = "Web Content Article",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECTED");
		}

		task ("Assert the previously removed asset type is not selected on the main page") {
			AssertElementNotPresent(
				key_assetType = "Wiki Page",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECTED");
		}

		task ("Open the 'Select Types' modal and assert the select all checkbox is checked in indeterminate state when some but not all asset types are checked") {
			Button.click(button = "Select Asset Types");

			AssertChecked.assertCheckedNotVisible(locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_SELECT_ALL_CHECKBOX");
		}

		task ("Assert at least one of the asset types are checked and the previously removed asset type is not checked") {
			AssertChecked.assertCheckedNotVisible(
				key_assetType = "Web Content Article",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX");

			AssertNotChecked.assertNotCheckedNotVisible(
				key_assetType = "Wiki Page",
				locator1 = "Blueprints#BLUEPRINTS_SEARCHABLE_ASSET_TYPE_CHECKBOX");
		}
	}

	@priority = 3
	test ViewUnsavedChangesAlertForBlueprints {
		Blueprints.openBlueprintsAdmin();

		Blueprints.createBlueprint(title = "Test Blueprint");

		Blueprints.addElement(element = "Boost Tags Match");

		ClickNoError(
			key_text = "Cancel",
			locator1 = "Link#ANY");

		Confirm.dismissAlert();

		AssertElementPresent(
			key_element = "Boost Tags Match",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT");

		ClickNoError(
			key_text = "Cancel",
			locator1 = "Link#ANY");

		AssertConfirm(value1 = "You have unsaved changes. Do you want to proceed without saving?");

		Blueprints.gotoBlueprint(title = "Test Blueprint");

		AssertElementPresent(locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENTS_EMPTY");

		Blueprints.addElement(element = "Boost Tags Match");

		ApplicationsMenuHelper.openApplicationsMenu();

		ClickNoError(
			key_category = "Search Experiences",
			key_portlet = "Blueprints",
			locator1 = "ApplicationsMenu#PORTLET");

		Confirm.dismissAlert();

		AssertElementPresent(
			key_element = "Boost Tags Match",
			locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENT");

		ClickNoError(
			key_category = "Search Experiences",
			key_portlet = "Blueprints",
			locator1 = "ApplicationsMenu#PORTLET");

		AssertConfirm(value1 = "You have unsaved changes. Do you want to proceed without saving?");

		Blueprints.gotoBlueprint(title = "Test Blueprint");

		AssertElementPresent(locator1 = "Blueprints#BLUEPRINTS_ADDED_ELEMENTS_EMPTY");
	}

	@priority = 3
	test ViewUnsavedChangesAlertForElements {
		Blueprints.openBlueprintsAdmin();

		Navigator.gotoNavItem(navItem = "Elements");

		Click(locator1 = "Button#PLUS");

		PortletEntry.inputTitle(title = "Test Element");

		Button.click(button = "Create");

		var elementSourceJson = '''
{
	"elementDefinition": {
		"configuration": {},
		"uiConfiguration": {}
	},
	"title_i18n": {
		"en_US": "Unsaved Element"
	}
}
		''';

		Type.typeCodeMirrorEditorNoError(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = ${elementSourceJson});

		ClickNoError(
			key_text = "Cancel",
			locator1 = "Link#ANY");

		Confirm.dismissAlert();

		AssertTextEquals.assertPartialText(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = "Unsaved Element");

		ClickNoError(
			key_text = "Cancel",
			locator1 = "Link#ANY");

		AssertConfirm(value1 = "You have unsaved changes. Do you want to proceed without saving?");

		Blueprints.gotoElement(element = "Test Element");

		AssertTextNotEquals.assertNotPartialMatch(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = "Unsaved Element");

		Type.typeCodeMirrorEditorNoError(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = ${elementSourceJson});

		ApplicationsMenuHelper.openApplicationsMenu();

		ClickNoError(
			key_category = "Search Experiences",
			key_portlet = "Blueprints",
			locator1 = "ApplicationsMenu#PORTLET");

		Confirm.dismissAlert();

		AssertTextEquals.assertPartialText(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = "Unsaved Element");

		ApplicationsMenuHelper.openApplicationsMenu();

		ClickNoError(
			key_category = "Search Experiences",
			key_portlet = "Blueprints",
			locator1 = "ApplicationsMenu#PORTLET");

		AssertConfirm(value1 = "You have unsaved changes. Do you want to proceed without saving?");

		Blueprints.gotoElement(element = "Test Element");

		AssertTextNotEquals.assertNotPartialMatch(
			locator1 = "Blueprints#CODE_MIRROR_EDITOR",
			value1 = "Unsaved Element");
	}

}