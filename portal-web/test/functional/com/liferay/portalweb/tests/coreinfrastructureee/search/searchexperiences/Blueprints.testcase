		SelectWindow(value1 = "Creating and Managing Search Blueprints - Liferay Learn");

		Close.closeAndSelectWindow(value1 = "Edit Blueprint - ${siteName}");

		Check.checkNotVisible(
			locator1 = "Radio#ANY",
			radioLabel = "Enable All");

		Navigator.gotoNavTab(navTab = "Configuration");

		Click(
			key_linkContext = "Enter additional blueprints configuration settings",
			key_linkText = "Learn more",
			locator1 = "Blueprints#DOC_LINK_GENERIC");

		SelectWindow(value1 = "Search Blueprints Configuration Reference - Liferay Learn");

		Close.closeAndSelectWindow(value1 = "Edit Blueprint - ${siteName}");

		Click(
			key_linkContext = "Add aggregations to those already present",
			key_linkText = "Learn more",
