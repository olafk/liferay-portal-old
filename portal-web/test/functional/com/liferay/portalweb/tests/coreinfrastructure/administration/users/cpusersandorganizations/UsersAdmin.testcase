@component-name = "portal-commerce"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Users and Organizations";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();

		task ("Enable dynamic and manual selection") {
			AssetPublisherPortlet.enableDynamicAndManualSelection();
		}
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "test@liferay.com",
				userLoginFullName = "Test Test");

			JSONUser.tearDownNonAdminUsers();

			Role.tearDownCP();

			Site.tearDownCP();

			Organization.tearDownCP(orgName = "Suborganization*");

			Organization.tearDownCP();
		}
	}

	@description = "This is a use case for LPS-119168."
	@priority = 4
	test AddUser {
		ApplicationsMenu.gotoPortlet(
			category = "Users",
			panel = "Control Panel",
			portlet = "Users and Organizations");

		User.addCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		Alert.viewSuccessMessage();

		User.openUsersAdmin();

		User.viewCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		AssertConsoleTextNotPresent(value1 = "java.lang.NullPointerException");
	}

	@description = "This is a use case for LPS-95340."
	@priority = 4
	test AddUserAfterPublishContentPageWithAP {
		HeadlessSite.addSite(siteName = "Test Site Name");

		PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

		ContentPages.addPage(pageName = "Test Content Page Name");

		PageEditor.addWidget(portletName = "Asset Publisher");

		PageEditor.publish();

		Navigator.openWithAppendToBaseURL(urlAppend = "web/test-site-name/test-content-page-name");

		Alert.viewInfoMessageSpecific(infoMessage = "There are no results.");

		User.openUsersAdmin();

		User.addCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		AssertConsoleTextNotPresent(value1 = "FileNotFoundException");
	}

	@priority = 4
	test AddUsers {
		var count = 1;

		while (${count} != 4) {
			User.openUsersAdmin();

			User.addCP(
				userEmailAddress = "userea${count}@liferay.com",
				userFirstName = "userfn${count}",
				userLastName = "userln${count}",
				userScreenName = "usersn${count}");

			var count = ${count} + 1;
		}

		var count = 1;

		while (${count} != 4) {
			User.openUsersAdmin();

			User.viewCP(
				userEmailAddress = "userea${count}@liferay.com",
				userFirstName = "userfn${count}",
				userLastName = "userln${count}",
				userScreenName = "usersn${count}");

			var count = ${count} + 1;
		}
	}

	@priority = 4
	test AddUserScreenNameInvalid {
		User.openUsersAdmin();

		User.addCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "!@#$",
			userScreenNameVariation = "Invalid");

		Navigator.gotoBack();

		User.viewCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "!@#$",
			userScreenNameVariation = "Invalid");
	}

	@priority = 4
	test AddUserScreenNameNumber {
		property custom.properties = "users.screen.name.allow.numeric=true";

		User.openUsersAdmin();

		User.addCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = 11111);

		User.openUsersAdmin();

		User.viewCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = 11111);
	}

	@priority = 4
	test AddUserSpecialCharacters {
		property custom.properties = "jsonws.web.service.paths.excludes=";

		JSONUser.addUser(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "<userfn>",
			userLastName = "userln",
			userScreenName = "usersn");

		User.openUsersAdmin();

		User.viewCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "<userfn>",
			userLastName = "userln",
			userScreenName = "usersn");

		User.openUsersAdmin();

		JSONUser.setFirstPassword(
			agreeToTermsAndAnswerReminderQuery = "true",
			requireReset = "false",
			userEmailAddress = "userea@liferay.com");

		User.openUsersAdmin();

		User.assignRegularRoleCP(
			roleTitle = "Administrator",
			userScreenName = "usersn");

		User.logoutPG();

		User.loginUserPG(
			password = PropsUtil.get("default.admin.password"),
			userEmailAddress = "userea@liferay.com");

		UserBar.gotoDropdownItem(dropdownItem = "My Profile");

		AssertTextEquals(
			locator1 = "Home#SITE_NAME",
			value1 = "<userfn> userln");
	}

	@description = "This is a use case for LPS-130750."
	@priority = 4
	test AssertRelevanceSortOptionDisplaysWhenSearching {
		JSONUser.addUser(
			userEmailAddress = "userea1@liferay.com",
			userFirstName = "userfn1",
			userLastName = "userln1",
			userScreenName = "usersn1");

		JSONUser.addUser(
			userEmailAddress = "testuser@liferay.com",
			userFirstName = "testuserfn",
			userLastName = "testuserln",
			userScreenName = "testusersn");

		User.openUsersAdmin();

		ManagementBar.viewFilterAndOrderNoItem(menuItem = "Relevance");

		Search.searchCP(searchTerm = "user");

		ManagementBar.viewFilterAndOrderItem(menuItem = "Relevance");
	}

	@priority = 4
	test AssignUserGroupToUser {
		property portal.acceptance = "true";

		JSONUser.addUser(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		JSONUserGroup.addUserGroup(
			userGroupDescription = "UG UserGroup Name Description",
			userGroupName = "UG UserGroup Name");

		User.openUsersAdmin();

		UserNavigator.gotoUser(userScreenName = "usersn");

		User.assignUserGroupCP(userGroupName = "UG UserGroup Name");

		User.openUsersAdmin();

		UserNavigator.gotoUser(userScreenName = "usersn");

		User.viewMemberships(
			assetType = "User Groups",
			assigneeName = "UG UserGroup Name");
	}

	@description = "This is a use case for can add comment for user."
	@priority = 4
	test CanAddComment {
		User.openUsersAdmin();

		User.addCP(
			userComment = "test",
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		Alert.viewSuccessMessage();

		User.openUsersAdmin();

		UserNavigator.gotoUser(userScreenName = "usersn");

		AssertElementPresent(
			locator1 = "TextArea#COMMENTS",
			userComment = "test");

		AssertConsoleTextNotPresent(value1 = "java.lang.NullPointerException");
	}

	@description = "This is a use case for LPS-159181. Assert user can add widget to its private site page."
	@priority = 4
	test CanAddWidgettoMyDashbaordPage {
		UserBar.gotoDropdownItem(dropdownItem = "My Dashboard");

		Portlet.addPG(portletName = "Calendar");

		UserBar.gotoDropdownItem(dropdownItem = "My Dashboard");

		Portlet.viewDefaultTitle(portletName = "Calendar");
	}

	@description = "This is a use case for LPS-159181. Assert user can add widget to its public site page."
	@priority = 4
	test CanAddWidgettoMyProfilePage {
		Navigator.gotoPersonalSite();

		Portlet.addPG(portletName = "Asset Publisher");

		Navigator.gotoPersonalSite();

		Portlet.viewDefaultTitle(portletName = "Asset Publisher");
	}

	@description = "This test changes to cards view for users."
	@priority = 4
	test CanChangeToCardsView {
		JSONUser.addUser(
			userEmailAddress = "userea1@liferay.com",
			userFirstName = "userfn1",
			userLastName = "userln1",
			userScreenName = "usersn1");

		User.openUsersAdmin();

		ManagementBar.changeDisplayStyle(displayStyle = "Cards");

		LexiconCard.viewCardTitle(card = "userfn1 userln1");

		LexiconCard.viewCardSubtitle(
			card = "userfn1 userln1",
			cardSubtitle = "usersn1");
	}

	@description = "This test changes to list view for users."
	@priority = 4
	test CanChangeToListView {
		JSONUser.addUser(
			userEmailAddress = "userea1@liferay.com",
			userFirstName = "userfn1",
			userLastName = "userln1",
			userScreenName = "usersn1");

		User.openUsersAdmin();

		ManagementBar.changeDisplayStyle(displayStyle = "List");

		LexiconList.viewListEntryTitle(listEntry = "userfn1 userln1");

		LexiconList.viewListEntrySubtitle(
			listEntry = "userfn1 userln1",
			listEntrySubtitle = "usersn1");
	}

	@description = "This is a use case for LPS-79937. Portlet options are visible from Control Panel when direct.servlet.context.enabled=false."
	@priority = 4
	test CanExportUsersWithDirectServletContextDisabled {
		property custom.properties = "direct.servlet.context.enabled=false";

		User.openUsersAdmin();

		AssertVisible(locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS");

		Click(locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS");

		MenuItem.clickNoError(menuItem = "Export Users");

		AssertConfirm(value1 = "Warning: This CSV file contains user supplied inputs. Opening a CSV file in a spreadsheet program may be dangerous.");

		AssertConsoleTextNotPresent(value1 = "jakarta.servlet.ServletException");
	}

	@description = "LPS-196309 | As an admin, I can assert that if the account the user is associated is deleted, the user will be listed again by using the filter type 'Unassociated Users'."
	@priority = 4
	test CanFilterByUnassociatedUsersAfterDeletingTheAssociatedAccount {
		property portal.acceptance = "false";

		task ("Given an account with an account user") {
			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Test Account",
				accountEntryType = "Business");

			JSONUser.addUser(
				userEmailAddress = "user1@liferay.com",
				userFirstName = "user1",
				userLastName = "user1",
				userScreenName = "user1");

			JSONAccountEntryUser.addExistUsertoAccount(
				accountEntryName = "Test Account",
				userEmailAddress = "user1@liferay.com");
		}

		task ("When the admin navigates to the Users and Organizations page") {
			User.openUsersAdmin();
		}

		task ("When the admin sets the filter to view Unassociated Users") {
			ManagementBar.setFilterAndOrder(filterBy = "Unassociated Users");
		}

		task ("Then can assert that only the test user is listed") {
			LexiconEntry.viewEntryName(rowEntry = "test");

			LexiconEntry.viewNoEntry(rowEntry = "user1");
		}

		task ("When the account is deleted") {
			Account.openAccountsAdmin();

			Account.deleteAccount(accountName = "Test Account");

			LexiconEntry.viewNoEntry(rowEntry = "Test Account");
		}

		task ("Then the admin can assert that both users are listed") {
			User.openUsersAdmin();

			ManagementBar.setFilterAndOrder(filterBy = "Unassociated Users");

			for (var userName : list "test,user1") {
				LexiconEntry.viewEntryName(rowEntry = ${userName});
			}
		}
	}

	@description = "LPS-196309 | As an admin, I can assert that if the user is removed from the organization, will be listed again by using the filter type 'Unassociated Users'."
	@priority = 4
	test CanFilterByUnassociatedUsersAfterRemovingUserFromOrganization {
		property portal.acceptance = "false";

		task ("Given a user and an organization is created and the user is linked to the organization") {
			JSONUser.addUser(
				userEmailAddress = "user1@liferay.com",
				userFirstName = "user1",
				userLastName = "user1",
				userScreenName = "user1");

			JSONOrganization.addOrganization(organizationName = "Org1");

			JSONOrganization.assignUserToOrganization(
				organizationName = "Org1",
				userEmailAddress = "user1@liferay.com");
		}

		task ("When the admin navigates to the Users and Organizations page") {
			User.openUsersAdmin();
		}

		task ("And the admin sets the filter to view Unassociated Users") {
			ManagementBar.setFilterAndOrder(filterBy = "Unassociated Users");
		}

		task ("Then can assert that only the test user is listed") {
			LexiconEntry.viewEntryName(rowEntry = "test");

			LexiconEntry.viewNoEntry(rowEntry = "user1");
		}

		task ("When the admin removes user from the organization") {
			User.openUsersAdmin();

			UserNavigator.gotoUser(userScreenName = "user1");

			UserNavigator.gotoOrganizations();

			Click(locator1 = "Icon#DELETE");

			Click(locator1 = "Icon#BACK");
		}

		task ("Then can assert that both users are listed") {
			ManagementBar.setFilterAndOrder(filterBy = "Unassociated Users");

			for (var userName : list "test,user1") {
				LexiconEntry.viewEntryName(rowEntry = ${userName});
			}
		}
	}

	@description = "LPS-196309 | As an admin, I can filter users that do not belong to an account or organization by using the filter type 'Unassociated Users'."
	@priority = 5
	test CanFilterUsersByUnassociatedUsers {
		property portal.acceptance = "true";

		task ("Given an account with an account user") {
			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Test Account",
				accountEntryType = "Business");

			JSONUser.addUser(
				userEmailAddress = "user1@liferay.com",
				userFirstName = "user1",
				userLastName = "user1",
				userScreenName = "user1");

			JSONAccountEntryUser.addExistUsertoAccount(
				accountEntryName = "Test Account",
				userEmailAddress = "user1@liferay.com");
		}

		task ("And 2 users not associated to the account but one of them is associated to an organization") {
			for (var newUsers : list "2,3") {
				JSONUser.addUser(
					userEmailAddress = "user${newUsers}@liferay.com",
					userFirstName = "user${newUsers}",
					userLastName = "user${newUsers}",
					userScreenName = "user${newUsers}");
			}

			JSONOrganization.addOrganization(organizationName = "Org1");

			JSONOrganization.assignUserToOrganization(
				organizationName = "Org1",
				userEmailAddress = "user2@liferay.com");
		}

		task ("When the admin navigates to the Users and Organizations page") {
			User.openUsersAdmin();
		}

		task ("Then can assert that all of the users are listed") {
			for (var userName : list "test,user1,user2,user3") {
				LexiconEntry.viewEntryName(rowEntry = ${userName});
			}
		}

		task ("When the admin sets the filter to view Unassociated Users") {
			ManagementBar.setFilterAndOrder(filterBy = "Unassociated Users");
		}

		task ("Then can assert that only the users that are not associated to the account and organization are listed") {
			for (var userName : list "test,user3") {
				LexiconEntry.viewEntryName(rowEntry = ${userName});
			}

			for (var userName : list "user1,user2") {
				LexiconEntry.viewNoEntry(rowEntry = ${userName});
			}
		}
	}

	@description = "This is a use case for LPS-202027. As and admin i cannot create a new user with a date of birth in the future."
	@priority = 4
	test CannotAddUserWithDateOfBirthInTheFuture {
		task ("Given an User with a date of birth in the future") {
			ApplicationsMenu.gotoPortlet(
				category = "Users",
				panel = "Control Panel",
				portlet = "Users and Organizations");

			User.addCP(
				userBirthday = "1/1/2099",
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");
		}

		task ("When an error message appears") {
			Alert.viewErrorMessage(errorMessage = "Error:Please enter a valid date.");
		}

		task ("And the date of birth is changed with the correct date") {
			Type(
				locator1 = "UsersAndOrganizationsEditUser#DETAILS_BIRTHDAY_FIELD",
				value1 = "1/1/1970");

			AssertClick(
				locator1 = "Button#SUBMIT",
				value1 = "Save");

			Alert.viewSuccessMessage();

			Navigator.gotoBack();
		}

		task ("Then the user is created correctly") {
			AssertElementPresent(
				key_rowEntry = "userfn userln",
				locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME");
		}
	}

	@priority = 4
	test CannotViewSiteSettingsInUserPersonalSite {
		Navigator.gotoPersonalSite();

		ProductMenuHelper.openProductMenu();

		ProductMenuHelper.expandCategory(category = "Configuration");

		AssertElementNotPresent(
			key_portlet = "Site Settings",
			locator1 = "ProductMenu#PORTLET");
	}

	@description = "This is a test for LPS-200153. As an admin, I can receive a notification after creating a new user when the Single Approver workflow is applied to User"
	@priority = 5
	test CanReceiveNewUserNotificationsWhenSingleApproverWorkflowIsAppliedToUser {
		property portal.acceptance = "true";

		task ("Given Workflow is configured to Single Approver for User") {
			Workflow.openWorkflowListView();

			Navigator.gotoNavItem(navItem = "Configuration");

			Workflow.configureWorkflow(
				workflowDefinition = "Single Approver",
				workflowResourceValue = "User");
		}

		task ("When a new user is created") {
			User.openUsersAdmin();

			User.addCP(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");
		}

		task ("Then a notification is sent to the Admin User containing the new user") {
			Navigator.openURL();

			Notifications.viewBadgeCount(notificationCount = 1);

			Notifications.gotoNotifications();

			WorkflowAsset.viewNotification(contentBody = "Test Test sent you a User for review in the workflow.");
		}
	}

	@description = "This test changes password through the API Explorer GUI."
	@priority = 4
	test ChangeUserPasswordViaAPIExplorerGUI {
		property custom.properties = "jsonws.web.service.paths.excludes=";

		task ("Given a user logs in") {
			JSONUser.addUser(
				userEmailAddress = "userea1@liferay.com",
				userFirstName = "userfn1",
				userLastName = "userln1",
				userScreenName = "usersn1");

			JSONUser.setFirstPassword(
				agreeToTermsAndAnswerReminderQuery = "true",
				requireReset = "false",
				userEmailAddress = "userea1@liferay.com");

			User.logoutAndLoginPG(
				userLoginEmailAddress = "userea1@liferay.com",
				userLoginFullName = "userfn1 userln1");
		}

		task ("When update the user's own password via the API Explorer GUI and back to Portal and refresh") {
			APIExplorer.navigateToOpenAPI(
				api = "headless-admin-user",
				version = "v1.0");

			var requestBody = '''
				{
					"currentPassword": "test",
					"password": "test2"
				}
			''';
			var value = JSONUserAPI._getUserIdByEmailAddress(userEmailAddress = "userea1@liferay.com");

			APIExplorer.executeAPIMethod(
				method = "patchUserAccount",
				parameter = "userAccountId",
				requestBody = ${requestBody},
				service = "UserAccount",
				value = ${value});

			AssertTextEquals(
				locator1 = "OpenAPI#RESPONSE_CODE",
				method = "patchUserAccount",
				value1 = 200);

			ExecuteJavaScript(value1 = "window.history.go(-1)");

			Refresh();
		}

		task ("Then user is not logged out and assert no NPE message") {
			UserBar.gotoDropdown();

			UserBar.viewFullName(userName = "USERFN1 USERLN1");

			AssertConsoleTextNotPresent(value1 = "java.lang.NullPointerException: null");
		}

		task ("When user logs out and logs in with new password") {
			User.logoutAndLoginPG(
				password = "test2",
				userLoginEmailAddress = "userea1@liferay.com",
				userLoginFullName = "userfn1 userln1");
		}

		task ("Then the user logs in successfully") {
			UserBar.gotoDropdown();

			UserBar.viewFullName(userName = "userfn1 userln1");
		}
	}

	@description = "This test changes password through the Password Reset link sent in email."
	@priority = 4
	test ChangingPasswordIsSuccessfulViaPasswordResetLink {
		property custom.properties = "mail.send.blacklist=noreply@liferay.com,noreply@domain.invalid,test@domain.invalid";
		property test.smtp.server.enabled = "true";

		var portalURL = PropsUtil.get("portal.url");

		PortalSettings.gotoConfiguration(
			configurationCategory = "Email",
			configurationName = "Email Sender",
			configurationScope = "Virtual Instance Scope");

		PortalSettings.configureEmailSender(
			emailAddress = "test@liferay.com",
			emailSenderName = "Joe Bloggs");

		User.openUsersAdmin();

		User.addCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		User.logoutPG();

		User.forgotPasswordSendResetLink(userEmailAddress = "userea@liferay.com");

		MockMock.openBodyLink(
			asset = "${portalURL}: Reset Your Password",
			content = "You can reset your password for ${portalURL}",
			subject = "${portalURL}: Reset Your Password");

		User.setPasswordByResetLink(
			newPassword1 = "Password1",
			newPassword2 = "Password1");

		User.logoutPG();

		User.loginPG(
			password = "Password1",
			userEmailAddress = "userea@liferay.com");
	}

	@priority = 4
	test DeleteUser {
		property portal.acceptance = "true";

		User.openUsersAdmin();

		User.addCP(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		User.openUsersAdmin();

		User.deactivateCP(
			deactivateType = "Actions",
			userFirstName = "userfn");

		User.openUsersAdmin();

		User.searchCP(searchTerm = "usersn");

		User.viewNoUsersFoundCP();

		User.openUsersAdmin();

		User.deleteCP(
			deactivateType = "Actions",
			userFirstName = "userfn");

		User.openUsersAdmin();

		ManagementBar.setFilterAndOrder(filterBy = "Inactive");

		User.searchCP(searchTerm = "usersn");

		User.viewNoUsersFoundCP();
	}

	@description = "This is a use case for LPS-121271."
	@priority = 4
	test EditAlertsandAnnouncementsDelivery {
		property portal.acceptance = "true";

		JSONUser.addUser(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		User.openUsersAdmin();

		UserNavigator.gotoUser(userScreenName = "usersn");

		User.editUserAlertsAndAnnouncementsDeliveryCP(
			checkbox = "Enable",
			deliveryOptions = "General,Test");

		User.openUsersAdmin();

		UserNavigator.gotoUser(userScreenName = "usersn");

		UserNavigator.gotoAlertsAndAnnouncementsDelivery();

		AssertChecked(
			key_tableEntry = "General",
			locator1 = "LexiconTable#TABLE_ENTRY_CHECKBOX");

		AssertChecked(
			key_tableEntry = "Test",
			locator1 = "LexiconTable#TABLE_ENTRY_CHECKBOX");

		AssertNotChecked(
			key_tableEntry = "News",
			locator1 = "LexiconTable#TABLE_ENTRY_CHECKBOX");
	}

	@priority = 4
	test EditUserAdditionalEmailAddresses {
		property portal.acceptance = "true";

		JSONUser.addUser(
			userEmailAddress = "userea@liferay.com",
			userFirstName = "userfn",
			userLastName = "userln",
			userScreenName = "usersn");

		User.openUsersAdmin();

		UserNavigator.gotoUser(userScreenName = "usersn");

		UserNavigator.gotoContact();

		Navigator.gotoNavNested(navNested = "Contact Information");

		User.addContactInformation(
