@component-name = "portal-upgrades"
definition {

	property ci.retries.disabled = "true";
	property database.types = "db2,mariadb,mysql,oracle,postgresql,sqlserver";
	property portal.release = "true";
	property portal.upstream = "true";
	property test.liferay.virtual.instance = "false";
	property test.run.type = "single";
	property testray.component.names = "LDAP";
	property testray.main.component.name = "Upgrades Security";

	setUp {
		SignIn.signIn();

		SearchAdministration.executeReindex();
	}

	@description = "This is a use case for LPS-119816. Assert all the configurations under LDAP are persisted after upgrade from 7.1.3. Blocked by LPS-190439"
	@ignore = "true"
	@priority = 3
	test ViewLDAPConfigurationAfterUpgrade713 {
		property data.archive.type = "data-archive-ldap";
		property database.types = "mariadb,mysql,postgresql";
		property portal.version = "7.1.3";

		ValidateLDAPUpgrade.viewLDAPConfiguration();
	}

	@description = "This is a use case for LPS-119816. Assert all the configurations under LDAP are persisted after upgrade from 7.2.1. Blocked by LPS-190439"
	@ignore = "true"
	@priority = 3
	test ViewLDAPConfigurationAfterUpgrade721 {
		property data.archive.type = "data-archive-ldap";
		property database.types = "mariadb,mysql,postgresql";
		property portal.version = "7.2.1";

		ValidateLDAPUpgrade.viewLDAPConfiguration();
	}

	@description = "This is a use case for LPS-119816. Assert all the configurations under LDAP are persisted after upgrade from 7.1.10.3. Blocked by LPS-190439"
	@ignore = "true"
	@priority = 3
	test ViewLDAPConfigurationAfterUpgrade71103 {
		property data.archive.type = "data-archive-ldap";
		property portal.version = "7.1.10.3";

		ValidateLDAPUpgrade.viewLDAPConfiguration();
	}

	@description = "This is a use case for LPS-119816. Assert all the configurations under LDAP are persisted after upgrade from 7.2.10.1. Blocked by LPS-190439"
	@ignore = "true"
	@priority = 3
	test ViewLDAPConfigurationAfterUpgrade72101 {
		property data.archive.type = "data-archive-ldap";
		property portal.version = "7.2.10.1";

		ValidateLDAPUpgrade.viewLDAPConfiguration();
	}

	@description = "This is a use case for LPS-119816. Assert all the configurations under LDAP are persisted after upgrade from 7.3.10.1"
	@priority = 3
	test ViewLDAPConfigurationAfterUpgrade73101 {
		property data.archive.type = "data-archive-ldap";
		property portal.version = "7.3.10.1";

		ValidateLDAPUpgrade.viewLDAPConfiguration();
	}

}