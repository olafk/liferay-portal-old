			contactName = "testfn testln",
			emailAddress = "test1@liferay.com");

		ContactsCenter.viewContactPG(
			contactName = "testfn testln",
			emailAddress = "test1@liferay.com");

		JSONWebcontent.addWebContent(
			content = "This is a WC Content for GDPR testing.",
