@component-name = "portal-db-infrastructure"
definition {

	property app.server.types = "tomcat";
	property ci.retries.disabled = "true";
	property data.archive.type = "data-archive-portal";
	property database.types = "mysql";
	property portal.release = "true";
	property portal.upstream = "true";
	property portal.version = "7.4.13";
	property skip.start.app.server = "true";
	property test.liferay.virtual.instance = "false";
	property test.run.type = "single";
	property testcase.url = "http://www.example.com";
	property testray.main.component.name = "Database Upgrade Tool";

	@description = "LPS-193985: The upgrade report is generated in the default path when the directory specified is write protected"
	@ignore = "true"
	@priority = 3
	test ReportGeneratedInDefaultPathWhenWriteProtectedDirectory {
		property custom.properties = "upgrade.report.dir=${liferay.home}/tools/portal-tools-db-upgrade-client/temp";
		property database.auto.upgrade.enabled = "true";
		property skip.upgrade-legacy-database = "true";

		task ("Given a write protected directory") {
			AntCommands.runCommand("modules/util/portal-tools-db-upgrade-client/src/testFunctional/ant/build-test-db-upgrade-client.xml", "create-write-protected-directory");
		}

		task ("When upgrade is complete") {
			Portlet.startServer(deleteLiferayHome = "false");
		}

		task ("Then the upgrade report is generated in the default directory") {
			var liferayHome = PropsUtil.get("liferay.home.dir.name");
			var upgradeLogContent = Log.getLogFileContent();

			if (!(contains(${upgradeLogContent}, "Unable to generate the upgrade report at ${liferayHome}/tools/portal-tools-db-upgrade-client/temp"))) {
				fail("Unable to generate upgrade report file message not present");
			}

			var upgradeReportExists = FileUtil.exists("${liferayHome}/reports/upgrade_report.info");

			if (${upgradeReportExists} == "false") {
				fail("Upgrade report is not generated in default directory: ${liferayHome}/reports");
			}
		}

		task ("Clean up write protected directory") {
			AntCommands.runCommand("modules/util/portal-tools-db-upgrade-client/src/testFunctional/ant/build-test-db-upgrade-client.xml", "delete-write-protected-directory");
		}
	}
}