@component-name = "portal-db-infrastructure"
definition {

	property app.server.types = "tomcat";
	property ci.retries.disabled = "true";
	property data.archive.type = "data-archive-portal";
	property database.types = "mysql";
	property portal.release = "true";
	property portal.upstream = "true";
	property portal.version = "7.4.13";
	property skip.start.app.server = "true";
	property test.liferay.virtual.instance = "false";
	property test.run.type = "single";
	property testcase.url = "http://www.example.com";
	property testray.main.component.name = "Database Upgrade Tool";

	@description = "LPS-193985: The upgrade report is generated in the default path when the directory specified is write protected"
	@ignore = "true"
	@priority = 3
	test ReportGeneratedInDefaultPathWhenWriteProtectedDirectory {
		property custom.properties = "upgrade.report.dir=${liferay.home}/tools/portal-tools-db-upgrade-client/temp";
		property database.auto.upgrade.enabled = "true";
		property skip.upgrade-legacy-database = "true";

		task ("Given a write protected directory") {
			AntCommands.runCommand("modules/util/portal-tools-db-upgrade-client/src/testFunctional/ant/build-test-db-upgrade-client.xml", "create-write-protected-directory");
		}

		task ("When upgrade is complete") {
			Portlet.startServer(deleteLiferayHome = "false");
		}

		task ("Then the upgrade report is generated in the default directory") {
			var liferayHome = PropsUtil.get("liferay.home.dir.name");
			var upgradeLogContent = Log.getLogFileContent();

			if (!(contains(${upgradeLogContent}, "Unable to generate the upgrade report at ${liferayHome}/tools/portal-tools-db-upgrade-client/temp"))) {
				fail("Unable to generate upgrade report file message not present");
			}

			var upgradeReportExists = FileUtil.exists("${liferayHome}/reports/upgrade_report.info");

			if (${upgradeReportExists} == "false") {
				fail("Upgrade report is not generated in default directory: ${liferayHome}/reports");
			}
		}

		task ("Clean up write protected directory") {
			AntCommands.runCommand("modules/util/portal-tools-db-upgrade-client/src/testFunctional/ant/build-test-db-upgrade-client.xml", "delete-write-protected-directory");
		}
	}

	@description = "LPS-154683: Upgrade Report is not created when property is not set to true"
	@priority = 4
	test ReportNotGenerated {
		property custom.properties = "upgrade.report.enabled=false";

		task ("Look for the upgrade report") {
			var liferayHome = PropsUtil.get("liferay.home.dir.name");

			var reportFileExists = FileUtil.exists("${liferayHome}/tools/portal-tools-db-upgrade-client/reports/upgrade_report.info");
		}

		task ("Check file doesn't exist") {
			if (${reportFileExists} == "true") {
				fail("Upgrade report found in ${liferayHome}/tools/portal-tools-db-upgrade-client/reports/");
			}
		}
	}

	@description = "LPS-193985: Upgrade report directory can be specified with auto-upgrade"
	@priority = 4
	test UserCanSpecifyUpgradeReportDirectoryWithAutoUpgrade {
		property custom.properties = "upgrade.report.dir=${liferay.home}/logs";
		property database.auto.upgrade.enabled = "true";
		property skip.start.app.server = "false";
		property skip.upgrade-legacy-database = "true";

		task ("Then the upgrade report is generated in the specified directory") {
			var liferayHome = PropsUtil.get("liferay.home.dir.name");

			var upgradeReportExists = FileUtil.exists("${liferayHome}/logs/upgrade_report.info");

			if (${upgradeReportExists} == "false") {
				fail("Upgrade report is not generated in specified directory: ${liferayHome}/logs");
			}
		}
	}

	@description = "LPS-193985: Upgrade report directory can be specified with upgrade tool"
	@priority = 4
	test UserCanSpecifyUpgradeReportDirectoryWithUpgradeTool {
		property custom.upgrade.properties = "upgrade.report.dir=${liferay.home}/tools/portal-tools-db-upgrade-client/logs";

		task ("Then the upgrade report is generated in the specified directory") {
			var liferayHome = PropsUtil.get("liferay.home.dir.name");

			var upgradeReportExists = FileUtil.exists("${liferayHome}/tools/portal-tools-db-upgrade-client/logs/upgrade_report.info");

			if (${upgradeReportExists} == "false") {
				fail("Upgrade report is not generated in specified directory: ${liferayHome}/tools/portal-tools-db-upgrade-client/logs");
			}
		}
	}

	@description = "LPS-158743: Upgrade report trace line is generated in the console"
	@priority = 3
	test UserNotifiedWhereToFindUpgradeReportAfterAutoUpgrade {
		property custom.properties = "upgrade.log.context.enabled=true";
		property database.auto.upgrade.enabled = "true";
		property log.context.enabled = "true";
		property skip.start.app.server = "false";
		property skip.upgrade-legacy-database = "true";

		task ("When the upgrade report is finished generating, Then the user is notified in the Portal log file where to find the upgrade report") {
			var liferayHome = PropsUtil.get("liferay.home.dir.name");

			AssertConsoleTextPresent(value1 = "Upgrade report generated in ${liferayHome}/reports/upgrade_report.info");
		}
	}

	@description = "LPS-181594: The message with the upgrade report file path is printed in the logs"
	@priority = 4
	test UserNotifiedWhereToFindUpgradeReportInUpgradeTool {
		task ("Given a user views the upgrade log file") {
			var upgradeLogContent = Log.getUpgradeLogFileContent();
		}

		task ("When the upgrade finishes, Then the user is notified in the upgrade log file that the upgrade report is being generated") {
			if (!(contains(${upgradeLogContent}, "Starting upgrade report generation"))) {
				fail("Starting upgrade report generation message not present in the logs");
			}
		}

		task ("When the upgrade report is finished generating, Then the user is notified in the upgrade log file where to find the upgrade report") {
			var liferayHome = PropsUtil.get("liferay.home.dir.name");

			if (!(contains(${upgradeLogContent}, "Upgrade report generated in ${liferayHome}/tools/portal-tools-db-upgrade-client/./reports/upgrade_report.info"))) {
				fail("Upgrade report file path message not present");
			}
		}
	}

}