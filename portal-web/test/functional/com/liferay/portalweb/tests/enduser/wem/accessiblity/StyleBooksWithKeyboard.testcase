@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Style Books";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-177721. Using Keyboard Navigation it is possible to access the back button of Style Books view and edit mode and the tooltip is Go to Style Books."
	@priority = 3
	test ViewBackButtonTooltipInStyleBookEditorViaKeyboard {
		task ("Given access to the style book editor") {
			StyleBooksAdmin.openStyleBooksAdmin(siteURLKey = "test-site-name");

			StyleBooksAdmin.addStyleBooks(styleBookName = "Test Style Book Name");
		}

		task ("When hover on the back button via keyboard") {
			KeyPress(
				locator1 = "ProductMenu#TOGGLE",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "Icon#BACK");
		}

		task ("Then see the tooltip message") {
			AssertVisible(
				key_content = "Go to Style Books",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}
	}

}