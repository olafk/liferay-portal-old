@component-name = "portal-frontend-infrastructure"
definition {

	property custom.properties = "feature.flag.LPS-164563=true${line.separator}feature.flag.LPS-167253=true${line.separator}feature.flag.LPS-184016=true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Client Extensions";
	property testray.main.component.name = "Client Extensions";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			Navigator.gotoPage(pageName = "Home");

			ClientExtensionGeneral.tearDown();
		}
	}

	@description = "LPS-190220. Verify that when the user clicks on Cancel, the changes are not saved."
	@priority = 4
	test CanCancelChanges {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And fill in fields JS URL, Source Code URL and Description :") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");

			Type.typeNoMouseOver(
				key_text = "JavaScript URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");

			Type(
				locator1 = "CKEditor#BODY_FIELD_IFRAME",
				value1 = "This filter adds the possibility to add slider ranges to the date filter.");

			Type(
				key_text = "Source Code URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");
		}

		task ("And clicks on Cancel button") {
			Button.clickCancel();
		}

		task ("Then there is no “Date Filter Improvements” entry on Client Extension admin page") {
			AssertElementNotPresent(
				key_tableEntryName = "Date Filter Improvements",
				locator1 = "ClientExtension#TABLE_ENTRY_NAME_REMOTE_TABLE");
		}
	}

	@description = "LPS-190220. Verify that the User can go to the CX Documentation when clicks on the help text."
	@priority = 3
	test CanClickOnHelpText {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And clicks on hyperlink help text “Learn more about browser based client extensions”") {
			Click(
				key_text = "Learn more about browser based client extensions.",
				locator1 = "Link#ANY");
		}

		task ("Then the user is redirected to Client Extension documentation") {
			Navigator.selectSpecificWindow(windowTitle = "Client Extensions - Liferay Learn");
		}
	}

	@description = "LPS-190220. Verify that when the user fills all fields and clicks on Publish, the changes are saved."
	@priority = 5
	test CanCreateACXFilter {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And fill in fields JS URL, Source Code URL and Description :") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");

			Type.typeNoMouseOver(
				key_text = "JavaScript URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");

			Type(
				locator1 = "CKEditor#BODY_FIELD_IFRAME",
				value1 = "This filter adds the possibility to add slider ranges to the date filter.");

			Type(
				key_text = "Source Code URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");
		}

		task ("And clicks on Publish button") {
			PortletEntry.publish();
		}

		task ("Then a confirmation message is displayed") {
			Alert.viewSuccessMessage();
		}

		task ("And “Date Filter Improvements” entry is present on Client Extension admin page") {
			ClientExtensionGeneral.viewTableEntries(
				entryName = "Date Filter Improvements",
				entryType = "Frontend Data Set Filter");
		}
	}

	@description = "LPS-190220. Verify that the user can Delete the FDS Filter entry"
	@priority = 5
	test CanDeleteACXFilterEntry {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And fill in fields JS URL, Source Code URL and Description :") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");

			Type.typeNoMouseOver(
				key_text = "JavaScript URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");

			Type(
				locator1 = "CKEditor#BODY_FIELD_IFRAME",
				value1 = "This filter adds the possibility to add slider ranges to the date filter.");

			Type(
				key_text = "Source Code URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");
		}

		task ("And clicks on Publish button") {
			PortletEntry.publish();
		}

		task ("And delete the Date Filter Improvements entry") {
			Click(locator1 = "Icon#SVG_ELLIPSIS");

			MenuItem.clickNoError(menuItem = "Delete");

			AssertConfirm(value1 = "Are you sure you want to delete Date Filter Improvements? Client extension will be removed immediately. Sites using this client extension will be affected. This action cannot be undone.");
		}

		task ("Then the Client Extension admin page is empty") {
			AssertTextEquals(
				locator1 = "Message#EMPTY_STATE_INFO",
				value1 = "No Results Found");
		}
	}

	@description = "LPS-190220. Verify that the user can edit the CX Filter entry"
	@priority = 5
	test CanEditCXFilterEntry {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And fill in fields JS URL, Source Code URL and Description :") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");

			Type.typeNoMouseOver(
				key_text = "JavaScript URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");

			Type(
				locator1 = "CKEditor#BODY_FIELD_IFRAME",
				value1 = "This filter adds the possibility to add slider ranges to the date filter.");

			Type(
				key_text = "Source Code URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");
		}

		task ("And clicks on Publish button") {
			PortletEntry.publish();
		}

		task ("And go to the edit page of the Extension client created ") {
			Click(locator1 = "Icon#SVG_ELLIPSIS");

			MenuItem.click(menuItem = "Edit");
		}

		task ("And change the name of client extension") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements Edited");
		}

		task ("And clicks on Publish button") {
			PortletEntry.publish();
		}

		task ("And “Date Filter Improvements Edited” entry is present on Client Extension admin page") {
			ClientExtensionGeneral.viewTableEntries(
				entryName = "Date Filter Improvements Edited",
				entryType = "Frontend Data Set Filter");
		}
	}

	@description = "LPS-190220. Verify that the user can hide Additional Resources section, clicking on the collapse icon"
	@priority = 3
	test CanHideAdditionalResourcesSection {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And clicks on Additional Resources icon") {
			ClientExtensionGeneral.openOrCloseCollapseField(
				key_fieldName = "Additional Resources",
				key_status = "Close");
		}

		task ("Then Source Code URL field is hidden") {
			AssertNotVisible(
				key_fieldName = "Source Code URL",
				locator1 = "ClientExtension#ANY_FIELD");
		}
	}

	@description = "LPS-190220. Verify that the use can hide Content section"
	@priority = 3
	test CanHideContentSection {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And clicks on Content collapse icon") {
			ClientExtensionGeneral.openOrCloseCollapseField(
				key_fieldName = "Content",
				key_status = "Close");
		}

		task ("Then JS URL field is hidden") {
			AssertNotVisible(
				key_fieldName = "JavaScript URL",
				locator1 = "ClientExtension#ANY_FIELD");
		}
	}

	@description = "LPS-190220. Verify that the user can hide Identity field, clicking on the collapse icon"
	@priority = 3
	test CanHideIdentityField {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And clicks on Identity collapse icon") {
			ClientExtensionGeneral.openOrCloseCollapseField(
				key_fieldName = "Identity",
				key_status = "Close");
		}

		task ("Then Name and Description fields are hidden") {
			AssertNotVisible(
				key_fieldName = "Name",
				locator1 = "ClientExtension#ANY_FIELD");

			AssertNotVisible(
				key_fieldName = "Description",
				locator1 = "ClientExtension#ANY_FIELD");
		}
	}

	@description = "LPS-190220. Verify that the JavaScript URL field is mandatory."
	@priority = 5
	test CannotLeaveJSURLFieldEmpty {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And fill in fields JS URL, Source Code URL and Description :") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");

			Type(
				locator1 = "CKEditor#BODY_FIELD_IFRAME",
				value1 = "This filter adds the possibility to add slider ranges to the date filter.");

			Type(
				key_text = "Source Code URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");
		}

		task ("And clicks on Publish button") {
			PortletEntry.publish();
		}

		task ("Then an error message should be displayed") {
			Alert.viewSpecificRequiredField(fieldFieldLabel = "JavaScript URL");
		}
	}

	@description = "LPS-190220. Verify that the Name field cannot be empty"
	@priority = 5
	test CannotLeaveNameFieldEmpty {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And fill in fields JS URL, Source Code URL and Description :") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "");

			Type.typeNoMouseOver(
				key_text = "JavaScript URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");

			Type(
				locator1 = "CKEditor#BODY_FIELD_IFRAME",
				value1 = "This filter adds the possibility to add slider ranges to the date filter.");

			Type(
				key_text = "Source Code URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");
		}

		task ("And clicks on Publish button") {
			PortletEntry.publish();
		}

		task ("Then an error message should be displayed") {
			Alert.viewErrorMessage(errorMessage = "Client extension name is required.");
		}
	}

	@description = "LPS-190220. Verify if the Description field is not mandatory and can be empty"
	@priority = 3
	test DescriptionFieldIsNotMandatory {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And fill in fields Name, JS URL, Source Code URL") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");

			Type.typeNoMouseOver(
				key_text = "JavaScript URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");

			Type(
				key_text = "Source Code URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");
		}

		task ("And clicks on Publish button") {
			PortletEntry.publish();
		}

		task ("Then a confirmation message is displayed") {
			Alert.viewSuccessMessage();
		}

		task ("And “Date Filter Improvements” entry is present on Client Extension admin page") {
			ClientExtensionGeneral.viewTableEntries(
				entryName = "Date Filter Improvements",
				entryType = "Frontend Data Set Filter");
		}
	}

	@description = "LPS-190220. Verify that the Name field is localizable."
	@priority = 3
	test LocalizedNameField {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("Add a title name in the English language") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");
		}

		task ("Add a title name in the Portuguese language") {
			Click(
				key_locale = "en-US",
				locator1 = "Translation#CURRENT_LOCALE_NAME");

			DropdownMenuItem.click(menuItem = "pt-BR");

			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements translated");
		}

		task ("And change the title to English") {
			Click(
				key_locale = "pt-BR",
				locator1 = "Translation#CURRENT_LOCALE_NAME");

			DropdownMenuItem.click(menuItem = "en-US");
		}

		task ("Then the title “Date Filter Improvements“ is shown in the Title field") {
			AssertElementPresent(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");
		}

		task ("When changing the title to portuguese") {
			Click(
				key_locale = "en-US",
				locator1 = "Translation#CURRENT_LOCALE_NAME");

			DropdownMenuItem.click(menuItem = "pt-BR");
		}

		task ("Then the title “Date Filter Improvements translated“ is shown in the Title field") {
			AssertElementPresent(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements translated");
		}
	}

	@description = "LPS-190220. Verify if Source Code URL field is not mandatory and can be empty"
	@priority = 3
	test SourceCodeURLFieldIsNotMandatory {
		task ("Given Client Extension admin page") {
			ClientExtensionGeneral.goToRemoteAppsPortlet();
		}

		task ("When to select the FDS filter option") {
			LexiconEntry.gotoAdd();

			DropdownMenuItem.click(menuItem = "Add Frontend Data Set Filter");
		}

		task ("And fill in fields JS URL, Source Code URL and Description :") {
			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Date Filter Improvements");

			Type.typeNoMouseOver(
				key_text = "JavaScript URL",
				locator1 = "TextInput#ANY",
				value1 = "https://liferay.github.io/liferay-frontend-projects/date-filter.js");

			Type(
				locator1 = "CKEditor#BODY_FIELD_IFRAME",
				value1 = "This filter adds the possibility to add slider ranges to the date filter.");
		}

		task ("And clicks on Publish button") {
			PortletEntry.publish();
		}

		task ("Then a confirmation message is displayed") {
			Alert.viewSuccessMessage();
		}

		task ("And “Date Filter Improvements” entry is present on Client Extension admin page") {
			ClientExtensionGeneral.viewTableEntries(
				entryName = "Date Filter Improvements",
				entryType = "Frontend Data Set Filter");
		}
	}

}