	@description = "LPS-185500. Confirm that can cancel field deletion on cancel button."
	@priority = 3
	test CanCancelFieldDeletion {
		task ("And adds 'id' field") {
			DataSetAdmin.addFields(key_fieldList = "id");
		}

		task ("When the user selects the Delete option in the 3 dots menu") {
			Click(
				key_fieldName = "id",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_BY_FIELDS_NAME");

			ClickNoError(locator1 = "ObjectPortlet#DELETE_ENTRY_BUTTON");
		}

		task ("Then the confirmation message is displayed") {
			AssertElementPresent(
				key_modalText = "Are you sure you want to delete this field? It will be removed immediately. Fragments using it will be affected. This action cannot be undone.",
				locator1 = "DataSet#DELETE_DATA_SET_MODAL_BODY");
		}

		task ("And the user cancels the confirmation message") {
			Button.clickCancel();
		}

		task ("Then the field is not deleted / And assert the field still appears in the Fields tab table") {
			DataSetAdmin.assertFieldsOnTable(
				key_position = 1,
				keyName = "id");
		}
	}

	@description = "LPS-176516 Confirm that the indication of a translation in the field and stop with the cancel button"
	@priority = 3
	test CanCancelTranslationOnCancelButton {
		task ("And adds two or more fields") {
			DataSetAdmin.addFields(key_fieldList = "creator,id,status");
		}

		task ("And clicks on ellipsis button on one of these fields") {
			Click(
				key_fieldName = "creator",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_BY_FIELDS_NAME");
		}

		task ("And clicks on Edit option") {
			MenuItem.click(menuItem = "Edit");
		}

		task ("And clicks on language button") {
			Click(
				key_symbolName = "",
				locator1 = "FormViewBuilder#BUTTON_LOCALIZATION");
		}

		task ("And add a pt-BR translate") {
			Click(
				locator1 = "CommerceWidget#TAG_FACET_COMPACT_LAYOUT",
				tagName = "pt_BR");

			Click(
				locator1 = "Portlet#MODAL_TITLE",
				value1 = "Edit creator");

			Type(
				key_text = "Label",
				locator1 = "TextInput#ANY",
				value1 = "PT-BR");

			Button.clickCancel();
		}

		task ("And clicks on edit again, and localization button") {
			Click(
				key_fieldName = "creator",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_BY_FIELDS_NAME");

			MenuItem.click(menuItem = "Edit");

			Click(
				key_symbolName = "",
				locator1 = "FormViewBuilder#BUTTON_LOCALIZATION");
		}

		task ("Then the translations are not saved, in the language dropdown dont have the TRANSLATED green label") {
			AssertElementNotPresent(
				locator1 = "CommerceWidget#TAG_FACET_LABEL_LAYOUT",
				tagName = "Translated");
		}
	}

	@description = "LPS-176516 Confirm that the indication of a translation in the field and stop with the close button "
	@priority = 3
	test CanCancelTranslationOnCloseButton {
		task ("And adds two or more fields") {
			DataSetAdmin.addFields(key_fieldList = "creator,id,status");
		}

		task ("And clicks on ellipsis button on one of these fields") {
