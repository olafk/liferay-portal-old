@component-name = "portal-page-management"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Page Editor";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Add a new user with site administrator role") {
			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.addUserToSite(
				groupName = "Test Site Name",
				userEmailAddress = "userea@liferay.com");

			JSONRole.assignSiteRoleToUser(
				groupName = "Test Site Name",
				roleTitle = "Site Administrator",
				userEmailAddress = "userea@liferay.com");
		}
	}

	@description = "This is a test for LPS-182022. The content page shouldn’t be locked when edit the displayed content."
	@priority = 4
	test CannotLockContentPageWhenEditDisplayedContent {
		task ("Given a page designer has a content page with displayed content") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONWebcontent.addWebContent(
				content = "Web Content Content",
				groupName = "Test Site Name",
				title = "Web Content Title");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Content Display");

			PageEditor.editContentDisplay(
				fragmentName = "Content Display",
				webcontent = "true",
				webContentContent = "Web Content Content",
				webContentTitle = "Web Content Title");

			PageEditor.publish();
		}

		task ("When the page designer edit the displayed content") {
			ContentPages.gotoPageEditor();

			PageEditor.gotoEllipsisMenuItemInPageContentPanel(
				itemName = "Web Content Title",
				menuItem = "Edit");

			WebContent.addCP(webContentTitle = "Welcome to Liferay");
		}

		task ("Then the content page shouldn't be locked") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ContentPages.gotoPageEditor();

			ContentPages.viewFragmentText(
				assetType = "journal",
				fragmentName = "Content Display",
				text = "Web Content Content");
		}
	}

	@description = "This is a test for LPS-182022. The user could edit the master page or style book used by a locked content page."
	@priority = 4
	test EditMasterPageOrStyleBookUsedByLockedContentPage {
		task ("Given a page designer has a locked content page using master page and style book") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONLayoutpagetemplate.addMasterPageTemplateEntry(
				groupName = "Test Site Name",
				masterPageTemplateEntryName = "Master Page Template",
				masterPageTemplateStatus = "Approved");

			JSONStylebooks.addStyleBookEntry(
				groupName = "Test Site Name",
				styleBookEntryName = "Test Style Book Name");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			PageEditor.gotoTab(tabName = "Page Design Options");

			MastersPageTemplates.selectMasterViaPageDesignOptions(masterLayoutName = "Master Page Template");

			StyleBooks.selectStyleBookViaPageDesignOptions(styleBookName = "Test Style Book Name");
		}

		task ("When the page designer navigates to the Masters admin") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Design",
				portlet = "Page Templates");
		}

		task ("Then the page designer could edit the master page") {
			MastersPageTemplatesAdmin.gotoMasters(masterLayoutName = "Master Page Template");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				dropTarget = "Header",
				fragmentName = "Heading",
				scope = "Master");

			MastersPageTemplates.propagateChange();
		}

		task ("When the page designer navigates to the Style Books admin") {
			ProductMenu.gotoPortlet(
				category = "Design",
				portlet = "Style Books");
		}

		task ("Then the page designer could edit the style book") {
			StyleBooksAdmin.gotoStyleBook(styleBookName = "Test Style Book Name");

			StyleBooks.selectForm(formName = "Buttons");

			StyleBooks.expandSection(sectionName = "Button Primary");

			Type(
				key_fieldLabel = "Background Color",
				key_groupLabel = "Button Primary",
				locator1 = "TextInput#GROUPED_TEXT_INPUT",
				value1 = "#00FF00");

			StyleBooks.clickManagementBar();

			StyleBooks.waitForAutoSave();

			StyleBooks.clickPublish();
		}
	}

	@description = "This is a test for LPS-182022. The user could overwrite the locked master page by import."
	@priority = 4
	test OverwriteLockedMasterPageByImport {
		task ("Given a page designer has a locked master page") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONLayoutpagetemplate.addMasterPageTemplateEntry(
				groupName = "Test Site Name",
				masterPageTemplateEntryName = "Master Page Template",
				masterPageTemplateStatus = "Approved");

			MastersPageTemplatesAdmin.openMastersAdmin(siteURLKey = "test-site-name");

			MastersPageTemplatesAdmin.gotoMastersEllipsisItem(
				item = "Export",
				masterLayoutName = "Master Page Template");

			DownloadTempFile();

			MastersPageTemplatesAdmin.gotoMasters(masterLayoutName = "Master Page Template");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				dropTarget = "Header",
				fragmentName = "Button",
				scope = "Master");
		}

		task ("When the page designer navigates to the Masters admin") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Design",
				portlet = "Page Templates");
		}

		task ("Then the page designer could overwrite the locked master page by import") {
			MastersPageTemplatesAdmin.importMastersFromTempFolder(importOption = "Overwrite Existing Items");

			MastersPageTemplatesAdmin.viewMastersPresent(masterLayoutName = "Master Page Template");
		}
	}

	@description = "This is a test for LPS-182022. The user could propagate the changes of fragment to a locked content page."
	@priority = 4
	test PropagateChangesOfFragmentToLockedContentPage {
		task ("Given a page designer has a locked content page with custom fragment") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONFragment.addFragmentCollection(
				groupName = "Test Site Name",
				name = "Fragment Set Name");

			var newLine = '''
''';
			var htmlSnippet = '''
<div class="fragment-name">
	Fragment Example
</div>''';

			var htmlSnippet = StringUtil.regexReplaceAll(${htmlSnippet}, ${newLine}, "");
			var jsonSnippet = '''
{
    "fieldSets": [
        {
            "fields" : [
                {
                    "label": "Link",
                    "name": "Link",
                    "type": "url"
                }
            ]
        }
    ]
}''';

			var jsonSnippet = StringUtil.regexReplaceAll(${jsonSnippet}, ${newLine}, "");

			JSONFragment.addSection(
				collectionName = "Fragment Set Name",
				configuration = ${jsonSnippet},
				fragmentStatus = "Approved",
				groupName = "Test Site Name",
				html = ${htmlSnippet},
				name = "Fragment Name");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Fragment Set Name",
				fragmentName = "Fragment Name");
		}

		task ("When the page designer makes some changes to custom fragment") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Design",
				portlet = "Fragments");

			FragmentsAdminNavigator.gotoCollection(collectionName = "Fragment Set Name");

			FragmentsAdminNavigator.gotoEntryEllipsisItem(
				entry = "Fragment Name",
				item = "Edit");

			var htmlSnippet = '''
<div class="fragment-name">
	Heading Example
</div>''';

			FragmentsEditor.typeHtmlEditor(content = ${htmlSnippet});

			FragmentsEditor.waitForAutoSave();

			FragmentsEditor.publish();
		}

		task ("Then the page designer could propagate changes of custom fragment to locked content page") {
			FragmentsAdminNavigator.gotoEntryEllipsisItem(
				entry = "Fragment Name",
				item = "View Usages");

			FragmentsAdmin.propagateChanges();
		}
	}

}