@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Page Editor";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Add a new user with site administrator role") {
			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.addUserToSite(
				groupName = "Test Site Name",
				userEmailAddress = "userea@liferay.com");

			JSONRole.assignSiteRoleToUser(
				groupName = "Test Site Name",
				roleTitle = "Site Administrator",
				userEmailAddress = "userea@liferay.com");
		}
	}

	@description = "This is a test for LPS-182022. The user should be redirected to the Page In Use when access to edit mode of a locked collection page."
	@priority = 4
	test RedirectToPageInUseWhenEditLockedCollectionPage {
		task ("Given a page designer has a locked collection page") {
			var siteName = selenium.getText("Home#SITE_NAME");

			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

			ContentPages.addCollectionPage(
				collectionName = "Most Viewed Assets",
				pageName = "Test Page Name",
				tabName = "Collection Providers");

			PageEditor.editFragmentText(
				fragmentName = "Heading",
				id = "element-text",
				text = "Welcome to Liferay");
		}

		task ("When the page designer edits the locked collection page") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			WaitForPageLoad();

			Click(locator1 = "Icon#EDIT_PENCIL");
		}

		task ("Then the page designer should be redirected to the Page in Use") {
			AssertVisible(
				key_title = "Page in Use",
				locator1 = "Header#H1_TITLE");

			Button.click(button = "Go to Test Page Name");

			ControlMenu.viewHeaderDraftTitle(headerTitle = "Test Page Name");
		}
	}

	@description = "This is a test for LPS-182022. The user should be redirected to the Page In Use when access to edit mode of a locked content page."
	@priority = 5
	test RedirectToPageInUseWhenEditLockedContentPage {
		task ("Given a page designer has a locked content page") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the page designer edits the locked content page") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			WaitForPageLoad();

			Click(locator1 = "Icon#EDIT_PENCIL");
		}

		task ("Then the page designer should be redirected to the Page in Use") {
			AssertVisible(
				key_title = "Page in Use",
				locator1 = "Header#H1_TITLE");

			Button.click(button = "Go to Test Page Name");

			ControlMenu.viewHeaderDraftTitle(headerTitle = "Test Page Name");
		}
	}

	@description = "This is a test for LPS-182022. The user should be redirected to the Page In Use when access to edit mode of a locked content page template."
	@priority = 4
	test RedirectToPageInUseWhenEditLockedContentPageTemplate {
		task ("Given a page designer has a locked content page template") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONLayoutpagetemplate.addLayoutPageTemplateCollection(
				groupName = "Test Site Name",
				layoutPageTemplateCollectionName = "Page Template Collection");

			JSONLayoutpagetemplate.addLayoutPageTemplateEntry(
				groupName = "Test Site Name",
				layoutPageTemplateCollectionName = "Page Template Collection",
				layoutPageTemplateEntryName = "Page Template Name",
				layoutPageTemplateStatus = "Draft",
				layoutPageTemplateType = "Content Page Template");

			PageTemplatesAdmin.openPageTemplatesAdmin(siteURLKey = "test-site-name");

			PageTemplatesAdmin.gotoPageTemplate(pageTemplateName = "Page Template Name");

			PageEditor.assertFragmentSidebarLoaded();

			WaitForVisible(locator1 = "Sidebar#PANEL_OPEN");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the page designer edits the locked content page template") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Design",
				portlet = "Page Templates");

			Navigator.gotoNavItem(navItem = "Page Templates");

			PageTemplatesAdmin.gotoPageTemplate(pageTemplateName = "Page Template Name");
		}

		task ("Then the page designer should be redirected to the Page in Use") {
			AssertVisible(
				key_title = "Page in Use",
				locator1 = "Header#H1_TITLE");

			Button.click(button = "Go to Page Templates");

			ControlMenu.viewHeaderTitle(headerTitle = "Page Templates");

			PageTemplatesAdmin.viewPageTemplatePresent(pageTemplateName = "Page Template Name");
		}
	}

	@description = "This is a test for LPS-182022. The user should be redirected to the Page In Use when access to edit mode of a locked display page template."
	@priority = 4
	test RedirectToPageInUseWhenEditLockedDisplayPageTemplate {
		task ("Given a page designer has a locked display page template") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONLayoutpagetemplate.addDisplayPageTemplateEntry(
				contentType = "Web Content Article",
				displayPageTemplateEntryName = "Display Page Name",
				groupName = "Test Site Name",
				subType = "Basic Web Content");

			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the page designer edits the locked display page template") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Design",
				portlet = "Page Templates");

			Navigator.gotoNavItem(navItem = "Display Page Templates");

			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Edit");
		}

		task ("Then the page designer should be redirected to the Page in Use") {
			AssertVisible(
				key_title = "Page in Use",
				locator1 = "Header#H1_TITLE");

			Button.click(button = "Go to Page Templates");

			ControlMenu.viewHeaderTitle(headerTitle = "Page Templates");

			DisplayPageTemplatesAdmin.viewDisplayPagePresent(displayPageName = "Display Page Name");
		}
	}

	@description = "This is a test for LPS-182022. The user should be redirected to the Page In Use when access to edit mode of a locked master page."
	@priority = 4
	test RedirectToPageInUseWhenEditLockedMasterPage {
		task ("Given a page designer has a locked master page") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONLayoutpagetemplate.addMasterPageTemplateEntry(
				groupName = "Test Site Name",
				masterPageTemplateEntryName = "Master Page Template");

			MastersPageTemplatesAdmin.openMastersAdmin(siteURLKey = "test-site-name");

			MastersPageTemplatesAdmin.gotoMasters(masterLayoutName = "Master Page Template");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				dropTarget = "Header",
				fragmentName = "Button",
				scope = "Master");
		}

		task ("When the page designer edits the locked master page") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Design",
				portlet = "Page Templates");

			MastersPageTemplatesAdmin.gotoMastersEllipsisItem(
				item = "Edit",
				masterLayoutName = "Master Page Template");
		}

		task ("Then the page designer should be redirected to the Page in Use") {
			AssertVisible(
				key_title = "Page in Use",
				locator1 = "Header#H1_TITLE");

			Button.click(button = "Go to Page Templates");

			ControlMenu.viewHeaderTitle(headerTitle = "Page Templates");

			MastersPageTemplatesAdmin.viewMastersPresent(masterLayoutName = "Master Page Template");
		}
	}

}