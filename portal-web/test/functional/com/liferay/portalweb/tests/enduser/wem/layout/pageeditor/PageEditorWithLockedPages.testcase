	@description = "This is a test for LPS-182022. The user should be redirected to the Page In Use when access to edit mode of a locked content page template."
	@priority = 4
	test RedirectToPageInUseWhenEditLockedContentPageTemplate {
		task ("Given a page designer has a locked content page template") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONLayoutpagetemplate.addLayoutPageTemplateCollection(
				groupName = "Test Site Name",
				layoutPageTemplateCollectionName = "Page Template Collection");

			JSONLayoutpagetemplate.addLayoutPageTemplateEntry(
				groupName = "Test Site Name",
				layoutPageTemplateCollectionName = "Page Template Collection",
				layoutPageTemplateEntryName = "Page Template Name",
				layoutPageTemplateStatus = "Draft",
				layoutPageTemplateType = "Content Page Template");

			PageTemplatesAdmin.openPageTemplatesAdmin(siteURLKey = "test-site-name");

			PageTemplatesAdmin.gotoPageTemplate(pageTemplateName = "Page Template Name");

			PageEditor.assertFragmentSidebarLoaded();

			WaitForVisible(locator1 = "Sidebar#PANEL_OPEN");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the page designer edits the locked content page template") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = "Test Site Name");

			ProductMenu.gotoPortlet(
				category = "Design",
				portlet = "Page Templates");

			Navigator.gotoNavItem(navItem = "Page Templates");

			PageTemplatesAdmin.gotoPageTemplate(pageTemplateName = "Page Template Name");
		}

		task ("Then the page designer should be redirected to the Page in Use") {
			AssertVisible(
				key_title = "Page in Use",
				locator1 = "Header#H1_TITLE");

			Button.click(button = "Go to Page Templates");

			ControlMenu.viewHeaderTitle(headerTitle = "Page Templates");

			PageTemplatesAdmin.viewPageTemplatePresent(pageTemplateName = "Page Template Name");
		}
	}

