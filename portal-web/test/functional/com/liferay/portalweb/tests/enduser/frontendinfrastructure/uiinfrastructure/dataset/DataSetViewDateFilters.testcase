@component-name = "portal-frontend-infrastructure"
definition {

	property custom.properties = "feature.flag.LPS-164563=true${line.separator}feature.flag.LPS-167253=true${line.separator}feature.flag.LPS-188645=true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Frontend Data Set";
	property testray.main.component.name = "Frontend Data Set";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		DataSetAdmin.deleteAllDataSetEntries();

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@description = "LPS-190851. Cannot create a date filter when the chosen endpoint does not have a date field"
	@priority = 5
	test CannotCreateFilterWithoutDateTypeField {
		property portal.acceptance = "true";

		task ("Given a new data set entry, view") {
			DataSetAdmin.createAndConfigureDataSetEntry(
				dataSetName = "Custom Data Set Entry",
				dataSetViewDescription = "View Description",
				dataSetViewName = "Date filters view",
				restApplication = "search-experiences-rest/v1.0",
				restEndpoint = "/",
				restSchema = "KeywordQueryContributor");
		}

		task ("When the user accesses the Filters tab") {
			DataSetAdmin.goToTab(tabName = "Filters");
		}

		task ("And selects the Date Range option") {
			DataSetAdmin.selectFilterType(key_filterType = "Date Range");
		}

		task ("Then the No Fields Available modal is displayed") {
			AssertTextEquals.assertPartialText(
				locator1 = "Modal#HEADER",
				value1 = "No Fields Available");

			AssertTextEquals(
				locator1 = "Modal#BODY",
				value1 = "There are no fields compatible with this type of filter.");
		}

		task ("When clicks on the Close button") {
			Click(
				key_modalTitle = "No Fields Available",
				locator1 = "Button#CLOSE_MODAL");
		}

		task ("Then the No Fields Available modal is closed") {
			AssertElementNotPresent(
				key_modalTitle = "No Fields Available",
				locator1 = "Button#CLOSE_MODAL");
		}
	}

}