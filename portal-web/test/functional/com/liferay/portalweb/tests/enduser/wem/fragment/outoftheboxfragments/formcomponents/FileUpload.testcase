@component-name = "portal-page-management"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Fragment Administration";

	setUp {
		task ("Set up instance and sign in") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();
		}

		task ("Add a new site and page in it") {
			HeadlessSite.addSite(siteName = "Test Site Name");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("Add a company Object with attachment fields") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Upload Object",
				objectName = "UploadObject",
				pluralLabelName = "Upload Object");
		}
	}

	@description = "This is a test for LPS-191357. The administrator cannot clear object entry’s mandatory attached file via associated display page."
	@priority = 3
	test CannotClearMandatoryAttachmentOnAssociatedDisplayPage {
		task ("Add an object") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Purchase Order",
				objectName = "PurchaseOrder",
				pluralLabelName = "Purchase Orders");
		}

		task ("Given a site administrater has a display page template for Object with mandatory attachment") {
			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Attachment",
				fieldLabelName = "Upload",
				fieldName = "upload",
				fieldType = "Long",
				fileSource = "documentsAndMedia",
				isRequired = "true",
				objectName = "PurchaseOrder");

			ObjectAdmin.publishObjectViaAPI(objectName = "PurchaseOrder");

			ObjectAdmin.addAttachmentFileFromDMInObjectEntryViaUI(
				fileName = "Document_1.jpg",
				objectName = "PurchaseOrder");

			Navigator.gotoBack();

			ObjectPortlet.viewEntry(entry = "Document_1.jpg");

			var objectEntryId = selenium.getText("ObjectPortlet#ENTRY_ID");

			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = ${siteURLKey});

			DisplayPageTemplatesAdmin.addDisplayPage(
				contentType = "Purchase Order",
				displayPageName = "Display Page Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Purchase Order (Default)");

			PageEditor.publish();

			DisplayPageTemplatesAdmin.markDisplayPageAsDefault(displayPageName = "Display Page Name");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Collection Display");

			PageEditor.editCollectionDisplay(
				fragmentName = "Collection Display",
				infoListProviderName = "Purchase Orders");

			PageEditor.addFragmentToCollectionDisplay(
				collectionName = "Basic Components",
				entryTitle = "Purchase Orders",
				fragmentName = "Button");

			PageEditorEditableLink.gotoEditableFieldLink(
				fragmentName = "Button",
				id = "link");

			PageEditorEditableLink.mapURLToAsset(field = "Default");

			PageEditor.publish();
		}

		task ("When the site administrater accesses to the associated display page") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			Button.click(button = "Go Somewhere");

			ControlMenu.viewHeaderTitle(headerTitle = ${objectEntryId});
		}

		task ("Then the site administrater cannot clear the mandatory attached file") {
			Click(locator1 = "ObjectAutoGenerated#DELETE_ATTACHMENT_ICON");

			Button.clickSubmitButton();

			AssertTextNotPresent(value1 = "Thank you. Your information was successfully received.");

			AssertAttributeValue(
				fieldLabel = "Upload",
				index = 2,
				locator1 = "Fragment#INPUT_FIELD_WITH_LABEL",
				type = "file-upload",
				value1 = "validationMessage",
				value2 = "Please fill out this field.");
		}
	}

	@description = "This is a test for LPS-194129. Add the filter to the windows popup that opens for you to select from the PC."
	@priority = 4
	test FilterAttachmentFromComputerByFileType {
		task ("Given a user has a File Upload fragment mapped to an attachment from user's computer only accept pdf file extension") {
			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Attachment",
				fieldLabelName = "Custom Attachment From Computer",
				fieldName = "customAttachmentFromComputer",
				fieldType = "Long",
				fileSource = "userComputer",
				isRequired = "false",
				objectName = "UploadObject");

			ObjectAdmin.openObjectAdmin();

			ObjectPortlet.selectCustomObject(label = "Upload Object");

			ObjectAdmin.goToFieldsTab();

			ObjectAdmin.goToFieldsDetails(label = "Custom Attachment From Computer");

			SystemSettings.editTextAreaSetting(
				settingName = "Accepted File ExtensionsMandatory",
				settingValue = "pdf");

			ObjectField.save();

			ObjectAdmin.publishObjectViaAPI(objectName = "UploadObject");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Upload Object");
		}

		task ("When the user accesses to the content page at view mode") {
			PageEditor.publish();
		}

		task ("Then the user should see the File Upload only accept pdf file extension") {
			PageEditor.viewInputStyle(
				helpText = "Upload a .pdf no larger than 100 MB.",
				type = "file-upload");
		}
	}

	@description = "This is a test for LPS-194129. Filtering the Documents that are in Libraries."
	@priority = 4
	test FilterAttachmentFromDocumentsAndMediaByFileType {
		task ("Given a user has a File Upload fragment mapped to an attachment from documents and media only accept pdf file extension") {
			var groupId = JSONGroupSetter.setGroupId(groupName = "Test Site Name");

			DocumentAPI.addDocumentWithFileInSite(
				dmDocumentTitle = "Image Title",
				siteId = ${groupId},
				sourceFileName = "Document_1.jpg");

			DocumentAPI.addDocumentWithFileInSite(
				dmDocumentTitle = "PDF Title",
				siteId = ${groupId},
				sourceFileName = "Document_1.pdf");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Attachment",
				fieldLabelName = "Custom Attachment From DM",
				fieldName = "customAttachmentFromDM",
				fieldType = "Long",
				fileSource = "documentsAndMedia",
				isRequired = "false",
				objectName = "UploadObject");

			ObjectAdmin.openObjectAdmin();

			ObjectPortlet.selectCustomObject(label = "Upload Object");

			ObjectAdmin.goToFieldsTab();

			ObjectAdmin.goToFieldsDetails(label = "Custom Attachment From DM");

			SystemSettings.editTextAreaSetting(
				settingName = "Accepted File ExtensionsMandatory",
				settingValue = "pdf");

			ObjectField.save();

			ObjectAdmin.publishObjectViaAPI(objectName = "UploadObject");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Upload Object");

			PageEditor.publish();
		}

		task ("When the user opens the Select File modal at view mode") {
			PageEditor.viewInputStyle(
				helpText = "Upload a .pdf no larger than 100 MB.",
				type = "file-upload");

			Click(locator1 = "Button#SELECT_FILE");
		}

		task ("Then the user should only see file with pdf extension") {
			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			LexiconCard.viewCardPresent(card = "PDF Title");

			LexiconCard.viewCardNotPresent(card = "Image Title");
		}
	}

	@description = "This is a test for LPS-151402. The user could see error message when submit a form with attached file size larger than allowed maximum upload size."
	@priority = 4
	test ViewErrorMessageWhenSubmitFormWithAttachedFileSizeLargerThanAllowedMaximumUploadSize {
		task ("Given a user has a content page where a File Upload and Submit Button fragments are inside a Form Container") {
			task ("Add an Attachment field to object") {
				ObjectAdmin.openObjectAdmin();

				ObjectPortlet.selectCustomObject(label = "Upload Object");

				ObjectAdmin.goToFieldsTab();

				ObjectAdmin.addObjectFieldViaUI(
					enableShowFiles = "true",
					fieldAttachment = "Upload Directly from the User",
					fieldLabel = "Custom Attachment From Computer",
					fieldType = "Attachment");
			}

			task ("Change the Maximum File Size to 2 MB") {
				ObjectAdmin.goToFieldsDetails(label = "Custom Attachment From Computer");

				Type(
					key_text = "Maximum File Size",
					locator1 = "TextInput#ANY",
					value1 = 2);

				ObjectField.save();

				ObjectAdmin.publishObjectViaAPI(objectName = "UploadObject");
			}

			task ("Add a Form Container framgment to content page") {
				JSONLayout.addPublicLayout(
					groupName = "Test Site Name",
					layoutName = "Test Page Name",
					type = "content");

				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Page Name",
					siteName = "Test Site Name");

				PageEditor.addFragment(
					collectionName = "Form Components",
					fragmentName = "Form Container");

				PageEditor.editFormContainer(contentType = "Upload Object");

				PageEditor.publish();
			}
		}

		task ("When the user submits form with attached file size larger than allowed maximum upload size") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			UploadDependencyFile.uploadFile(fileName = "high_resolution_photo.jpg");

			Button.clickSubmitButton();
		}

		task ("Then the user should see an error message") {
			Alert.viewErrorMessage(errorMessage = "File size is larger than the allowed maximum upload size (2 MB).");
		}
	}

	@description = "This is a test for LPS-151402. The user could see error message when submit a form with invalid extension of attached file."
	@priority = 4
	test ViewErrorMessageWhenSubmitFormWithInvalidExtensionOfAttachedFile {
		task ("Given a user has a content page where a File Upload and Submit Button fragments are inside a Form Container") {
			task ("Add an Attachment field to object") {
				ObjectAdmin.addObjectFieldViaAPI(
					fieldBusinessType = "Attachment",
					fieldLabelName = "Custom Attachment From Computer",
					fieldName = "customAttachmentFromComputer",
					fieldType = "Long",
					fileSource = "userComputer",
					isRequired = "false",
					objectName = "UploadObject");

				ObjectAdmin.publishObjectViaAPI(objectName = "UploadObject");
			}

			task ("Add a Form Container framgment to content page") {
				JSONLayout.addPublicLayout(
					groupName = "Test Site Name",
					layoutName = "Test Page Name",
					type = "content");

				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Page Name",
					siteName = "Test Site Name");

				PageEditor.addFragment(
					collectionName = "Form Components",
					fragmentName = "Form Container");

				PageEditor.editFormContainer(contentType = "Upload Object");

				PageEditor.publish();
			}
		}

		task ("When the user submits form with invalid extension of attached file") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			UploadDependencyFile.uploadFile(fileName = "Document_1.doc");

			Button.clickSubmitButton();
		}

		task ("Then the user should see an error message") {
			Alert.viewErrorMessage(errorMessage = "Please enter a file with a valid extension (jpeg, jpg, pdf, png).");
		}
	}

	@description = "This is a test for LPS-182728. The user should see the field error below the File Upload fragment."
	@priority = 3
	test ViewFileUploadFieldErrorMessageWhenPartialValidationFailure {
		task ("Given a user has a content page where a File Upload fragment mapped to a mandatory Attachment field") {
			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Attachment",
				fieldLabelName = "Custom Attachment From Computer",
				fieldName = "customAttachmentFromComputer",
				fieldType = "Long",
				fileSource = "userComputer",
				isRequired = "true",
				objectName = "UploadObject");

			ObjectAdmin.publishObjectViaAPI(objectName = "UploadObject");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Upload Object");

			PageEditor.publish();
		}

		task ("When the user submits form without attachment") {
			SetElementAttribute.removeElementAttribute(
				attribute1 = "required",
				locator1 = "TextInput#FILE");

			Button.clickSubmitButton();
		}

		task ("Then the user should see a field error message below File Upload") {
			Alert.viewFieldErrorMessage(
				errorMessage = "This field is required.",
				fieldLabel = "Custom Attachment From Computer");
		}
	}

}