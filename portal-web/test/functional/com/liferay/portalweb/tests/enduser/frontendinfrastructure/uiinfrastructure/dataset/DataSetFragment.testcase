	@description = "LPS-185993. Confirm that by default the column is sortable and when the option is cleared the button Sort is no longer shown"
	@priority = 4
	test ConfirmDefaultSort {
		task ("Given creating a Data Set entry, view and fields") {
			DataSetAdmin.createAndConfigureDataSetEntry(
				dataSetName = "Countries",
				dataSetViewDescription = "View Description",
				dataSetViewName = "Cities view",
				key_fieldList = "id,name,number",
				restApplication = "/headless-admin-address/v1.0",
				restEndpoint = "/v1.0/countries",
				restSchema = "Country");
		}

		task ("And uncheck sortble in the Name and number fields") {
			DataSetAdmin.editField(
				key_fieldItem = "name",
				sortable = "Uncheck");

			DataSetAdmin.editField(
				key_fieldItem = "number",
				sortable = "Uncheck");
		}

		task ("And adds the data set Fragment portlet in the page created") {
			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Data Set Test Page",
				siteName = "test-site-name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Data Set");
		}

		task ("And adds the Cities view to the data set Fragment portlet") {
			DataSetFragment.addDataSetView(dataSetViewName = "Cities view");
		}

		task ("And publishes the page") {
			var portalURL = PropsUtil.get("portal.url");

			SelectFrameTop();

			Button.clickPublish();

			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

			Navigator.openSpecificURL(url = "${portalURL}/web/test-site-name/data-set-test-page");
		}

		task ("Then Check the Sort icon is displayed next to the column id") {
			AssertElementPresent(
				key_field = "id",
				locator1 = "FrontendDataSet#SORT_FIELD");
		}

		task ("And the sort option is not shown in the name and number columns") {
			AssertElementNotPresent(
				key_field = "name",
				locator1 = "FrontendDataSet#SORT_FIELD");

			AssertElementNotPresent(
				key_field = "number",
				locator1 = "FrontendDataSet#SORT_FIELD");
		}
	}

	@description = "LPS-185993. Confirm that you can configure the order of a fragment column"
	@priority = 5
	test ConfirmNewSortApplied {
		task ("Given creating a Data Set entry, view and fields") {
			DataSetAdmin.createAndConfigureDataSetEntry(
				dataSetName = "Countries",
				dataSetViewDescription = "View Description",
				dataSetViewName = "Cities view",
				key_fieldList = "id,name,number",
				restApplication = "/headless-admin-address/v1.0",
				restEndpoint = "/v1.0/countries",
				restSchema = "Country");
		}

		task ("And Add a two default sorting") {
			DataSetAdmin.goToTab(tabName = "Sorting");

			DataSetAdmin.createASort(
				key_field = "name",
				key_sorting = "Descending");
		}

		task ("And adds the data set Fragment portlet in the page created") {
			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Data Set Test Page",
				siteName = "test-site-name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Data Set");
		}

		task ("And adds the Cities view to the data set Fragment portlet") {
			DataSetFragment.addDataSetView(dataSetViewName = "Cities view");
		}

		task ("And publishes the page") {
			var portalURL = PropsUtil.get("portal.url");

			SelectFrameTop();

			Button.clickPublish();

			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

			Navigator.openSpecificURL(url = "${portalURL}/web/test-site-name/data-set-test-page");
		}

		task ("Then Confirm that the table is ordered by the Name in descending order") {
			AssertElementPresent(
				key_labelName = "zimbabwe",
				key_rowPosition = 1,
				locator1 = "DataSet#VIEW_LABEL_POSITION");

			AssertElementPresent(
				key_labelName = "zambia",
				key_rowPosition = 2,
				locator1 = "DataSet#VIEW_LABEL_POSITION");
		}
	}

	@description = "LPS-185993. Confirm that you can configure the order by date of a fragment column"
	@priority = 4
	test ConfirmNewSortingByDate {
		task ("Given a new Object entity") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Date Object",
				objectName = "DateObject",
				pluralLabelName = "Date Objects");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Date",
				fieldLabelName = "Date Field",
				fieldName = "dateField",
				fieldType = "Date",
				isRequired = "false",
				objectName = "DateObject");

			ObjectAdmin.publishObjectViaAPI(objectName = "DateObject");
		}

		task ("And new entries in the new Object entity") {
			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "dateField",
				objectName = "DateObject",
				value = "2022-02-02");

			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "dateField",
				objectName = "DateObject",
				value = "2022-01-01");
		}

		task ("And creating a Data Set entry, view and fields") {
			DataSetAdmin.createAndConfigureDataSetEntry(
				dataSetName = "Custom Data Set Entry",
				dataSetViewDescription = "View Description",
				dataSetViewName = "Dates view",
				key_fieldList = "dateField,id,dateCreated",
				restApplication = "/c/dateobjects",
				restEndpoint = "/",
				restSchema = "DateObject");
		}

		task ("And Add a default sorting") {
			DataSetAdmin.goToTab(tabName = "Sorting");

			DataSetAdmin.createASort(
				key_field = "dateField",
				key_sorting = "Descending");
		}

		task ("And adds the data set Fragment portlet in the page created") {
			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Data Set Test Page",
				siteName = "test-site-name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Data Set");
		}

		task ("And adds the Cities view to the data set Fragment portlet") {
			DataSetFragment.addDataSetView(dataSetViewName = "Dates view");
		}

		task ("And publishes the page") {
			var portalURL = PropsUtil.get("portal.url");

			SelectFrameTop();

			Button.clickPublish();

			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

			Navigator.openSpecificURL(url = "${portalURL}/web/test-site-name/data-set-test-page");
		}

		task ("Then Confirm that the table is ordered by the dateField in descending order") {
			AssertElementPresent(
				key_labelName = "2022-02-02T00:00:00Z",
				key_rowPosition = 1,
				locator1 = "DataSet#VIEW_LABEL_POSITION");

			AssertElementPresent(
				key_labelName = "2022-01-01T00:00:00Z",
				key_rowPosition = 2,
				locator1 = "DataSet#VIEW_LABEL_POSITION");
		}
	}

	@description = "LPS-172403. Confirm empty message when no view was created"
	@priority = 4
	test EmptyMessageDisplayedWhenNoViewCreated {
		task ("When add a dataset fragment") {
			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Data Set");
		}

		task ("Then Confirm that the portlet shows the message: Select a dataset view.") {
			PageEditor.viewFragmentMessageInfo(
				fragmentName = "Data Set",
				messageInfo = "Select a data set view.");
		}

		task ("When clicking on Select Data Set View") {
			PageEditor.gotoConfiguration(fragmentName = "Data Set");

			Click.javaScriptClick(
				key_value = "Select Data Set View",
				locator1 = "Button#SECONDARY_BY_TITLE");
		}

		task ("Then confirm that the Dataset view modal is opened") {
			AssertTextEquals(
				locator1 = "DataEngineModal#MODAL_TITLE",
				value1 = "Select");
		}

		task ("And confirm that there is no created views") {
			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			AssertTextEquals(
				locator1 = "Message#EMPTY_STATE_INFO",
				value1 = "No Results Found");
		}
	}

	@description = "LPS-172403. Confirm that the select view button changes to the name of the selected view"
	@priority = 4
	test NameOfViewIsDisplayedOnButton {
		property test.liferay.virtual.instance = "false";

		task ("Given creating a Data Set entry, view and fields") {
			DataSetAdmin.createAndConfigureDataSetEntry(
				dataSetName = "Countries",
				dataSetViewDescription = "View Description",
				dataSetViewName = "Full countries View",
				key_fieldList = "id,name,number",
				restApplication = "/headless-admin-address/v1.0",
				restEndpoint = "/v1.0/countries",
				restSchema = "Country");
		}

		task ("When the user accesses the edit page And add a dataset fragment") {
			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Data Set Test Page",
				siteName = "test-site-name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Data Set");
		}

		task ("And Select Full countries View ") {
			DataSetFragment.addDataSetView(dataSetViewName = "Full countries View");
		}

		task ("Then Confirm that the select view button changes to the name of the selected view") {
			SelectFrameTop();

			AssertElementPresent(
				locator1 = "DataSet#SELECT_DATA_SET_VIEW",
				value1 = "Full countries View");
		}
	}

	@description = "LPS-172403. Smoke test to verify options relates to Data Set Fragment"
	@priority = 5
	test ViewInfoFields {
		task ("When viewing the configuration menu of the portlet") {
			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Data Set");
		}

		task ("Then configuration model is present") {
			PageEditor.gotoConfiguration(fragmentName = "Data Set");
		}

		task ("And assert that General, Styles and Advanced tabs are present.") {
			Navigator.viewNavTab(navTab = "General");

			Navigator.viewNavTab(navTab = "Styles");

			Navigator.viewNavTab(navTab = "Advanced");
		}

		task ("And Confirm the button Select Data Set View is displayed") {
			AssertElementPresent(
				key_value = "Select Data Set View",
				locator1 = "Button#SECONDARY_BY_TITLE");

			AssertElementPresent(locator1 = "Button#PLUS");
		}
	}

}