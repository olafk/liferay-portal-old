@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Page Editor";

	static var randomSiteName = StringUtil.randomString(8);

	var siteURLKey = StringUtil.toLowerCase(${randomSiteName});

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = ${randomSiteName});
		}
	}

	@description = "This is a test for LPS-85145. The focus should go to the Product Menu when open it."
	@priority = 3
	test FocusOnProductMenuWhenOpenIt {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			PagesAdmin.openPagesAdmin(siteURLKey = ${siteURLKey});

			PagesAdmin.gotoPageEllipsisMenuItem(
				menuItem = "Edit",
				pageName = "Test Page Name");

			PageEditor.assertFragmentSidebarLoaded();
		}

		task ("When the page creator opens the Product Menu") {
			ProductMenuHelper.openProductMenu();
		}

		task ("Then the focus goes to the Product Menu") {
			KeyPress(
				locator1 = "//nav[@aria-label='Product Menu']",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "//button[contains(@aria-label,'Go to Other Site')]");
		}
	}

	@description = "This is a test for LPS-165278. The page creator could see hovered status when navigate through treeview nodes via keyboard."
	@priority = 3
	test NavigateThroughTreeviewNodesViaKeyboard {
		task ("Given a page creator has fragment composition on a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Layout Elements",
				fragmentName = "Container");

			PageEditor.addElementToContainer(
				collectionName = "Layout Elements",
				fragmentName = "Grid",
				navTab = "Fragments");

			PageEditor.addElementToColumn(
				collectionName = "Basic Components",
				columnNumber = 1,
				fragmentName = "Heading",
				navTab = "Fragments");
		}

		task ("When the page creator accesses to the Browser panel") {
			PageEditor.gotoTab(tabName = "Browser");
		}

		task ("Then the page creator could navigate through treeview nodes via keyboard") {
			KeyPress(
				key_text = "times",
				locator1 = "Icon#ANY",
				value1 = "\TAB");

			AssertCssValue(
				locator1 = "//div[contains(@data-qa-id,'Container') and contains(@role,'treeitem')]",
				locator2 = "background-color",
				value1 = "rgba(240, 245, 255, 1)");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Container",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_HIDE_INDEX");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Container",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_VERTICAL_ELLIPSIS");

			KeyPress(
				key_nodeName = "Container",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_COLLAPSED",
				value1 = "\RIGHT");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Container') and contains(@role,'treeitem') and @aria-expanded='true']",
				value1 = "\DOWN");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Grid') and contains(@role,'treeitem')]",
				value1 = "\ENTER");

			AssertCssValue(
				locator1 = "//div[contains(@data-qa-id,'Grid') and contains(@role,'treeitem')]",
				locator2 = "background-color",
				value1 = "rgba(240, 245, 255, 1)");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Grid",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_HIDE_INDEX");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Grid",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_VERTICAL_ELLIPSIS");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Grid') and contains(@role,'treeitem') and @aria-expanded='true']",
				value1 = "\DOWN");

			KeyPress(
				key_nodeName = "Module",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_COLLAPSED",
				value1 = "\RIGHT");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Module') and contains(@role,'treeitem') and @aria-expanded='true']",
				value1 = "\DOWN");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Heading') and contains(@role,'treeitem')]",
				value1 = "\ENTER");

			AssertCssValue(
				locator1 = "//div[contains(@data-qa-id,'Heading') and contains(@role,'treeitem')]",
				locator2 = "background-color",
				value1 = "rgba(240, 245, 255, 1)");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Heading",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_HIDE_INDEX");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Heading",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_VERTICAL_ELLIPSIS");
		}
	}

	@description = "This is a test for LPS-165284. The Experience selector should have correct accessibility."
	@priority = 3
	test ViewAccessibilityOfExperienceSelector {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page creator accesses to the page editor") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("Then the Experience selector should have correct accessibility") {
			AssertAttributeValue(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "aria-expanded",
				value2 = "false");

			AssertAttributeValue(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "aria-haspopup",
				value2 = "true");

			KeyPress(
				locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS",
				value1 = "\TAB");

			KeyPress(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "\ENTER");

			AssertAttributeValue(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "aria-expanded",
				value2 = "true");

			AssertElementFocused(locator1 = "//button[@aria-label='New Experience']");

			Type.sendKeys(
				ariaLabel = "New Experience",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "keys=SHIFT,TAB");

			AssertAttributeValue(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "aria-expanded",
				value2 = "false");

			AssertElementFocused(locator1 = "//div[contains(@class,'page-editor__toolbar-experience')]//button");
		}
	}

	@description = "This is a test for LPS-194375. The Page Editor filter is WCAG 2.1 AA compliant."
	@priority = 3
	test ViewAccessibilityOfFilterByContentTypeSelector {
		task ("Given a page creator has displayed assets on content page") {
			JSONWebcontent.addWebContent(
				content = "Web Content Content",
				groupName = ${randomSiteName},
				title = "Web Content Title");

			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Content Display",
				targetFragmentName = "Heading");

			PageEditor.editContentDisplay(
				fragmentName = "Content Display",
				webcontent = "true",
				webContentContent = "Web Content Content",
				webContentTitle = "Web Content Title");
		}

		task ("When the page creator opens the dropdown menu of Filter by Content Type") {
			PageEditor.gotoTab(tabName = "Page Content");

			Click(locator1 = "PageEditor#PAGE_CONTENTS_CONTENT_FILTER_TOGGLE");

			AssertElementAccessible(locator1 = "//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li");

			Click(locator1 = "PageEditor#PAGE_CONTENTS_CONTENT_FILTER_TOGGLE");

			AssertElementAccessible(locator1 = "xpath=(//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li)[2]");

			Click(locator1 = "PageEditor#PAGE_CONTENTS_CONTENT_FILTER_TOGGLE");

			AssertElementAccessible(locator1 = "xpath=(//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li)[3]");
		}
	}

	@description = "This is a test for LPS-168850. All the elements are announced as Link."
	@priority = 4
	test ViewAccessibilityOfNavigationMenu {
		task ("Given a page has several nested content pages") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Home",
				type = "content");

			for (var i : list "1,2") {
				JSONLayout.addPublicLayout(
					groupName = ${randomSiteName},
					layoutName = "Home Child Page ${i}",
					parentLayoutName = "Home");
			}

			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Home Child Page 1 Child Page",
				parentLayoutName = "Home Child Page 1");
		}

		task ("When selecting Bar with Links in Display Template field of Menu Display") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Home",
				siteName = ${randomSiteName});

			PageEditor.addWidgetViaKeyboard(
				categoryName = "Content Management",
				upCount = 1,
				widgetName = "Menu Display");

			NavigationMenusWidget.gotoNavigationMenuWidgetConfig();

			NavigationMenusWidget.selectDisplayTemplate(templateName = "Bar With Links");

			AssertTextEquals(
				locator1 = "Select#DISPLAY_TEMPLATE",
				value1 = "Bar With Links");

			Portlet.saveAndCloseConfig();

			PageEditor.publish();
		}

		task ("Then role attribute is not present in all menu items") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Home",
				siteName = ${randomSiteName});

			MouseOver(locator1 = "//div[@id='main-content']//section[contains(@id,'SiteNavigationMenuPortlet')]//div[@class='portlet-body']//span");

			for (var pageName : list "Home Child Page 1,Home Child Page 1 Child Page,Home Child Page 2") {
				AssertAttributeValue.assertAttributeNotPresent(
					locator1 = "//div[contains(@class,'layout-content')]//a[contains(@class, 'dropdown-item')][contains(text(), '${pageName}')]",
					value1 = "role");
			}
		}
	}

	@description = "This is a test for LPS-196462. The New Rule Modal complies with WCAG 2.1 AA standard."
	@priority = 2
	test ViewAccessibilityOfNewRuleModal {
		property custom.properties = "feature.flag.LPS-169837=true";

		task ("Given a page designer has a Button fragment on a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("When the page designer opens the New Rule modal") {
			PageEditor.gotoTab(tabName = "Page Rules");

			Button.click(button = "New Rule");
		}

		task ("Then the New Rule modal should have correct accessibility") {
			AssertElementAccessible(locator1 = "Modal#MODAL_CONTENT");
		}
	}

	@description = "This is a test for LPS-165288. The Page Design Options panel should have correct accessibility."
	@priority = 3
	test ViewAccessibilityOfPageDesignOptionsPanel {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page creator accesses to the Page Design Options panel") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.gotoTab(tabName = "Page Design Options");
		}

		task ("Then the Page Design Options panel should have correct accessibility") {
			AssertElementPresent(locator1 = "//h2[normalize-space(text())='Page Design Options']");

			AssertAttributeValue(
				locator1 = "PageEditor#MORE_LINK",
				value1 = "title",
				value2 = "More Page Design Options");
		}
	}

	@description = "This is a test for LPS-182022. The Page In Use should comply with the WCAG 2.1 AA standard."
	@priority = 4
	test ViewAccessibilityOfPageInUse {
		task ("Given a page designer has a locked content page") {
			var siteName = selenium.getText("Home#SITE_NAME");

			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.addUserToSite(
				groupName = ${randomSiteName},
				userEmailAddress = "userea@liferay.com");

			JSONRole.assignSiteRoleToUser(
				groupName = ${randomSiteName},
				roleTitle = "Site Administrator",
				userEmailAddress = "userea@liferay.com");

			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the page designer redirects to the Page in Use") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet");

			User.impersonateCP(
				siteName = ${siteName},
				userScreenName = "usersn");

			UserBar.gotoMySite(siteName = ${randomSiteName});

			WaitForPageLoad();

			Click(locator1 = "Icon#EDIT_PENCIL");

			AssertVisible(
				key_title = "Page in Use",
				locator1 = "Header#H1_TITLE");
		}

		task ("Then the Page in Use should have correct accessibility") {
			AssertAccessible();
		}
	}

	@description = "This is a test for LPS-196461. The Page Rules section complies with WCAG 2.1 AA standard."
	@priority = 2
	test ViewAccessibilityOfPageRulesPanel {
		property custom.properties = "feature.flag.LPS-169837=true";

		task ("Given a page designer has a Button fragment on a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the page designer opens the Page Rules panel") {
			PageEditor.gotoTab(tabName = "Page Rules");
		}

		task ("Then the Page Rules panel should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[@aria-label='Page Rules Panel']");
		}

		task ("When the page designer adds a page rule") {
			PageEditor.addPageRule(
				selectAction = "Hide",
				selectActionValue = "Button",
				selectCondition = "Is the User",
				selectConditionValue = "test",
				selectItemForTheAction = "Fragment",
				selectItemForTheCondition = "User");
		}

		task ("Then the Page Rules panel should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[@aria-label='Page Rules Panel']");
		}
	}

	@description = "This is a test for LPS-165296. The screen reader should be able to distinguish between view mode and edit mode."
	@priority = 3
	test ViewPageTitleOfViewModeAndEditMode {
		task ("Given a page creator has a published content page") {
			Navigator.openURL();

			var defaultSiteName = selenium.getText("Home#SITE_NAME");

			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			JSONLayout.publishLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name");
		}

		task ("When the page creator accesses to the content page at view mode") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("Then the page title doesn't have (Editing)") {
			var viewModeTitle = selenium.getTitle();

			StringUtil.assertEquals("Test Page Name - ${randomSiteName} - ${defaultSiteName}", ${viewModeTitle});
		}

		task ("When the page creator accesses to the content page at edit mode") {
			ContentPages.gotoPageEditor();
		}

		task ("Then the title has (Editing)") {
			var editModeTitle = selenium.getTitle();

			StringUtil.assertEquals("Test Page Name - ${randomSiteName} - ${defaultSiteName} (Editing)", ${editModeTitle});
		}
	}
}