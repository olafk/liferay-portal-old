@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Page Editor";

	static var randomSiteName = StringUtil.randomString(8);

	var siteURLKey = StringUtil.toLowerCase(${randomSiteName});

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = ${randomSiteName});
		}
	}

	@description = "This is a test for LPS-167387. The page creator could go back to button from link on the experience selector via shift + tab shortcuts."
	@priority = 3
	test BackToButtonFromLinkOnExperienceSelectorViaKeyboard {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page creator focuses on the link on the experience selector") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.openExperienceMenu();

			KeyPress(
				key_text = "New Experience",
				locator1 = "Button#ANY",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "//a[contains(.,'Content Page Personalization')]");
		}

		task ("Then the page creator could go back to the button on the experience selector via shift + tab shortcuts") {
			Type.sendKeys(
				key_text = "Content Page Personalization",
				locator1 = "Link#ANY",
				value1 = "keys=SHIFT,TAB");

			AssertElementFocused(locator1 = "//*[not(self::div)][contains(@class,'btn')][normalize-space()='New Experience'][not(contains(@class,'navbar'))]");
		}
	}

	@description = "This is a test for LPS-166297. The page creator could go back to the node on the Browser panel via shift + tab shortcuts."
	@priority = 3
	test BackToNodeOnBrowserPanelViaKeyboard {
		task ("Given a page creator has a fragment composition on a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Layout Elements",
				fragmentName = "Container");

			PageEditor.addElementToContainer(
				collectionName = "Basic Components",
				fragmentName = "Heading",
				navTab = "Fragments");

			PageEditor.addElementToContainer(
				collectionName = "Basic Components",
				fragmentName = "Button",
				navTab = "Fragments",
				targetElementName = "Heading");
		}

		task ("When the page creator accesses to the Browser panel") {
			PageEditor.gotoTab(tabName = "Browser");

			KeyPress(
				key_text = "times",
				locator1 = "Icon#ANY",
				value1 = "\TAB");
		}

		task ("Then the page creator could expand the Container node via keyboard") {
			KeyPress(
				key_nodeName = "Container",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_COLLAPSED",
				value1 = "\RIGHT");

			for (var nodeName : list "Heading,Button") {
				AssertVisible(
					key_nodeName = ${nodeName},
					locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE");
			}
		}

		task ("When the page creator focuses on the drag handler of Container node via Tab key") {
			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Container') and contains(@role,'treeitem') and @aria-expanded='true']",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "//button[@aria-label='Move Container']");
		}

		task ("Then the page creator could go back to the Container node via shift + tab shortcuts") {
			Type.sendKeys(
				ariaLabel = "Move Container",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "keys=SHIFT,TAB");

			AssertElementFocused(locator1 = "//div[contains(@data-qa-id,'Container') and contains(@role,'treeitem') and @aria-expanded='true']");
		}
	}

	@description = "This is a test for LPS-165295. The page creator cannot access to disabled area via keyboard."
	@priority = 3
	test CannotAccessToDisabledAreaViaKeyboard {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page creator accesses to the page editor") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("Then the page creator cannot access to the disabled area via keyboard") {
			AssertAttributeValue(
				locator1 = "//header[contains(@class,'disabled-area')]//div[contains(@class,'navbar-top')]",
				value1 = "inert",
				value2 = "");

			AssertAttributeValue(
				locator1 = "//header[contains(@class,'disabled-area')]//div[contains(@class,'navbar-expand')]",
				value1 = "inert",
				value2 = "");
		}
	}

	@description = "This is a test for LPS-165791. Focus on experience selector when the window width is less than 990px."
	@priority = 3
	test FocusOnExperienceSelectorWhenWindowWidthLessThan990 {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("When the page creator resize the window size less than 990px") {
			SetWindowSize(value1 = "900,1040");
		}

		task ("Then the page creator can focus on the Experience selector") {
			KeyPress(
				locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "//div[contains(@class,'page-editor__toolbar-experience')]//button");
		}
	}

	@description = "This is a test for LPS-85145. The focus should go to the Product Menu when open it."
	@priority = 3
	test FocusOnProductMenuWhenOpenIt {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			PagesAdmin.openPagesAdmin(siteURLKey = ${siteURLKey});

			PagesAdmin.gotoPageEllipsisMenuItem(
				menuItem = "Edit",
				pageName = "Test Page Name");

			PageEditor.assertFragmentSidebarLoaded();
		}

		task ("When the page creator opens the Product Menu") {
			ProductMenuHelper.openProductMenu();
		}

		task ("Then the focus goes to the Product Menu") {
			KeyPress(
				locator1 = "//div[@aria-label='Product Menu']",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "//button[contains(@aria-label,'Go to Other Site')]");
		}
	}

	@description = "This is a test for LPS-166296. The sidebar buttons should be on focus after close the panel."
	@priority = 3
	test FocusOnSidebarButtonAfterClosePanel {
		task ("Given a page creator accesses the Browser panel of content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.gotoTab(tabName = "Browser");
		}

		task ("When the page creator closes the panel") {
			Click(
				key_text = "times",
				locator1 = "Icon#ANY");
		}

		task ("Then the browser button should be on focus") {
			AssertElementFocused(locator1 = "//div[contains(@class,'page-editor__sidebar__buttons')]//*[@*='Browser']");
		}
	}

	@description = "This is a test for LPS-165278. The page creator could see hovered status when navigate through treeview nodes via keyboard."
	@priority = 3
	test NavigateThroughTreeviewNodesViaKeyboard {
		task ("Given a page creator has fragment composition on a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Layout Elements",
				fragmentName = "Container");

			PageEditor.addElementToContainer(
				collectionName = "Layout Elements",
				fragmentName = "Grid",
				navTab = "Fragments");

			PageEditor.addElementToColumn(
				collectionName = "Basic Components",
				columnNumber = 1,
				fragmentName = "Heading",
				navTab = "Fragments");
		}

		task ("When the page creator accesses to the Browser panel") {
			PageEditor.gotoTab(tabName = "Browser");
		}

		task ("Then the page creator could navigate through treeview nodes via keyboard") {
			KeyPress(
				key_text = "times",
				locator1 = "Icon#ANY",
				value1 = "\TAB");

			AssertCssValue(
				locator1 = "//div[contains(@data-qa-id,'Container') and contains(@role,'treeitem')]",
				locator2 = "background-color",
				value1 = "rgba(240, 245, 255, 1)");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Container",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_HIDE_INDEX");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Container",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_VERTICAL_ELLIPSIS");

			KeyPress(
				key_nodeName = "Container",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_COLLAPSED",
				value1 = "\RIGHT");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Container') and contains(@role,'treeitem') and @aria-expanded='true']",
				value1 = "\DOWN");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Grid') and contains(@role,'treeitem')]",
				value1 = "\ENTER");

			AssertCssValue(
				locator1 = "//div[contains(@data-qa-id,'Grid') and contains(@role,'treeitem')]",
				locator2 = "background-color",
				value1 = "rgba(240, 245, 255, 1)");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Grid",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_HIDE_INDEX");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Grid",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_VERTICAL_ELLIPSIS");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Grid') and contains(@role,'treeitem') and @aria-expanded='true']",
				value1 = "\DOWN");

			KeyPress(
				key_nodeName = "Module",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_COLLAPSED",
				value1 = "\RIGHT");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Module') and contains(@role,'treeitem') and @aria-expanded='true']",
				value1 = "\DOWN");

			KeyPress(
				locator1 = "//div[contains(@data-qa-id,'Heading') and contains(@role,'treeitem')]",
				value1 = "\ENTER");

			AssertCssValue(
				locator1 = "//div[contains(@data-qa-id,'Heading') and contains(@role,'treeitem')]",
				locator2 = "background-color",
				value1 = "rgba(240, 245, 255, 1)");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Heading",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_NODE_HIDE_INDEX");

			AssertVisible(
				key_index = 1,
				key_nodeName = "Heading",
				locator1 = "Treeview#PAGE_STRUCTURE_TREE_VERTICAL_ELLIPSIS");
		}
	}

	@description = "This is a test for LPS-165485. The page creator could switch edit mode via keyboard."
	@priority = 3
	test SwitchEditModeViaKeyboard {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("When the page creator opens the dropdown menu of edit mode selector via keyboard") {
			KeyPress(
				key_deviceType = "Portrait Phone",
				locator1 = "PageEditor#DEVICE_TYPE",
				value1 = "\TAB");

			KeyPress(
				locator1 = "PageEditor#EDIT_MODE_SELECTOR",
				value1 = "\ENTER");
		}

		task ("Then the page creator switchs to Content Editing via keyboard") {
			KeyPress(
				locator1 = "PageEditor#EDIT_MODE_SELECTOR",
				value1 = "\UP");

			KeyPress(
				locator1 = "PageEditor#EDIT_MODE_SELECTOR",
				value1 = "\ENTER");

			AssertTextEquals(
				locator1 = "PageEditor#EDIT_MODE_SELECTOR",
				value1 = "Content Editing");

			AssertElementFocused(locator1 = "PageEditor#EDIT_MODE_SELECTOR");
		}
	}

	@description = "This is a test for LPS-167116. The page creator could go back to the times icon on the Browser panel via shift + tab shortcuts."
	@priority = 3
	test ViewAccessibilityOfBrowserPanel {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the page creator accesses to the treeview modes on the Browser panel") {
			PageEditor.gotoTab(tabName = "Browser");

			KeyPress(
				key_text = "times",
				locator1 = "Icon#ANY",
				value1 = "\TAB");

			AssertCssValue(
				data_qa_id = "Button",
				locator1 = "Treeview#NODE_ITEM_BY_DATA_QA_ID",
				locator2 = "background-color",
				value1 = "rgba(240, 245, 255, 1)");
		}

		task ("Then the page creator could go back to the times icon via shift + tab shortcuts") {
			Type.sendKeys(
				data_qa_id = "Button",
				locator1 = "Treeview#NODE_ITEM_BY_DATA_QA_ID",
				value1 = "keys=SHIFT,TAB");

			AssertElementFocused(locator1 = "//*[*[name()='svg'][contains(@class,'lexicon-icon-times')]]");
		}
	}

	@description = "This is a test for LPS-191827. Check the accessibility when warning message displays in a Collection Display with configuration can cause performance issues in page edit mode."
	@priority = 3
	test ViewAccessibilityOfCollectionDisplayPagePerformanceWarningMessageInPageEditor {
		property custom.properties = "feature.flag.LPS-187284=true${line.separator}feature.flag.LPS-187285=true";

		task ("Given a user has a Collection Display with None pagination on a content page") {
			AssetListsAdmin.openAssetListsAdmin(siteURLKey = ${siteURLKey});

			AssetListsAdmin.addDynamicSelection(assetListTitle = "Dynamic Collection");

			AssetListsAdmin.configureItemTypeInDynamicCollection(itemType = "All Types");

			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Collection Display");

			PageEditor.editCollectionDisplay(
				assetListName = "Dynamic Collection",
				fragmentName = "Collection Display",
				pagination = "None");
		}

		task ("When the user enables the Display All Collection Items") {
			PageEditor.editCollectionDisplay(
				displayAllCollectionItems = "true",
				fragmentName = "Collection Display",
				selectedName = "Dynamic Collection");
		}

		task ("Then the warning message should have correct accessibility") {
			AssertElementAccessible(
				fieldLabel = "Display All Collection Items",
				locator1 = "Message#WARNING_WITH_LABEL");
		}
	}

	@description = "This is a test for LPS-165288. The Comments panel should have correct accessibility."
	@priority = 3
	test ViewAccessibilityOfCommentsPanel {
		task ("Given a page creator has a fragment on a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");
		}

		task ("When the page creator accesses to the Comments panel of fragment") {
			PageEditor.gotoCommentViaFragment(fragmentName = "Heading");
		}

		task ("Then the Comments panel should have correct accessibility") {
			AssertElementPresent(
				key_fragmentName = "Heading",
				locator1 = "PageEditor#FRAGMENT_SIDEBAR_COMMENT_SECTION_NAME");

			AssertAttributeValue(
				locator1 = "PageEditor#FRAGMENT_SIDEBAR_BACK",
				value1 = "aria-label",
				value2 = "Back");

			AssertAttributeValue(
				locator1 = "PageEditor#FRAGMENT_SIDEBAR_COMMENTS",
				value1 = "aria-label",
				value2 = "Add Comment");
		}
	}

	@description = "This is a test for LPS-165264. The Name and Page Template Set fields on create page template modal should have requried attribute."
	@priority = 3
	test ViewAccessibilityOfCreatePageTemplateModal {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page creator opens the create page template modal before creating a page template set") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			LexiconEntry.gotoHeaderMenuItem(menuItem = "Convert to Page Template");
		}

		task ("Then the page creator sees the Name field with required attribute on modal") {
			AssertAttributeValue(
				locator1 = "TextInput#NAME",
				value1 = "required",
				value2 = "true");

			IFrame.closeFrame();
		}

		task ("When the page creator opens the create page template modal after creating a page template set") {
			JSONLayoutpagetemplate.addLayoutPageTemplateCollection(
				groupName = ${randomSiteName},
				layoutPageTemplateCollectionName = "Page Template Set");

			LexiconEntry.gotoHeaderMenuItem(menuItem = "Convert to Page Template");
		}

		task ("Then the page creator sees the Page Template Set field with required attribute on modal") {
			AssertAttributeValue(
				key_fieldLabel = "Page Template Set",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "required",
				value2 = "true");
		}
	}

	@description = "This is a test for LPS-165824. The edit mode selector should have aria-label attribute."
	@priority = 3
	test ViewAccessibilityOfEditModeSelector {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page creator accesses to the page editor") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("Then the edit mode selector should have correct aria-label") {
			AssertAttributeValue(
				locator1 = "PageEditor#EDIT_MODE_SELECTOR",
				value1 = "aria-label",
				value2 = "Page Edition Mode");
		}
	}

	@description = "This is a test for LPS-165284. The Experience selector should have correct accessibility."
	@priority = 3
	test ViewAccessibilityOfExperienceSelector {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page creator accesses to the page editor") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("Then the Experience selector should have correct accessibility") {
			AssertAttributeValue(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "aria-expanded",
				value2 = "false");

			AssertAttributeValue(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "aria-haspopup",
				value2 = "true");

			KeyPress(
				locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS",
				value1 = "\TAB");

			KeyPress(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "\ENTER");

			AssertAttributeValue(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "aria-expanded",
				value2 = "true");

			AssertElementFocused(locator1 = "//button[@aria-label='New Experience']");

			Type.sendKeys(
				ariaLabel = "New Experience",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "keys=SHIFT,TAB");

			AssertAttributeValue(
				locator1 = "PageEditor#EXPERIENCE_SELECTOR",
				value1 = "aria-expanded",
				value2 = "false");

			AssertElementFocused(locator1 = "//div[contains(@class,'page-editor__toolbar-experience')]//button");
		}
	}

	@description = "This is a test for LPS-194375. The Page Editor filter is WCAG 2.1 AA compliant."
	@priority = 3
	test ViewAccessibilityOfFilterByContentTypeSelector {
		task ("Given a page creator has displayed assets on content page") {
			JSONWebcontent.addWebContent(
				content = "Web Content Content",
				groupName = ${randomSiteName},
				title = "Web Content Title");

			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Content Display",
				targetFragmentName = "Heading");

			PageEditor.editContentDisplay(
				fragmentName = "Content Display",
				webcontent = "true",
				webContentContent = "Web Content Content",
				webContentTitle = "Web Content Title");
		}

		task ("When the page creator opens the dropdown menu of Filter by Content Type") {
			PageEditor.gotoTab(tabName = "Page Content");

			Click(locator1 = "PageEditor#PAGE_CONTENTS_CONTENT_FILTER_TOGGLE");
		}

		task ("Then the dropdown menu should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li");

			AssertElementAccessible(locator1 = "xpath=(//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li)[2]");

			AssertElementAccessible(locator1 = "xpath=(//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li)[3]");
		}
	}

	@description = "This is a test for LPS-165625 and LPS-194374. The Language Selector shouldn't have aria-pressed attribute. The Language Selector should comply with WCAG 2.1 AA standard."
	@priority = 3
	test ViewAccessibilityOfLanguageSelector {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page creator accesses to the page editor") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("Then the Language Selector should have correct accessibility") {
			AssertElementNotPresent(locator1 = "//button[contains(@type,'button')][@aria-pressed][*[name()='svg'][contains(@class,'lexicon-icon-en-us')]]");

			AssertElementPresent(locator1 = "//button[contains(@type,'button')][@aria-label='Select a language, current language: en-US.']");
		}

		task ("When the page creator opens the dropdown menu of the language selector") {
			Click(
				key_currentLocale = StringUtil.lowerCase("en-US"),
				locator1 = "Button#TRANSLATIONS_LOCALIZATION");
		}

		task ("Then the dropdown menu should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li");

			AssertElementAccessible(locator1 = "xpath=(//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li)[2]");

			AssertElementAccessible(locator1 = "xpath=(//div[contains(@class,'dropdown-menu-select')][contains(@class,'show')]//li)[3]");
		}
	}

	@description = "This is a test for LPS-168850. All the elements are announced as Link."
	@priority = 4
	test ViewAccessibilityOfNavigationMenu {
		task ("Given a page has several nested content pages") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Home",
				type = "content");

			for (var i : list "1,2") {
				JSONLayout.addPublicLayout(
					groupName = ${randomSiteName},
					layoutName = "Home Child Page ${i}",
					parentLayoutName = "Home");
			}

			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Home Child Page 1 Child Page",
				parentLayoutName = "Home Child Page 1");
		}

		task ("When selecting Bar with Links in Display Template field of Menu Display") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Home",
				siteName = ${randomSiteName});

			PageEditor.addWidgetViaKeyboard(
				categoryName = "Content Management",
				upCount = 1,
				widgetName = "Menu Display");

			NavigationMenusWidget.gotoNavigationMenuWidgetConfig();

			NavigationMenusWidget.selectDisplayTemplate(templateName = "Bar With Links");

			AssertTextEquals(
				locator1 = "Select#DISPLAY_TEMPLATE",
				value1 = "Bar With Links");

			Portlet.saveAndCloseConfig();

			PageEditor.publish();
		}

		task ("Then role attribute is not present in all menu items") {
			ContentPagesNavigator.openViewContentPage(
				pageName = "Home",
				siteName = ${randomSiteName});

			MouseOver(locator1 = "//div[@id='main-content']//section[contains(@id,'SiteNavigationMenuPortlet')]//div[@class='portlet-body']//span");

			for (var pageName : list "Home Child Page 1,Home Child Page 1 Child Page,Home Child Page 2") {
				AssertAttributeValue.assertAttributeNotPresent(
					locator1 = "//div[contains(@class,'layout-content')]//a[contains(@class, 'dropdown-item')][contains(text(), '${pageName}')]",
					value1 = "role");
			}
		}
	}

	@description = "This is a test for LPS-196462. The New Rule Modal complies with WCAG 2.1 AA standard."
	@priority = 2
	test ViewAccessibilityOfNewRuleModal {
		property custom.properties = "feature.flag.LPS-169837=true";

		task ("Given a page designer has a Button fragment on a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("When the page designer opens the New Rule modal") {
			PageEditor.gotoTab(tabName = "Page Rules");

			Button.click(button = "New Rule");
		}

		task ("Then the New Rule modal should have correct accessibility") {
			AssertElementAccessible(locator1 = "Modal#MODAL_CONTENT");
		}
	}

	@description = "This is a test for LPS-165288. The Page Design Options panel should have correct accessibility."
