	@description = "This is a test for LPS-194373. The Page Design / Content Editing picker should comply with WCAG 2.1 AA standard."
	@priority = 3
	test ViewAccessibilityOfPageEditionModeSelector {
		task ("Given a page creator has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
