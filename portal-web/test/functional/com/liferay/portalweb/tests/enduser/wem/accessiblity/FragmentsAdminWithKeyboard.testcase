@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Fragments";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-175120. The site administrator could choose import option via keyboard when import fragments."
	@priority = 4
	test ChooseImportOptionViaKeyboard {
		task ("Given a site administrator exports a fragment") {
			JSONFragment.addFragmentCollection(
				description = "Collection Description",
				groupName = "Test Site Name",
				name = "Collection Name");

			JSONFragment.addSection(
				collectionName = "Collection Name",
				fragmentStatus = "Approved",
				groupName = "Test Site Name",
				name = "Fragment Name");

			FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = "test-site-name");

			FragmentsAdmin.exportCollection(collectionName = "Collection Name");
		}

		task ("When the site administrator imports the fragment") {
			FragmentsAdminNavigator.gotoImportCollection();

			WaitForPageLoad();

			var collectionsZipFileName = TestCase.getDownloadedTempFileName(fileNamePattern = "collections-*.zip");

			UploadTempFile.uploadTempFileHiddenNoMouseOver(
				locator1 = "TextInput#FILE",
				value1 = ${collectionsZipFileName});
		}

		task ("Then the site administrator could choose import option via keyboard") {
			KeyPress(
				key_text = "Cancel",
				locator1 = "Button#ANY",
				value1 = "\TAB");

			KeyPress(
				key_text = "Import",
				locator1 = "Button#ANY",
				value1 = "\ENTER");

			WaitForVisible(locator1 = "Modal#HEADER");

			KeyPress(
				ariaLabel = "close",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\TAB");

			KeyPress(
				locator1 = "Radio#ANY",
				radioLabel = "Do Not Import Existing Items",
				value1 = "\DOWN");

			KeyPress(
				locator1 = "Radio#ANY",
				radioLabel = "Overwrite Existing Items",
				value1 = "\DOWN");

			KeyPress(
				key_text = "Cancel",
				locator1 = "Modal#MODAL_FOOTER_BUTTON",
				value1 = "\TAB");

			KeyPress(
				key_text = "Import",
				locator1 = "Modal#MODAL_FOOTER_BUTTON",
				value1 = "\ENTER");

			AssertTextEquals(
				locator1 = "Message#SUCCESS_IMPORT",
				value1 = "1 item was imported.");
		}
	}

	@description = "This is a use case for LPS-177682. Using Keyboard Navigation it is possible to access the back button of fragments entry and is Go to Fragments."
	@priority = 2
	test ViewBackButtonTooltipInFragmentEditorViaKeyboard {
		task ("Given access to the Fragment editor page") {
			JSONFragment.addFragmentCollection(
				groupName = "Test Site Name",
				name = "Fragment Set Name");

			FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = "test-site-name");

			FragmentsAdminNavigator.gotoCollection(collectionName = "Fragment Set Name");

			FragmentsAdmin.addFragment(fragmentName = "Fragment Name");
		}

		task ("When hover on the back button via keyboard") {
			KeyPress(
				locator1 = "ProductMenu#TOGGLE",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "Icon#BACK");
		}

		task ("Then see the tooltip message") {
			AssertVisible(
				key_content = "Go to Fragments",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}
	}

	@description = "This is a test for LPS-177682. Using Keyboard Navigation it is possible to access the back button of usages and is Go to Fragments."
	@priority = 3
	test ViewBackButtonTooltipInViewUsagesViaKeyboard {
		task ("Given the View Usages page of a fragment") {
			JSONFragment.addFragmentCollection(
				groupName = "Test Site Name",
				name = "Fragment Set Name");

			JSONFragment.addSection(
				collectionName = "Fragment Set Name",
				fragmentStatus = "Approved",
				groupName = "Test Site Name",
				name = "Fragment Name");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Fragment Set Name",
				fragmentName = "Fragment Name");

			FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = "test-site-name");

			FragmentsAdminNavigator.gotoCollection(collectionName = "Fragment Set Name");

			FragmentsAdminNavigator.gotoEntryEllipsisItem(
				entry = "Fragment Name",
				item = "View Usages");
		}

		task ("When hover on the back button via keyboard") {
			KeyPress(
				locator1 = "ProductMenu#TOGGLE",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "Icon#BACK");
		}

		task ("Then see the tooltip message") {
			AssertVisible(
				key_content = "Go to Fragments",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}
	}

}