			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Widget Page Name");
		}

		task ("When adding a Link to URL type page and setting Target in advanced tab") {
			PagesAdmin.openPagesAdmin(siteURLKey = ${siteURLKey});

			PagesAdmin.addPage(
				pageName = "Test Link to URL Page Name",
				pageTypeURL = "https://www.google.com",
				sitePageType = "Link to URL",
				target = "_blank");
		}

		task ("Then viewing the linked URL page opens in new tab") {
			Navigator.openSiteURL(siteName = ${randomSiteName});

			AssertVisible(
				key_href = "https://www.google.com",
				key_pageName = "Test Link to URL Page Name",
				locator1 = "Home#PAGE_HREF_BLANK");

			PagesFinder.goToPagesFinder();

			AssertVisible(
				key_href = "https://www.google.com",
				key_pageName = "Test Link to URL Page Name",
				locator1 = "PagesFinder#PAGE_HREF_BLANK");

			PagesAdmin.openPagesAdmin(siteURLKey = ${siteURLKey});

			PagesAdmin.openPageEllipsisMenu(pageName = "Test Link to URL Page Name");

			AssertVisible(
				key_href = "https://www.google.com",
				locator1 = "PagesAdmin#LIST_GROUP_ITEM_HREF_BLANK");
		}
	}

	@description = "This is a test for LPS-159631. Page opens in current page in default setting."
	@priority = 4
	test ViewLinkToURLTypePageWithDefaultSetting {
		task ("Given a page creator has a widget page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Widget Page Name");
		}

		task ("When adding a Link to URL type page with default setting") {
			PagesAdmin.openPagesAdmin(siteURLKey = ${siteURLKey});

			PagesAdmin.addPage(
				pageName = "Test Link to URL Page Name",
				pageTypeURL = "https://www.google.com",
				sitePageType = "Link to URL");
		}

		task ("Then viewing the linked URL page opens in current page") {
			Navigator.openSiteURL(siteName = ${randomSiteName});

			AssertClick.assertPartialTextClickAt(
				key_pageName = "Test Link to URL Page Name",
				locator1 = "Home#PAGE",
				value1 = "Test Link to URL Page Name");

			AssertLocation.assertPartialLocation(value1 = "https://www.google.com");

			Navigator.openSiteURL(siteName = ${randomSiteName});

			PagesFinder.goToPagesFinder();

			Click(
				key_pageName = "Test Link to URL Page Name",
				locator1 = "PagesFinder#PAGE_NAME",
				value1 = ${pageName});

			AssertLocation.assertPartialLocation(value1 = "https://www.google.com");

			PagesAdmin.openPagesAdmin(siteURLKey = ${siteURLKey});

			PagesAdmin.gotoPageEllipsisMenuItem(
				menuItem = "View",
				pageName = "Test Link to URL Page Name");

			AssertLocation.assertPartialLocation(value1 = "https://www.google.com");
		}
	}

	@description = "This is a test for LPS-175090. Permissions are copied when a Page is created as a copy of another Page."
	@priority = 4
	test ViewPermissionsPersistedInCopyPage {
		task ("Given a page designer has a page without view permissions for guest") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Content Page Name",
				type = "content");

			PagesAdmin.openPagesAdmin(siteURLKey = ${randomSiteName});

			PagesAdmin.gotoPageEllipsisMenuItem(
				menuItem = "Permissions",
				pageName = "Test Content Page Name");

			IFrame.selectPermissionsFrame();

			Role.removePermissionPG(
				permissionDefinitionKey = "CONTENT_PERMISSIONS_VIEW_CHECKBOX",
				roleTitle = "Guest");

			IFrame.closeFrame();

			PagesAdmin.gotoPageEllipsisMenuItem(
				menuItem = "Edit",
				pageName = "Test Content Page Name");

			PageEditor.assertFragmentSidebarLoaded();

			PageEditor.publish();
		}

		task ("When the page designer creates a copy of this page with permissions") {
			PagesAdmin.gotoPageEllipsisMenuItem(
				menuItem = "Make a Copy",
				pageName = "Test Content Page Name");

			DropdownMenuItem.click(menuItem = "Page With Permissions");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			PortletEntry.inputName(name = "Copy Content Page Name");

			Button.click(button = "Add");

			SelectFrame.selectFrameTop();

			Alert.viewSuccessMessage();
		}

		task ("Then the copy of page should keep the permissions") {
			PermissionsInline.gotoPagePG(
				pageName = "Copy Content Page Name",
				site = ${randomSiteName});

			AssertNotChecked.assertNotCheckedNotVisible(
				key_roleTitle = "Guest",
				locator1 = "Permissions#CONTENT_PERMISSIONS_VIEW_CHECKBOX");
		}
	}

}