@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Content Pages";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-182024. The Locked Pages admin should comply with WCAG 2.1 AA standard."
	@priority = 4
	test ViewAccessibilityOfLockedPages {
		task ("Given a user doesn't have locked pages") {
			SetWindowSize.maximizeWindow();

			ApplicationsMenu.gotoSite(site = "Test Site Name");
		}

		task ("When a user accesses to the Locked Pages admin") {
			ProductMenu.gotoPortlet(
				category = "Configuration",
				portlet = "Locked Pages");
		}

		task ("Then the Locked Pages admin should have correct accessibility") {
			AssertAccessible();
		}

		task ("Given a user has a locked pages") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When a user accesses to the Locked Pages admin in a new tab") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/web/test-site-name");

			ProductMenu.gotoPortlet(
				category = "Configuration",
				portlet = "Locked Pages");
		}

		task ("Then the Locked Pages admin should have correct accessibility") {
			AssertAccessible();
		}

		task ("When the user unlocks the locked page") {
			LexiconTable.clickEllipsisItem(
				item = "Unlock",
				tableEntry = "Test Page Name");
		}

		task ("Then the Unlock Pages modal should have correct accessibility") {
			AssertAccessible();
		}
	}

	@description = "This is a test for LPS-194238. The Locked Pages admin should comply with WCAG 2.1 AA standard with the filter menu and sort menu opened."
	@priority = 4
	test ViewLockedPagesFilterAndOrderAccessibility {
		task ("Given a locked content pages") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When filtering by Display Page Template, ordering by Name and sort is added") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/web/test-site-name");

			ProductMenu.gotoPortlet(
				category = "Configuration",
				portlet = "Locked Pages");

			ManagementBar.setFilterAndOrder(
				filterBy = "Display Page Template",
				orderBy = "Name");

			Click(locator1 = "ManagementBar#ORDER_ICON_GENERIC");
		}

		task ("Then it is possible to check accessibility") {
			AssertAccessible();
		}
	}

}