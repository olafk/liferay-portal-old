			AssertVisible(
				key_colPosition = 1,
				key_entryTitle = "GA8 Interior",
				key_fragmentName = "Collection Display",
				key_rowPosition = 1,
				locator1 = "PageEditor#COLLECTION_ITEM_TITLE");

