	@description = "LPS-194126 Confirm that when creating a field with a pt-BR translation, the label is translated when pt is added to the page URL"
	@priority = 4
	test TheFieldValueIsTranslated {
		task ("Given a product created and a data set entry with app:/headless-commerce-admin-catalog/v1.0") {
			ApplicationsMenu.gotoPortlet(
				category = "Product Management",
				panel = "Commerce",
				portlet = "Products");

			LexiconEntry.gotoAdd();

			Click(
				key_menuItem = "Simple",
				locator1 = "MenuItem#MENU_ITEM_SPECIFIC");

			CommerceEntry.addProductsEntry(
				compileDescription = "true",
				productCatalog = "Master",
				productFullDescription = "test",
				productName = "Product FDS",
				productShortDescription = "Test",
				publishProduct = "Approved");

			DataSetAdmin.goToDataSetAdminPage();

			DataSetAdmin.createDataSetEntryViaAPI(
				dataSetName = "Data Set Test",
				restApplication = "/headless-commerce-admin-catalog/v1.0",
				restEndpoint = "/v1.0/products",
				restSchema = "Product");
		}

		task ("And a data set view created via api") {
