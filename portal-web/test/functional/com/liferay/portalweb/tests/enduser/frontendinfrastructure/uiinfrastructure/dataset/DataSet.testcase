				key_dataSetViewNameList = "View Test");
		}

		task ("When go to the View page of the data set created.") {
			DataSetAdmin.goToSpecificViewPage(
				dataSetName = "Data Set Test",
				key_viewName = "View Test");
		}

		task ("When goes to Fields Tab.") {
			DataSetAdmin.goToTab(tabName = "Fields");
		}

		task ("And adds a field name") {
			DataSetAdmin.addFields(key_fieldList = "name");
		}

		task ("And clicks on ellipsis button on name field and add a new translation") {
			DataSetAdmin.addAFDSFieldWithTranslation(
				dropdownMenuItem = "Edit",
				key_fieldName = "name",
				key_newLabel = "Nome",
				selectLanguage = "pt_BR");
		}

		task ("When the user adds a widget page and add a fragment Data Set") {
			Navigator.openURL();

			ContentPages.addPage(pageName = "Data Set Test");

			PageEditor.addFragment(
