	@description = "LPS-185990 Confirm that when selecting the single option in the created filter, it is possible to preselect an item value"
	@priority = 3
	test IsOnlyPossibleToSelectOneItem {
		task ("Given the creation of a new data set") {
			DataSetAdmin.goToDataSetAdminPage();

			DataSetAdmin.createDataSetEntryViaAPI(
				dataSetName = "Data Set Test",
				restApplication = "/data-set-manager/fields",
				restEndpoint = "/",
				restSchema = "FDSField");

			DataSetAdmin.createFDSViewViaAPI(
				dataSetName = "Data Set Test",
				dataSetViewDescription = "FDSViewDescription",
				key_dataSetViewNameList = "View Test");

			DataSetAdmin.goToSpecificViewPage(
				dataSetName = "Data Set Test",
				key_viewName = "View Test");
		}

		task ("And creating a picklist and Items bike,car,bus") {
			Picklist.addPicklistViaAPI(picklistName = "Transport");

			Picklist.addPicklistItemViaAPI(
				itemKey = "bike",
				itemName = "bike",
				picklistName = "Transport");

			Picklist.addPicklistItemViaAPI(
				itemKey = "car",
				itemName = "car",
				picklistName = "Transport");

			Picklist.addPicklistItemViaAPI(
				itemKey = "bus",
				itemName = "bus",
				picklistName = "Transport");
		}

		task ("When the user creates a new filter //Name: Filter test //Filter by: creator //Source option: Transport the selection is multiple") {
			DataSetAdmin.goToTab(tabName = "Filters");

			LexiconEntry.gotoAdd();

			Click(
				key_menuItem = "Selection",
				locator1 = "MenuItem#ANY_MENU_ITEM");

			Type(
				key_text = "Name",
				locator1 = "TextInput#ANY",
				value1 = "Filter test");

			Click(
				key_class = "btn-secondary",
				key_index = 3,
				locator1 = "Button#ANY_WITH_CLASS_AND_INDEX");

			SelectFrameTop();

			Click.javaScriptClick(
				key_sortOption = "creator",
				locator1 = "DataSet#SELECT_SORT_OPTION");

			Select(
				locator1 = "DataSet#SOURCE_OPTIONS_SELECT",
				value1 = "Transport");

			Click.clickAtNotVisible(
				key_radioOption = "Single",
				locator1 = "CommerceEntry#RADIO_BUTTON");

			Click(
				key_fieldName = "Select a default value for your filter",
				locator1 = "DataSet#PRESELECT_VALUE_INPUT");
		}

		task ("Then the text “Select a value“ is present in the Preselected Values field, It is only possible to add one item") {
			for (var asserttransport : list "car,bike") {
				Click(
					key_sortOption = ${asserttransport},
					locator1 = "DataSet#SELECT_SORT_OPTION");
			}

			Click(
				key_modal_title = "New Selection Filter",
				locator1 = "AccessibilityMenu#MODAL_TITLE");

			AssertElementPresent(
				key_helpText = "Only one value is allowed in",
				locator1 = "ObjectField#HELP_TEXT");
		}
	}

