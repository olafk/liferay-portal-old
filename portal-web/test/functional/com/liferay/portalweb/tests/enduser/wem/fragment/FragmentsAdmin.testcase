@component-name = "portal-page-management"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Fragment Administration";

	static var randomSiteName = StringUtil.randomString(8);

	var siteURLKey = StringUtil.toLowerCase(${randomSiteName});

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = ${randomSiteName});
		}
	}

	@description = "This is a test for LPS-90063 and LPS-159235. Add folders to fragment resource and check hints."
	@priority = 4
	test AddFoldersToResourceAndCheckHints {
		task ("When user is in resources tab") {
			task ("Add a fragment collection") {
				JSONFragment.addFragmentCollection(
					groupName = ${randomSiteName},
					name = "Collection Name");
			}

			task ("Navigate to the fragment collection") {
				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = ${siteURLKey});

				FragmentsAdminNavigator.gotoCollection(collectionName = "Collection Name");
			}

			task ("Navigate to the resources tab") {
				Navigator.gotoNavItem(navItem = "Resources");
			}
		}

		task ("Then the user could add folders to fragment resource and see the hints for resources in folders") {
			task ("Add 2 folders in root") {
				FragmentsAdmin.addFolder(folderName = "Folder 1");

				FragmentsAdmin.addFolder(folderName = "Folder 2");
			}

			task ("View 2 folders") {
				FragmentsAdmin.viewEntryPresent(entry = "Folder 1");

				FragmentsAdmin.viewEntryPresent(entry = "Folder 2");
			}

			task ("Add a sub folder for one of the created folders") {
				FragmentsAdmin.addSubfolder(
					folderName = "Folder 1",
					subfolderName = "Subfolder 1");
			}

			task ("View sub folder") {
				FragmentsAdmin.viewEntryPresent(entry = "Subfolder 1");
			}

			task ("Add a resource to one of the folders in root") {
				Navigator.gotoNavItem(navItem = "Resources");

				FragmentsAdmin.addResourceToFolder(
					folderName = "Folder 1",
					resourceFile = "Document_1.png");

				FragmentsAdmin.viewEntryPresent(entry = "Document_1");
			}

			task ("Add a fragment and type to invoke hint") {
				Navigator.gotoNavItem(navItem = "Fragments");

				FragmentsAdmin.addFragment(fragmentName = "Fragment Name");

				AssertElementNotPresent(locator1 = "Message#SUCCESS_DISMISSIBLE");

				var htmlSnippet = '''[resources:''';

				FragmentsEditor.typeHtmlEditor(content = "");

				Type.sendKeysAceEditor(
					locator1 = "FragmentEditor#HTML_EDITOR_CONTENT",
					value1 = ${htmlSnippet});
			}

			task ("Assert there is a hint for resources with path") {
				AssertElementPresent(
					autocompleteField = "Folder 1/Document_1",
					locator1 = "FragmentEditor#AUTOCOMPLETE_FIELD");
			}

			task ("Add a resource to sub folder") {
				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = ${siteURLKey});

				FragmentsAdminNavigator.gotoCollection(collectionName = "Collection Name");

				Navigator.gotoNavItem(navItem = "Resources");

				LexiconCard.clickCardTitleLink(card = "Folder 1");

				FragmentsAdmin.addResourceToFolder(
					folderName = "Subfolder 1",
					resourceFile = "Document_2.png");
			}

			task ("Add a fragment and type to invoke hint") {
				Navigator.gotoNavItem(navItem = "Fragments");

				FragmentsAdminNavigator.gotoEntry(entry = "Fragment Name");

				FragmentsEditor.typeHtmlEditor(content = "");

				Type.sendKeysAceEditor(
					locator1 = "FragmentEditor#HTML_EDITOR_CONTENT",
					value1 = ${htmlSnippet});
			}

			task ("Assert there is a hint for resources with path") {
				AssertElementPresent(
					autocompleteField = "Folder 1/Subfolder 1/Document_2",
					locator1 = "FragmentEditor#AUTOCOMPLETE_FIELD");
			}
		}
	}

	@description = "This is a test for LPS-177286. Able to enable and disable the propagation of Contributed Fragments on the instance startup."
	@priority = 4
	test ManuallyPropagateChanges {
		task ("Given a site administrator accesses to the Page Fragments configuration of Instance Settings") {
			PortalSettings.gotoConfiguration(
				configurationCategory = "Page Fragments",
				configurationName = "Page Fragments",
				configurationScope = "Virtual Instance Scope");
		}

		task ("When the site administrater unchecks the Propagate Default Fragments Changes During Deploy Process Automatically") {
			FormFields.disableCheckbox(fieldName = "Propagate Default Fragments Changes During Deploy Process Automatically");

			PortletEntry.save();
		}

		task ("Then the site administrater could cancel manually propagate changes") {
			Button.click(button = "Propagate Changes");

			Click(
				key_text = "Cancel",
				locator1 = "Modal#MODAL_FOOTER_BUTTON");
		}

		task ("When the site administrater manually propagate changes") {
			Button.click(button = "Propagate Changes");

			Click(
				key_text = "Continue",
				locator1 = "Modal#MODAL_FOOTER_BUTTON");

			Alert.viewSuccessMessage();
		}

		task ("Then the Propagate changes button is disabled") {
			AssertNotEditable(
				key_text = "Propagate Changes",
				locator1 = "Button#ANY");
		}

		task ("When restart the portal") {
			Portlet.shutdownServer();

			Portlet.startServer(deleteLiferayHome = "false");
		}

		task ("Then the Propagate changes button is enabled") {
			PortalSettings.gotoConfiguration(
				configurationCategory = "Page Fragments",
				configurationName = "Page Fragments",
				configurationScope = "Virtual Instance Scope");

			AssertEditable(
				key_text = "Propagate Changes",
				locator1 = "Button#ANY");
		}
	}

	@description = "This is a test for LPS-180331. The new site should inherit form fragment displayed by default per field type from the global site."
	@priority = 4
	test ViewDefaultFormFragmentOfTextFieldAddedInGlobalSiteInheritesInNewSite {
		task ("Given a Text Input fragment copied from Form Components in global site") {
			task ("Add a fragment set") {
				JSONFragment.addFragmentCollection(
					groupName = "Global",
					name = "Fragment Set Name");
			}

			task ("Navigate to the fragments admin") {
				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = "Global");
			}

			task ("Copy the Text Input fragment from Form Components to new fragment set") {
				FragmentsAdminNavigator.gotoCollection(collectionName = "Form Components");

				FragmentsAdminNavigator.gotoEntryEllipsisItem(
					entry = "Text",
					item = "Copy To",
					specificFormFragment = "true");

				FragmentsAdmin.selectCollection(collectionName = "Fragment Set Name");
			}
		}

		task ("When configure default form fragment by default for Text field type") {
			task ("Navigate to the configuration page via ellipsis button on control menu") {
				LexiconEntry.gotoHeaderMenuItem(menuItem = "Configuration");
			}

			task ("Open the Select Fragment modal for Text field type") {
				Click(
					key_tableEntry = "Text",
					key_text = "Select",
					locator1 = "LexiconTable#TABLE_ENTRY_BUTTON");
			}

			task ("View two tabs shown on modal, Default, Global") {
				SelectFrame(locator1 = "IFrame#MODAL_BODY");

				for (var navItem : list "Default,Global") {
					AssertVisible(
						key_navItem = ${navItem},
						locator1 = "NavBar#NAV_ITEM_LINK");
				}
			}

			task ("Select the copy of fragment from global site") {
				Click(
					key_navItem = "Global",
					locator1 = "NavBar#NAV_ITEM_LINK");

				LexiconCard.clickCardTitle(card = "Fragment Set Name");

				LexiconCard.clickCard(card = "Text (Copy)");
			}
		}

		task ("Then assert the copy of fragment is shown in Form Fragment selector for Text field type") {
			task ("View the copy of fragment is shown in Form Fragment selector for Text field type") {
				SelectFrameTop();

				FragmentsAdmin.viewFormFragementForEachFieldType(
					fieldType = "Text",
					formFragmentName = "Text (Copy)");
			}

			task ("Save and back to fragment admin configuration") {
				Button.clickSave();

				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = ${siteURLKey});

				LexiconEntry.gotoHeaderMenuItem(menuItem = "Configuration");
			}

			task ("View the copy of fragment is shown in Form Fragment selector for Text field type") {
				FragmentsAdmin.viewFormFragementForEachFieldType(
					fieldType = "Text",
					formFragmentName = "Text (Copy)");
			}
		}
	}

	@description = "This is a test for LPS-180331. The site administrator could select the form fragment displayed by default per field type in normal site."
	@priority = 4
	test ViewDefaultFormFragmentOfTextFieldChangedInNormalSite {
		task ("Given a Text Input fragment copied from Form Components in normal site") {
			task ("Add a fragment set") {
				JSONFragment.addFragmentCollection(
					groupName = ${randomSiteName},
					name = "Fragment Set Name");
			}

			task ("Navigate to the fragments admin") {
				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = ${siteURLKey});
			}

			task ("Copy the Text Input fragment from Form Components to new fragment set") {
				FragmentsAdminNavigator.gotoCollection(collectionName = "Form Components");

				FragmentsAdminNavigator.gotoEntryEllipsisItem(
					entry = "Text",
					item = "Copy To",
					specificFormFragment = "true");

				FragmentsAdmin.selectCollection(collectionName = "Fragment Set Name");
			}
		}

		task ("When configure default form fragment by default for Text field type") {
			task ("Navigate to the configuration page via ellipsis button on control menu") {
				LexiconEntry.gotoHeaderMenuItem(menuItem = "Configuration");
			}

			task ("View the default form fragment displayed by default for each field type") {
				var fieldTypeList = "Boolean,Date,File,Form Button,HTML,Long Text,Multiselect,Number,Relationship,Select,Text";
				var formFragmentNameList = "Checkbox,Date,File Upload,Form Button,Rich Text,Textarea,Multiselect,Numeric,Select,Select,Text";
				var i = 0;
				var list1 = ListUtil.newListFromString(${fieldTypeList});
				var list2 = ListUtil.newListFromString(${formFragmentNameList});
				var size = ListUtil.size(${list1});

				while (${i} != ${size}) {
					var fieldType = ListUtil.get(${list1}, ${i});
					var formFragmentName = ListUtil.get(${list2}, ${i});

					FragmentsAdmin.viewFormFragementForEachFieldType(
						fieldType = ${fieldType},
						formFragmentName = ${formFragmentName});

					var i = ${i} + 1;

					var i = StringUtil.valueOf(${i});
				}
			}

			task ("Open the Select Fragment modal for Text field type") {
				Click(
					key_tableEntry = "Text",
					key_text = "Select",
					locator1 = "LexiconTable#TABLE_ENTRY_BUTTON");
			}

			task ("View three tabs shown on modal, Default, Global and current site") {
				SelectFrame(locator1 = "IFrame#MODAL_BODY");

				for (var navItem : list "Default,Global,${randomSiteName}") {
					AssertVisible(
						key_navItem = ${navItem},
						locator1 = "NavBar#NAV_ITEM_LINK");
				}
			}

			task ("Select the copy of fragment from current site") {
				Click(
					key_navItem = ${randomSiteName},
					locator1 = "NavBar#NAV_ITEM_LINK");

				LexiconCard.clickCardTitle(card = "Fragment Set Name");

				LexiconCard.clickCard(card = "Text (Copy)");
			}
		}

		task ("Then assert the copy of fragment is shown in Form Fragment selector for Text field type") {
			task ("View the copy of fragment is shown in Form Fragment selector for Text field type") {
				SelectFrameTop();

				FragmentsAdmin.viewFormFragementForEachFieldType(
					fieldType = "Text",
					formFragmentName = "Text (Copy)");
			}

			task ("Save and back to fragment admin configuration") {
				Button.clickSave();

				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = ${siteURLKey});

				LexiconEntry.gotoHeaderMenuItem(menuItem = "Configuration");
			}

			task ("View the copy of fragment is shown in Form Fragment selector for Text field type") {
				FragmentsAdmin.viewFormFragementForEachFieldType(
					fieldType = "Text",
					formFragmentName = "Text (Copy)");
			}
		}
	}

	@description = "This is a test for LPS-180331. The site administrator should see the link for configuration of the form fragments when configure a published form fragment."
	@priority = 4
	test ViewLinkForConfigurationWhenConfigureFormFragment {
		task ("Given a Text Input fragment from Form Components in normal site") {
			task ("Add a fragment set") {
				JSONFragment.addFragmentCollection(
					groupName = ${randomSiteName},
					name = "Fragment Set Name");
			}

			task ("Navigate to the fragments admin") {
				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = ${siteURLKey});
			}

			task ("Copy the Text Input fragment from Form Components to new fragment set") {
				FragmentsAdminNavigator.gotoCollection(collectionName = "Form Components");

				FragmentsAdminNavigator.gotoEntryEllipsisItem(
					entry = "Text",
					item = "Copy To",
					specificFormFragment = "true");

				FragmentsAdmin.selectCollection(collectionName = "Fragment Set Name");
			}
		}

		task ("When go to edit the copy of fragment's configuration") {
			FragmentsAdminNavigator.gotoEntryEllipsisItem(
				entry = "Text (Copy)",
				item = "Edit");

			FragmentsEditor.gotoConfigurationTab();
		}

		task ("Then view the link for configuration of the form fragments") {
			task ("Click the link Define the default form fragments for this site") {
				Click(
					key_text = "Define the default form fragments for this site.",
					locator1 = "Link#ANY");
			}

			task ("View the configuration page of form fragments shown in a new tab") {
				SelectWindow.selectPopUp(value1 = "null");

				ControlMenu.viewHeaderTitle(headerTitle = "Fragment Configuration");

				Close.closeWindow();
			}

			task ("Add a draft form fragment for Text field type") {
				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = ${siteURLKey});

				FragmentsAdmin.addFragment(
					fragmentName = "Draft Form Fragment Name",
					fragmentType = "Form Fragment",
					supportedFieldTypes = "Text");
			}

			task ("Navigate to the configuration page via ellipsis button on control menu") {
				FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = ${siteURLKey});

				FragmentsAdminNavigator.gotoCollection(collectionName = "Fragment Set Name");

				FragmentsAdminNavigator.gotoEntryEllipsisItem(
					entry = "Draft Form Fragment Name",
					item = "Edit");

				FragmentsEditor.gotoConfigurationTab();
			}

			task ("View the link Define the default form fragments for this site not shown") {
				AssertElementNotPresent(
					key_text = "Define the default form fragments for this site.",
					locator1 = "Link#ANY");
			}
		}
	}

}