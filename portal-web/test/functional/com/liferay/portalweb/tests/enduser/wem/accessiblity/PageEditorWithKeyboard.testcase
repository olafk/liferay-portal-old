			KeyPress(
				key_text = "Save",
				locator1 = "Modal#MODAL_FOOTER_BUTTON",
				value1 = "\ENTER");

			Alert.viewSuccessMessage();

			AssertVisible(
				key_rule = "Test Page RuleIfUserIs the UsertestHideFragmentButton",
				key_ruleName = "Test Page Rule",
				locator1 = "PageEditor#PAGE_RULE_LIST_ITEM");
		}

		task ("When the page designer focuses on the ellipsis button of page rule via keyboard") {
			KeyPress(
				key_text = "New Rule",
				locator1 = "Button#ANY",
