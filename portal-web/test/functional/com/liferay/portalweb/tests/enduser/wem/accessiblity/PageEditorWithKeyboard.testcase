				value1 = "No Rules Yet");

			AssertTextEquals(
				locator1 = "Message#EMPTY_STATE_TEXT",
				value1 = "Fortunately, it is very easy to add new ones.");
		}
	}

	@description = "This is a test for LPS-196461. The Section “Page rules“is accessible via Keyboard and also everything inside that tab."
	@priority = 3
	test OpenPageRulesPanelViaKeyboard {
		property custom.properties = "feature.flag.LPS-169837=true";

		task ("Given a page designer has a content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");
		}

		task ("When the page designer navigates to the page editor") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});
		}

		task ("Then the page designer could open the Page Rules panel via keyboard") {
			KeyPress(
				key_text = "format",
				locator1 = "Icon#ANY",
				value1 = "\DOWN");

			AssertVisible(
				key_content = "Page Rules",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");

			KeyPress(
				key_text = "rules",
				locator1 = "Icon#ANY",
				value1 = "\ENTER");

			AssertTextEquals(
				locator1 = "Message#EMPTY_STATE_INFO",
				value1 = "No Rules Yet");

			AssertTextEquals(
				locator1 = "Message#EMPTY_STATE_TEXT",
				value1 = "Fortunately, it is very easy to add new ones.");

			AssertVisible(
				key_text = "New Rule",
				locator1 = "Button#ANY");

			KeyPress(
				key_text = "rules",
				locator1 = "Icon#ANY",
				value1 = "\TAB");

			AssertElementFocused(
				key_text = "times",
				locator1 = "Icon#ANY");

			KeyPress(
				key_text = "times",
				locator1 = "Icon#ANY",
				value1 = "\ENTER");

			AssertElementNotPresent(locator1 = "Sidebar#PANEL_OPEN");
		}
	}

	@description = "This is a test for LPS-195025. Using Keyboard navigation is possible to click on the new added Preview button. The screen reader should announce Preview Success/Error Notification for Preview button."
	@priority = 3
	test PreviewNotification {
		property custom.properties = "feature.flag.LPS-187846=true";

		task ("Given a page creator has a content page with a Button fragment mapped to a standalone action") {
			for (var objectName : list "Question,Student") {
				ObjectAdmin.addObjectViaAPI(
					labelName = ${objectName},
					objectName = ${objectName},
					pluralLabelName = "${objectName}s");

				ObjectAdmin.addObjectFieldViaAPI(
					fieldBusinessType = "Text",
					fieldLabelName = "Name",
					fieldName = "name",
					fieldType = "String",
					isRequired = "false",
					objectName = ${objectName});

				ObjectAdmin.publishObjectViaAPI(objectName = ${objectName});
			}

			ObjectAdmin.openObjectAdmin();

			ObjectPortlet.selectCustomObject(label = "Student");

			ObjectAdmin.goToActionsTab();

			ObjectAdmin.addObjectActionViaUI(
				actionLabel = "Submit",
				active = "true",
				errorMessage = "You don't have permissions.",
				fieldName = "Name",
				inputExpressionValue = "name",
				inputMethod = "false",
				objectLabel = "Question",
				thenAction = "Add an Object Entry",
				whenAction = "Standalone");

			var objectEntryId = ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "name",
				objectName = "Student",
				value = "Jack");

			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			PageEditorAction.gotoEditableFieldAction(
				className = "btn",
				fragmentName = "Button",
				id = "action");

			PageEditorMapping.mapEditableFieldToAsset(
				entryTitle = ${objectEntryId},
				navItem = "Students",
				rowItem = "//*[@data-qa-id='row'][contains(.,'${objectEntryId}')]");
		}

		task ("When the page creator enables notification") {
			PageEditor.configureFragment(
				action = "Submit",
				errorInteraction = "Show Notification",
				errorText = "You don't have permissions.",
				successInteraction = "Show Notification",
				successText = "We are glad to receive your Form!");
		}

		task ("Then the page creator could preview notification via keyboard") {
			KeyPress(
				key_text = "Success Text",
				locator1 = "TextInput#ANY",
				value1 = "\TAB");

			KeyPress(
				ariaLabel = "Preview Success Notification",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\ENTER");

			Alert.viewSuccessMessageText(successMessage = "We are glad to receive your Form!");

			KeyPress(
				key_text = "Error Text",
				locator1 = "TextInput#ANY",
				value1 = "\TAB");

			KeyPress(
				ariaLabel = "Preview Error Notification",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\ENTER");

			Alert.viewErrorMessage(errorMessage = "You don't have permissions.");
		}
	}

	@description = "This is a test for LPS-165776. The page creator could reorder fragments on page editor via Browser panel with keyboard."
	@priority = 5
	test ReorderElements {
		property portal.acceptance = "true";

		task ("Given a page creator has fragments on content page") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Layout Elements",
				fragmentName = "Container");

			PageEditor.addElementToContainer(
				collectionName = "Basic Components",
				fragmentName = "Image",
				navTab = "Fragments");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading",
				targetFragmentName = "Container");

			PageEditor.addWidget(
				portletName = "Documents and Media",
				targetFragmentName = "Heading");
		}

		task ("When the page creator accesses to the Browser panel") {
			PageEditor.gotoTab(tabName = "Browser");
		}

		task ("Then the page creator could reorder elements via keyboard") {
			PageEditor.reorderElementViaKeyboard(
				elementName = "Documents and Media",
				upCount = 4);

			AssertElementPresent(
				key_elementHeader = "//div[@aria-label='Documents and Media']",
				key_elementType = "Container",
				key_position = 1,
				locator1 = "PageEditor#CONTAINER_CONTAINER_NESTED_ELEMENT");

			PageEditor.viewFragmentOrder(
				fragmentName = "Container",
				position = 1);

			PageEditor.viewFragmentOrder(
				fragmentName = "Documents and Media",
				position = 2);

			PageEditor.viewFragmentOrder(
				fragmentName = "Image",
				position = 3);

			PageEditor.viewFragmentOrder(
				fragmentName = "Heading",
				position = 4);

			PageEditor.reorderElementViaKeyboard(
				downCount = 3,
				elementName = "Image");

			PageEditor.viewFragmentOrder(
				fragmentName = "Container",
				position = 1);

			PageEditor.viewFragmentOrder(
				fragmentName = "Documents and Media",
				position = 2);

			PageEditor.viewFragmentOrder(
				fragmentName = "Heading",
				position = 3);

			PageEditor.viewFragmentOrder(
				fragmentName = "Image",
				position = 4);
		}
	}

	@description = "This is a test for LPS-195827. Via keyboard navigation, it is possible to select redirect to Display Page Template as a successful object action."
	@priority = 3
	test SelectGoToEntryDisplayPageAsSuccessInteractionViaKeyboard {
		task ("Given a page creator has a standalone action") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Student",
				objectName = "Student",
				pluralLabelName = "Students");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Text",
				fieldLabelName = "Name",
				fieldName = "name",
				fieldType = "String",
				isRequired = "false",
				objectName = "Student");

			ObjectAdmin.publishObjectViaAPI(objectName = "Student");

			ObjectAdmin.addObjectViaAPI(
				labelName = "Teacher",
				objectName = "Teacher",
				pluralLabelName = "Teachers");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Text",
				fieldLabelName = "Subject",
				fieldName = "subject",
				fieldType = "String",
				isRequired = "false",
				objectName = "Teacher");

			ObjectAdmin.publishObjectViaAPI(objectName = "Teacher");

			ObjectAdmin.openObjectAdmin();

			ObjectPortlet.selectCustomObject(label = "Student");

			ObjectAdmin.goToActionsTab();

			ObjectAdmin.addObjectActionViaUI(
				actionLabel = "Vote",
				active = "true",
				errorMessage = "You don't have permissions.",
				fieldName = "Subject",
				inputExpressionValue = "name",
				inputMethod = "false",
				objectLabel = "Teacher",
				thenAction = "Add an Object Entry",
				whenAction = "Standalone");

			var objectEntryId = ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "name",
				objectName = "Student",
				value = "Jack");

			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = ${siteURLKey});

			DisplayPageTemplatesAdmin.addDisplayPage(
				contentType = "Student",
				displayPageName = "Display Page Name");

			PageEditor.addFragment(
				collectionName = "Form Components",
				fragmentName = "Form Container");

			PageEditor.mapFormContainerToObject(contentType = "Student (Default)");

			PageEditor.publish();
		}

		task ("When the page creator maps the standalone action to Button fragment") {
			JSONLayout.addPublicLayout(
				groupName = ${randomSiteName},
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			PageEditorAction.gotoEditableFieldAction(
				className = "btn",
				fragmentName = "Button",
				id = "action");
		}

		task ("Then the page creator could select the Go to Entry Display Page as success interaction via keyboard") {
			PageEditorMapping.mapEditableFieldToAsset(
				entryTitle = ${objectEntryId},
				navItem = "Students",
				rowItem = "//*[@data-qa-id='row'][contains(.,'${objectEntryId}')]");

			PageEditor.configureFragment(action = "Vote");

			KeyPress(
				key_fieldLabel = "Action",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\TAB");

			KeyPress(
				key_fieldLabel = "Success Interaction",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\ENTER");

			KeyPress(
				key_fieldLabel = "Success Interaction",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\DOWN");

			KeyPress(
				key_fieldLabel = "Success Interaction",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\DOWN");

			KeyPress(
				key_fieldLabel = "Success Interaction",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\DOWN");

			KeyPress(
				key_fieldLabel = "Success Interaction",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\DOWN");

			KeyPress(
				key_fieldLabel = "Success Interaction",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\ENTER");

			PageEditor.waitForAutoSave();

			KeyPress(
				key_fieldLabel = "Success Interaction",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\TAB");

			KeyPress(
				key_fieldLabel = "Display Page",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\ENTER");

			KeyPress(
				key_fieldLabel = "Display Page",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\DOWN");

			KeyPress(
				key_fieldLabel = "Display Page",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\DOWN");

			KeyPress(
				key_fieldLabel = "Display Page",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "\ENTER");

			PageEditor.waitForAutoSave();

			PageEditor.publish();
		}

		task ("When the page creator triggers the standalone action") {
			Button.click(button = "Go Somewhere");

			Alert.viewSuccessMessage();
		}

		task ("Then the page creator should be redirected to entry display page") {
			ControlMenu.viewHeaderTitle(headerTitle = ${objectEntryId});

			InputField.viewText(
				fieldLabel = "Name",
				text = "Jack");
		}
	}

}