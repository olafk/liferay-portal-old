			KeyPress(
				index = 3,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_CONDITION_ITEM",
				value1 = "\ENTER");

			KeyPress(
				index = 3,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_CONDITION_ITEM",
				value1 = "\ENTER");

			KeyPress(
				index = 1,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION",
				value1 = "\TAB");

			KeyPress(
				index = 1,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION_ITEM",
				value1 = "\ENTER");

			KeyPress(
				index = 1,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION_ITEM",
				value1 = "\DOWN");

			KeyPress(
				index = 1,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION_ITEM",
				value1 = "\ENTER");

			KeyPress(
				index = 1,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION_ITEM",
				value1 = "\TAB");

			KeyPress(
				index = 2,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION_ITEM",
				value1 = "\ENTER");

			KeyPress(
				index = 2,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION_ITEM",
				value1 = "\ENTER");

			KeyPress(
				index = 2,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION_ITEM",
				value1 = "\TAB");

			KeyPress(
				index = 3,
				locator1 = "PageEditor#PAGE_RULE_BUILDER_ACTION_ITEM",
				value1 = "\ENTER");

			KeyPress(
