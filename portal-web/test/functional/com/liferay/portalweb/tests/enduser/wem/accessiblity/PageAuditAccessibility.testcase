@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Page Audit";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-191827. Check the accessibility when warning message displays in a Collection Display with configuration can cause performance issues in page audit."
	@priority = 3
	test ViewAccessibilityOfCollectionDisplayPagePerformanceWarningMessageOnPageAudit {
		property custom.properties = "feature.flag.LPS-187284=true${line.separator}feature.flag.LPS-187285=true";

		task ("Given a user has a Collection Display with None pagination and Display All Collection Items on a content page") {
			AssetListsAdmin.openAssetListsAdmin(siteURLKey = "test-site-name");

			AssetListsAdmin.addDynamicSelection(assetListTitle = "Dynamic Collection");

			AssetListsAdmin.configureItemTypeInDynamicCollection(itemType = "All Types");

			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Collection Display");

			PageEditor.editCollectionDisplay(
				assetListName = "Dynamic Collection",
				displayAllCollectionItems = "true",
				fragmentName = "Collection Display",
				pagination = "None");

			PageEditor.publish();
		}

		task ("When the user navigates to the Performance tab of page audit") {
			PageAudit.openPageAuditSidebar();

			PageAudit.goToElementDetails(elementName = "Collection Display");
		}

		task ("Then the warning message should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[contains(@class,'panel-unstyled')][.//div[contains(@class,'panel-title')][normalize-space()='Warnings']]//ul");
		}
	}

}