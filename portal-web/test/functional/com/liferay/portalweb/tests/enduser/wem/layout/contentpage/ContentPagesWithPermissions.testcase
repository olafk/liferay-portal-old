	@description = "This is a test for LPS-137155. The page creator can change permissions of content page via header ellipsis icon at edit mode."
	@priority = 3
	test RemoveViewPermissionForGuestViaHeaderEllipsisIcon {
		task ("Given a page designer has content page") {
			PagesAdmin.openPagesAdmin(siteURLKey = ${siteURLKey});

			PagesAdmin.viewPageItemPresent(pageName = "Test Content Page Name");
		}

		task ("When the page designer removes view permission of guest role via header ellipsis icon at edit mode") {
			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Content Page Name",
				siteName = ${randomSiteName});

			LexiconEntry.gotoHeaderMenuItem(menuItem = "Permissions");

			PermissionsInline.addOrRemoveAnyPermissionsFromSpecificRole(
				addOrRemoveViewPermission = "Remove",
				permissionsKeyList = "INLINE_PERMISSIONS_VIEW_CHECKBOX",
				roleTitle = "guest");

			IFrame.closeFrame();

			PageEditor.publish();
		}

		task ("Then a guest user cannot access to the content page") {
			User.logoutPG();

			ContentPagesNavigator.openViewContentPage(
				pageName = "Test Content Page Name",
				siteName = ${randomSiteName});

			ContentPages.viewFragmentText(
				fragmentName = "heading",
				id = "element-text",
				text = 404);
		}
	}

	@description = "This is a test for LPS-173440. The user without View permission for object should see alert message on mapped Collection Display or Content Display at edit mode."
	@priority = 4
	test ViewAlertOnMappedCollectionDisplayOrContentDisplayWithoutViewPermissionForObjectAtEditMode {
		var labelName = StringUtil.randomString(8);

		var objectName = "A${labelName}";
		var randomRoleKey = StringUtil.randomString(8);

		var randomRoleKey = StringUtil.toLowerCase(${randomRoleKey});

		task ("Given a site object with 2 object entries") {
			task ("Add a site object with a Text field") {
				ObjectAdmin.addObjectViaAPI(
					labelName = ${labelName},
					objectName = ${objectName},
					panelCategoryKey = "site_administration.content",
					pluralLabelName = "${labelName}s",
					scope = "site");

				ObjectAdmin.addObjectFieldViaAPI(
					fieldBusinessType = "Text",
					fieldLabelName = "Name",
					fieldName = "name",
					fieldType = "String",
					isRequired = "false",
					objectName = ${objectName});

				ObjectAdmin.publishObjectViaAPI(objectName = ${objectName});
			}

			task ("Create two object entries") {
				var objectEntryId = JSONObject.addObjectEntryViaJSONAPI(
					fieldName = "name",
					fieldValue = "Apple",
					groupName = ${randomSiteName},
					objectName = ${objectName},
					scope = "site");

				JSONObject.addObjectEntryViaJSONAPI(
					fieldName = "name",
					fieldValue = "Banana",
					groupName = ${randomSiteName},
					objectName = ${objectName},
					scope = "site");
			}
		}

		task ("When not define view permission for object") {
			task ("Add a new regular role") {
				JSONRole.addRegularRole(
					roleKey = ${randomRoleKey},
					roleTitle = ${randomRoleKey});
			}

			task ("Define the permissions of regular role") {
				Permissions.definePermissionsViaJSONAPI(
					resourceNameActionList = "com.liferay.portal.kernel.model.Layout,UPDATE,VIEW",
					roleTitle = ${randomRoleKey},
					roleType = "regular");
			}

			task ("Assign the regular role to new user") {
				JSONRole.assignRoleToUser(
					roleTitle = ${randomRoleKey},
					userEmailAddress = StringUtil.toLowerCase("${randomUserEmailAddress}@liferay.com"));
			}

			task ("Add a dynamic collection for site object") {
				AssetListsAdmin.openAssetListsAdmin(siteURLKey = ${randomSiteName});

				AssetListsAdmin.addDynamicSelection(assetListTitle = "Dynamic Collection");

				AssetListsAdmin.configureItemTypeInDynamicCollection(itemType = ${labelName});
			}

			task ("Remove the View permission for Guest and Site Member") {
				AssetListsAdmin.openAssetListsAdmin(siteURLKey = ${randomSiteName});

				LexiconEntry.gotoEntryMenuItem(
					menuItem = "Permissions",
					rowEntry = "Dynamic Collection");

				Role.removePermissionPG(
					permissionDefinitionKey = "CONTENT_PERMISSIONS_VIEW_CHECKBOX",
					roleTitle = "Guest");

				Role.removePermissionPG(
					permissionDefinitionKey = "CONTENT_PERMISSIONS_VIEW_CHECKBOX",
					roleTitle = "Site Member");
			}
		}

		task ("Then user can see alert message on mapped Collection Display or Content Display at edit mode") {
			task ("Add a second content page") {
				JSONLayout.addPublicLayout(
					groupName = ${randomSiteName},
					layoutName = "Test Content Page Name 2",
					type = "content");
			}

			task ("Add a third content page") {
				JSONLayout.addPublicLayout(
					groupName = ${randomSiteName},
					layoutName = "Test Content Page Name 3",
					type = "content");
			}

			task ("Add a Collection Display to the first content page") {
				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Content Page Name",
					siteName = ${randomSiteName});

				PageEditor.addFragment(
					collectionName = "Content Display",
					fragmentName = "Collection Display");
			}

			task ("Select the dynamic collection in Collection Display") {
				PageEditor.editCollectionDisplay(
					assetListName = "Dynamic Collection",
					fragmentName = "Collection Display");
			}

			task ("Add a Heading fragment to the first cell") {
				PageEditor.addFragmentToCollectionDisplay(
					collectionName = "Basic Components",
					entryTitle = "",
					fragmentName = "Heading");
			}

			task ("Map the Text field to Heading fragment") {
				PageEditorMapping.mapEditableFieldToCollectionItems(
					field = "Name",
					fragmentName = "Heading",
					id = "element-text");

				PageEditor.publish();
			}

			task ("Add a Content Display to the second content page") {
				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Content Page Name 2",
					siteName = ${randomSiteName});

				PageEditor.addFragment(
					collectionName = "Content Display",
					fragmentName = "Content Display");
			}

			task ("Select one object entry in Content Display") {
				PageEditor.editContentDisplay(
					entryContent = "Apple",
					fragmentName = "Content Display",
					object = "${labelName}s",
					objectEntryId = ${objectEntryId});

				PageEditor.publish();
			}

			task ("Add a Collection Display to the third content page") {
				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Content Page Name 3",
					siteName = ${randomSiteName});

				PageEditor.addFragment(
					collectionName = "Content Display",
					fragmentName = "Collection Display");
			}

			task ("Select the dynamic collection in Collection Display") {
				PageEditor.editCollectionDisplay(
					assetListName = "Dynamic Collection",
					fragmentName = "Collection Display");
			}

			task ("Add a Heading fragment to the first cell") {
				PageEditor.addFragmentToCollectionDisplay(
					collectionName = "Basic Components",
					entryTitle = "",
					fragmentName = "Heading");

				PageEditor.publish();
			}

			task ("Sign in as new user") {
				User.logoutAndLoginPG(userLoginEmailAddress = StringUtil.toLowerCase("${randomUserEmailAddress}@liferay.com"));
			}

			task ("Navigate to the first content page at edit mode") {
				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Content Page Name",
					siteName = ${randomSiteName});
			}

			task ("View the alert message shown on Collection Display") {
				AssertVisible(
					key_alertInfo = "This content cannot be displayed due to permission restrictions.",
					key_fragmentName = "Collection Display",
					locator1 = "Fragment#ALERT_INFO");
			}

			task ("View the password-policies icon shown before the text") {
				AssertVisible(
					key_text = "password-policies",
					locator1 = "Icon#ANY");
			}

			task ("View the alert message shown on General panel") {
				PageEditor.gotoConfiguration(fragmentName = "Collection Display");

				AssertTextEquals.assertPartialText(
					locator1 = "PageEditor#ITEM_CONFIGURATION_SIDEBAR",
					value1 = "This content cannot be displayed due to permission restrictions.");
			}

			task ("View the collapsed node of Collection Display is not shown on Browser panel") {
				takeScreenshot();

				AssertElementNotPresent(
					key_text = "hr",
					locator1 = "Icon#ANY");
			}

			task ("View the password-policies icon shown on Collection Display node") {
				AssertVisible(
					key_indexNumber = 2,
					key_text = "password-policies",
					locator1 = "Icon#ANY_N");
			}

			task ("View Restricted Content is shown on Page Content panel") {
				PageEditor.gotoTab(tabName = "Page Content");

				AssertVisible(
					key_itemName = "Restricted Content",
					locator1 = "PageEditor#PAGE_CONTENTS_ITEM");
			}

			task ("View the password-policies icon shown before the Restricted Content") {
				AssertVisible(
					key_indexNumber = 2,
					key_text = "password-policies",
					locator1 = "Icon#ANY_N");
			}

			task ("View the user can delete the Collection Display") {
				PageEditor.removeFragment(fragmentName = "Collection Display");
			}

			task ("View the success message shown when click the publish button") {
				PageEditor.publish();
			}

			task ("Navigate to the second content page at edit mode") {
				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Content Page Name 2",
					siteName = ${randomSiteName});
			}

			task ("View the alert message shown on Content Display") {
				AssertVisible(
					key_alertInfo = "This content cannot be displayed due to permission restrictions.",
					key_fragmentName = "Content Display",
					locator1 = "Fragment#ALERT_INFO");
			}

			task ("View the password-policies icon shown before the text") {
				AssertVisible(
					key_text = "password-policies",
					locator1 = "Icon#ANY");
			}

			task ("View the alert message shown on General panel") {
				PageEditor.gotoConfiguration(fragmentName = "Content Display");

				AssertTextEquals.assertPartialText(
					locator1 = "PageEditor#ITEM_CONFIGURATION_SIDEBAR",
					value1 = "This content cannot be displayed due to permission restrictions.");
			}

			task ("View the password-policies icon shown on Content Display node on Browser panel") {
				AssertVisible(
					key_indexNumber = 2,
					key_text = "password-policies",
					locator1 = "Icon#ANY_N");
			}

			task ("View Restricted Content is shown on Page Content panel") {
				PageEditor.gotoTab(tabName = "Page Content");

				AssertVisible(
					key_itemName = "Restricted Content",
					locator1 = "PageEditor#PAGE_CONTENTS_ITEM");
			}

			task ("View the user can delete the Content Display") {
				PageEditor.removeFragment(fragmentName = "Content Display");
			}

			task ("View the success message shown when click the publish button") {
				PageEditor.publish();
			}

			task ("Navigate to the third content page at edit mode") {
				ContentPagesNavigator.openEditContentPage(
					pageName = "Test Content Page Name 3",
					siteName = ${randomSiteName});
			}

			task ("View the alert message shown on Collection Display") {
				AssertVisible(
					key_alertInfo = "This content cannot be displayed due to permission restrictions.",
					key_fragmentName = "Collection Display",
					locator1 = "Fragment#ALERT_INFO");
			}

			task ("View the Inline Text section is not shown in Page Content panel") {
				AssertElementNotPresent(
					key_panel = "Inline Text",
					locator1 = "Panel#PANEL");
			}
		}
	}

	@description = "This is a test for LPS-165556. The page creator without trigger permission could see the available actions in Action selector."
	@priority = 4
	test ViewAvailableActionsInActionSelectorAsUserWithoutTriggerPermission {
		var labelName = StringUtil.randomString(8);

		var objectName = "A${labelName}";
		var randomRoleKey = StringUtil.randomString(8);

		var randomRoleKey = StringUtil.toLowerCase(${randomRoleKey});

		task ("Given a page creator without trigger permission has a content page with a Button fragment") {
			for (var i : list "1,2") {
				ObjectAdmin.addObjectViaAPI(
					labelName = "${labelName}${i}",
					objectName = "${objectName}${i}",
					pluralLabelName = "${labelName}${i}s");

				ObjectAdmin.addObjectFieldViaAPI(
					fieldBusinessType = "Text",
					fieldLabelName = "Name",
					fieldName = "name",
					fieldType = "String",
					isRequired = "false",
					objectName = "${objectName}${i}");

				ObjectAdmin.publishObjectViaAPI(objectName = "${objectName}${i}");
			}

			ObjectAdmin.openObjectAdmin();

			ObjectPortlet.selectCustomObject(label = "${labelName}2");

			ObjectAdmin.goToActionsTab();

			ObjectAdmin.addObjectActionViaUI(
				actionLabel = "Vote",
				active = "true",
				errorMessage = "You don't have permissions.",
				fieldName = "Name",
				inputExpressionValue = "name",
				inputMethod = "false",
				objectLabel = "${labelName}1",
				thenAction = "Add an Object Entry",
				whenAction = "Standalone");

			JSONRole.addRegularRole(
				roleKey = ${randomRoleKey},
				roleTitle = ${randomRoleKey});

			var objectDefinitionId = JSONObject.getObjectId(objectName = "${objectName}2");
			var objectEntryId = ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "name",
				objectName = "${objectName}2",
				value = "Liferay");
			var objectDefinitionClassName = ObjectDefinitionAPI._getObjectDefinitionClassNameById(objectDefinitionId = ${objectDefinitionId});
			var objectDefinitionPortletId = ObjectDefinitionAPI._getObjectDefinitionPortletId(objectDefinitionId = ${objectDefinitionId});

			Permissions.definePermissionsViaJSONAPI(
				resourceNameActionList = "com.liferay.portal.kernel.model.Layout,UPDATE:${objectDefinitionPortletId},VIEW:${objectDefinitionClassName},VIEW",
				roleTitle = ${randomRoleKey},
				roleType = "regular");

			JSONRole.assignRoleToUser(
				roleTitle = ${randomRoleKey},
				userEmailAddress = StringUtil.toLowerCase("${randomUserEmailAddress}@liferay.com"));

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			PageEditor.publish();
		}

		task ("When the page creator navigates to the Action panel of Button fragment") {
			User.logoutAndLoginPG(userLoginEmailAddress = StringUtil.toLowerCase("${randomUserEmailAddress}@liferay.com"));

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = ${randomSiteName});

			PageEditorAction.gotoEditableFieldAction(
				className = "btn",
				fragmentName = "Button",
				id = "action");
		}

		task ("Then the page creator could see available standalone actions in Action selector") {
			Click(
				key_fieldLabel = "Item",
				key_text = "plus",
				locator1 = "Icon#ANY_ITEM_SELECTOR");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			Click(
				key_listEntry = ${objectEntryId},
				locator1 = "LexiconList#LIST_ENTRY");

			SelectFrameTop();

			AssertTextEquals(
				key_fieldLabel = "Item",
				locator1 = "PageEditor#ITEM_SELECTOR_CONTENT_INPUT",
				value1 = ${objectEntryId});

			AssertElementPresent(
				key_fieldLabel = "Action",
				key_value = "Vote",
				locator1 = "Select#GENERIC_SELECT_VALUE");
		}
	}

}