@component-name = "portal-page-management"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Display Page Templates";

	setUp {
		task ("Set up instance and sign in") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();
		}

		task ("Add a site via JSON") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Add a display page") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.addDisplayPage(
				contentType = "Web Content Article",
				displayPageName = "Display Page Name",
				subType = "Basic Web Content");
		}
	}

	@description = "This is a use case for LPS-129360 and LPS-106776. The user could change the display style of Documents and Media in display page template."
	@priority = 4
	test ChangeDisplayStyleOfDocumentsAndMediaInDisplayPageTemplate {
		task ("Add a Documents and Media widget to the display page template") {
			PageEditor.addWidget(portletName = "Documents and Media");

			PageEditor.publish();
		}

		task ("Mark the display page template as default") {
			DisplayPageTemplatesAdmin.markDisplayPageAsDefault(displayPageName = "Display Page Name");
		}

		task ("Add a document entry") {
			JSONDocument.addFileWithUploadedFile(
				dmDocumentTitle = "Document Title",
				groupName = "Test Site Name",
				mimeType = "image/jpeg",
				sourceFileName = "Document_4.jpg");
		}

		task ("Add a web content") {
			JSONWebcontent.addWebContent(
				content = "Webcontent Content",
				groupName = "Test Site Name",
				title = "Webcontent Title");
		}

		task ("Navigate to display page template at view mode") {
			WebContentNavigator.openWebContentAdmin(siteURLKey = "test-site-name");

			WebContentNavigator.gotoEntryMenuItem(
				entry = "Webcontent Title",
				menuItem = "View Content");
		}

		task ("View the document entry displayed as Cards style") {
			DMDocument.viewCardTitle(dmDocumentTitle = "Document Title");

			LexiconEntry.viewActiveDisplayStyle(displayStyle = "cards");
		}

		task ("Change to List display style") {
			LexiconEntry.changeDisplayStyle(displayStyle = "list");
		}

		task ("View the document entry displayed as List style") {
			LexiconList.viewListEntryTitle(listEntry = "Document Title");

			LexiconEntry.viewActiveDisplayStyle(displayStyle = "list");
		}
	}

	@description = "This is a test for LPS-193213. It is possible to access the configuration of an existing Display Page Template from the ellipsis menu of the card."
	@priority = 4
	test ConfigureDisplayPageTemplateInPageTemplatesAdmin {
		task ("Given a user has a display page template") {
			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");

			PageEditor.publish();
		}

		task ("When the user accesses to the Page Templates admin") {
			DisplayPageTemplatesAdmin.viewDisplayPagePresent(displayPageName = "Display Page Name");
		}

		task ("Then the user could configure display page template") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Configure");

			Navigator.gotoNavTab(navTab = "Design");

			Theme.configureLookAndFeelSpecificLook();

			Theme.changeCurrentTheme(themeName = "Speedwell");

			PortletEntry.save();

			Navigator.gotoBack();

			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name");

			AssertCssValue(
				fragmentName = "heading",
				id = "element-text",
				index = 1,
				locator1 = "Fragment#CONTRIBUTED_FRAGMENT_TEXT",
				locator2 = "font-size",
				value1 = "40px");

			LexiconEntry.gotoHeaderMenuItem(menuItem = "Configure");

			SelectWindow.selectPopUp(value1 = "null");

			Navigator.gotoNavTab(navTab = "Design Draft");

			PagesAdmin.viewCurrentTheme(themeName = "Speedwell");
		}
	}

	@description = "This is a test for LPS-191986. Can configure friendly URL for default display page template."
	@priority = 3
	test ConfigureFriendlyURLOfDefaultDisplayPageTemplate {
		task ("Given a user has a default display page template") {
			PageEditor.publish();

			DisplayPageTemplatesAdmin.markDisplayPageAsDefault(displayPageName = "Display Page Name");
		}

		task ("When the user accesses to the configuration page of display page template") {
			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name");

			LexiconEntry.gotoHeaderMenuItem(menuItem = "Configure");
		}

		task ("Then the user could configure the friendly URL of display page template") {
			Navigator.viewActivatedNavTab(navTab = "General");

			AssertTextEquals(
				key_text = "Friendly URL",
				locator1 = "TextInput#ANY",
				value1 = "/display-page-name");

			PagesAdmin.editFriendlyURL(friendlyURLEdit = "/welcome");

			AssertTextEquals(
				key_text = "Friendly URL",
				locator1 = "TextInput#ANY",
				value1 = "/welcome");
		}

		task ("When the user accesses to the SEO sheet") {
			Navigator.gotoNavTab(navTab = "SEO");
		}

		task ("Then the user could configure the Robots and Sitemap settings") {
			AssertEditable(
				key_label = "Robots",
				locator1 = "TextArea#ANY_LABELED");

			AssertAttributeValue(
				key_label = "Robots",
				locator1 = "TextArea#ANY_LABELED",
				value1 = "placeholder",
				value2 = "Robots");

			AssertEditable(
				key_fieldLabel = "Include",
				locator1 = "Select#GENERIC_SELECT_FIELD");

			AssertSelectedLabel(
				key_fieldLabel = "Include",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Yes");

			AssertEditable(
				key_text = "Page Priority",
				locator1 = "TextInput#ANY");

			AssertAttributeValue(
				key_text = "Page Priority",
				locator1 = "TextInput#ANY",
				value1 = "placeholder",
				value2 = "0.0");

			AssertEditable(
				key_fieldLabel = "Change Frequency",
				locator1 = "Select#GENERIC_SELECT_FIELD");

			AssertSelectedLabel(
				key_fieldLabel = "Change Frequency",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Daily");
		}
	}

	@description = "This is a test for LPS-86191. Configure the theme of display page template."
	@priority = 4
	@uitest
	test ConfigureTheme {
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";

		task ("Publish the display page template") {
			PageEditor.publish();
		}

		task ("Import a theme") {
			AppManager.openAppManagerAdmin();

			AppManager.uploadApp(
				appName = "test-theme",
				warFileName = "test-theme.war");
		}

		task ("Add a web content") {
			JSONWebcontent.addWebContent(
				content = "Webcontent Content",
				groupName = "Test Site Name",
				title = "Webcontent Title");
		}

		task ("Select the display page template in web content") {
			WebContentNavigator.openWebContentAdmin(siteURLKey = "test-site-name");

			WebContentNavigator.gotoEditCP(webContentTitle = "Webcontent Title");

			WebContent.editDisplayPage(
				pageName = "Display Page Name",
				pageType = "Display Page Templates");

			PortletEntry.publish();
		}

		task ("Navigate to the display page template at view mode") {
			Navigator.openWithAppendToBaseURL(urlAppend = "web/test-site-name/w/webcontent-title");
		}

		task ("View the Classic theme is shown") {
			AssertElementPresent(locator1 = "//link[contains(@href,'classic-theme')]");

			AssertElementNotPresent(locator1 = "//link[contains(@href,'test-theme')]");
		}

		task ("Change the theme from Classic to Fjord") {
			DisplayPageTemplate.clickPencilItem(item = "Edit Display Page Template");

			PageEditor.gotoTab(tabName = "Page Design Options");

			Click(locator1 = "PageEditor#MORE_LINK");

			Theme.configureLookAndFeelSpecificLook();

			Theme.changeCurrentTheme(themeName = "test-theme-7-4");

			PortletEntry.save();

			Navigator.gotoBack();

			PageEditor.assertFragmentSidebarLoaded();

			PageEditor.publish();
		}

		task ("View the Fjord theme is shown") {
			AssertElementPresent(locator1 = "//link[contains(@href,'test-theme')]");

			AssertElementNotPresent(locator1 = "//link[contains(@href,'classic-theme')]");
		}
	}

	@description = "This is a test for LPS-192724. It is possible to copy an existing Display Page Template from the ellipsis menu of the card."
	@priority = 5
	test CopyDisplayPageTemplate {
		property portal.acceptance = "true";

		task ("When the page creator navigates to the Display Page Templates admin") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");
		}

		task ("Then the page creator cannot make a copy of display page template without published version") {
			Click.waitForMenuToggleJSClick(
				key_card = "Display Page Name",
				locator1 = "Card#SPECIFIC_CARD_ELLIPSIS");

			MenuItem.viewDisabled(menuItem = "Make a Copy");
		}

		task ("When the page creator publishes the display page template") {
			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name");

			PageEditor.publish();
		}

		task ("Then the page creator could make a copy of display page template") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Make a Copy");

			MenuItem.click(menuItem = "Display Page");

			Alert.viewSuccessMessage();

			DisplayPageTemplatesAdmin.viewDisplayPagePresent(displayPageName = "Display Page Name (Copy)");

			LexiconCard.viewCardSubtitle(
				card = "Display Page Name (Copy)",
				cardSubtitle = "Web Content Article - Basic Web Content");

			LexiconCard.viewCardLabel(
				card = "Display Page Name (Copy)",
				cardLabel = "Draft");
		}

		task ("When the page creator makes a copy of the original display page template again") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Make a Copy");

			MenuItem.click(menuItem = "Display Page");

			Alert.viewSuccessMessage();
		}

		task ("Then the copy name should have a sequential number 1") {
			DisplayPageTemplatesAdmin.viewDisplayPagePresent(displayPageName = "Display Page Name (Copy 1)");
		}

		task ("When the page creator makes a copy of the original display page template again") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Make a Copy");

			MenuItem.click(menuItem = "Display Page");

			Alert.viewSuccessMessage();
		}

		task ("Then the copy name should have a sequential number 2") {
			DisplayPageTemplatesAdmin.viewDisplayPagePresent(displayPageName = "Display Page Name (Copy 2)");
		}

		task ("When the page creator makes a copy of the first copy") {
			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name (Copy)");

			PageEditor.publish();

			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name (Copy)",
				item = "Make a Copy");

			MenuItem.click(menuItem = "Display Page");

			Alert.viewSuccessMessage();
		}

		task ("Then the (Copy) should be appended to copy name") {
			DisplayPageTemplatesAdmin.viewDisplayPagePresent(displayPageName = "Display Page Name (Copy) (Copy)");
		}
	}

	@description = "This is a test for LPS-192724. When copying a published DPT, the copy is the same as the published one. The copy of a DPT is the same as the last version."
	@priority = 4
	test CopyDisplayPageTemplateWithContent {
		task ("Given a page creator has a published display page template with content") {
			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");

			PageEditor.publish();
		}

		task ("When the page creator makes a copy of display page template") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Make a Copy");

			MenuItem.click(menuItem = "Display Page");

			Alert.viewSuccessMessage();
		}

		task ("Then the copy of display page template should keep the content") {
			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name (Copy)");

			PageEditor.viewFragment(fragmentName = "Heading");
		}

		task ("When the page creator makes a copy of original display page template with draft") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name");

			PageEditor.editFragmentText(
				fragmentName = "Heading",
				id = "element-text",
				text = "Welcome to Liferay");

			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Make a Copy");

			MenuItem.click(menuItem = "Display Page");

			Alert.viewSuccessMessage();
		}

		task ("Then the copy of display page template should keep the same content with last published version") {
			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name (Copy 1)");

			PageEditor.viewFragment(fragmentName = "Heading");
		}
	}

	@description = "This is a test for LPS-192724. The site administrator could copy a display page template with mapping."
	@priority = 4
	test CopyDisplayPageTemplateWithMapping {
		task ("Given a page creator has a published display page template with mapping") {
			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");

			PageEditorMapping.mapEditableTextToField(
				field = "Title",
				fragmentName = "Heading",
				id = "element-text");

			PageEditor.publish();
		}

		task ("When the page creator makes a copy of display page template") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Make a Copy");

			MenuItem.click(menuItem = "Display Page");

			Alert.viewSuccessMessage();
		}

		task ("Then the copy of display page template should keep the mapping") {
			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name (Copy)");

			PageEditorMapping.gotoEditableFieldMapping(
				fragmentName = "Heading",
				id = "element-text");

			AssertSelectedLabel(
				key_fieldLabel = "Field",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Title");
		}
	}

	@description = "This is a test for LPS-192724. The site administrator could copy a display page template with permissions."
	@priority = 4
	test CopyDisplayPageTemplateWithPermissions {
		task ("Given a page creator has a published display page template with permissions") {
			PageEditor.publish();

			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Permissions");

			PermissionsInline.addOrRemoveAnyPermissionsFromSpecificRole(
				addOrRemoveViewPermission = "Remove",
				permissionsKeyList = "CONFIGURATION_PERMISSIONS_VIEW_CHECKBOX",
				roleTitle = "Guest");

			IFrame.closeFrame();
		}

		task ("When the page creator makes a copy of display page template") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Make a Copy");

			MenuItem.click(menuItem = "Display Page With Permissions");

			Alert.viewSuccessMessage();
		}

		task ("Then the copy of display page template should keep the permissions") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name (Copy)",
				item = "Permissions");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			PermissionsInline.viewPermissionsRemoved(
				permissionDefinitionKey = "CONFIGURATION_PERMISSIONS_VIEW_CHECKBOX",
				roleTitle = "Guest");
		}
	}

	@description = "User can delete default display page template."
	@priority = 5
	@uitest
	test DeleteDefaultDisplayPageTemplate {
		property portal.acceptance = "true";

		task ("Publish the display page template") {
			PageEditor.publish();
		}

		task ("Mark the display page template as default") {
			DisplayPageTemplatesAdmin.markDisplayPageAsDefault(displayPageName = "Display Page Name");
		}

		task ("Add a web content") {
			JSONWebcontent.addWebContent(
				content = "Webcontent Content",
				groupName = "Test Site Name",
				title = "Webcontent Title");
		}

		task ("View the default page template is selected in web content") {
			WebContentNavigator.openWebContentAdmin(siteURLKey = "test-site-name");

			WebContentNavigator.gotoEditCP(webContentTitle = "Webcontent Title");

			WebContent.viewSelectedDisplayPageTemplateCP(
				displayPageTemplateName = "Display Page Name",
				displayPageTemplateType = "Default");
		}

		task ("Delete the default display page template") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.deleteDisplayPage(
				defaultDisplayPageTemplate = "true",
				displayPageName = "Display Page Name");

			Alert.viewSuccessMessageText(successMessage = "You successfully deleted 1 display page template(s).");
		}

		task ("View the default display page template not shown") {
			DisplayPageTemplatesAdmin.viewDisplayPageNotPresent(displayPageName = "Display Page Name");
		}
	}

	@description = "This is a test for LPS-86191 and LPS-96438. Disable Show Header and Show Footer of display page template."
	@priority = 4
	@uitest
	test DisableShowHeaderAndFooter {
		task ("Publish the display page template") {
			PageEditor.publish();
		}

		task ("Add two widget pages") {
			for (var n : list "1,2") {
				JSONLayout.addPublicLayout(
					groupName = "Test Site Name",
					layoutName = "Test Page ${n}");
			}
		}

		task ("Add a web content") {
			JSONWebcontent.addWebContent(
				content = "Webcontent Content",
				groupName = "Test Site Name",
				title = "Webcontent Title");
		}

		task ("Select the display page template in web content") {
			WebContentNavigator.openWebContentAdmin(siteURLKey = "test-site-name");

			WebContentNavigator.gotoEditCP(webContentTitle = "Webcontent Title");

			WebContent.editDisplayPage(
				pageName = "Display Page Name",
				pageType = "Display Page Templates");

			PortletEntry.publish();
		}

		task ("Navigate to the display page template at view mode") {
			Navigator.openWithAppendToBaseURL(urlAppend = "web/test-site-name/w/webcontent-title");
		}

		task ("View the site logo, search bar and navigation menu shown in header") {
			AssertVisible(locator1 = "Home#DEFAULT_LOGO");

			AssertVisible(
				key_infoMessage = "This search bar is not visible to users yet.",
				locator1 = "Message#INFO_SPECIFIC");

			for (var n : list "1,2") {
				AssertVisible(
					key_pageName = "Test Page ${n}",
					locator1 = "Home#PAGE");
			}
		}

		task ("View the footer is shown") {
			AssertVisible(locator1 = "Home#FOOTER");
		}

		task ("Disable show header and footer") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.gotoDisplayPage(displayPageName = "Display Page Name");

			PageEditor.gotoTab(tabName = "Page Design Options");

			Click(locator1 = "PageEditor#MORE_LINK");

			Theme.configureLookAndFeelSpecificLook();

			Theme.configureLookAndFeelShowFooter(showFooter = "false");

			Theme.configureLookAndFeelShowHeader(showHeader = "false");

			PortletEntry.save();

			Navigator.gotoBack();

			PageEditor.assertFragmentSidebarLoaded();

			PageEditor.publish();
		}

		task ("Navigate to the display page template at view mode") {
			Navigator.openWithAppendToBaseURL(urlAppend = "web/test-site-name/w/webcontent-title");
		}

		task ("View the header is not shown") {
			AssertElementNotPresent(locator1 = "Home#DEFAULT_LOGO");

			AssertElementNotPresent(
				key_infoMessage = "This search bar is not visible to users yet.",
				locator1 = "Message#INFO_SPECIFIC");

			for (var n : list "1,2") {
				AssertElementNotPresent(
					key_pageName = "Test Page ${n}",
					locator1 = "Home#PAGE");
			}
		}

		task ("View the footer is not shown") {
			AssertElementNotPresent(locator1 = "Home#FOOTER");
		}
	}

	@description = "This is a use case for LPS-106776. User can edit a display page. This includes adding and removing fragments and includes editing text in fragment editable fields."
	@priority = 5
	@uitest
	test EditDisplayPageTemplate {
		property portal.acceptance = "true";

		task ("Add a Heading, Button, and Paragraph fragments to display page template") {
			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button",
				targetFragmentName = "Heading");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Paragraph",
				targetFragmentName = "Button");
		}

		task ("Publish the display page template") {
			PageEditor.publish();
		}

		task ("Edit the display page template") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Edit");
		}

		task ("Add a HTML fragment below the Paragraph") {
			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "HTML",
				targetFragmentName = "Paragraph");
		}

		task ("Edit the inline content of Paragraph") {
			PageEditor.editFragmentText(
				fragmentName = "Paragraph",
				id = "element-text",
				text = "Editing Finished");
		}

		task ("Remove the Button fragment") {
			PageEditor.removeFragment(fragmentName = "Button");
		}

		task ("Publish the display page template") {
			PortletEntry.publish();
		}

		task ("Access to the display page template in edit mode") {
			DisplayPageTemplatesAdmin.gotoDisplayPageEllipsisItem(
				displayPageName = "Display Page Name",
				item = "Edit");
		}

		task ("View the edited inline content shown in Paragraph") {
			PageEditor.viewFragmentEditableText(
				editableText = "Editing Finished",
				fragmentName = "Paragraph",
				id = "element-text");
		}

		task ("View the Button is not shown") {
			PageEditor.viewFragmentNotPresent(fragmentName = "Button");
		}

		task ("View the Heading and HTML fragments are shown") {
			PageEditor.viewFragmentEditableText(
				editableText = "Heading Example",
				fragmentName = "Heading",
				id = "element-text");

			AssertTextEquals.assertPartialText(
				fragmentName = "html",
				id = "element-html",
				index = 1,
				locator1 = "Fragment#CONTRIBUTED_FRAGMENT_TEXT",
				value1 = "HTML Example");
		}
	}

	@description = "This is a test for LPS-189857. View the display page info in folder."
	@priority = 3
	test ViewInfoPanelOfDisplayPageTemplateInsideFolder {
		property custom.properties = "feature.flag.LPS-189856=true";

		task ("Given a site administrator has a default display page template inside a folder") {
			DisplayPageTemplatesAdmin.openDisplayPagesAdmin(siteURLKey = "test-site-name");

			DisplayPageTemplatesAdmin.addFolder(folderName = "Test Folder Name");

			DisplayPageTemplatesAdmin.gotoFolder(folderName = "Test Folder Name");

			DisplayPageTemplatesAdmin.addDisplayPage(
				contentType = "Web Content Article",
				displayPageName = "Liferay DXP",
				subType = "Basic Web Content");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");

			PageEditor.publish();
		}

		task ("When the site administrator opens the info panel of display page template") {
			DisplayPageTemplatesAdmin.markDisplayPageAsDefault(displayPageName = "Liferay DXP");

			LexiconCard.checkCardCheckbox(card = "Liferay DXP");

			ManagementBar.clickInfo();
		}

		task ("Then the site administrator could see the relevant information") {
			AssertTextEquals(
				locator1 = "Sidebar#COMPONENT_TITLE",
				value1 = "Liferay DXP");

			AssertTextEquals(
				locator1 = "Sidebar#COMPONENT_SUBTITLE",
				value1 = "Display Page Template");

			AssertVisible(
				key_labelName = "Default",
				locator1 = "Sidebar#HEADER_LABEL");

			AssertVisible(
				key_labelName = "Approved",
				locator1 = "Sidebar#HEADER_LABEL");

			AssertTextEquals(
				locator1 = "Sidebar#LOCALTION",
				value1 = "Home > Test Folder Name");

			AssertTextEquals(
				locator1 = "Sidebar#CONTENT_TYPE",
				value1 = "Web Content Article");

			AssertTextEquals(
				locator1 = "Sidebar#SUBTYPE",
				value1 = "Basic Web Content");

			AssertTextMatches(
				locator1 = "Sidebar#CREATED",
				value1 = "^\w\w\w\s[0-9]{1,2},\s(\d{2}|\d{4})\s[0-9]{1,2}:[0-9]{1,2}:[0-9]{1,2}\s\w\w\sby\sTest\sTest$");

			AssertTextMatches(
				locator1 = "Sidebar#MODIFIED",
				value1 = "^\w\w\w\s[0-9]{1,2},\s(\d{2}|\d{4})\s[0-9]{1,2}:[0-9]{1,2}:[0-9]{1,2}\s\w\w\sby\sTest\sTest$");
		}
	}

}