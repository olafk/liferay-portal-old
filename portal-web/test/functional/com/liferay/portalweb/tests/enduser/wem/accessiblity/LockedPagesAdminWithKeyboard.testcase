@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property custom.properties = "feature.flag.LPS-180328=true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Content Pages";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-182060. Allow Automatic Unlocking Process can be enabled and disabled  via keyboard."
	@priority = 4
	test EnableAllowAutomaticUnlockingProcessUnderInstanceSettingsViaKeyboard {
		task ("Given the configuration of locked pages in instance settings") {
			ApplicationsMenu.gotoPortlet(
				category = "Configuration",
				panel = "Control Panel",
				portlet = "Instance Settings");

			SystemSettings.gotoConfiguration(
				configurationCategory = "Pages",
				configurationName = "Locked Pages",
				configurationScope = "Virtual Instance Scope");
		}

		task ("When focusing on the Allow Automatic Unlocking Process toggle via keyboard") {
			KeyPress(
				locator1 = "//label[contains(@class,'toggle-switch')]",
				value1 = "\TAB");
		}

		task ("Then it is possible to disable the toggle via keyboard") {
			KeyPress(
				key_toggleSwitchLabel = "Allow Automatic Unlocking Process",
				locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH",
				value1 = "\SPACE");

			AssertNotChecked.assertNotCheckedNotVisible(
				key_toggleSwitchLabel = "Allow Automatic Unlocking Process",
				locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH");
		}

		task ("When focusing on the Allow Automatic Unlocking Process toggle via keyboard") {
			KeyPress(
				locator1 = "//label[contains(@class,'toggle-switch')]",
				value1 = "\TAB");
		}

		task ("Then it is possible to enable the toggle via keyboard") {
			KeyPress(
				key_toggleSwitchLabel = "Allow Automatic Unlocking Process",
				locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH",
				value1 = "\SPACE");

			AssertChecked.assertCheckedNotVisible(
				key_toggleSwitchLabel = "Allow Automatic Unlocking Process",
				locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH");
		}

		task ("When filling in the Time Without Autosave field") {
			Type(
				key_fieldLabel = "Time Without Autosave",
				locator1 = "TextInput#GENERIC_NUMBER_INPUT",
				value1 = 7);
		}

		task ("Then it is possible to save changes via keyboard") {
			KeyPress(
				locator1 = "//button[@type='submit']",
				value1 = "\TAB");

			KeyPress(
				key_text = "Save",
				locator1 = "Button#ANY",
				value1 = "\ENTER");

			Alert.viewSuccessMessage();
		}

		task ("When focusing on the Cancel button via keyboard") {
			KeyPress(
				locator1 = "//button[contains(@class,'cancel')]",
				value1 = "\TAB");
		}

		task ("Then it is possible to return to the Instance Settings page via keyboard") {
			KeyPress(
				key_text = "Cancel",
				locator1 = "Button#ANY",
				value1 = "\ENTER");

			ControlMenu.viewHeaderTitle(headerTitle = "Instance Settings");
		}
	}

	@description = "This is a test for LPS-194238. Filter and sort menus can be navigated via keyboard."
	@priority = 4
	test FilterAndSortViaKeyboard {
		var baseURL = PropsUtil.get("portal.url");

		task ("Given two locked pages") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			Open.openInTheNewTab(value1 = "${baseURL}/group/test-site-name/~/control_panel/manage?p_p_id=com_liferay_layout_admin_web_portlet_GroupPagesPortlet");

			Navigator.gotoNavTab(navTab = "Utility Pages");

			PagesAdmin.addUtilityPage(pageName = "404 Error Utility Page");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");
		}

		task ("When navigate to the Locked Pages admin in a new tab") {
			Open.openInTheNewTab(value1 = "${baseURL}/web/test-site-name");

			ProductMenu.gotoPortlet(
				category = "Configuration",
				portlet = "Locked Pages");
		}

		task ("Then could filter and sort via keyboard") {
			KeyPress(
				ariaLabel = "Select All Items on the Page",
				locator1 = "TextInput#ANY_WITH_ARIA_LABEL",
				value1 = "\TAB");

			KeyPress(
				ariaLabel = "Filter and Order",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\ENTER");

			KeyPress(
				key_menuItem = "Collection Page",
				locator1 = "MenuItem#ANY_MENU_ITEM",
				value1 = "\DOWN");

			KeyPress(
				key_menuItem = "Content Page",
				locator1 = "MenuItem#ANY_MENU_ITEM",
				value1 = "\ENTER");

			LexiconTable.viewTableEntryTitle(tableEntry = "Test Page Name");

			LexiconTable.viewTableEntryNotPresent(tableEntry = "404 Error Utility Page");

			KeyPress(
				ariaLabel = "Filter and Order",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\ENTER");

			KeyPress(
				key_menuItem = "Collection Page",
				locator1 = "MenuItem#ANY_MENU_ITEM",
				value1 = "\UP");

			KeyPress(
				key_menuItem = "All",
				locator1 = "MenuItem#ANY_MENU_ITEM",
				value1 = "\ENTER");

			KeyPress(
				ariaLabel = "Filter and Order",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\ENTER");

			KeyPress(
				key_menuItem = "Last Autosave",
				locator1 = "MenuItem#ANY_MENU_ITEM",
				value1 = "\DOWN");

			KeyPress(
				key_menuItem = "Name",
				locator1 = "MenuItem#ANY_MENU_ITEM",
				value1 = "\ENTER");

			AssertElementPresent(
				index = 1,
				key_tableEntry = "Test Page Name",
				locator1 = "LexiconTable#TABLE_ENTRY_TITLE_INDEXED");

			AssertElementPresent(
				index = 2,
				key_tableEntry = "404 Error Utility Page",
				locator1 = "LexiconTable#TABLE_ENTRY_TITLE_INDEXED");

			KeyPress(
				ariaLabel = "Filter and Order",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\TAB");

			KeyPress(
				key_text = "order-list-down",
				locator1 = "Icon#ANY",
				value1 = "\ENTER");

			AssertElementPresent(
				index = 1,
				key_tableEntry = "404 Error Utility Page",
				locator1 = "LexiconTable#TABLE_ENTRY_TITLE_INDEXED");

			AssertElementPresent(
				index = 2,
				key_tableEntry = "Test Page Name",
				locator1 = "LexiconTable#TABLE_ENTRY_TITLE_INDEXED");
		}
	}

	@description = "This is a test for LPS-194499. Using keyboard navigation, the name of the Utility page in the Locked Pages list is clickable and opens the Utility page in a new tab."
	@priority = 4
	test NavigateToLockedPageInListViaKeyboard {
		var siteName = selenium.getText("Home#SITE_NAME");
		var baseURL = PropsUtil.get("portal.url");

		task ("Given a locked utility page") {
			PagesAdmin.openPagesAdmin(siteURLKey = "Test Site Name");

			Navigator.gotoNavTab(navTab = "Utility Pages");

			PagesAdmin.addUtilityPage(pageName = "404 Error Utility Page");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When navigating to the locked pages admin page") {
			Open.openInTheNewTab(value1 = "${baseURL}/group/test-site-name/~/control_panel/manage/-/style_books/style_books");

			ProductMenu.gotoPortlet(
				category = "Configuration",
				portlet = "Locked Pages");
		}

		task ("Then can click on the name link of the blocked page just using the keyboard") {
			KeyPress(
				key_tableEntry = "404 Error Utility Page",
				locator1 = "LexiconTable#TABLE_ENTRY_CHECKBOX",
				value1 = "\TAB");

			AssertElementFocused(
				key_columnName = "name",
				key_tableEntry = "404 Error Utility Page",
				locator1 = "LexiconTable#TABLE_ENTRY_COLUMN_LINK");

			KeyPress(
				key_columnName = "name",
				key_tableEntry = "404 Error Utility Page",
				locator1 = "LexiconTable#TABLE_ENTRY_COLUMN_LINK",
				value1 = "\ENTER");

			SelectWindow(value1 = "title=404 Error Utility Page - Test Site Name - ${siteName}");

			ControlMenu.viewHeaderDraftTitle(headerTitle = "404 Error Utility Page");
		}
	}

	@description = "This is a test for LPS-182024. The administrator could unlock locked page via keyboard."
	@priority = 4
	test UnlockLockedPageViaKeyboard {
		task ("Given an administrator has a locked page") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");
		}

		task ("When the administrator navigates to the Locked Pages admin in a new tab") {
			var baseURL = PropsUtil.get("portal.url");

			Open.openInTheNewTab(value1 = "${baseURL}/web/test-site-name");

			ProductMenu.gotoPortlet(
				category = "Configuration",
				portlet = "Locked Pages");
		}

		task ("Then it is possible to unlock a locked page") {
			KeyPress(
				key_text = "Test Page Name",
				locator1 = "Link#ANY",
				value1 = "\TAB");

			KeyPress(
				ariaLabel = "Actions for Test Page Name",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\ENTER");

			KeyPress(
				key_menuItem = "Unlock",
				locator1 = "MenuItem#ANY_MENU_ITEM",
				value1 = "\ENTER");

			KeyPress(
				key_text = "Cancel",
				locator1 = "Button#ANY",
				value1 = "\TAB");

			KeyPress(
				key_text = "Unlock",
				locator1 = "Button#ANY",
				value1 = "\ENTER");

			Alert.viewSuccessMessageText(successMessage = "Success:1 pages were successfully unlocked.");

			AssertTextEquals(
				locator1 = "Message#EMPTY_INFO",
				value1 = "No locked pages were found.");
		}
	}

}