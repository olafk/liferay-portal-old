@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Page Templates";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-175120. The site administrator could choose import option via keyboard when import page templates."
	@priority = 4
	test ChooseImportOptionViaKeyboard {
		task ("Given a site administrator exports a content page template") {
			JSONLayoutpagetemplate.addLayoutPageTemplateCollection(
				groupName = "Test Site Name",
				layoutPageTemplateCollectionName = "Page Template Collection");

			JSONLayoutpagetemplate.addLayoutPageTemplateEntry(
				groupName = "Test Site Name",
				layoutPageTemplateCollectionName = "Page Template Collection",
				layoutPageTemplateEntryName = "Page Template Name",
				layoutPageTemplateStatus = "Approved",
				layoutPageTemplateType = "Content Page Template");

			PageTemplatesAdmin.openPageTemplatesAdmin(siteURLKey = "test-site-name");

			PageTemplatesAdmin.gotoPageTemplateEllipsisItem(
				item = "Export",
				pageTemplateName = "Page Template Name");

			DownloadTempFile();
		}

		task ("When the site administrator imports the content page template") {
			Click.waitForMenuToggleJSClick(locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS");

			MenuItem.click(menuItem = "Import");

			WaitForPageLoad();

			var pageTemplateZipFileName = TestCase.getDownloadedTempFileName(fileNamePattern = "page-template-*.zip");

			UploadTempFile.uploadTempFileHiddenNoMouseOver(
				locator1 = "TextInput#FILE",
				value1 = ${pageTemplateZipFileName});
		}

		task ("Then the site administrator could choose import option via keyboard") {
			KeyPress(
				key_text = "Cancel",
				locator1 = "Button#ANY",
				value1 = "\TAB");

			KeyPress(
				key_text = "Import",
				locator1 = "Button#ANY",
				value1 = "\ENTER");

			WaitForVisible(locator1 = "Modal#HEADER");

			KeyPress(
				ariaLabel = "close",
				locator1 = "Button#ANY_WITH_ARIA_LABEL",
				value1 = "\TAB");

			KeyPress(
				locator1 = "Radio#ANY",
				radioLabel = "Do Not Import Existing Items",
				value1 = "\DOWN");

			KeyPress(
				locator1 = "Radio#ANY",
				radioLabel = "Overwrite Existing Items",
				value1 = "\DOWN");

			KeyPress(
				key_text = "Cancel",
				locator1 = "Modal#MODAL_FOOTER_BUTTON",
				value1 = "\TAB");

			KeyPress(
				key_text = "Import",
				locator1 = "Modal#MODAL_FOOTER_BUTTON",
				value1 = "\ENTER");

			AssertTextEquals(
				locator1 = "Message#SUCCESS_IMPORT",
				value1 = "1 item was imported.");
		}
	}

	@description = "This is a test for LPS-199793. Using Keyboard navigation it is possible to copy an existing Master Page from the ellipsis menu of the card."
	@priority = 4
	test CopyMasterPageTemplateViaKeyboard {
		property custom.properties = "feature.flag.LPS-195263=true${line.separator}feature.flag.LPS-197408=true";

		task ("Given a user has a master page") {
			JSONLayoutpagetemplate.addMasterPageTemplateEntry(
				groupName = "Test Site Name",
				masterPageTemplateEntryName = "Custom Masters Page Template",
				masterPageTemplateStatus = "Approved");
		}

		task ("When the user accesses to the Masters admin") {
			MastersPageTemplatesAdmin.openMastersAdmin(siteURLKey = "test-site-name");
		}

		task ("Then the user could copy master page via keyboard") {
			KeyPress(
				key_card = "Custom Masters Page Template",
				locator1 = "Card#CARD_TITLE_LINK",
				value1 = "\TAB");

			KeyPress(
				key_card = "Custom Masters Page Template",
				locator1 = "Card#CARD_ELLIPSIS",
				value1 = "\ENTER");

			for (var menuItem : list "Edit,Change Thumbnail,Mark as Default,Rename,Export") {
				KeyPress(
					key_menuItem = ${menuItem},
					locator1 = "MenuItem#ANY_MENU_ITEM",
					value1 = "\DOWN");
			}

			for (var menuItem : list "Make a Copy,Master Page") {
				KeyPress(
					key_menuItem = ${menuItem},
					locator1 = "MenuItem#ANY_MENU_ITEM",
					value1 = "\ENTER");
			}

			MastersPageTemplatesAdmin.viewMastersPresent(masterLayoutName = "Custom Masters Page Template (Copy)");
		}
	}

}