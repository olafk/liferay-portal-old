@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property custom.properties = "feature.flag.LRAC-14771=true";
	property portal.release = "true";
	property portal.upstream = "true";
	property property.group = "analytics.cloud.profile";
	property test.run.type = "single";
	property testray.main.component.name = "Fragments";

	setUp {
		task ("Open Analytics Cloud") {
			ACUtils.launchAC();
		}

		task ("Take token from Analytics Cloud") {
			ACSettings.takeTokenFromAnalyticsCloud();
		}

		task ("Go to DXP portal, login and create site") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();

			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Connect and synchronyze with Analytics Cloud") {
			ACDXPSettings.connectDXPtoAnalyticsCloudWithTryAgain(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-200644. View content under the collection under Most Popular Content on a content page."
	@priority = 4
	test AddCollectionDisplayWithMostPopularContentOnContentPage {
		task ("Given a page designer has a Collection Display on a content page") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Collection Display");
		}

		task ("When the page designer selects the collection provider in the Collection Display") {
			PageEditor.gotoConfiguration(fragmentName = "Collection Display");

			Click(
				key_fieldLabel = "Collection",
				key_text = "plus",
				locator1 = "Icon#ANY_ITEM_SELECTOR");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			NavItem.click(navItem = "Collection Providers");
		}

		task ("Then the page designer could select the Most Popular Content in Collection Display") {
			LexiconCard.viewCardLabel(
				card = "Most Popular Content",
				cardLabel = "Beta");

			LexiconCard.clickCard(card = "Most Popular Content");

			SelectFrameTop();

			PageEditor.waitForAutoSave();

			PageEditor.viewItemSelectorText(
				fieldLabel = "Collection",
				text = "Most Popular Content");

			PageEditor.viewCollectionItem(assetTitle = "Sample Collection Item");
		}
	}

	@description = "This is a test for LPS-200576. View content under the collection under User's personalized content recommendations on a content page."
	@priority = 4
	test AddCollectionDisplayWithUsersPersonalizedContentRecommendationsOnContentPage {
		task ("Given a page designer has a Collection Display on a content page") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Collection Display");
		}

		task ("When the page designer selects the collection provider in the Collection Display") {
			PageEditor.gotoConfiguration(fragmentName = "Collection Display");

			Click(
				key_fieldLabel = "Collection",
				key_text = "plus",
				locator1 = "Icon#ANY_ITEM_SELECTOR");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			NavItem.click(navItem = "Collection Providers");
		}

		task ("Then the page designer could select the User's Personalized Content Recommendations in Collection Display") {
			LexiconCard.viewCardLabel(
				card = "User',\"'\",'s Personalized Content Recommendations",
				cardLabel = "Beta");

			LexiconCard.clickCard(card = "User',\"'\",'s Personalized Content Recommendations");

			SelectFrameTop();

			PageEditor.waitForAutoSave();

			PageEditor.viewItemSelectorText(
				fieldLabel = "Collection",
				text = "User's Personalized Content Recommendations");

			PageEditor.viewCollectionItem(assetTitle = "Sample Collection Item");
		}
	}

	@description = "This is a test for LPS-200644. View content under the collection under Most Popular Content on a collection page."
	@priority = 4
	test AddCollectionPageBasedOnMostPopularContent {
		task ("Given a page designer accesses to the Pages admin") {
			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");
		}

		task ("When the page designer adds a collection page") {
			LexiconEntry.gotoAdd();

			MenuItem.click(menuItem = "Collection Page");
		}

		task ("Then the page designer could select the Most Popular Content collection provider") {
			Navigator.gotoNavTab(navTab = "Collection Providers");

			LexiconCard.viewCardLabel(
				card = "Most Popular Content",
				cardLabel = "Beta");

			LexiconCard.clickCard(card = "Most Popular Content");

			LexiconCard.clickCard(card = "Blank");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			PortletEntry.inputName(name = "Test Page Name");

			Button.click(button = "Add");

			SelectFrameTop();

			PageEditor.assertFragmentSidebarLoaded();

			ControlMenu.viewHeaderDraftTitle(headerTitle = "Test Page Name");

			PageEditor.viewFragmentEditableText(
				editableText = "Most Popular Content",
				fragmentName = "Heading",
				id = "element-text");

			PageEditor.viewCollectionItem(assetTitle = "Sample Collection Item");

			PageEditor.gotoConfiguration(fragmentName = "Collection Display");

			PageEditor.viewItemSelectorText(
				fieldLabel = "Collection",
				text = "Most Popular Content");
		}
	}

	@description = "This is a test for LPS-200576. View content under the collection under User's personalized content recommendations on a collection page."
	@priority = 4
	test AddCollectionPageBasedOnUsersPersonalizedContentRecommendations {
		task ("Given a page designer accesses to the Pages admin") {
			PagesAdmin.openPagesAdmin(siteURLKey = "test-site-name");
		}

		task ("When the page designer adds a collection page") {
			LexiconEntry.gotoAdd();

			MenuItem.click(menuItem = "Collection Page");
		}

		task ("Then the page designer could select the User's Personalized Content Recommendations collection provider") {
			Navigator.gotoNavTab(navTab = "Collection Providers");

			LexiconCard.viewCardLabel(
				card = "User',\"'\",'s Personalized Content Recommendations",
				cardLabel = "Beta");

			LexiconCard.clickCard(card = "User',\"'\",'s Personalized Content Recommendations");

			LexiconCard.clickCard(card = "Blank");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			PortletEntry.inputName(name = "Test Page Name");

			Button.click(button = "Add");

			SelectFrameTop();

			PageEditor.assertFragmentSidebarLoaded();

			ControlMenu.viewHeaderDraftTitle(headerTitle = "Test Page Name");

			PageEditor.viewFragmentEditableText(
				editableText = "User's Personalized Content Recommendations",
				fragmentName = "Heading",
				id = "element-text");

			PageEditor.viewCollectionItem(assetTitle = "Sample Collection Item");

			PageEditor.gotoConfiguration(fragmentName = "Collection Display");

			PageEditor.viewItemSelectorText(
				fieldLabel = "Collection",
				text = "User's Personalized Content Recommendations");
		}
	}

}