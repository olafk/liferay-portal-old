@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Fragments";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-188478. View the accessibility of fragment import."
	@priority = 3
	test ViewAccessibilityOfFragmentImport {
		task ("Given a user accesses to the Fragments admin") {
			FragmentsAdminNavigator.openFragmentsAdmin(siteURLKey = "test-site-name");
		}

		task ("When the user accesses to the fragment import page") {
			FragmentsAdminNavigator.gotoImportCollection();

			WaitForPageLoad();
		}

		task ("Then the fragment import page should have correct accessibility") {
			AssertAccessible();
		}

		task ("When the user imports a fragment set") {
			UploadDependencyFile.uploadArchiveFile(fileName = "fragment-collection.zip");

			Button.clickImport();

			AssertVisible(locator1 = "Message#SUCCESS_IMPORT");
		}

		task ("Then the import results page should have correct accessibility") {
			AssertElementAccessible(locator1 = "//div[contains(@id,'main-content')]//div[contains(@role,'tabpanel')]");
		}
	}

}