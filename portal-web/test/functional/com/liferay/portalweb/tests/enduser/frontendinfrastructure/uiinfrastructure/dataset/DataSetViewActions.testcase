@component-name = "portal-frontend-infrastructure"
definition {

	property custom.properties = "feature.flag.LPS-164563=true${line.separator}feature.flag.LPS-192282=true";
	property portal.acceptance = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Frontend Data Set";
	property testray.main.component.name = "Frontend Data Set";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();

		task ("Given a new data set entry") {
			DataSetAdmin.goToDataSetAdminPage();

			DataSetAdmin.createDataSetEntryViaAPI(
				dataSetName = "Data Set Test",
				restApplication = "/data-set-manager/fields",
				restEndpoint = "/",
				restSchema = "FDSField");
		}

		task ("And add new view") {
			DataSetAdmin.createFDSViewViaAPI(
				dataSetName = "Data Set Test",
				dataSetViewDescription = "FDSViewDescription",
				key_dataSetViewNameList = "View Test");
		}

		task ("When the user goes to the Action tab") {
			DataSetAdmin.goToSpecificViewPage(
				dataSetName = "Data Set Test",
				key_viewName = "View Test");
		}

		task ("When the user goes to the Action tab.") {
			DataSetAdmin.goToTab(tabName = "Actions");
		}
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		DataSetAdmin.deleteAllDataSetEntries();

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@description = "LPS-191486. Verify if the user can cancel the deletion of an entry by clicking the Cancel button"
	@priority = 4
	test CanCancelADeletionInCancelButton {
		task ("And creates an item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				icon = "trash",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("Then the Delete option is displayed in the item action dropdown menu") {
			MenuItem.viewPresent(menuItem = "Delete");
		}

		task ("When the user clicks on the Delete option") {
			MenuItem.click(menuItem = "Delete");
		}

		task ("Then the Delete modal appears") {
			AssertVisible(locator1 = "Modal#BODY");
		}

		task ("When the user clicks on Cancel button") {
			Button.clickCancel();
		}

		task ("Then the Delete modal is closed") {
			AssertElementNotPresent(locator1 = "Modal#BODY");
		}

		task ("And the item action is present in the item action list") {
			AssertElementPresent(
				key_position = 1,
				keyName = "delete",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

	@description = "LPS-191486. Verify if the user can cancel the deletion of an entry by clicking the Close(x) button"
	@priority = 3
	test CanCancelADeletionInXButton {
		task ("And creates an item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				icon = "trash",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("Then the Delete option is displayed in the item action dropdown menu") {
			MenuItem.viewPresent(menuItem = "Delete");
		}

		task ("When the user clicks on the Delete option") {
			MenuItem.click(menuItem = "Delete");
		}

		task ("Then the Delete modal appears") {
			AssertVisible(locator1 = "Modal#BODY");
		}

		task ("When the user clicks on Close button") {
			Click(
				key_modalTitle = "Delete action?",
				locator1 = "Button#CLOSE_MODAL");
		}

		task ("Then the Delete modal is closed") {
			AssertElementNotPresent(locator1 = "Modal#BODY");
		}

		task ("And the item action is present in the item action list") {
			AssertElementPresent(
				key_position = 1,
				keyName = "delete",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

	@description = "LPS-186876. Confirm that is possible to cancel changes in the Actions tab."
	@priority = 3
	test CanCancelChangesOnActions {
		task ("And clicks on Create Item Action button") {
			Click.clickNoMouseOver(
				key_text = "Create Item Action",
				locator1 = "Button#ANY_SECONDARY");
		}

		task ("And add some information in the fields") {
			Type(
				key_unnamedTitle = "",
				locator1 = "TextInput#DEPOT_UNNAMED_DEFAULT_TITLE",
				value1 = "New Action");

			Type(
				key_fieldId = "URL",
				locator1 = "TextArea#ANY_ID",
				value1 = "www.able.com");
		}

		task ("And clicks on Cancel button") {
			Button.clickCancel();
		}

		task ("Then the item action is not saved and it does not appear in the list of the Item Actions tab") {
			AssertElementPresent(
				key_entryName = "No actions were created.",
				locator1 = "ObjectAdmin#VIEW_ENTRY_NAME_ON_PAGE");
		}
	}

	@description = "LPS-191488. Confirm that it's possible to cancel changes in the Actions tab."
	@priority = 5
	test CanCancelEditions {
		task ("And creates a new item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				confirmationMessage = "This item was deleted successfully.",
				icon = "trash",
				messageType = "Info",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("And clicks on the Edit option") {
			MenuItem.click(menuItem = "Edit");
		}

		task ("And changes the Label field content") {
			Type(
				key_unnamedTitle = "",
				locator1 = "TextInput#DEPOT_UNNAMED_DEFAULT_TITLE",
				value1 = "remove");
		}

		task ("And changes the Confirmation Message field content") {
			Type(
				key_placeholder = "Add a message here.",
				locator1 = "FrontendDataSet#PLACEHOLDER",
				value1 = "This item was removed successfully.");
		}

		task ("And clicks on Cancel button") {
			Button.clickCancel();
		}

		task ("Then the changes are not saved") {
			AssertElementPresent(
				key_position = 1,
				keyName = "delete",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

	@description = "LPS-192149. Verify if the user can an Action"
	@priority = 5
	test CanCreateActionEntry {
		task ("And clicks on Create Item Action button") {
			LexiconEntry.gotoAdd();
		}

		task ("And fills the fields in the Action tab") {
			Type(
				key_unnamedTitle = "",
				locator1 = "TextInput#DEPOT_UNNAMED_DEFAULT_TITLE",
				value1 = "View");

			Select(
				key_fieldLabel = "Type",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Link");

			Select(
				key_fieldLabel = "Icon",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "view");

			Type(
				key_fieldId = "URL",
				locator1 = "TextArea#ANY_ID",
				value1 = "http://localhost:8080/o/data-set-manager/");
		}

		task ("And clicks on the Save button") {
			Click(
				key_fieldLabel = "Icon",
				locator1 = "Select#GENERIC_SELECT_FIELD");

			PortletEntry.save();
		}

		task ("Then a confirmation message is displayed") {
			Alert.viewSuccessMessage();
		}

		task ("And the item action is saved and it appears in the list of the Item Actions tab") {
			AssertElementPresent(
				key_position = 1,
				keyName = "View",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

	@description = "LPS-191486. Verify if the user can delete an Action entry"
	@priority = 5
	test CanDeleteAction {
		task ("And creates an item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				icon = "trash",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("Then the Delete option is displayed in the item action dropdown menu") {
			MenuItem.viewPresent(menuItem = "Delete");
		}

		task ("When the user clicks on the Delete option") {
			MenuItem.click(menuItem = "Delete");
		}

		task ("Then the Delete modal appears") {
			AssertVisible(locator1 = "Modal#BODY");
		}

		task ("When the user clicks on Delete button") {
			Button.clickDelete();
		}

		task ("Then the Delete modal is closed") {
			AssertElementNotPresent(locator1 = "Modal#BODY");
		}

		task ("And an confirmation toast message is displayed") {
			Alert.viewSuccessMessage();
		}

		task ("And the item action is present in the item action list") {
			AssertElementNotPresent(
				key_position = 1,
				keyName = "delete",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

	@description = "LPS-192149. Verify if the user can change the entry order with drag and drop in the action entries table"
	@priority = 4
	test CanDragAndDropActionEntry {
		task ("And creates two or more item actions") {
			DataSetAdmin.addActions(
				actionName = "delete",
				icon = "trash",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");

			DataSetAdmin.addActions(
				actionName = "view",
				icon = "view",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("Then the list of item actions includes the correct information about the Icon, Label and Type") {
			for (var name_listTable : list "view,view,link") {
				AssertElementPresent(
					key_position = 1,
					keyName = ${name_listTable},
					locator1 = "DataSet#FIELDS_TABLE");
			}

			for (var name_listTable : list "trash,delete,link") {
				AssertElementPresent(
					key_position = 2,
					keyName = ${name_listTable},
					locator1 = "DataSet#FIELDS_TABLE");
			}
		}

		task ("When the user changes the item actions position using drag and drop") {
			DragAndDrop.javaScriptDragAndDropToBottom(
				key_position = 2,
				key_rowNumber = 1,
				keyName = "delete",
				locator1 = "DataSet#DRAG_ROW",
				locator2 = "DataSet#FIELDS_TABLE");
		}

		task ("Then the item actions are ordered correctly following the changes") {
			AssertElementPresent(
				key_position = 2,
				keyName = "view",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

	@description = "LPS-191488. Confirm that is possible to save an Action only with mandatory fields filled and the rest empty"
	@priority = 4
	test CanFillOnlyMandatoryFields {
		task ("And creates a new item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				confirmationMessage = "This item was deleted successfully.",
				icon = "trash",
				messageType = "Info",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("And clicks on the Edit option") {
			MenuItem.click(menuItem = "Edit");
		}

		task ("And changes the Label field content") {
			Type(
				key_unnamedTitle = "",
				locator1 = "TextInput#DEPOT_UNNAMED_DEFAULT_TITLE",
				value1 = "remove");
		}

		task ("And leaves the Confirmation Message field empty") {
			Type(
				key_placeholder = "Add a message here.",
				locator1 = "FrontendDataSet#PLACEHOLDER",
				value1 = "");
		}

		task ("And leaves the Message Type field empty") {
			Select(
				key_fieldLabel = "Message Type",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Info");
		}

		task ("And leaves the Headless Action Key field empty") {
			Type(
				key_placeholder = "Add a value here.",
				locator1 = "FrontendDataSet#PLACEHOLDER",
				value1 = "");
		}

		task ("And clicks on Save button") {
			PortletEntry.save();
		}

		task ("And a successful toast message is displayed") {
			Alert.viewSuccessMessage();
		}

		task ("Then the changes are saved") {
			AssertElementPresent(
				key_position = 1,
				keyName = "remove",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

