	@description = "LPS-191485. Verify if is possible to edit a Async Item created"
	@priority = 5
	test CanEditAsyncItemAction {
		property portal.acceptance = "true";

		task ("When Create a New Action") {
			LexiconEntry.gotoAdd();
		}

		task ("And Fill in the required fields") {
			Type(
				key_unnamedTitle = "",
				locator1 = "TextInput#DEPOT_UNNAMED_DEFAULT_TITLE",
				value1 = "Async Item Action");

			Click(locator1 = "Button#PLUS");

			SelectFrameTop();

			Type(
				locator1 = "DataSet#MODAL_SEARCH",
				value1 = "asterisk");

			Click.clickNoMouseOver(
				key_text = "asterisk",
				locator1 = "Modal#MODAL_ICON");

			Select(
				key_fieldLabel = "Type",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Async");

			Type(
				key_fieldId = "URL",
				locator1 = "TextArea#ANY_ID",
				value1 = "/group/control_panel/manage?p_p_id=com_liferay_object_web_internal_object_definitions_portlet_ObjectDefinitionsPortlet_34759&p_p_lifecycle=0&p_p_state=maximized&p_p_mode=view&_com_liferay_object_web_internal_object_definitions_portlet_ObjectDefinitionsPortlet_34759_objectDefinitionId=34759&_com_liferay_object_web_internal_object_definitions_portlet_ObjectDefinitionsPortlet_34759_mvcRenderCommandName=%2Fobject_entries%2Fedit_object_entry&_com_liferay_object_web_internal_object_definitions_portlet_ObjectDefinitionsPortlet_34759_externalReferenceCode={externalReferenceCode}");

			Select(
				key_fieldLabel = "Method",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "GET");

			Type(
				key_option = "Success",
				locator1 = "DataSet#MESSAGE_FIELD",
				value1 = "Passed.");

			ClickNoError(
				key_text = "Error",
				locator1 = "Button#ANY");

			Type(
				key_option = "Error",
				locator1 = "DataSet#MESSAGE_FIELD",
				value1 = "Failed.");

			PortletEntry.save();
		}

		task ("And Edit the action item created") {
			DataSetAdmin.editActions(
				newActionName = "Async Item Action Edited",
				newErrorMessage = "Failed Edited.",
				newIcon = "reload",
				newMethod = "POST",
				newSuccessMessage = "Passed Edited.",
				oldActionName = "Async Item Action");
		}

		task ("Then it appears on the Action tab table with the new title.") {
			AssertElementPresent(
				key_position = 1,
				keyName = "Async Item Action Edited",
				locator1 = "DataSet#FIELDS_TABLE");
		}

		task ("When Open the item creates") {
			Click(
				key_tableEntry = "Async Item Action Edited",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");

			MenuItem.click(menuItem = "Edit");
		}

		task ("Then Check all the values set in the creation for all the fields are still present") {
			AssertElementPresent(
				key_unnamedTitle = "",
				locator1 = "TextInput#DEPOT_UNNAMED_DEFAULT_TITLE",
				value1 = "Async Item Action Edited");

			AssertElementPresent(
				key_fieldLabel = "Type",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Async");

			AssertElementPresent(
				key_fieldLabel = "Method",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "POST");

			AssertElementPresent(
				key_option = "Success",
				locator1 = "DataSet#MESSAGE_FIELD",
				value1 = "Passed Edited.");

			ClickNoError(
				key_text = "Error",
				locator1 = "Button#ANY");

			AssertElementPresent(
				key_option = "Error",
				locator1 = "DataSet#MESSAGE_FIELD",
				value1 = "Failed Edited.");
		}
	}

