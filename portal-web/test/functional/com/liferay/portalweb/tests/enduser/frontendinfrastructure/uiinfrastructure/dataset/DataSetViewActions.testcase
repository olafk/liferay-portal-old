	@description = "LPS-192149. Verify if when an Action entry was not created, a text and an empty table will appears"
	@priority = 4
	test CanSeeEmptyActionTable {
		task ("And there are no item actions created") {
			AssertElementNotPresent(
				key_position = 1,
				keyName = "delete",
				locator1 = "DataSet#FIELDS_TABLE");
		}

		task ("Then the text “No actions were created. Start creating one action to interact with your data.” is displayed above the Create Item Action button") {
			AssertElementPresent(
				key_textName = "No actions were created.",
				locator1 = "DataSet#ACTIONS_EMPTY_TABLE");
		}
	}

	@description = "LPS-191488. Verify if the user can edit a created Action and see the informations"
	@priority = 5
	test CanSeeModalWhenClicksOnEditAction {
		task ("And creates a new item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				confirmationMessage = "This item was deleted successfully.",
				icon = "trash",
				messageType = "Info",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");

			MenuItem.click(menuItem = "Edit");
		}

		task ("Then a modal is diplayed and the modal title is the name of the new item action") {
			AssertVisible(
				key_title = "delete",
				locator1 = "Header#H2_TITLE");
		}
	}

	@description = "LPS-191486. Verify if the user can view the delete modal when it will delete an Action entry."
	@priority = 3
	test CanViewDeleteModalInActions {
		task ("And creates an item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				icon = "trash",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("Then the Delete option is displayed in the item action dropdown menu") {
			MenuItem.viewPresent(menuItem = "Delete");
		}

		task ("When the user clicks on the Delete option") {
			MenuItem.click(menuItem = "Delete");
		}

		task ("Then the Delete modal appears") {
			AssertVisible(locator1 = "Modal#BODY");
