			DataSetAdmin.addFields(key_fieldList = "id,status");
		}

		task ("When the user goes to the Action tab") {
			DataSetAdmin.goToTab(tabName = "Actions");
		}

		task ("And creates a new link item action") {
			var erc = StringUtil.substring(${erc}, 0, 470);

			DataSetAdmin.addActions(
				actionName = "edit",
				icon = "pencil",
				type = "Link",
				url = ${erc});
		}

		task ("And creates a new content Page") {
			Navigator.openURL();

			ContentPages.addPage(pageName = "Data Set Object");
		}

		task ("And adds the data set fragment to the page") {
			PageEditor.addFragment(
				collectionName = "Content Display",
				fragmentName = "Data Set");
		}

		task ("And configure it to the new view") {
			Click(locator1 = "ReportsAdminViewReportEntry#INFO_MESSAGE");

			Click.javaScriptClick(
				key_value = "Select Data Set View",
				locator1 = "Button#SECONDARY_BY_TITLE");

			SelectFrame(
				key_title = "Select",
				locator1 = "IFrame#MODAL_ANY");

			Click.clickAtNotVisible(
				key_radioOption = "View Object Test",
				locator1 = "CommerceEntry#RADIO_BUTTON");

			Button.clickSave();
		}

		task ("And publishes the page") {
			SelectFrame(locator1 = "DataSet#DEFOCUS");

			Click.javaScriptClick(locator1 = "WorkflowMetricsIndex#METRICS_REINDEX_ALL_BUTTON");
		}

		task ("Then the link action created is displayed close to each item") {
			Navigator.openURL();

			Navigator.gotoPage(pageName = "Data Set Object");

			AssertElementPresent(
				key_entryName = "Approved",
				key_icon = "pencil",
				key_rowNumber = 1,
				locator1 = "FrontendDataSet#ICON_IN_DATA_SET_FRAGMENT");

			AssertElementPresent(
				key_entryName = "Approved",
				key_icon = "pencil",
				key_rowNumber = 2,
				locator1 = "FrontendDataSet#ICON_IN_DATA_SET_FRAGMENT");
		}
	}

	@description = "LPS-191486. Verify if the user can view the delete modal when it will delete an Action entry."
	@priority = 3
	test CanViewDeleteModalInActions {
		task ("And creates an item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				icon = "trash",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("Then the Delete option is displayed in the item action dropdown menu") {
			MenuItem.viewPresent(menuItem = "Delete");
		}

		task ("When the user clicks on the Delete option") {
			MenuItem.click(menuItem = "Delete");
		}

		task ("Then the Delete modal appears") {
			AssertVisible(locator1 = "Modal#BODY");
		}

		task ("And the text “Are you sure you want to delete this action?” is displayed in the modal") {
			AssertElementPresent(
				key_modalText = "Are you sure you want to delete this action?",
				locator1 = "DataSet#DELETE_DATA_SET_MODAL_BODY");
		}
	}

	@description = "LPS-192149. Verify if the Headless Action Key is not mandatory and contains an tooltip Icon with an message"
	@priority = 3
	test HeadlessActionKeyIsNotMandatory {
		task ("And clicks on Create Item Action button") {
			LexiconEntry.gotoAdd();
		}

		task ("Then the Headless Action Key field is not mandatory") {
			AssertElementNotPresent(
				key_fieldName = "Headless Action Key",
				locator1 = "DataSet#MANDATORY_FIELD");
		}

		task ("And next to the Headless Action Key field title there is a tooltip icon.") {
			AssertElementPresent(
				key_indexNumber = 1,
				key_text = "question-circle-full",
				locator1 = "Icon#ANY_N");
		}

		task ("When the user hovers the tooltip icon") {
			MouseOver(
				key_indexNumber = 1,
				key_text = "question-circle-full",
				locator1 = "Icon#ANY_N");
		}

		task ("Then the message “This key allows the action to be performed when the permission is associated with it” is displayed.") {
			AssertElementPresent(
				key_title = "",
				locator1 = "DataSet#FILTER_TOOLTIP",
				value1 = "This key is used to display the action if the user has the permission for it by checking if the key is present in the data item's actions array.");
		}

		task ("When the mandatory fields are filled") {
			Type(
				key_unnamedTitle = "",
				locator1 = "TextInput#DEPOT_UNNAMED_DEFAULT_TITLE",
				value1 = "New Action");

			Type(
				key_fieldId = "URL",
				locator1 = "TextArea#ANY_ID",
				value1 = "http://localhost:8080/o/data-set-manager/");
		}

		task ("And clicks on Save button") {
			PortletEntry.save();
		}

		task ("And a successful toast message is displayed") {
			Alert.viewSuccessMessage();
		}

		task ("Then the changes are saved") {
			AssertElementPresent(
				key_position = 1,
				keyName = "New Action",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

