				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("And clicks on the Edit option") {
			MenuItem.click(menuItem = "Edit");
		}

		task ("And changes the Label field content") {
			Type(
				key_unnamedTitle = "",
				locator1 = "TextInput#DEPOT_UNNAMED_DEFAULT_TITLE",
				value1 = "remove");
		}

		task ("And changes the Headless Action Key field content") {
			Type(
				key_placeholder = "Add a value here.",
				locator1 = "FrontendDataSet#PLACEHOLDER",
				value1 = "delete");
		}

		task ("And changes the Confirmation Message field content") {
			Type(
				key_placeholder = "Add a message here.",
				locator1 = "FrontendDataSet#PLACEHOLDER",
				value1 = "This item was removed successfully.");
		}

		task ("And changes the URL field content") {
