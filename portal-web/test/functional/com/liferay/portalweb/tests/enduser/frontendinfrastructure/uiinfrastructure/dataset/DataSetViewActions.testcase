				value1 = "/group/control_panel/manage?p_p_id=com_liferay_object_web_internal_object_definitions_portlet_ObjectDefinitionsPortlet_34759&p_p_lifecycle=0&p_p_state=maximized&p_p_mode=view&_com_liferay_object_web_internal_object_definitions_portlet_ObjectDefinitionsPortlet_34759_objectDefinitionId=34759&_com_liferay_object_web_internal_object_definitions_portlet_ObjectDefinitionsPortlet_34759_mvcRenderCommandName=%2Fobject_entries%2Fedit_object_entry&_com_liferay_object_web_internal_object_definitions_portlet_ObjectDefinitionsPortlet_34759_externalReferenceCode={externalReferenceCode}");

			Select(
				key_fieldLabel = "Method",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "GET");

			Type(
				key_option = "Success",
				locator1 = "DataSet#MESSAGE_FIELD",
				value1 = "Passed.");

			ClickNoError(
				key_text = "Error",
				locator1 = "Button#ANY");

			Type(
				key_option = "Error",
				locator1 = "DataSet#MESSAGE_FIELD",
				value1 = "Failed.");

			PortletEntry.save();
		}

		task ("And Edit the action item created") {
			DataSetAdmin.editActions(
				newActionName = "Async Item Action Edited",
				newErrorMessage = "Failed Edited.",
				newIcon = "reload",
				newMethod = "POST",
				newSuccessMessage = "Passed Edited.",
				newURL = "",
				oldActionName = "Async Item Action");
		}

		task ("Then A message error appears") {
			AssertElementPresent(locator1 = "Message#ERROR_FORM_FIELD_REQUIRED");
		}

		task ("And the changes cannot be saved") {
			AssertElementNotPresent(
				key_position = 1,
				keyName = "Async Item Action Edited",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

