			AssertElementPresent(
				key_fieldLabel = "Type",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Modal");

			AssertElementPresent(
				key_fieldId = "URL",
				locator1 = "TextArea#ANY_ID",
				value1 = "https://gist.github.com/deborasoliveira/40716d0b03d33ff7e636ca5d366c79c5#file-link-action-url-example");

			AssertElementPresent(
				key_fieldLabel = "Variant",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Small");

			AssertElementPresent(
				key_fieldName = "add-here-the-title-of-the-modal",
				locator1 = "DataSet#PRESELECT_VALUE_INPUT",
				value1 = "Edit item Action");
		}
	}

	@description = "LPS-191485. Verify if the options GET, POST, PATCH, LPS-199219DELETE are present in the Method dropdown in the Item Action"
	@priority = 4
	test AssertAllMethodOptionsArePresentOnItemAction {
		task ("When clicks on New Action button") {
			Click(
				key_text = "New Item Action",
				locator1 = "Button#ANY_SECONDARY");
		}

		task ("When the user selects the Async option in Type field") {
			Select(
				key_fieldLabel = "Type",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Async");
		}

		task ("And fills URL field") {
			Type(
				key_fieldId = "URL",
				locator1 = "TextArea#ANY_ID",
				value1 = "wwww.liferay.com");
		}

		task ("Then Confirm that the DELETE option is selected by default.") {
			AssertElementPresent(
				key_fieldLabel = "Method",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "DELETE");
		}

		task ("When the user selects the Method option") {
			Select(
				key_fieldLabel = "Method",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "DELETE");
		}

		task ("Then The options GET, POST, PATCH, DELETE are present in the Method dropdown") {
			for (var assertFields : list "GET,POST,PATCH,DELETE") {
				AssertElementPresent(
					key_fieldLabel = "Method",
					locator1 = "Select#GENERIC_SELECT_FIELD",
					value1 = ${assertFields});
			}
		}

		task ("And confirm that it is not possible to save the action") {
			AssertVisible(
				key_title = "New Item Action",
				locator1 = "Header#H2_TITLE");
		}
	}

	@description = "LPS-191485. Verify if when the user selects the Headless option, the following fields are displayed in the modal in the Item Action"
	@priority = 3
	test AssertAllTypeOptionsArePresentOnItemAction {
		task ("When clicks on New Action button") {
			Click(
				key_text = "New Item Action",
				locator1 = "Button#ANY_SECONDARY");
		}

		task ("And the user selects the Headless option in Type field") {
			Select(
				key_fieldLabel = "Type",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = "Headless");
		}

		task ("Then Headless Action Key, Confirmation Message, Message Type are displayed") {
			AssertElementPresent(
				key_placeholder = "Add a value here.",
				locator1 = "FrontendDataSet#PLACEHOLDER");

			AssertElementPresent(
				key_placeholder = "Add a message here.",
				locator1 = "FrontendDataSet#PLACEHOLDER");

			AssertElementPresent(
				key_fieldLabel = "Message Type",
				locator1 = "Select#GENERIC_SELECT_FIELD");
		}
	}

	@description = "LPS-194351 Confirm that the field field cannot be edited in the Creation Action"
	@priority = 4
	test CanAssertThatTheTypeFieldIsDisabledInCreationAction {
		task ("And creates a new item action") {
			DataSetAdmin.addActions(
				actionName = "Edit",
				actionTab = "Creation Actions",
				icon = "pencil",
				type = "Link",
				url = "https://gist.github.com/deborasoliveira/40716d0b03d33ff7e636ca5d366c79c5#file-link-action-url-example");
		}

		task ("When the user clicks on the new item action 3 dots button and edit") {
			Click(
				key_index = 2,
				key_text = "Actions",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_N");

			Click(
				key_menuItem = "Edit",
				locator1 = "MenuItem#DROPDOWN_MENU_ITEM");
		}

		task ("Then Error messages are displayed and the save button is disabled") {
			AssertElementPresent(
				key_placeholderText = "Please select an option.",
				locator1 = "DataSet#ANY_DISABLED");
		}
	}

	@description = "LPS-194351 confirm that when creating an action, and clicking on the three dots button, the "Edit" option is displayed in the Creation Action"
	@priority = 3
	test CanAssertTheEditButtonActionInCreationAction {
		task ("And creates a new item action") {
			DataSetAdmin.addActions(
				actionName = "Edit",
				actionTab = "Creation Actions",
				icon = "pencil",
				type = "Link",
				url = "https://gist.github.com/deborasoliveira/40716d0b03d33ff7e636ca5d366c79c5#file-link-action-url-example");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_index = 2,
				key_text = "Actions",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_N");

			AssertElementPresent(
				key_menuItem = "Edit",
				locator1 = "MenuItem#DROPDOWN_MENU_ITEM");
		}

		task ("Then the Delete and Edit option is listed in the dropdown menu") {
			AssertElementPresent(
				key_menuItem = "Delete",
				locator1 = "MenuItem#DROPDOWN_MENU_ITEM");
		}
	}

	@description = "LPS-194351 Confirm that a created action can be deleted, and a success message is displayed in the Creation Action"
	@priority = 5
	test CanBeDeletedAction {
		property portal.acceptance = "true";

		task ("And clicks on Create Item Action button") {
			DataSetAdmin.addActions(
				actionName = "Edit",
				actionTab = "Creation Actions",
				icon = "pencil",
				readlessAction = "xx-ee",
				type = "Link",
				url = "https://gist.github.com/deborasoliveira/40716d0b03d33ff7e636ca5d366c79c5#file-link-action-url-example");
		}

		task ("And clicks on the Edit option and clicks on delete button") {
			Click(
				key_index = 2,
				key_text = "Actions",
				locator1 = "DataSet#VERTICAL_ELLIPSIS_N");

			Click(
				key_menuItem = "Delete",
				locator1 = "MenuItem#DROPDOWN_MENU_ITEM");
		}

		task ("Then a modal is opened with the message: “Are you sure you want to delete this action?/ and click on delete") {
			AssertElementPresent(
				key_modalText = "Are you sure you want to delete this action?",
				locator1 = "DataSet#DELETE_DATA_SET_MODAL_BODY");

			Click(locator1 = "Button#MODAL_DELETE");
		}

		task ("Then a successful toast message is displayed and the creation action list is empty") {
			AssertTextEquals.assertPartialText(
				locator1 = "Message#SUCCESS",
				value1 = "Your request completed successfully.");

			AssertElementNotPresent(
				key_position = 1,
				keyName = "Edit",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

	@description = "LPS-191486. Verify if the user can cancel the deletion of an entry by clicking the Cancel button"
	@priority = 4
	test CanCancelADeletionInCancelButton {
		task ("And creates an item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				icon = "trash",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("Then the Delete option is displayed in the item action dropdown menu") {
			MenuItem.viewPresent(menuItem = "Delete");
		}

		task ("When the user clicks on the Delete option") {
			MenuItem.click(menuItem = "Delete");
		}

		task ("Then the Delete modal appears") {
			AssertVisible(locator1 = "Modal#BODY");
		}

		task ("When the user clicks on Cancel button") {
			Button.clickCancel();
		}

		task ("Then the Delete modal is closed") {
			AssertElementNotPresent(locator1 = "Modal#BODY");
		}

		task ("And the item action is present in the item action list") {
			AssertElementPresent(
				key_position = 1,
				keyName = "delete",
				locator1 = "DataSet#FIELDS_TABLE");
		}
	}

	@description = "LPS-191486. Verify if the user can cancel the deletion of an entry by clicking the Close(x) button"
	@priority = 3
	test CanCancelADeletionInXButton {
		task ("And creates an item action") {
			DataSetAdmin.addActions(
				actionName = "delete",
				icon = "trash",
				type = "Link",
				url = "http://localhost:8080/o/data-set-manager/");
		}

		task ("When the user clicks on the new item action 3 dots button") {
			Click(
				key_tableEntry = "delete",
				locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS");
		}

		task ("Then the Delete option is displayed in the item action dropdown menu") {
			MenuItem.viewPresent(menuItem = "Delete");
		}

		task ("When the user clicks on the Delete option") {
			MenuItem.click(menuItem = "Delete");
		}

		task ("Then the Delete modal appears") {
			AssertVisible(locator1 = "Modal#BODY");
		}

		task ("When the user clicks on Close button") {
			Click(
				key_modalTitle = "Delete action?",
				locator1 = "Button#CLOSE_MODAL");
		}

		task ("Then the Delete modal is closed") {
			AssertElementNotPresent(locator1 = "Modal#BODY");
		}

		task ("And the item action is present in the item action list") {
			AssertElementPresent(
