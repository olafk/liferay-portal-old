@component-name = "portal-analytics-cloud"
definition {

	property analytics.cloud.release = "true";
	property analytics.cloud.upstream = "true";
	property portal.release = "false";
	property portal.upstream = "true";
	property property.group = "analytics.cloud.profile";
	property testray.main.component.name = "Analytics Cloud";

	static var nameABTest = "AB Test";

	setUp {
		task ("Copy the token from AC") {
			ACUtils.launchAC();

			ACSettings.takeTokenFromAnalyticsCloud();
		}

		task ("Set up instance and sign in DXP") {
			TestCase.setUpPortalInstance();

			ACUtils.launchDXP();
		}

		task ("Add a new site with a public widget page") {
			ACUtils.addSiteAndPage(type = "content");
		}

		task ("Connect DXP to Analytics Cloud") {
			ACDXPSettings.connectDXPtoAnalyticsCloud(siteName = "Site Name");
		}

		task ("Go to Site Page") {
			ACUtils.navigateToSitePage(
				pageName = "AC Page",
				siteName = "Site Name");
		}

		task ("Create an AB Test") {
			ABTest.createABTest(
				goal = "Bounce Rate",
				testTitle = ${nameABTest});

			ABTest.createVariant(variantName = "Variant name");
		}
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		// It is not possible to delete properties and data source after LRAC-13389. This functionality should return after LRAC-8040

		//ACUtils.tearDownAC();

		ACUtils.tearDownABTest();

		ACUtils.tearDownDXP();

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			JSONGroup.deleteGroupByName(groupName = "Site Name");
		}
	}

	@description = "Story: LRAC-14220 | Automation ID: LRAC-14444 | Test Summary: Draft AB test delete button redirects to DXP"
	@priority = 3
	test ABTestDraftDeleteButtonRedirectsToDXP {
		task ("Go to AC > Tests > Open your test") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});

			ACNavigation.goToTests();

			ACNavigation.openItem(itemName = ${nameABTest});
		}

		task ("Click on the delete button on the top") {
			Button.clickDelete();
		}

		task ("Get site assigned property name and get data source name") {
			var dataSource = StringUtil.extractFirst(${assignedPropertyName}, " ");
		}

		task ("Click on the new tab open and delete the created AB test") {
			SelectWindow(locator1 = "title=AC Page - Site Name - ${dataSource}");

			AssertTextEquals.assertPartialText(
				locator1 = "Modal#MODAL_CONTENT",
				value1 = "Are you sure you want to delete this? It will be deleted immediately. You will lose all data related to it. You will not be able to undo this operation.");

			Click(locator1 = "ACSettings#CONFIRMATION_BUTTON");

			Alert.viewSuccessMessageText(successMessage = "Success:Your request completed successfully.");
		}

		task ("Assert the empty state after the test is deleted") {
			ABTest.assertDXPABTestEmptyState();
		}

		task ("Go to AC > Tests > Assert the empty state") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});

			ACNavigation.goToTests();

			ACUtils.viewGenericText(textValueList = "There are no tests found.");

			ACUtils.viewGenericText(textValueList = "Create a new test from Liferay DXP by clicking on the , icon in the toolbar when viewing a page in DXP.");
		}
	}

	@description = "Story: LRAC-14220 | Automation ID: LRAC-14445 | Test Summary: Draft AB test Review button redirects to DXP"
	@priority = 3
	test ABTestDraftReviewButtonRedirectsToDXP {
		task ("Go to AC > Tests > Open your test") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});

			ACNavigation.goToTests();

			ACNavigation.openItem(itemName = ${nameABTest});
		}

		task ("Click on the review button on the top") {
			Button.click(button = "Review");
		}

		task ("Get site assigned property name and get data source name") {
			var dataSource = StringUtil.extractFirst(${assignedPropertyName}, " ");
		}

		task ("See the redirection to the review and run test modal in DXP") {
			task ("Go to the new tab open") {
				SelectWindow(locator1 = "title=AC Page - Site Name - ${dataSource}");
			}

			task ("Assert the review and run modal is open") {
				AssertTextEquals.assertPartialText(
					locator1 = "Modal#MODAL_CONTENT",
					value1 = "Review and Run Test");
			}
		}
	}

	@description = ""
	@priority = 4
	test AssertPublishButtonNoLongerShownAndDeleteButtonDeletesTestInAC {
		task ("Click to open the AB test panel") {
			ABTest.openABTestPanel();

			task ("Click to review and run the test") {
				ABTest.runTest();
			}
		}

		task ("Click to terminate the test on DXP side") {
			Button.click(button = "Terminate Test");

			ABTest.assertTerminateTest();
		}

		task ("Create a new AB test") {
			ABTest.createABTest(
				goal = "Bounce Rate",
				testTitle = "AB Test 2");

			ABTest.createVariant(variantName = "Variant name 2");
		}

		task ("Go to AC > Tests") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});

			ACNavigation.goToTests();
		}

		task ("Select the first created test") {
			ACNavigation.openItem(itemName = ${nameABTest});
		}

		task ("Assert the publish button is no longer shown") {
			AssertElementNotPresent(
				key_text = "Publish",
				locator1 = "Button#ANY");
		}

		task ("Delete the test and assert the test is no longer shown in the list") {
			ABTest.deleteABTestACSide();

			ACNavigation.goToTests();

			ACUtils.assertItemsNameNotPresent(itemList = ${nameABTest});
		}
	}

	@description = "Story: LRAC-14070 | Automation ID: LRAC-14574 | Test Summary: Can publish control from a terminated test"
	@priority = 5
	test CanPublishControlFromTerminatedTest {
		task ("Edit the variant created") {
			ABTest.editVariant(variantName = "Variant name");
		}

		task ("Add a heading to the page to diferentiate from the control") {
			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");
		}

		task ("Click to save the variant") {
			ABTest.saveVariant();
		}

		task ("Click to open the AB test panel") {
			ABTest.openABTestPanel();

			task ("Click to review and run the test") {
				ABTest.runTest();
			}
		}

		task ("Click to terminate the test") {
			Button.click(button = "Terminate Test");

			ABTest.assertTerminateTest();
		}

		task ("Click to publish the control") {
			ABTest.publishVariant(variantName = "Control");
		}

		task ("Assert the alert is shown") {
			Alert.viewSuccessMessageText(successMessage = "Success:Control was published successfully.");
		}

		task ("Assert the control is published") {
			AssertElementNotPresent(
				locator1 = "Experience#FRAGMENT_HEADING",
				value1 = "Heading Example");
		}

		task ("Click to edit the page and add a widget to the page and then click save") {
			ContentPages.gotoPageEditor();

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			PageEditor.publish();
		}

		task ("Assert if the page is published with the modifications") {
			PageEditor.viewFragment(fragmentName = "Button");
		}

		task ("Go to AC and open the AB test") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});

			ACNavigation.goToTests();

			ACNavigation.openItem(itemName = ${nameABTest});
		}

		task ("Assert the AB Test") {
			ACUtils.wGenericTextInOrder(textValueList = ${nameABTest});
		}
	}

	@description = "Story: LRAC-14070 | Automation ID: LRAC-14573 | Test Summary: Can publish variant from a terminated test and delete test in AC"
	@priority = 5
	test CanPublishVariantFromTerminatedTestAndDeleteTest {
		task ("Edit the variant created") {
			ABTest.editVariant(variantName = "Variant name");
		}

		task ("Add a heading to the page to diferentiate from the control") {
			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");
		}

		task ("Click to save the variant") {
			ABTest.saveVariant();
		}

		task ("Click to open the AB test panel") {
			ABTest.openABTestPanel();

			task ("Click to review and run the test") {
				ABTest.runTest();
			}
		}

		task ("Terminate the test") {
			ACTests.terminateABTest(testName = ${nameABTest});
		}

		task ("Click to publish the variant") {
			ABTest.publishVariant(variantName = "Variant name");
		}

		task ("Assert the alert is shown") {
			Alert.viewSuccessMessageText(successMessage = "Success:Variant name was published successfully.");
		}

		task ("Assert the variant published") {
			ContentPages.viewFragmentText(
				fragmentName = "heading",
				id = "element-text",
				text = "Heading Example");
		}

		task ("Now edit the variant and add a widget to the page and then click save") {
			ContentPages.gotoPageEditor();

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Button");

			PageEditor.publish();
		}

		task ("Assert if the page is published with the modifications") {
			PageEditor.viewFragment(fragmentName = "Button");
		}

		task ("Go to AC > Tests") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});

			ACNavigation.goToTests();
		}

		task ("Open the AB test") {
			ACNavigation.openItem(itemName = ${nameABTest});
		}

		task ("Delete the test in AC") {
			ABTest.deleteABTestACSide();
		}

		task ("Assert the test is no longer present in the list") {
			ACUtils.assertItemsNameNotPresent(itemList = ${nameABTest});
		}
	}

	@description = "Story: LRAC-14101 | Automation ID: LRAC-14542 | Test Summary: Terminate button in AC is redirecting to DXP"
	@priority = 3
	test CheckTerminateButtonRedirectingToDXP {
		task ("Click on Review and Run test") {
			ABTest.runTest();
		}

		task ("Go to AC > Tests > Open your test") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});

			ACNavigation.goToTests();

			ACNavigation.openItem(itemName = ${nameABTest});
		}

		task ("Click on the terminate button on the top") {
			Button.click(button = "Terminate");
		}

		task ("Get site assigned property name and get data source name") {
			var dataSource = StringUtil.extractFirst(${assignedPropertyName}, " ");
		}

		task ("Click on the new tab open and terminate the created AB test") {
			SelectWindow(locator1 = "title=AC Page - Site Name - ${dataSource}");

			ABTest.assertTerminateTest();
		}

		task ("Check that the test status is terminated") {
			ABTest.statusABTestInDXP(status = "Terminated");
		}

		task ("Check that the alert explaining that the AB test was terminated manually appears") {
			Alert.viewWarningSpecific(warningMessage = "The test has not gathered sufficient data to confidently determine a winner. However, variants can still be published.");
		}

		task ("Check that the create new test button is present") {
			AssertElementPresent(
				key_text = "Create New Test",
				locator1 = "Button#ANY");
		}
	}

}