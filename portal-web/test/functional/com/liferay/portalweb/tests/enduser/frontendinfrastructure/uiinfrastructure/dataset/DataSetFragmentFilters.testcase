				dataSetViewName = "View Test",
				pageName = "Data Set Page");
		}

		task ("Then the filter appears in the filter menu") {
			Click(locator1 = "FrontendDataSet#FILTER_BUTTON");

			AssertVisible(
				key_filter = "Filter Transport",
				locator1 = "FrontendDataSet#FILTER_OPTION");

			Click(locator1 = "FrontendDataSet#FILTER_BUTTON");
		}

		task ("When the user adds a new value in the filter") {
			DataSetAdmin.editFragmentFilter(
				filterName = "Filter Transport",
				newFilterValue = "bike");
		}

		task ("Then the filter is edited") {
			AssertVisible(
				key_filterName = "Filter Transport: bike",
				locator1 = "DataSet#DATA_SET_FRAGMENT_FILTER");
		}
	}

	@description = "LPS-191295. Confirm that after created a filter is displayed in the fragment and it is also possible to apply it. "
	@priority = 5
	test CanApplyFilter {
		property portal.acceptance = "true";
		
		task ("Given a new Object entity") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Date Object",
				objectName = "DateObject",
				pluralLabelName = "Date Objects");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Date",
				fieldLabelName = "Date Field",
				fieldName = "dateField",
				fieldType = "Date",
				isRequired = "false",
				objectName = "DateObject");

			ObjectAdmin.publishObjectViaAPI(objectName = "DateObject");
		}

		task ("And new entries in the new Object entity") {
			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "dateField",
				objectName = "DateObject",
				value = "2023-06-06");

			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "dateField",
				objectName = "DateObject",
				value = "2023-02-02");

			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "dateField",
				objectName = "DateObject",
				value = "2023-03-03");
		}

		task ("And creating a Data Set entry, view and fields") {
			DataSetAdmin.createAndConfigureDataSetEntry(
				dataSetName = "Custom Data Set Entry",
				dataSetViewDescription = "View Description",
				dataSetViewName = "Date filters view",
				key_fieldList = "dateField,id,dateCreated",
				restApplication = "/c/dateobjects",
				restEndpoint = "/",
				restSchema = "DateObject");
		}

		task ("and add date filter to view") {
			DataSetAdmin.goToTab(tabName = "Filters");

			DataSetAdmin.createDateFilter(
				fieldValueFrom = "2023-01-01",
				fieldValueTo = "2023-03-10",
				filterBy = "dateField",
				filterName = "Date Filter 1",
				valueDayFrom = 1,
				valueDayTo = 10,
				valueMonthFrom = "January",
				valueMonthTo = "March",
				valueYearFrom = 2023,
				valueYearTo = 2023);
		}

		task ("And adds the data set Fragment portlet in the page") {
			DataSetFragment.setUpDataSetPage(
				dataSetViewName = "Date filters view",
				pageName = ${pageName});
		}

		task ("Then Confirm that only data within the filter range is shown") {
			AssertElementPresent(
				key_labelName = "2023-02-02T00:00:00Z",
				key_rowPosition = 1,
				locator1 = "DataSet#VIEW_LABEL_POSITION");

			AssertElementPresent(
				key_labelName = "2023-03-03T00:00:00Z",
				key_rowPosition = 2,
				locator1 = "DataSet#VIEW_LABEL_POSITION");
		}
	}

	@description = "Blocked by LPS-198444 | LPS-191295. Confirm that after created a filter is displayed in the fragment and it is also possible to apply it. "
	@ignore = "true"
	@priority = 4
	test CanChangeFilters {

		// TODO LPS-191295 CanChangeFilters pending implementation

	}

	@description = "LPS-191295. It's possible to remove a filter from the fragment"
	@priority = 4
	test CanRemoveFilter {
		task ("Given a new Object entity") {
			ObjectAdmin.addObjectViaAPI(
				labelName = "Date Object",
				objectName = "DateObject",
				pluralLabelName = "Date Objects");

			ObjectAdmin.addObjectFieldViaAPI(
				fieldBusinessType = "Date",
				fieldLabelName = "Date Field",
				fieldName = "dateField",
				fieldType = "Date",
				isRequired = "false",
				objectName = "DateObject");

			ObjectAdmin.publishObjectViaAPI(objectName = "DateObject");
		}

		task ("And new entries in the new Object entity") {
			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "dateField",
				objectName = "DateObject",
				value = "2023-06-06");

			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "dateField",
				objectName = "DateObject",
				value = "2023-02-02");

			ObjectAdmin.addObjectSingleFieldEntryViaAPI(
				fieldName = "dateField",
				objectName = "DateObject",
				value = "2023-03-03");
		}

		task ("And creating a Data Set entry, view and fields") {
			DataSetAdmin.createAndConfigureDataSetEntry(
				dataSetName = "Custom Data Set Entry",
				dataSetViewDescription = "View Description",
				dataSetViewName = "Date filters view",
				key_fieldList = "dateField,id,dateCreated",
				restApplication = "/c/dateobjects",
				restEndpoint = "/",
				restSchema = "DateObject");
		}

		task ("and add date filter to view") {
			DataSetAdmin.goToTab(tabName = "Filters");

			DataSetAdmin.createDateFilter(
				fieldValueFrom = "2023-01-01",
				fieldValueTo = "2023-03-10",
				filterBy = "dateField",
				filterName = "Date Filter 1",
				valueDayFrom = 1,
				valueDayTo = 10,
				valueMonthFrom = "January",
				valueMonthTo = "March",
				valueYearFrom = 2023,
				valueYearTo = 2023);
		}

		task ("And adds the data set Fragment portlet in the page") {
			DataSetFragment.setUpDataSetPage(
				dataSetViewName = "Date filters view",
				pageName = ${pageName});
		}

		task ("And open the menu of filters") {
			FrontendDataSetFilters.removeFilter(key_filter = "Date Filter 1");
		}

		task ("Then Confirm that all fields are shown") {
			AssertElementPresent(
				key_labelName = "2023-06-06T00:00:00Z",
				key_rowPosition = 1,
				locator1 = "DataSet#VIEW_LABEL_POSITION");

			AssertElementPresent(
				key_labelName = "2023-02-02T00:00:00Z",
				key_rowPosition = 2,
				locator1 = "DataSet#VIEW_LABEL_POSITION");

			AssertElementPresent(
				key_labelName = "2023-03-03T00:00:00Z",
				key_rowPosition = 3,
				locator1 = "DataSet#VIEW_LABEL_POSITION");
		}
	}

