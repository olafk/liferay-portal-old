			DataSetAdmin.selectRadioButtonOption(optionName = "Multiple");

			DataSetAdmin.selectPreSelectedValue(preSelectedValue = "car");

			DataSetAdmin.selectPreSelectedValue(preSelectedValue = "bus");

			DataSetAdmin.selectPreSelectedValue(preSelectedValue = "bike");
		}

		task ("And the filter mode is Include") {
			DataSetAdmin.selectRadioButtonOption(optionName = "Include");

			Click(
				locator1 = "Button#SAVE",
				value1 = "Save");
		}

		task ("When the user adds the new data set view to a new content page") {
			DataSetFragment.setUpDataSetPage(
				dataSetViewName = "View Test",
				pageName = "Data Set Page");
		}

		task ("Then the filter appears in the filter menu") {
			AssertVisible(
				key_filterName = "Filter Transport: car, bus, bike",
				locator1 = "DataSet#DATA_SET_FRAGMENT_FILTER");
		}
	}

