@component-name = "portal-frontend-infrastructure"
definition {

	property custom.properties = "feature.flag.LPS-164563=true${line.separator}feature.flag.LPS-188645=true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Frontend Data Set";
	property testray.main.component.name = "Frontend Data Set";

	var pageName = "Data Set Test Page";

	setUp {
		var portalURL = PropsUtil.get("portal.url");

		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		JSONLayout.deletePublicLayout(
			groupName = "Guest",
			layoutName = ${pageName});

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			DataSetAdmin.deleteAllDataSetEntries();
		}
	}

	@description = "LPS-185995 Verify it's possible to create a exclude selection filter with pre populated values."
	@priority = 4
	test AssertExcludeSingleSelectionPrePopulatedFilterIsDisplayed {
		task ("Given a picklist") {
			Picklist.addPicklistViaAPI(picklistName = "Transport");
		}

		task ("And adding items to the created picklist") {
			Picklist.addPicklistItemViaAPI(
				itemKey = "bike",
				itemName = "bike",
				picklistName = "Transport");

			Picklist.addPicklistItemViaAPI(
				itemKey = "car",
				itemName = "car",
				picklistName = "Transport");

			Picklist.addPicklistItemViaAPI(
				itemKey = "bus",
				itemName = "bus",
				picklistName = "Transport");
		}

		task ("And a new Objects entity using the new picklist in a field") {
			ObjectAdmin.openObjectAdmin();

			ObjectAdmin.addObjectViaAPI(
				labelName = "Filter Transport",
				objectName = "FilterTransport",
				pluralLabelName = "Filters Transport");

			Refresh();

			Click(
				key_labelName = "Filter Transport",
				locator1 = "CreateObject#OBJECT_NAME");

			ObjectAdmin.goToFieldsTab();

			ObjectAdmin.addObjectFieldViaUI(
				fieldLabel = "Field Picklist",
				fieldPicklist = "Transport",
				fieldType = "Picklist");

			ObjectAdmin.goToDetailsTab();

			ObjectAdmin.selectDropdownItem(
				labelName = "Panel Link",
				optionName = "Object");

			ObjectAdmin.publishObjectViaUI();
		}

		task ("And add new entries to the new Object entity") {
			ApplicationsMenu.gotoPortlet(
				category = "Object",
				panel = "Control Panel",
				portlet = "Filters Transport");

			ObjectAdmin.addObjectPicklistFieldEntryViaUI(
				labelName = "Field Picklist",
				picklistOption = "car");

			Click(
				key_text = "angle-left",
				locator1 = "Icon#ANY");

			ObjectAdmin.addObjectPicklistFieldEntryViaUI(
				labelName = "Field Picklist",
				picklistOption = "bike");
		}

		task ("When the user creates a new data set ") {
			DataSetAdmin.goToDataSetAdminPage();

			DataSetAdmin.createDataSet(
				key_name = "Data Set Test",
				key_type = "/c/filtertransports");
		}

		task ("And a new view") {
			DataSetAdmin.goToViews(dataSetName = "Data Set Test");

			DataSetAdmin.createDataSetView(
				description = "Description",
				key_name = "View Test");

			DataSetAdmin.goToSpecificViewPage(
				dataSetName = "Data Set Test",
				key_viewName = "View Test");
		}

		task ("When the user creates a single selection filter") {
			DataSetAdmin.chooseFilterType(filterType = "Selection");

			PortletEntry.inputName(name = "Filter Transport");

			DataSetAdmin.selectFilterBy(filterByField = "creator");

			Select(
				locator1 = "DataSet#SOURCE_OPTIONS_SELECT",
				value1 = "Transport");

			DataSetAdmin.selectRadioButtonOption(optionName = "Single");

			DataSetAdmin.selectPreSelectedValue(preSelectedValue = "bike");
		}

		task ("And the filter mode is Exclude") {
			Click(
				key_optionName = "Exclude",
				locator1 = "DataSet#RADIO_BUTTON_OPTION");

			Click(
				locator1 = "Button#SAVE",
				value1 = "Save");
		}

		task ("When the user adds the new data set view to a new content page") {
			DataSetFragment.setUpDataSetPage(
				dataSetViewName = "View Test",
				pageName = "Data Set Page");
		}

		task ("Then the filter appears in the filter menu") {
			AssertVisible(
				key_filterName = "Filter Transport: (Exclude) bike",
				locator1 = "DataSet#DATA_SET_FRAGMENT_FILTER");
		}
	}

	@description = "LPS-185995 Verify it's possible create a include selection filter with pre populated values."
	@priority = 4
	test AssertIncludeMultipleSelectionPrePopulatedFilterIsDisplayed {
		task ("Given a picklist") {
			Picklist.addPicklistViaAPI(picklistName = "Transport");
		}

		task ("And adding items to the created picklist") {
