		}

		task ("When the user creates a multiple selection filter") {
			DataSetAdmin.chooseFilterType(filterType = "Selection");

			PortletEntry.inputName(name = "Filter Transport");

			DataSetAdmin.selectFilterBy(filterByField = "creator");

			Select(
