@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property test.liferay.virtual.instance = "false";
	property test.run.type = "single";
	property testray.component.names = "Upgrades WEM";
	property testray.main.component.name = "Nested Portlets Widget";

	setUp {
		SignIn.signIn();

		var portalURL = PropsUtil.get("portal.url");

		AssertLocation(value1 = "${portalURL}/web/guest?SM_USER=test@liferay.com");

		SearchAdministration.executeReindex();
	}

	@description = "View nested portlets after upgrade from 625."
	@priority = 5
	test ViewNestedPortletsArchive625 {
		property data.archive.type = "data-archive-nested-portlets";
		property database.types = "mariadb,mysql,postgresql";
		property portal.version = "6.2.5";

		ValidateWebContentUpgrade.viewNestedPortlets();
	}

	@description = "View nested portlets after upgrade from 621015."
	@priority = 5
	test ViewNestedPortletsArchive621015 {
		property data.archive.type = "data-archive-nested-portlets";
		property database.types = "db2,mariadb,mysql,oracle,postgresql,sybase";
		property portal.version = "6.2.10.15";

		ValidateWebContentUpgrade.viewNestedPortlets();
	}

	@description = "View nested portlets after upgrade from 621021."
	@priority = 5
	test ViewNestedPortletsArchive621021 {
		property data.archive.type = "data-archive-nested-portlets";
		property database.types = "db2,mariadb,mysql,oracle,postgresql,sybase";
		property portal.version = "6.2.10.21";

		ValidateWebContentUpgrade.viewNestedPortlets();
	}

	@description = "This is a use case for LPS-66141. View nested portlets in staging site after upgrade from 625."
	@priority = 5
	test ViewStagingNestedPortletsArchive625 {
		property data.archive.type = "data-archive-staging-nested-portlets";
		property database.types = "mariadb,mysql,postgresql";
		property portal.version = "6.2.5";

		ValidateStagingUpgrade.viewStagingNestedPortlets();
	}

	@description = "This is a use case for LPS-66141. View nested portlets in staging site after upgrade from 62105."
	@priority = 5
	test ViewStagingNestedPortletsArchive621015 {
		property data.archive.type = "data-archive-staging-nested-portlets";
		property database.types = "db2,mariadb,mysql,oracle,postgresql,sybase";
		property portal.version = "6.2.10.15";

		ValidateStagingUpgrade.viewStagingNestedPortlets();
	}

	@description = "This is a use case for LPS-66141. View nested portlets in staging site after upgrade from 621021."
	@priority = 5
	test ViewStagingNestedPortletsArchive621021 {
		property data.archive.type = "data-archive-staging-nested-portlets";
		property database.types = "db2,mariadb,mysql,oracle,postgresql,sybase";
		property portal.version = "6.2.10.21";

		ValidateStagingUpgrade.viewStagingNestedPortlets();
	}

}