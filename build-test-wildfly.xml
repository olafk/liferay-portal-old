<?xml version="1.0"?>

<project basedir="." default="test" name="portal-test-wildfly" xmlns:antelope="antlib:ise.antelope.tasks">
	<import file="build-test.xml" />

	<target name="run-selenium-wildfly">
		<lstopwatch action="start" name="run.selenium.wildfly" />

		<app-server-properties-update>
			app.server.type=wildfly
		</app-server-properties-update>

		<if>
			<not>
				<isset property="build.app.server" />
			</not>
			<then>
				<ant antfile="build-dist.xml" target="build-dist-wildfly" />
			</then>
		</if>

		<antcall target="record-test-generated-properties" />

		<antcall target="prepare-virtual-host-name-properties" />

		<antcall inheritAll="false" target="run-wildfly">
			<param name="test.class" value="${test.class}" />
		</antcall>

		<lstopwatch action="total" name="run.selenium.wildfly" />
	</target>

	<target name="run-wildfly">
		<lstopwatch action="start" name="run.wildfly" />

		<antcall target="run-simple-server" />

		<lstopwatch action="total" name="run.wildfly" />
	</target>

	<target name="setup-wildfly-playwright">
		<lstopwatch action="start" name="setup.jboss" />

		<app-server-properties-update>
			app.server.type=wildfly
		</app-server-properties-update>

		<set-app-server-version-number app.server.type="wildfly" app.server.version="30.0.0" />

		<antcall target="prepare-osgi-module-configurations" />

		<antcall target="prepare-portal-properties" />

		<antcall target="prepare-portal-ext-properties" />

		<antcall target="prepare-portlet-ext-properties" />

		<antcall target="prepare-system-ext-properties" />

		<prepare-app-server-configuration />

		<prepare-database-jndi />

		<antcall target="clean-app-server-deploy-dir" />

		<lstopwatch action="total" name="setup.jboss" />
	</target>

	<target name="stop-wildfly-playwright">
		<lstopwatch action="start" name="setup.jboss" />

		<antcall target="stop-app-server" />

		<lstopwatch action="total" name="setup.jboss" />
	</target>
</project>