components:
    schemas:
        CollectionType:
            default: "all"
            type: string
        ExternalLink:
            properties:
                dateCreated:
                    description:
                        The external link's creation date.
                    format: date-time
                    readOnly: true
                    type: string
                # DOMAIN
                domain:
                    description:
                        The external domain.
                    type: string
info:
