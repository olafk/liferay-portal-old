package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Wilson Ferreira
 */
public class LPD_53535 {

	public void method() {
		CommerceInventoryBookedQuantityLocalServiceUtil.deleteCommerceInventoryBookedQuantity(_commerceOrderItem.getCommerceInventoryBookedQuantityId());
		_commerceOrderItemWrapper.getCommerceInventoryBookedQuantityId();
	}

	public void method(long bookedQuantityId) {
		CommerceOrderItemLocalServiceUtil.fetchCommerceOrderItemByCommerceInventoryBookedQuantityId(bookedQuantityId);
		CommerceOrderItemUtil.countByCommerceInventoryBookedQuantityId(bookedQuantityId);
		CommerceOrderItemUtil.fetchByCommerceInventoryBookedQuantityId(bookedQuantityId);
		CommerceOrderItemUtil.findByCommerceInventoryBookedQuantityId(bookedQuantityId);
		CommerceOrderItemUtil.removeByCommerceInventoryBookedQuantityId(bookedQuantityId);
		_commerceOrderItemLocalService.fetchCommerceOrderItemByCommerceInventoryBookedQuantityId(bookedQuantityId);
		_commerceOrderItemLocalServiceWrapper.fetchCommerceOrderItemByCommerceInventoryBookedQuantityId(bookedQuantityId);
		_commerceOrderItemWrapper.setCommerceInventoryBookedQuantityId(bookedQuantityId);
	}

	private CommerceOrderItem _commerceOrderItem;

	@Reference
	private CommerceOrderItemLocalService _commerceOrderItemLocalService;

	private CommerceOrderItemLocalServiceWrapper _commerceOrderItemLocalServiceWrapper;
	private CommerceOrderItemWrapper _commerceOrderItemWrapper;

}