package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Mateus Xavier
 */
public class LPD_41244 {

	public void method(
		long cpInstanceId, long cProductId, long commercePriceListId,
		String externalReferenceCode, String cpInstanceUuid, BigDecimal price,
		BigDecimal promoPrice, ServiceContext serviceContext) {

		CommercePriceEntryLocalServiceUtil.addCommercePriceEntry(cpInstanceId, commercePriceListId, price, promoPrice, serviceContext);
		_commercePriceEntryLocalService.addCommercePriceEntry(123, commercePriceListId, price, promoPrice, serviceContext);
		_commercePriceEntryLocalService.addCommercePriceEntry(cpInstanceId, commercePriceListId, price, promoPrice, serviceContext);

		CommercePriceEntryLocalServiceUtil.addCommercePriceEntry(cpInstanceId, commercePriceListId, externalReferenceCode, price, promoPrice, serviceContext);
		_commercePriceEntryLocalService.addCommercePriceEntry(123, commercePriceListId, externalReferenceCode, price, promoPrice, serviceContext);
		_commercePriceEntryLocalService.addCommercePriceEntry(cpInstanceId, commercePriceListId, externalReferenceCode, price, promoPrice, serviceContext);

		CommercePriceEntryLocalServiceUtil.addCommercePriceEntry(cProductId, cpInstanceUuid, commercePriceListId, price, promoPrice, serviceContext);
		_commercePriceEntryLocalService.addCommercePriceEntry(123, cpInstanceUuid, commercePriceListId, price, promoPrice, serviceContext);
		_commercePriceEntryLocalService.addCommercePriceEntry(cProductId, cpInstanceUuid, commercePriceListId, price, promoPrice, serviceContext);

		CommercePriceEntryServiceUtil.addCommercePriceEntry(cpInstanceId, commercePriceListId, price, promoPrice, serviceContext);
		_commercePriceEntryService.addCommercePriceEntry(123, commercePriceListId, price, promoPrice, serviceContext);
		_commercePriceEntryService.addCommercePriceEntry(cpInstanceId, commercePriceListId, price, promoPrice, serviceContext);

		CommercePriceEntryServiceUtil.addCommercePriceEntry(cpInstanceId, commercePriceListId, externalReferenceCode, price, promoPrice, serviceContext);
		_commercePriceEntryService.addCommercePriceEntry(123, commercePriceListId, externalReferenceCode, price, promoPrice, serviceContext);
		_commercePriceEntryService.addCommercePriceEntry(cpInstanceId, commercePriceListId, externalReferenceCode, price, promoPrice, serviceContext);
	}

	@Reference
	private CommercePriceEntryLocalService _commercePriceEntryLocalService;

	@Reference
	private CommercePriceEntryService _commercePriceEntryService;

}