package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Agnes Maciel
 */
public class LPD_47117 {

	public void method(
		long userId, String className, long classPK, String name,
		Map<Locale, String> titleMap, Map<Locale, String> descriptionMap,
		int type, String subtype, ServiceContext serviceContext) {

		RoleLocalServiceUtil.addRole(123, className, classPK, name, titleMap, descriptionMap, type, subtype, serviceContext);
		RoleLocalServiceUtil.addRole(null, userId, className, classPK, name, titleMap, descriptionMap, type, subtype, serviceContext);
		RoleServiceUtil.addRole("test123", classPK, name, titleMap, descriptionMap, type, subtype, serviceContext);
		RoleServiceUtil.addRole(null, className, classPK, name, titleMap, descriptionMap, type, subtype, serviceContext);
		_roleLocalService.addRole(null, userId, className, classPK, name, titleMap, descriptionMap, type, subtype, serviceContext);
		_roleService.addRole(null, className, classPK, name, titleMap, descriptionMap, type, subtype, serviceContext);
	}

	@Reference
	private RoleLocalService _roleLocalService;

	@Reference
	private RoleService _roleService;

}