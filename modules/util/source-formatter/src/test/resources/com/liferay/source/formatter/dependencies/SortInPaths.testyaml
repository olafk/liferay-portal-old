openapi: 3.0.1
paths:
    "/sites/{siteId}/message-board-messages/by-friendly-url-path/{friendlyUrlPath}":
        get:
            operationId: getSiteMessageBoardMessageByFriendlyUrlPath
            parameters:
                -   in: path
                    name: friendlyUrlPath
                    required: true
                    schema:
                        type: string
                -   in: path
                    name: siteId
                    required: true
                    schema:
                        format: int64
                        type: integer
                -   in: header
                    name: Accept-Language
                    schema:
                        type: string