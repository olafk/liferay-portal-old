package com.liferay.source.formatter.dependencies;

import com.liferay.portal.kernel.security.auth.CompanyThreadLocal;

/**
 * @author Alan Huang
 */
public class CompanyThreadLocalUsage {

	public void method1(String companyId) {
		CompanyThreadLocal.setCompanyId(companyId);
	}

	public void method2(String companyId) {
		_safeCloseable1 = CompanyThreadLocal.setCompanyIdWithSafeCloseable(
			companyId);
	}

	public void method3(String companyId) {
		_safeCloseable2 = CompanyThreadLocal.lock(companyId);
	}

	private static SafeCloseable _safeCloseable1;
	private static SafeCloseable _safeCloseable2;

}