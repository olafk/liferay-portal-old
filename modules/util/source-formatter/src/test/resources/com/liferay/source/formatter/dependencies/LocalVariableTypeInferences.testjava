package com.liferay.source.formatter.dependencies;

import java.util.Comparator;
import java.util.Map;

/**
 * @author Alan Huang
 */
public class LocalVariableTypeInferences {

	public int method(Map<String, String> map) {
		var myMap = map;

		myMap.put("key", "value");

		return myMap.size();
	}

	protected Comparator<Map.Entry<String, Double>> comparator =
		(var entry1, var entry2) -> Double.compare(
			entry2.getValue(), entry1.getValue());

}