package com.liferay.source.formatter.dependencies.upgrade;

import com.liferay.portal.kernel.util.SetUtil;
import com.liferay.portal.util.PropsValues;

/**
 * @author Nícolas Moura
 */
public class LPD_40678 {

	public void method(DLFileEntry dlFileEntry) {
		if (!SetUtil.fromArray(PropsValues.MIME_TYPES_WEB_IMAGES).contains(dlFileEntry.getMimeType())) {
			return dlFileEntry;
		}
	}

}