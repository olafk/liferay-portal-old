@default = "confirm"
@summary = "Execute the confirmation of a confirmation window"
definition {

	function acceptAlert() {
		selenium.acceptAlert();
	}

	function confirm() {
		selenium.getConfirmation(${value1});
	}

	function dismissAlert() {
		selenium.dismissAlert();
	}

	function typeAlert() {
		selenium.typeAlert(${value1});
	}

}