@default = "doubleClick"
definition {

	function doubleClick() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.doubleClick(${locator1});
	}

	function doubleClickAt() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.doubleClickAt(${locator1}, ${value1});
	}

	function javaScriptDoubleClick() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.javaScriptDoubleClick(${locator1});
	}

}