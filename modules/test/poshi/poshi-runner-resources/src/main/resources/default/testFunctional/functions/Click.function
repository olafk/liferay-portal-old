@default = "click"
@summary = "Click on '${locator1}'"
definition {

	function click() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});
	}

	function clickAt(locator1, value1) {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});
	}

	function clickAtNotVisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});
	}

	function clickNoMouseOver() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.click(${locator1});
	}

	function clickNoMouseOverNoWaitForVisible() {
		selenium.click(${locator1});
	}

	function clickNoWaitForVisible() {
		selenium.mouseOver(${locator1});

		selenium.click(${locator1});
	}

	function javaScriptClick() {
		selenium.javaScriptClick(${locator1});
	}

	function mouseDownMouseUp() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseDown(${locator1});

		selenium.mouseUp(${locator1});
	}

	function mouseOverClick() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.click(${locator1});
	}

	function pauseClickAt() {
		selenium.pause(1000);

		selenium.mouseOver(${locator1});

		Click.clickAt();
	}

}