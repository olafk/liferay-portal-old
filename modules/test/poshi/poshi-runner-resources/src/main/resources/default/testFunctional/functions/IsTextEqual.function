@default = "isTextEqual"
definition {

	function isPartialText() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.isPartialTextCaseInsensitive(${locator1}, ${value1});
	}

	function isText() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.isTextCaseInsensitive(${locator1}, ${value1});
	}

	function isTextEqual(locator1) {
		if (contains(${locator1}, "/input")) {
			IsTextEqual.isValue();
		}
		else {
			IsTextEqual.isText();
		}
	}

	function isValue() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.isValue(${locator1}, ${value1});
	}

}