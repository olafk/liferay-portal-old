@default = "assertTextEquals"
@summary = "Assert that '${locator1}' equals the value '${value1}'"
definition {

	@summary = "Assert that '${locator1}' contains the value '${value1}'"
	function assertPartialText() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.waitForPartialTextCaseInsensitive(${locator1}, ${value1});

		selenium.assertPartialTextCaseInsensitive(${locator1}, ${value1});
	}

	function assertPartialTextAceEditor() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.waitForPartialTextAceEditor(${locator1}, ${value1});

		selenium.assertPartialTextAceEditor(${locator1}, ${value1});
	}

	function assertText() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.waitForTextCaseInsensitive(${locator1}, ${value1});

		selenium.assertTextCaseInsensitive(${locator1}, ${value1});
	}

	function assertTextCaseSensitive() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.waitForText(${locator1}, ${value1});

		selenium.assertText(${locator1}, ${value1});
	}

	function assertTextEquals(locator1) {
		if (contains(${locator1}, "/input")) {
			AssertTextEquals.assertValue();
		}
		else {
			AssertTextEquals.assertText();
		}
	}

	function assertValue() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.waitForValue(${locator1}, ${value1});

		selenium.assertValue(${locator1}, ${value1});
	}

}