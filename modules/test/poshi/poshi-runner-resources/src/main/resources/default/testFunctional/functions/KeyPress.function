@default = "keyPress"
definition {

	function keyDown() {
		selenium.mouseOver(${locator1});

		selenium.keyDown(${locator1}, ${value1});
	}

	function keyPress() {
		selenium.mouseOver(${locator1});

		selenium.keyPress(${locator1}, ${value1});
	}

	function keyPressCKEditorWaitForCKEditor() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.pause(1000);

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.keyPress(${locator1}, ${value1});
	}

	function keyPressNoError() {
		selenium.mouseOver(${locator1});

		selenium.keyPress(${locator1}, ${value1});
	}

	function keyUp() {
		selenium.mouseOver(${locator1});

		selenium.keyUp(${locator1}, ${value1});
	}

}