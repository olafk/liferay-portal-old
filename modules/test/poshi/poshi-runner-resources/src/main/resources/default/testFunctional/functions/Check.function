@default = "clickAt"
definition {

	function checkNotVisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});

			selenium.pause(1000);
		}

		selenium.assertChecked(${locator1});
	}

	function checkToggleSwitch() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}
	}

	function checkToggleSwitchAndPause() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		selenium.pause(1000);

		AssertChecked.assertCheckedNotVisible();
	}

	function clickAt() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertChecked.assertChecked();
	}

	function toggleSwitch() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertElementPresent();
	}

}