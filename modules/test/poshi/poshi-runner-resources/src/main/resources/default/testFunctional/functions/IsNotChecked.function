@default = "isNotChecked"
definition {

	function isNotChecked() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.isNotChecked(${locator1});
	}

	function isNotCheckedNotVisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.isNotChecked(${locator1});
	}

}