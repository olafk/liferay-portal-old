@default = "uploadCommonFile"
definition {

	function uploadCommonFile() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.uploadCommonFile(${locator1}, ${value1});
	}

	function uploadCommonFileHidden() {
		selenium.mouseOver(${locator1});

		selenium.uploadCommonFile(${locator1}, ${value1});
	}

	function uploadCommonFileHiddenNoMouseOver() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.uploadCommonFile(${locator1}, ${value1});
	}

}