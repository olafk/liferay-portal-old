@default = "assertNotChecked"
definition {

	function assertNotChecked() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.assertNotChecked(${locator1});
	}

	function assertNotCheckedHiddenToggleSwitch(locator1) {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.assertNotChecked("xpath=(${locator1})/../../input");
	}

	function assertNotCheckedNotVisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.assertNotChecked(${locator1});
	}

}