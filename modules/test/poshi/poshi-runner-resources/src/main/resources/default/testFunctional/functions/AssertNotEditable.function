@default = "assertNotEditable"
definition {

	function assertNotEditable() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.waitForNotEditable(${locator1});

		selenium.assertNotEditable(${locator1});
	}

	function assertNotEditableNotVisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.waitForNotEditable(${locator1});

		selenium.assertNotEditable(${locator1});
	}

}