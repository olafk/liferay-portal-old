@default = "isElementNotPresent"
definition {

	function isElementNotPresent() {
		if (selenium.isElementPresent(${locator1})) {
			selenium.isNotVisible(${locator1});
		}
		else {
			selenium.isElementNotPresent(${locator1});
		}
	}

	function isNotVisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.isNotVisible(${locator1});
	}

}