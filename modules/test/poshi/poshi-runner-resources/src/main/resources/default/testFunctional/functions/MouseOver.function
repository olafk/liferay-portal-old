@default = "mouseOver"
@summary = "Mouse over '${locator1}'"
definition {

	function javaScriptMouseOver() {
		selenium.javaScriptMouseOver(${locator1});
	}

	function mouseOver() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});
	}

	function mouseOverInvisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});
	}

	function mouseOverNotVisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.waitForVisible(${locator1}, ${value1});
	}

}