@default = "clickAt"
definition {

	function clickAt() {
		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertNotChecked.assertNotChecked();
	}

	function uncheckNotVisible() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});

			selenium.pause(1000);
		}

		selenium.assertNotChecked(${locator1});
	}

	function uncheckToggleSwitch() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertNotChecked.assertNotCheckedNotVisible();
	}

	function uncheckToggleSwitchAndPause() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		selenium.pause(1000);

		AssertNotChecked.assertNotCheckedNotVisible();
	}

	function uncheckToggleSwitchNoErrorNoAssert() {
		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}
	}

}