Bundle-SymbolicName: jakarta.ws.rs
Bundle-Version: 3.1.0.LIFERAY-PATCHED-2
Export-Package: jakarta.ws.rs.*
Require-Capability:\
	osgi.ee;\
		filter:="(&(osgi.ee=JavaSE)(version=1.8))",\
	osgi.extender;\
		filter:="(osgi.extender=osgi.serviceloader.processor)",\
	osgi.serviceloader;\
		cardinality:=multiple;\
		filter:="(osgi.serviceloader=jakarta.ws.rs.client.ClientBuilder)",\
	osgi.serviceloader;\
		cardinality:=multiple;\
		filter:="(osgi.serviceloader=jakarta.ws.rs.ext.RuntimeDelegate)",\
	osgi.serviceloader;\
		cardinality:=multiple;\
		filter:="(osgi.serviceloader=jakarta.ws.rs.sse.SseEventSource.Builder)"