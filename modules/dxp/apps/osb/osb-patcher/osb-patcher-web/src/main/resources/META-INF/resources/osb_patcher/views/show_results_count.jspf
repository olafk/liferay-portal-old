--%>

<div class="taglib-page-iterator">
	<div class="clearfix lfr-pagination">
		<small class="search-results">
			<c:choose>
				<c:when test="<%= resultsTotal == 1 %>">
					<liferay-ui:message arguments="<%= resultsTotal %>" key="showing-x-result" />
				</c:when>
				<c:otherwise>
					<liferay-ui:message arguments="<%= resultsTotal %>" key="showing-x-results" />
				</c:otherwise>
			</c:choose>
		</small>
	</div>
</div>