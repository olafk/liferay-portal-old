@component-name = "portal-wcm"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property test.assert.warning.exceptions = "true";
	property test.liferay.virtual.instance = "false";
	property test.run.type = "single";
	property testray.component.names = "Page SEO Links";
	property testray.main.component.name = "Upgrades WEM";

	setUp {
		SignIn.signIn();

		var portalURL = PropsUtil.get("portal.url");

		AssertLocation.assertPartialLocation(value1 = "${portalURL}/web/guest");

		SearchAdministration.executeReindex();
	}

	@priority = 5
	@refactorneeded
	test ViewCustomMetaTags73101 {
		property data.archive.type = "data-archive-custom-meta-tag";
		property portal.version = "7.3.10.1";

		ValidateSEOUpgrade.viewAndEditCustomMetaTag();
	}

}