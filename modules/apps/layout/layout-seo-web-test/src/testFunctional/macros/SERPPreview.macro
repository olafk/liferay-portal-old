definition {

	@summary = "Default summary"
	macro addGeneralSettings(htmlTitle = null, description = null) {
		if (isSet(htmlTitle)) {
			PortletEntry.inputText(
				fieldLabel = "HTML Title",
				text = ${htmlTitle});
		}

		if (isSet(description)) {
			PortletEntry.inputText(
				fieldLabel = "Description",
				text = ${description});
		}
	}

	@summary = "Default summary"
	macro viewPreviewDefault() {
		AssertVisible(locator1 = "PagesAdmin#PREVIEW_SERP");
	}

}