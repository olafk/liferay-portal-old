@component-name = "portal-commerce"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property release.feature.flags.disable.DISABLE_PRIVATE_LAYOUTS = "true";
	property testray.main.component.name = "Order Management";

	setUp {
		CommerceConfiguration.commerceSetUp();
	}

	tearDown {
		CommerceConfiguration.commerceTearDown();
	}

	@description = "This is a test for COMMERCE-6231. Discount lifecycle"
	@priority = 5
	test AddEditAndDeleteDiscountEntry {
		property portal.acceptance = "true";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";

		// TODO Review

		CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

		CommerceAccelerators.initializeNewSiteViaAccelerator(
			siteName = "Minium 2",
			siteTemplateName = "Minium");

		CommerceChannels.openChannelsAdmin();

		AssertElementPresent(
			key_entryName = "Minium Portal",
			locator1 = "CommerceNavigation#ENTRY_NAME");

		AssertElementPresent(
			key_entryName = "Minium 2 Portal",
			locator1 = "CommerceNavigation#ENTRY_NAME");

		CommerceNavigator.goToDiscountAdmin();

		Click(locator1 = "Button#PLUS");

		CommerceEntry.addNewDiscountsEntry(
			channelsEligibility = "Minium Portal",
			discountAmount = 25,
			discountName = "Test Discount",
			discountTarget = "Products",
			discountType = "Percentage");

		CommerceRelations.assignSingleRelationToProductsEntry(
			entryName = "U-Joint",
			title = "Add Products");

		Button.clickPublish();

		CommerceEntry.gotoMenuTab(menuTab = "Eligibility");

		CommerceEntry.setEntryEligibility(channelsEligibility = "Minium Portal");

		Navigator.openWithAppendToBaseURL(urlAppend = "web/minium");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		CommerceAcceleratorsInitializer.gotoMiniumProductDetailsPage(productName = "U-Joint");

		CommerceAcceleratorsInitializer.viewDiscountedProductDetailsPage(
			discountPercentage = 25,
			productDiscountedPrice = "18.00",
			productListPrice = "24.00");

		Navigator.openWithAppendToBaseURL(urlAppend = "web/minium-2");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		CommerceAcceleratorsInitializer.gotoMiniumProductDetailsPage(productName = "U-Joint");

		AssertElementNotPresent(locator1 = "CommerceAccelerators#PRODUCT_DETAILS_DISCOUNT");

		AssertElementNotPresent(locator1 = "CommerceAccelerators#PRODUCT_DETAILS_NET_PRICE");

		AssertTextEquals.assertPartialText(
			locator1 = "CommerceAccelerators#PRODUCT_DETAILS_LIST_PRICE",
			value1 = "24.00");

		CommerceNavigator.goToDiscountAdmin();

		Click(
			key_value = "Test Discount",
			locator1 = "CommerceEntry#BODY_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = "Edit");

		Type(
			locator1 = "CommerceEntry#DISCOUNT_AMOUNT",
			value1 = 10);

		Button.clickPublish();

		Alert.viewSuccessMessage();

		Refresh();

		Navigator.openWithAppendToBaseURL(urlAppend = "web/minium");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		CommerceAcceleratorsInitializer.gotoMiniumProductDetailsPage(productName = "U-Joint");

		CommerceAcceleratorsInitializer.viewDiscountedProductDetailsPage(
			discountPercentage = 10,
			productDiscountedPrice = "21.60",
			productListPrice = "24.00");

		Navigator.openWithAppendToBaseURL(urlAppend = "web/minium-2");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		CommerceAcceleratorsInitializer.gotoMiniumProductDetailsPage(productName = "U-Joint");

		AssertElementNotPresent(locator1 = "CommerceAccelerators#PRODUCT_DETAILS_DISCOUNT");

		AssertElementNotPresent(locator1 = "CommerceAccelerators#PRODUCT_DETAILS_NET_PRICE");

		AssertTextEquals.assertPartialText(
			locator1 = "CommerceAccelerators#PRODUCT_DETAILS_LIST_PRICE",
			value1 = "24.00");

		CommerceNavigator.goToDiscountAdmin();

		Click(
			key_value = "Test Discount",
			locator1 = "CommerceEntry#BODY_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = "Delete");

		Alert.viewSuccessMessage();
	}

	@description = "This is a test for COMMERCE-6232. Discount Rules lifecycle"
	@ignore = "true"
	@priority = 3
	test AddEditAndRemoveDiscountRule {

		// TODO COMMERCE-6232 AddEditAndRemoveDiscountRule Pending Implementation

	}

	@priority = 5
	test AssertDiscountIsAppliedToChannel {
		property portal.acceptance = "true";
		property portal.upstream = "true";

		CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

		CommerceAccelerators.initializeNewSiteViaAccelerator(
			siteName = "Minium 2",
			siteTemplateName = "Minium");

		CommerceChannels.openChannelsAdmin();

		AssertElementPresent(
			key_entryName = "Minium Portal",
			locator1 = "CommerceNavigation#ENTRY_NAME");

		AssertElementPresent(
			key_entryName = "Minium 2 Portal",
			locator1 = "CommerceNavigation#ENTRY_NAME");

		CommerceNavigator.goToDiscountAdmin();

		Click(locator1 = "Button#PLUS");

		CommerceEntry.addNewDiscountsEntry(
			channelsEligibility = "Minium Portal",
			discountAmount = 25,
			discountName = "Test Discount",
			discountTarget = "Products",
			discountType = "Percentage");

		CommerceRelations.assignSingleRelationToProductsEntry(
			entryName = "U-Joint",
			title = "Add Products");

		Button.clickPublish();

		CommerceEntry.gotoMenuTab(menuTab = "Eligibility");

		CommerceEntry.setEntryEligibility(channelsEligibility = "Minium Portal");

		Navigator.openWithAppendToBaseURL(urlAppend = "web/minium");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		CommerceAcceleratorsInitializer.gotoMiniumProductDetailsPage(productName = "U-Joint");

		CommerceAcceleratorsInitializer.viewDiscountedProductDetailsPage(
			discountPercentage = 25,
			productDiscountedPrice = "18.00",
			productListPrice = "24.00");

		Navigator.openWithAppendToBaseURL(urlAppend = "web/minium-2");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

		CommerceAcceleratorsInitializer.gotoMiniumProductDetailsPage(productName = "U-Joint");

		AssertElementNotPresent(locator1 = "CommerceAccelerators#PRODUCT_DETAILS_DISCOUNT");

		AssertElementNotPresent(locator1 = "CommerceAccelerators#PRODUCT_DETAILS_NET_PRICE");

		AssertTextEquals.assertPartialText(
			locator1 = "CommerceAccelerators#PRODUCT_DETAILS_LIST_PRICE",
			value1 = "24.00");
	}

	@description = "This is a test for COMMERCE-12768. As a buyer, I want to use the coupon code discount applied with case insensitive"
	@priority = 5
	test CanApplyCaseInsensitiveCouponCodeDiscount {
		property custom.properties = "jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a Minium site with a buyer user") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And a discount with coupon code (Coupon50) is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				couponCode = "Coupon50",
				level = "L1",
				percentageLevel1 = 50,
				target = "total",
				title = "Test Discount",
				useCouponCode = "true",
				usePercentage = "true");
		}

		task ("And Coupon Code Entry widget is deployed in the Pending Orders page") {
			Navigator.openWithAppendToBaseURL(urlAppend = "web/minium/pending-orders");

			CommerceAcceleratorsInitializer.addPortlet(portletName = "Coupon Code Entry");
		}

		task ("And the buyer adds U-Joint product to the cart") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = "test",
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");

			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);
		}

		task ("When the coupon code is applied with coupon50 (lowercase) in the Pending Orders page") {
			Navigator.openWithAppendToBaseURL(urlAppend = "web/minium/pending-orders");

			AssertTextEquals(
				key_cellName1 = "Commerce Account",
				key_cellName2 = "Buyer User",
				key_columnNumber = 8,
				locator1 = "CommerceEntry#TABLE_CELL_BY_COLUMN_ORDER_NO_TITLE",
				value1 = "$ 24.00");

			FrontStore.applyCouponCode(discountCouponCode = "coupon50");
		}

		task ("Then can view the discount applied for the order entry") {
			AssertTextEquals(
				key_cellName1 = "Commerce Account",
				key_cellName2 = "Buyer User",
				key_columnNumber = 8,
				locator1 = "CommerceEntry#TABLE_CELL_BY_COLUMN_ORDER_NO_TITLE",
				value1 = "$ 12.00");
		}

		task ("And can view the discount applied in the order entry's details") {
			Button.click(button = "View");

			CommerceOrders.viewOrdersDetails(
				productListPrice = "24.00",
				productName = "U-Joint",
				productQuantity = 1,
				productSku = "MIN55861",
				productTotalPrice = "24.00");

			CommerceOrders.viewOrderPrices(
				deliveryPrice = "0.00",
				subTotalPrice = "24.00",
				taxPrice = "0.00",
				totalPrice = "12.00");
		}
	}

	@description = "COMMERCE-11821 | Discount is applied correctly when a tax category is enabled"
	@priority = 4
	test CanApplyDiscountWithTaxCategoryEnabled {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "false";

		task ("Given a Minium site is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");
		}

		task ("And an account associated with a buyer user") {
			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And a discount with a rule is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				level = "L1",
				percentageLevel1 = 15,
				target = "shipping",
				title = "Discount 1",
				usePercentage = "false");

			CommerceNavigator.goToDiscountAdmin();

			CommerceNavigator.gotoEntry(entryName = "Discount 1");

			CommerceDiscounts.addNewDiscountsRule(
				name = "FREESHIPPING",
				type = "Cart Total");

			LexiconEntry.gotoEntryMenuItem(
				menuItem = "Edit",
				rowEntry = "FREESHIPPING");

			CommerceDiscounts.editDiscountRule(
				key_fieldLabel = "Cart Total Minimum Amount",
				quantity = 200);
		}

		task ("And a Tax Categories entry is created") {
			CommerceNavigator.goToTaxCategoriesAdmin();

			CommerceEntry.addTaxCategory(
				keyDescription = "Test Description",
				keyName = "Test",
				keyReferenceCode = "Test Reference");
		}

		task ("And Tax Rate is configurated") {
			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			CommerceChannels.editTaxCalculation(
				active = "true",
				fieldLabel = "Rate",
				percentage = "true",
				quantity = 10,
				taxCalculationName = "Fixed Tax Rate",
				taxCategory = "Test");
		}

		task ("And product configuration is set with tax category") {
			CommerceProducts.openProductsAdmin();

			CommerceProducts.searchAndGoToProductEntry(entryProductName = "U-Joint");

			CommerceEntry.gotoMenuTab(menuTab = "Configuration");

			Select(
				key_title = "Tax Category",
				locator1 = "CommerceEntry#CATALOGS_FORM",
				value1 = "Test");

			Button.clickPublish();
		}

		task ("And the buyer user logs in") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = "test",
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");
		}

		task ("When a buyer user adds a product to the cart") {
			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 10);
		}

		task ("Then the user completes the checkout process and tax and discount are correctly applied") {
			CommerceCheckout.gotoCheckoutViaMiniCart();

			CommerceCheckout.initializersCheckout(
				deliveryDiscountFixedAmount = 15,
				newAddressAddress = "Test Address",
				newAddressCity = "Test City",
				newAddressCountry = "United States",
				newAddressName = "Address Name",
				newAddressZipCode = "Test Zip Code",
				productName = "U-Joint",
				productQuantity = 10,
				productUnitPrice = 24,
				shippingMethod = "Standard",
				taxValue = 24,
				totalValue = 264);
		}
	}

	@description = "COMMERCE-9787 | Apply a discount with eligibility only to account groups that are eligible"
	@priority = 5
	test CanApplySpecificAccountGroupCouponCodeDiscount {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a Minium site") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");
		}

		task ("And 2 accounts associated with a buyer user") {
			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account 2",
				accountType = "Business",
				createNewAccount = "true",
				existingUser = "true",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And one of the accounts is part of an account group") {
			JSONAccountGroup.addAccountGroup(accountGroupName = "AG1");

			AccountGroups.openAccountGroupsAdmin();

			LexiconEntry.gotoEntry(rowEntry = "AG1");

			AccountGroups.viewDefault(tabName = "Accounts");

			AccountGroups.addAssignee(
				accountGroupName = "AG1",
				assigneeNames = "Commerce Account");
		}

		task ("And a discount with coupon code is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				couponCode = "FREESHIPPING",
				level = "L1",
				maximumDiscountAmount = 100,
				percentageLevel1 = 100,
				target = "shipping",
				title = "Free Shipping Discount",
				useCouponCode = "true",
				usePercentage = "true");
		}

		task ("And AG1 is eligible for the discount") {
			CommerceJSONDiscountsAPI._addDiscountAccountGroup(
				accountGroupName = "AG1",
				discountTitle = "Free Shipping Discount");
		}

		task ("And Coupon Code Entry widget is deployed on the Checkout page") {
			Navigator.openWithAppendToBaseURL(urlAppend = "web/minium/checkout");

			CommerceAcceleratorsInitializer.addPortlet(portletName = "Coupon Code Entry");
		}

		task ("When the buyer logs in") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = "test",
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");
		}

		task ("And a new order is created") {
			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);
		}

		task ("Then the coupon code is successfully applied") {
			CommerceNavigator.gotoMiniCart();

			Button.click(button = "View Details");

			Button.click(button = "Checkout");

			FrontStore.applyCouponCode(discountCouponCode = "FREESHIPPING");
		}

		task ("And on the Order Summary, the discount is shown applied to the shipping") {
			CommerceCheckout.initializersCheckout(
				deliveryDiscountPercentage = 100,
				deliveryDiscountValue = "15.00",
				deliveryValue = "$ 15.00",
				newAddressAddress = "Test Address",
				newAddressCity = "Test City",
				newAddressCountry = "United States",
				newAddressName = "Address Name",
				newAddressZipCode = "Test Zip Code",
				productName = "U-Joint",
				productQuantity = 1,
				productUnitPrice = 24,
				shippingMethod = "Standard");
		}

		task ("When Commerce Account 2 is set as active") {
			CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

			CommerceAcceleratorsInitializer.selectAccountFromAccountSelector(accountName = "Commerce Account 2");
		}

		task ("And a new order is created") {
			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);
		}

		task ("Then an error is thrown when the coupon code is applied") {
			CommerceCheckout.gotoCheckout();

			FrontStore.applyCouponCode(
				discountCouponCode = "FREESHIPPING",
				errorMessage = "Error: The account is not qualified to use the discount.");
		}
	}

	@description = "This is a test for COMMERCE-10663. Single Approver workflow for Commerce Discounts is triggered once the user clicks on 'Submit for Workflow'"
	@priority = 3
	test CanAssertCommerceDiscountSingleApproverWorkflowIsApplied {
		property portal.acceptance = "false";

		task ("Given Single Approver workflow is set for Commerce Discount") {
			Workflow.openWorkflowProcessBuilderConfiguration();

			Workflow.configureWorkflow(
				workflowDefinition = "Single Approver",
				workflowResourceValue = "Discount");
		}

		task ("When a new discount is created") {
			CommerceNavigator.goToDiscountAdmin();

			Click(locator1 = "Button#PLUS");

			CommerceEntry.addNewDiscountsEntry(
				discountName = "Test Discount",
				discountTarget = "Products",
				discountType = "Percentage",
				publish = "false");
		}

		task ("Then the discount status is Draft") {
			AssertElementPresent(
				key_status = "Draft",
				locator1 = "CommerceEntry#WORKFLOW_STATUS");
		}

		task ("When the user submits the discount for publication") {
			Click(
				key_text = "Submit for Workflow",
				locator1 = "Button#ANY");
		}

		task ("Then status for the discount is changed to PENDING") {
			AssertElementPresent(
				key_status = "Pending",
				locator1 = "CommerceEntry#WORKFLOW_STATUS");
		}
	}

	@description = "COMMERCE-12099 | As a Discount Manager, I want the field Last Modified in the Discounts table to be localized"
	@priority = 3
	test CanAssertDiscountEntryModifiedDateFieldIsLocalized {
		property portal.acceptance = "false";

		task ("Given a discount is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				level = "L1",
				percentageLevel1 = 10,
				target = "products",
				title = "Test Discount",
				usePercentage = "true");

			CommerceNavigator.goToDiscountAdmin();

			var modifiedDate = CommerceJSONDiscountsAPI.getCommerceDiscountsFieldValuesList(jsonPath = "$..['modifiedDate']");

			var modifiedDate = CommerceUtilities.getLocaleDate(date = ${modifiedDate});

			var modifiedDate = DateUtil.format(${modifiedDate}, "M/d/yyyy, h:mm:ss a", "MMM d, yyyy, h:mm:ss a");

			CommerceEntry.assertTableRowSpecificColumnValue(
				column = 6,
				entryName = "Test Discount",
				row = 1,
				value = ${modifiedDate});
		}

		task ("When the user changes the language selected") {
			MyAccount.configureDisplaySettingsLanguage(languageName = "español (España)");
		}

		task ("Then the Last Modified field is localized") {
			CommerceNavigator.goToDiscountAdmin();

			var localizedDate = CommerceUtilities.getLocaleDateLocalized(
				date = ${modifiedDate},
				lang = "es-ES",
				options = '''{"dateStyle": "medium", "timeStyle": "medium"}''');

			CommerceEntry.assertTableRowSpecificColumnValue(
				column = 6,
				entryName = "Test Discount",
				row = 1,
				value = ${localizedDate});

			UserBar.gotoDropdownItem(dropdownItem = "Mi cuenta");

			Select(
				locator1 = "MyAccount#LANGUAGE_SELECT",
				value1 = "English (United States)");

			AssertClick(
				key_saveButton = "Guardar",
				locator1 = "Button#SAVE_LOCALIZED",
				value1 = "Guardar");

			VerifyElementPresent(locator1 = "Message#SUCCESS");
		}
	}

	@description = "COMMERCE-12099 | As a Discount Manager, I want the discounts table to be sorted by Last Modified Date/Time"
	@priority = 5
	test CanAssertDiscountsAreSortedByModifiedDate {
		property portal.acceptance = "true";

		task ("Given discount entries are created") {
			for (var num : list "1,2,3") {
				CommerceJSONDiscountsAPI._addDiscount(
					active = "true",
					level = "L1",
					percentageLevel1 = 10,
					target = "products",
					title = "TestDiscount${num}",
					usePercentage = "true");
			}
		}

		task ("When the user navigates to Discounts admin page") {
			CommerceNavigator.goToDiscountAdmin();
		}

		task ("Then discounts table is sorted by Last Modified Date/Time") {
			var modifiedDateList = CommerceJSONDiscountsAPI.getCommerceDiscountsFieldValuesList(jsonPath = "$..['modifiedDate']");
			var discountCount = 1;
			var rowCount = 3;

			for (var modifiedDate : list ${modifiedDateList}) {
				var modifiedDate = CommerceUtilities.getLocaleDate(date = ${modifiedDate});

				var modifiedDate = DateUtil.format(${modifiedDate}, "M/d/yyyy, h:mm:ss a", "MMM d, yyyy, h:mm:ss a");

				CommerceEntry.assertTableRowSpecificColumnValue(
					column = 6,
					entryName = "TestDiscount${discountCount}",
					row = ${rowCount},
					value = ${modifiedDate});

				var discountCount = ${discountCount} + 1;
				var rowCount = ${rowCount} - 1;
			}
		}

		task ("When one of the discount entries is modified") {
			CommerceNavigator.gotoEntry(entryName = "TestDiscount2");

			Button.clickPublish();
		}

		task ("Then the sorting of the entries is changed based on the latest discounts entry modified") {
			CommerceNavigator.goToDiscountAdmin();

			var modifiedDateList = "";

			for (var discount : list "1,3,2") {
				var modifiedDate = CommerceJSONDiscountsAPI.getCommerceDiscountFieldById(
					discountTitle = "TestDiscount${discount}",
					jsonPath = "$..['modifiedDate']");

				var modifiedDateList = "${modifiedDateList}${modifiedDate},";
			}

			echo("Values: ${modifiedDateList}");

			var discountCount = 1;
			var rowCount = 3;

			for (var modifiedDate : list ${modifiedDateList}) {
				var modifiedDate = CommerceUtilities.getLocaleDate(date = ${modifiedDate});

				var modifiedDate = DateUtil.format(${modifiedDate}, "M/d/yyyy, h:mm:ss a", "MMM d, yyyy, h:mm:ss a");

				CommerceEntry.assertTableRowSpecificColumnValue(
					column = 6,
					entryName = "TestDiscount${discountCount}",
					row = ${rowCount},
					value = ${modifiedDate});

				if (${discountCount} == 1) {
					var discountCount = 3;
				}
				else if (${discountCount} == 3) {
					var discountCount = 2;
				}

				var rowCount = ${rowCount} - 1;
			}
		}
	}

	@description = "COMMERCE-9789 | Apply coupon code discount to not eligible account group and assert the coupon is not applicable"
	@priority = 5
	test CanAssertNotEligibleAccountGroupCouponCodeDiscountNotApplied {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a Minium site") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");
		}

		task ("And an account associated with a buyer user") {
			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And 2 account groups are created") {
			for (var accountGroupName : list "AG1,AG2") {
				JSONAccountGroup.addAccountGroup(accountGroupName = ${accountGroupName});
			}
		}

		task ("And the account is associated with AG2") {
			AccountGroups.openAccountGroupsAdmin();

			LexiconEntry.gotoEntry(rowEntry = "AG2");

			AccountGroups.viewDefault(tabName = "Accounts");

			AccountGroups.addAssignee(
				accountGroupName = "AG2",
				assigneeNames = "Commerce Account");
		}

		task ("And a discount with coupon code is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				couponCode = "FREESHIPPING",
				level = "L1",
				maximumDiscountAmount = 100,
				percentageLevel1 = 100,
				target = "shipping",
				title = "Free Shipping Discount",
				useCouponCode = "true",
				usePercentage = "true");
		}

		task ("And AG1 is eligible for the discount") {
			CommerceJSONDiscountsAPI._addDiscountAccountGroup(
				accountGroupName = "AG1",
				discountTitle = "Free Shipping Discount");
		}

		task ("And Coupon Code Entry widget is deployed on the Checkout page") {
			Navigator.openWithAppendToBaseURL(urlAppend = "web/minium/checkout");

			CommerceAcceleratorsInitializer.addPortlet(portletName = "Coupon Code Entry");
		}

		task ("When the buyer logs in") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = "test",
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");
		}

		task ("And a new order is created") {
			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);
		}

		task ("Then an error is thrown when the coupon code is applied") {
			CommerceCheckout.gotoCheckout();

			FrontStore.applyCouponCode(
				discountCouponCode = "FREESHIPPING",
				errorMessage = "Error: The account is not qualified to use the discount.");
		}
	}

	@description = "This is a test case for COMMERCE-10819. User with Discount Manager role can access Discounts from Control Panel"
	@priority = 3
	test CanDiscountManagerAccessDiscountsPanel {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "false";

		task ("Given a Minium site") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");
		}

		task ("And a user with Discount Manager role is created") {
			JSONUser.addUserWithRole(
				roleTitle = "Discount Manager",
				userEmailAddress = "discount.manager@liferay.com",
				userFirstName = "Discount",
				userLastName = "Manager",
				userScreenName = "discount.manager");
		}

		task ("When Discount Manager logs in") {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "discount.manager@liferay.com",
				userLoginFullName = "Discount Manager");
		}

		task ("Then Discounts panel is shown") {
			CommerceNavigator.goToDiscountAdmin();

			AssertTextEquals(
				locator1 = "ControlMenu#HEADING",
				value1 = "Discounts");
		}
	}

	@description = "This is a test for COMMERCE-10053. An error message shows up when the eligibility element is already linked"
	@priority = 3
	test CannotSelectDiscountEligibilitiesTwice {
		property portal.acceptance = "false";

		task ("Given a Minium site is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");
		}

		task ("And a business account is created") {
			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Commerce Account",
				accountEntryType = "Business");
		}

		task ("And an order type is created") {
			CommerceJSONOrdersAPI._addOrderType(
				active = "true",
				orderTypeName = "Order Type Test");
		}

		task ("And a discount is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				level = "L1",
				percentageLevel1 = 20,
				target = "products",
				title = "Test Discount",
				usePercentage = "true");
		}

		task ("When the admin navigates to the discount's entry") {
			CommerceNavigator.goToDiscountAdmin();

			CommerceNavigator.gotoEntry(entryName = "Test Discount");
		}

		task ("And sets the eligibilities for the discount") {
			Navigator.gotoNavTab(navTab = "Eligibility");

			CommerceEntry.setEntryEligibility(
				accountsEligibility = "Commerce Account",
				channelsEligibility = "Minium Portal",
				orderTypesEligibility = "Order Type Test");
		}

		task ("And sets again the same eligibility for channel") {
			CommerceEntry.setEntryEligibility(
				channelsEligibility = "Minium Portal",
				unpublish = "true");
		}

		task ("Then an error message shows up") {
			Alert.viewErrorMessage(errorMessage = "The channel relation already exists.");
		}

		task ("When the admin sets again the same eligibility for account") {
			CommerceEntry.setEntryEligibility(
				accountsEligibility = "Commerce Account",
				unpublish = "true");
		}

		task ("Then an error message shows up") {
			Alert.viewErrorMessage(errorMessage = "The account relation already exists.");
		}

		task ("When the admin sets again the same eligibility for order type") {
			CommerceEntry.setEntryEligibility(
				orderTypesEligibility = "Order Type Test",
				unpublish = "true");
		}

		task ("Then an error message shows up") {
			Alert.viewErrorMessage(errorMessage = "The order type relation already exists.");
		}
	}

	@description = "This is a test for COMMERCE-8912. Buyer users cannot view product discounts when the discounts are saved as draft status"
	@priority = 3
	test CannotViewProductDiscountsWhenDiscountsAreSavedAsDraft {
		property portal.acceptance = "false";

		task ("Given a Minium site with a buyer user") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("When a 10% discount is applied to the U-Joint product") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				level = "L1",
				percentageLevel1 = 10,
				productNames = "U-Joint",
				target = "products",
				title = "Test Discount",
				usePercentage = "true");
		}

		task ("Then the buyer can view the U-Joint product with a 10% discount applied") {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "buyer@liferay.com",
				userLoginFullName = "Buyer User");

			Navigator.openWithAppendToBaseURL(urlAppend = "web/minium/p/u-joint");

			CommerceAcceleratorsInitializer.viewDiscountedProductDetailsPage(
				discountPercentage = 10,
				productDiscountedPrice = "21.60",
				productListPrice = "24.00");
		}

		task ("When the admin modified the discount and save it as draft") {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "test@liferay.com",
				userLoginFullName = "Test Test");

			CommerceNavigator.goToDiscountAdmin();

			CommerceNavigator.gotoEntry(entryName = "Test Discount");

			Type(
				locator1 = "CommerceEntry#DISCOUNT_AMOUNT",
				value1 = 20);

			Button.clickSaveAsDraft();

			Alert.viewSuccessMessage();

			AssertElementPresent(
				key_status = "Draft",
				locator1 = "CommerceEntry#WORKFLOW_STATUS");
		}

		task ("Then the buyer can view only the U-Joint product to be displayed with the list price") {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "buyer@liferay.com",
				userLoginFullName = "Buyer User");

			Navigator.openWithAppendToBaseURL(urlAppend = "web/minium/p/u-joint");

			FrontStore.assertProductDetails(
				productListPrice = "24.00",
				productName = "U-Joint",
				productSKU = "MIN55861");

			AssertElementNotPresent(locator1 = "CommerceAccelerators#PRODUCT_DETAILS_DISCOUNT");

			AssertElementNotPresent(locator1 = "CommerceAccelerators#PRODUCT_DETAILS_NET_PRICE");
		}
	}

	@description = "COMMERCE-11893 | Admin verifies that the search displays only account groups based on the keyword entered."
	@priority = 4
	test CanSearchAccountGroupsBasedOnKeywords {
		property portal.acceptance = "false";

		task ("Given the admin creates 3 account groups") {
			AccountGroups.openAccountGroupsAdmin();

			for (var accountGroupNum : list "1,2,3") {
				AccountGroups.addCP(accountGroupName = "A Group${accountGroupNum}");

				Navigator.gotoBack();
			}
		}

		task ("And a discount is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				level = "L1",
				percentageLevel1 = 20,
				target = "products",
				title = "Test Discount",
				usePercentage = "true");
		}

		task ("When the admin navigates to the discount's entry") {
			CommerceNavigator.goToDiscountAdmin();

			CommerceNavigator.gotoEntry(entryName = "Test Discount");
		}

		task ("And sets the eligibilities for the discount") {
			Navigator.gotoNavTab(navTab = "Eligibility");

			Click(
				locator1 = "Radio#ANY",
				radioLabel = "Specific Account Groups");
		}

		task ("And types the initial letter A common for all the 3 account groups") {
			Type(
				key_title = "Add Account Groups",
				locator1 = "CommerceEntry#ADD_RELATION_FIELD",
				value1 = "A");
		}

		task ("Then all the 3 account groups are selectable") {
			for (var accountGroupNum : list "1,2,3") {
				WaitForElementPresent(
					key_entryName = "A Group${accountGroupNum}",
					key_title = "Add Account Groups",
					locator1 = "CommerceEntry#ADD_RELATION_FIELD_SELECT");
			}
		}

		task ("When the admin types a keyword referring only to the first account group") {
			Type(
				key_title = "Add Account Groups",
				locator1 = "CommerceEntry#ADD_RELATION_FIELD",
				value1 = "Group1");
		}

		task ("Then only the first of the 3 account groups is selectable") {
			WaitForElementPresent(
				key_entryName = "A Group1",
				key_title = "Add Account Groups",
				locator1 = "CommerceEntry#ADD_RELATION_FIELD_SELECT");

			for (var accountGroupNum : list "2,3") {
				WaitForElementNotPresent(
					key_entryName = "A Group${accountGroupNum}",
					key_title = "Add Account Groups",
					locator1 = "CommerceEntry#ADD_RELATION_FIELD_SELECT");
			}
		}

		task ("When the admin types the letter 't' which is the initial letter of the admin user Test") {
			Type(
				key_title = "Add Account Groups",
				locator1 = "CommerceEntry#ADD_RELATION_FIELD",
				value1 = "t");
		}

		task ("Then no results are shown") {
			for (var accountGroupNum : list "1,2,3") {
				WaitForElementNotPresent(
					key_entryName = "A Group${accountGroupNum}",
					key_title = "Add Account Groups",
					locator1 = "CommerceEntry#ADD_RELATION_FIELD_SELECT");
			}
		}
	}

	@description = "This is a test for COMMERCE-12062 and COMMERCE-12091, Verify that is not possible to use the comma and that the Minimum Amount must be filled with a number"
	@priority = 5
	test CanUserReciveAnErrorForEmptyOrDecimalCommaNumberForMinimumAmountField {
		property portal.acceptance = "true";

		task ("Given a Discount is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				level = "L1",
				percentageLevel1 = 10,
				target = "products",
				title = "Discount 1 10% off",
				usePercentage = "true");

			CommerceNavigator.goToDiscountAdmin();

			CommerceNavigator.gotoEntry(entryName = "Discount 1 10% off");
		}

		task ("And a new rule is added") {
			CommerceDiscounts.addNewDiscountsRule(
				name = "Rule",
				type = "Cart Total");

			AssertElementPresent(
				locator1 = "ClientExtensionEntry#REMOTE_APPS_ERROR_WITH_MESSAGE",
				text = "Cart total minimum amount cannot be empty and must be a decimal number.");
		}

		task ("And the user leaves the Minimum Amount empty") {
			LexiconEntry.gotoEntryMenuItem(
				menuItem = "Edit",
				rowEntry = "Rule");

			SelectFrame.selectFrameNoLoading(locator1 = "CommerceEntry#IFRAME_SIDE_PANEL");

			AssertTextEquals(
				key_fieldLabel = "Cart Total Minimum Amount",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = "");
		}

		task ("Then the user will receive an error") {
			Button.clickSave();

			AssertElementPresent(
				key_field = "The Cart Total Minimum Amount field is required.",
				locator1 = "RaylifeAP#FIELD_REQUIRED_MESSAGE");
		}

		task ("And if the user add a number with the comma into the field") {
			Click(locator1 = "Icon#CLOSE");

			SelectFrameTop();

			LexiconEntry.gotoEntryMenuItem(
				menuItem = "Edit",
				rowEntry = "Rule");

			SelectFrame.selectFrameNoLoading(locator1 = "CommerceEntry#IFRAME_SIDE_PANEL");

			Type.sendKeys(
				key_fieldLabel = "Cart Total Minimum Amount",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = "1000,00");

			Button.clickSave();
		}

		task ("Then the user will receive an error") {
			AssertElementPresent(
				locator1 = "ClientExtensionEntry#REMOTE_APPS_ERROR_WITH_MESSAGE",
				text = "Cart total minimum amount cannot be empty and must be a decimal number.");
		}
	}

	@description = "This is a test for COMMERCE-9592."
	@priority = 5
	test CanViewErrorNotificationWhenApplyingCouponCodeToWrongProduct {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given a Minium site with a buyer user") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And a discount of 10% applied to ABS Sensor product") {
			CommerceNavigator.goToDiscountAdmin();

			Click(locator1 = "Button#PLUS");

			CommerceEntry.addNewDiscountsEntry(
				discountAmount = 10,
				discountName = "Test Discount",
				discountTarget = "Products",
				discountType = "Percentage");

			CommerceRelations.assignSingleRelationToProductsEntry(
				entryName = "ABS Sensor",
				title = "Add Products");
		}

		task ("And a coupon code added for the discount") {
			Click(
				key_name = "Coupon Code",
				locator1 = "ToggleSwitch#ENABLE_SPECIFIC_TOGGLE_SWITCH");

			Type(
				key_fieldLabel = "Coupon Code",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = "TEST");

			Button.clickPublish();
		}

		task ("And a coupon code entry widget added to the checkout page") {
			Navigator.openWithAppendToBaseURL(urlAppend = "web/minium/checkout");

			CommerceAcceleratorsInitializer.addPortlet(portletName = "Coupon Code Entry");
		}

		task ("When the buyer logs in and goes into Minium site") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = "test",
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");
		}

		task ("And the buyer adds ABS Sensor product to the cart") {
			CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

			CommerceAcceleratorsInitializer.changeProductsSorting(sortingType = "Name Ascending");

			FrontStore.addInitializerProductToCart(
				productName = "ABS Sensor",
				productQuantity = 1);
		}

		task ("And the buyer navigates to checkout, applying the coupon code") {
			CommerceNavigator.gotoMiniCart();

			Button.click(button = "View Details");

			Button.click(button = "Checkout");

			Type(
				locator1 = "TextInput#DISCOUNT",
				value1 = "TEST");

			Click(
				key_tab = "Apply",
				locator1 = "Button#TAB_SUBMIT_BTN");

			CommerceCheckout.setAddress(
				newAddressAddress = "Test Address",
				newAddressCity = "Test City",
				newAddressCountry = "United States",
				newAddressName = "Address Name",
				newAddressZipCode = "Test Zip Code");

			Click(locator1 = "Button#CONTINUE");

			Click(
				key_radioOption = "Standard",
				locator1 = "CommerceEntry#RADIO_BUTTON");

			Click(locator1 = "Button#CONTINUE");
		}

		task ("Then the discount of 10% is applied") {
			AssertTextEquals.assertPartialText(
				key_subtotalValue = "45.00",
				locator1 = "CommerceAccelerators#CHECKOUT_SUMMARY_SUBTOTAL",
				value1 = "45.00");

			Click(locator1 = "Button#CONTINUE");
		}

		task ("When the buyer adds a different product to the cart") {
			CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Catalog");

			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 1);
		}

		task ("And applies the same coupon code") {
			CommerceNavigator.gotoMiniCart();

			Button.click(button = "View Details");

			Button.click(button = "Checkout");

			Type(
				locator1 = "TextInput#DISCOUNT",
				value1 = "TEST");

			Click(
				key_tab = "Apply",
				locator1 = "Button#TAB_SUBMIT_BTN");
		}

		task ("Then a UI error notification shows up and the discount of 10% is not applied") {
			Alert.viewErrorMessage(errorMessage = "Error: The discount is not applicable to the current order.");
		}
	}

	@description = "This is a test for creating a new discount"
	@priority = 5
	test CreateNewDiscount {
		property portal.acceptance = "true";
		property portal.upstream = "true";

		CommerceChannels.openChannelsAdmin();

		Click(locator1 = "Button#PLUS");

		CommerceEntry.addNewChannelsEntry(
			channelCurrency = "US Dollar",
			channelName = "Test Channel",
			channelType = "Site",
			siteName = "Guest");

		CommerceNavigator.goToDiscountAdmin();

		Click(locator1 = "Button#PLUS");

		CommerceEntry.addNewDiscountsEntry(
			discountAmount = 15,
			discountName = "Test Discount",
			discountTarget = "Products",
			discountType = "Percentage",
			maximumDiscountAmount = 10);

		CommerceEntry.gotoMenuTab(menuTab = "Eligibility");

		CommerceEntry.setEntryEligibility(channelsEligibility = "Test Channel");

		AssertElementPresent(locator1 = "Message#SUCCESS");

		CommerceNavigator.goToDiscountAdmin();

		CommerceNavigator.gotoEntry(entryName = "Test Discount");

		CommerceEntry.viewDiscountsEntry(
			channelsEligibility = "Test Channel",
			discountAmount = "15.00",
			discountName = "Test Discount",
			discountTarget = "Products",
			discountType = "Percentage",
			maximumDiscountAmount = "10.00");
	}

	@description = "This is a test for COMMERCE-6230. Discount coupon code limitations"
	@priority = 3
	test LimitCouponCodeUsability {
		property portal.acceptance = "false";

		// TODO Review

		CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

		ApplicationsMenu.gotoSite(site = "Minium");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Account Management");

		CommerceAcceleratorsInitializer.createNewAccountViaFront(accountName = "account1");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Account Management");

		CommerceAcceleratorsInitializer.createNewAccountViaFront(accountName = "account2");

		CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Account Management");

		CommerceAcceleratorsInitializer.createNewAccountViaFront(accountName = "account3");

		CommerceNavigator.goToDiscountAdmin();

		Click(locator1 = "Button#PLUS");

		CommerceEntry.addNewDiscountsEntry(
			discountAmount = 10,
			discountName = "Test Discount",
			discountTarget = "Products",
			discountType = "Percentage");

		CommerceRelations.assignSingleRelationToProductsEntry(
			entryName = "U-Joint",
			title = "Add Products");

		Click(
			key_name = "Coupon Code",
			locator1 = "ToggleSwitch#ENABLE_SPECIFIC_TOGGLE_SWITCH");

		Type(
			key_fieldLabel = "Coupon Code",
			locator1 = "TextInput#GENERIC_TEXT_INPUT",
			value1 = "TEST");

		Type(
			key_fieldLabel = "Maximum Total Uses",
			locator1 = "TextInput#GENERIC_TEXT_INPUT",
			value1 = 2);

		Type(
			key_fieldLabel = "Maximum Uses Per Account",
			locator1 = "TextInput#GENERIC_TEXT_INPUT",
			value1 = 1);

		Button.clickPublish();

		ApplicationsMenu.gotoSite(site = "Minium");

		FrontStore.addInitializerProductToCart(
			productName = "U-Joint",
			productQuantity = 1);

		CommerceCheckout.gotoCheckout();

		CommerceAcceleratorsInitializer.addPortlet(portletName = "Coupon Code Entry");

		Type(
			locator1 = "TextInput#DISCOUNT",
			value1 = "TEST");

		Click(
			key_tab = "Apply",
			locator1 = "Button#TAB_SUBMIT_BTN");

		Type(
			key_fieldName = "Name",
			locator1 = "CommerceAccelerators#CHECKOUT_GENERIC_TEXT_INPUT",
			value1 = "Address Name");

		Type(
			key_fieldName = "Address",
			locator1 = "CommerceAccelerators#CHECKOUT_GENERIC_TEXT_INPUT",
			value1 = "Test Address");

		Select(
			key_fieldName = "Country",
			locator1 = "CommerceAccelerators#CHECKOUT_GENERIC_SELECT",
			value1 = "United States");

		Type(
			key_fieldName = "Zip",
			locator1 = "CommerceAccelerators#CHECKOUT_GENERIC_TEXT_INPUT",
			value1 = "Test Zip Code");

		Type(
			key_fieldName = "City",
			locator1 = "CommerceAccelerators#CHECKOUT_GENERIC_TEXT_INPUT",
			value1 = "Test City");

		Click(locator1 = "Button#CONTINUE");

		Click(
			key_radioOption = "Standard",
			locator1 = "CommerceEntry#RADIO_BUTTON");

		Click(locator1 = "Button#CONTINUE");

		WaitForElementPresent(
			key_subtotalValue = "21.60",
			locator1 = "CommerceAccelerators#CHECKOUT_SUMMARY_SUBTOTAL",
			value1 = "21.60");

		AssertTextEquals.assertPartialText(
			key_subtotalValue = "21.60",
			locator1 = "CommerceAccelerators#CHECKOUT_SUMMARY_SUBTOTAL",
			value1 = "21.60");

		Click(locator1 = "Button#CONTINUE");

		ApplicationsMenu.gotoSite(site = "Minium");

		Click.clickNoMouseOver(locator1 = "CommerceAccelerators#ACCOUNT_SELECTOR_DROPDOWN");

		Click(locator1 = "CommerceAccelerators#ACCOUNT_SELECTOR_DROPDOWN_BACK_BUTTON");

		Click(
			key_accountName = "account2",
