	@description = "Verify a Sales Manager can limit who can see the billing address associated with an account"
	@priority = 3
	test AssertPermissionToViewBillingAddressIsPresent {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "false";

		task ("Given a Minium site with a buyer user") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("When the admin goes to the Account Roles page") {
			Role.openRolesAdmin();

			CommerceEntry.gotoMenuTab(menuTab = "Account Roles");
		}

		task ("And clicks the buyer role") {
			LexiconEntry.gotoEntry(rowEntry = "Buyer");
		}

		task ("And goes to the Define Permissions tab") {
			CommerceEntry.gotoMenuTab(menuTab = "Define Permissions");
		}

		task ("Then the View Billing Address permission is present") {
			Role.viewPermissionCP(
				permissionDefinitionValue = "View Billing Address",
				permissionNavigationValue = "Open Carts > Orders:");
		}
	}

	@description = "This is a test for COMMERCE-6912. Bulk delete orders"
	@priority = 3
	test BulkDeleteOrders {
		property portal.acceptance = "false";

		task ("Given a Minium Site with an account is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Commerce Account",
				accountEntryType = "Business");
		}

		task ("And the admin navigates to the Minium and creates some orders") {
			ApplicationsMenu.gotoSite(site = "Minium");

			CommerceAcceleratorsInitializer.createNewOrderFromPendingOrders();

			WaitForVisible(locator1 = "CommerceOrders#PENDING_ORDERS_ORDER_ID");

			var getOrderId = selenium.getText("CommerceOrders#PENDING_ORDERS_ORDER_ID");

			CommerceAcceleratorsInitializer.createNewOrderFromPendingOrders();

			CommerceAcceleratorsInitializer.createNewOrderFromPendingOrders();

			CommerceAcceleratorsInitializer.createNewOrderFromPendingOrders();

			CommerceAcceleratorsInitializer.createNewOrderFromPendingOrders();
		}

		task ("And the admin navigates to the Orders and verifies that the Trash icon is not present in the header") {
			CommerceOrders.openOrdersAdmin();

			AssertElementNotPresent(locator1 = "Button#TRASH_ENABLED");
		}

		task ("When the admin selects all the orders using the bulk delete and verifies that the trash icon is present in the header") {
			if (IsElementPresent(locator1 = "CommerceNavigation#SELECT_ALL_CHECKBOX")) {
				Click.clickNoMouseOverNoWaitForVisible(locator1 = "CommerceNavigation#SELECT_ALL_CHECKBOX");
			}

			AssertElementPresent(locator1 = "Button#TRASH_ENABLED");
		}

		task ("Then the admin can remove all the orders by clicking on the Trash icon") {
			ClickNoError(locator1 = "Button#TRASH_ENABLED");

			AssertConfirm.assertPartialConfirmation(value1 = "Are you sure you want to delete all selected orders?");

			CommerceUtilities.checkSuccessAlertAppearsAndDisappears();

			AssertElementPresent(locator1 = "CommerceNavigation#EMPTY_SEARCH_CONTAINER");
		}
	}

	@description = "This is a test for COMMERCE-12716. As an admin, I can assert a placed order can be converted from processing to completed status via API"
	@priority = 3
	test CanAssertOrdersAreConvertedFromProcessingToCompletedViaAPI {
		property portal.acceptance = "false";

		task ("Given a Minium site with a business account") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			JSONAccountEntry.addAccountEntry(
				accountEntryName = "Commerce Account",
				accountEntryType = "Business");
		}

		task ("And a virtual product is created") {
			CommerceJSONProductsAPI._addCommerceProduct(
				catalogName = "Minium",
				productDescription = "Full Description",
				productName = "Virtual Product",
				productType = "Virtual",
				shortDescription = "Short Description",
				sku = "VIRTUALSKU");
		}

		task ("And the Money Order payment is activated") {
			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoTableListEntry(entryName = "Minium Portal");

			CommerceChannels.activatePaymentMethod(paymentMethod = "Money Order");
		}

		task ("And an order is placed") {
			CommerceJSONOrdersAPI._addCommerceOrder(
				accountEntryName = "Commerce Account",
				orderItems = "VIRTUALSKU:1",
				orderStatus = 1,
				paymentMethod = "money-order",
				paymentStatus = 2);
		}

		task ("And the admin accepts the order") {
			CommerceOrders.openOrdersAdmin();

			CommerceNavigator.gotoOrderEntryViaAdmin(status = "Pending");

			Click(
				key_text = "Accept Order",
				locator1 = "Link#ANY");

			Alert.viewSuccessMessage();

			CommerceOrders.openOrdersAdmin();

			AssertElementPresent(
				key_orderStatus = "Processing",
				locator1 = "CommerceOrders#ORDER_ELLIPSIS_BY_STATUS");
		}

		task ("When the order status is updated from Processing to Completed via API") {
			CommerceJSONOrdersAPI._patchCommerceOrder(orderStatus = 0);
		}

		task ("Then can also verify the status of the order is Completed via UI") {
			CommerceOrders.openOrdersAdmin();

			AssertElementPresent(
				key_orderStatus = "Completed",
				locator1 = "CommerceOrders#ORDER_ELLIPSIS_BY_STATUS");
		}
	}

	@description = "This is a test for the story COMMERCE-9217, with the testplan COMMERCE-9336 and test ticket COMMERCE-9358"
	@priority = 5
	test CanButtonRetryPaymentDisappearIfThePaymentMethodIsDisabled {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "true";

		task ("Given the Admin already created a Minium Site and a buyer account") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");

			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("Given the Admin has already configured Paypal as an active payment method and is configured into Sandbox with the Client ID and Client Secret") {
			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			CommerceChannels.activatePaymentMethod(paymentMethod = "PayPal");

			SelectFrame.selectFrameTop();

			CommerceChannels.configurationPaypal(mode = "Sandbox");

			SelectFrame.selectFrameTop();
		}

		task ("Given the Admin create an order using API and the Admin change the Payment Status to 'Authorized' but PayPal is disabled") {
			CommerceJSONOrdersAPI._addCommerceOrder(
				accountEntryName = "Commerce Account",
				orderStatus = 2,
				paymentMethod = "paypal-integration",
				paymentStatus = 2);

			CommerceJSONOrdersAPI._addCommerceOrderItem(productSKU = "MIN55861");

			CommerceOrders.openOrdersAdmin();

			var orderId = CommerceJSONOrdersAPI._getCommerceOrder();

			CommerceNavigator.gotoEntry(entryName = ${orderId});

			Button.click(button = "Check Out");

			CommerceEntry.gotoMenuTab(menuTab = "Payments");

			AssertElementPresent(
				locator1 = "CommerceEntry#ORDER_PAYMENT_STATUS",
				paymentStatus = "Authorized");

			AssertElementPresent(
				locator1 = "CommerceEntry#ORDER_PAYMENT_METHOD",
				paymentMethod = "PayPal");
		}

		task ("When the Buyer goes to Minium") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = PropsUtil.get("default.admin.password"),
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");
		}

		task ("And goes into the 'Placed Orders' page") {
			CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Placed Orders");
		}

		task ("Then the button 'Retry Payment' and 'Reorder' is present because PayPal is active") {
			Click(
				key_orderAuthor = "Commerce Account",
				locator1 = "CommerceAccelerators#ORDERS_ENTRY_VIEW_BUTTON");

			AssertElementPresent(
				key_orderStatus = "In Progress",
				locator1 = "CommerceOrders#PENDING_ORDERS_ORDER_STATUS");

			AssertElementPresent(
				key_text = "Retry Payment",
				locator1 = "Button#ANY");

			AssertElementPresent(
				key_text = "Reorder",
				locator1 = "Button#ANY");
		}

		task ("When the Admin disable Paypal ") {
			User.logoutPG();

			User.firstLoginPG();

			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			CommerceChannels.disablePaymentMethod(paymentMethod = "PayPal");
		}

		task ("And the Buyer goes back to Minium") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = PropsUtil.get("default.admin.password"),
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");
		}

		task ("And goes into the 'Placed Orders' page") {
			CommerceNavigator.gotoMiniumSidebarItem(menuItem = "Placed Orders");
		}

		task ("Then the button 'Retry Payment' is not present because PayPal is disabled") {
			Click(
				key_orderAuthor = "Commerce Account",
				locator1 = "CommerceAccelerators#ORDERS_ENTRY_VIEW_BUTTON");

			AssertElementPresent(
				key_orderStatus = "In Progress",
				locator1 = "CommerceOrders#PENDING_ORDERS_ORDER_STATUS");

			AssertElementNotPresent(
				key_text = "Retry Payment",
				locator1 = "Button#ANY");
		}

		task ("But the 'Reorder' is present") {
			AssertElementPresent(
				key_text = "Reorder",
				locator1 = "Button#ANY");
		}
	}

	@description = "This is a test for COMMERCE-11386. As admin, I can cancel an order without getting an error in the log."
