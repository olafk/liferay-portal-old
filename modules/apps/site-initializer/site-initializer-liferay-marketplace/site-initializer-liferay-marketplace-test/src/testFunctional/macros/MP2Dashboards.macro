definition {

	@summary = "Default summary"
	macro assertNoResendInvitationButton() {
		AssertElementNotPresent(locator1 = "MP2Dashboards#RESEND_INVITATION");
	}

	@summary = "Default summary"
	macro assertResendInvitationButton() {
		AssertElementPresent(locator1 = "MP2Dashboards#RESEND_INVITATION");
	}

	@summary = "Default summary"
	macro clickBreadcrumb(accountTitle = null) {
		var key_accountTitle = ${accountTitle};

		Click(locator1 = "MP2Dashboards#SVG_DROPDOWN");

		Click(
			key_accountTitle = ${accountTitle},
			locator1 = "MP2Dashboards#SVG_DROPDOWN_LIST");
	}

	@summary = "Default summary"
	macro clickNewMemberButton(buttonName = null) {
		Click(
			key_buttonName = ${buttonName},
			locator1 = "MP2Dashboards#ANY_DASHBOARD_BUTTON");
	}

	@summary = "Default summary"
	macro clickOnTheInvitedUser(label = null, value = null) {
		Click(
			key_label = ${label},
			key_text = ${value},
			locator1 = "MP2Dashboards#DASHBOARD_TABLE");
	}

	@summary = "Default summary"
	macro clickOnTheResendInvitationButton() {
		Click(locator1 = "MP2Dashboards#RESEND_INVITATION");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro inviteNewMember(firstName = null, lastName = null, emailAddress = null, checkboxName = null) {
		MP2Dashboards.clickNewMemberButton(buttonName = "New Member");

		WaitForPageLoad();

		MP2Dashboards.typeNewMemberInfoFields(
			field = "firstName",
			fieldInput = ${firstName});

		MP2Dashboards.typeNewMemberInfoFields(
			field = "lastName",
			fieldInput = ${lastName});

		MP2Dashboards.typeNewMemberInfoFields(
			field = "emailAddress",
			fieldInput = ${emailAddress});

		MP2Utils.selectCheckbox(checkboxName = ${checkboxName});

		if (isSet(button)) {
			Button.click(button = "Send Invite");
		}

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro typeNewMemberInfoFields(field = null, fieldInput = null) {
		Type(
			key_field = ${field},
			locator1 = "MP2Dashboards#SETUP_FIELDS",
			value1 = ${fieldInput});
	}

	@summary = "Default summary"
	macro viewNewMemberButtonNotPresent() {
		AssertElementNotPresent(locator1 = "MP2Dashboards#ANY_DASHBOARD_BUTTON");
	}

}