definition {

	@summary = "Default summary"
	macro addProductVersionInBuild(key_name = null) {
		Click(locator1 = "Button#PLUS");

		Type(
			locator1 = "Testray#FIELD_NAME_MODAL",
			value1 = ${key_name});

		Click(locator1 = "Modal#SAVE_BUTTON");
	}

	@summary = "Default summary"
	macro changeTeamToComponent(tableEntry = null, newTeamName = null) {
		TestrayManage.selectTableRowOption(
			rowOption = "Edit",
			tableEntry = ${tableEntry});

		Select(
			key_fieldLabel = "Team",
			locator1 = "Select#GENERIC_SELECT_FIELD",
			value1 = ${newTeamName});

		Button.clickSave();
	}

	@summary = "Default summary"
	macro clickOptionSidebar(optionSidebar = null) {
		Click(
			key_button = ${optionSidebar},
			locator1 = "TestrayDropdown#SIDEBAR_CONTENT");
	}

	@summary = "Default summary"
	macro createCaseTypes(caseTypeName = null) {
		Click(locator1 = "Testray#MODAL_PLUS");

		if (isSet(caseTypeName)) {
			PortletEntry.inputName(name = ${caseTypeName});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro createComponent(teamName = null, componentName = null) {
		SelectFrame(locator1 = "Testray#MODAL_BODY");

		Click(locator1 = "Testray#MODAL_PLUS");

		if (isSet(componentName)) {
			PortletEntry.inputName(name = ${componentName});
		}

		if (isSet(teamName)) {
			Select(
				key_fieldLabel = "Team",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = ${teamName});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro createNewCategory(category = null) {
		Click(locator1 = "Testray#MODAL_PLUS");

		if (isSet(category)) {
			PortletEntry.inputName(name = ${category});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro createNewOption(category = null, option = null) {
		Click(locator1 = "Testray#MODAL_PLUS");

		PortletEntry.inputName(name = ${option});

		if (isSet(category)) {
			Select(
				locator1 = "Select#SELECT_ID",
				selectFieldId = "factorCategoryId",
				value1 = ${category});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro createProductVersion(productVersion = null) {
		Click(locator1 = "Testray#MODAL_PLUS");

		if (isSet(productVersion)) {
			PortletEntry.inputName(name = ${productVersion});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro createTeam(teamName = null, component = null) {
		Click(locator1 = "Testray#MODAL_PLUS");

		if (isSet(teamName)) {
			PortletEntry.inputName(name = ${teamName});
		}

		if (isSet(component)) {
			Click(
				key_parameterType = "Unassigned",
				locator1 = "Testray#PARAMETER_TYPE_OPTIONS",
				value1 = ${component});

			Click(
				key_arrowDirection = "Right",
				key_parameterType = "Unassigned",
				locator1 = "Testray#ARROW_DIRECTION");
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro deleteAllCasesTypes() {
		Refresh();

		TestrayDropdown.selectOptionSidebar(
			buttonOption = "Manage",
			menuItem = "Case Types");

		Testray.changePagination(
			modal = "true",
			quantity = 150);

		while (IsElementPresent(key_tableEntry = "Case_", locator1 = "Testray#TABLE_ENTRY")) {
			TestrayManage.selectTableRowOption(
				rowOption = "Delete",
				tableEntry = "Case_");

			AssertConfirm(value1 = "Are you sure you want to delete this item?");

			Alert.viewSuccessMessage();

			Testray.checkSuccessAlertAppearsAndDisappears();
		}
	}

	@summary = "Default summary"
	macro deleteAllCategories() {
		Refresh();

		TestrayDropdown.selectOptionSidebar(
			buttonOption = "Manage",
			menuItem = "Categories");

		while (IsElementPresent(key_tableEntry = "Environments_", locator1 = "Testray#TABLE_ENTRY")) {
			TestrayManage.selectTableRowOption(
				rowOption = "Delete",
				tableEntry = "Environments_");

			AssertConfirm(value1 = "Are you sure you want to delete this item?");

			Alert.viewSuccessMessage();

			Testray.checkSuccessAlertAppearsAndDisappears();
		}
	}

	@summary = "Default summary"
	macro deleteCasesTypes(tableEntry = null) {
		TestrayManage.selectTableRowOption(
			rowOption = "Delete",
			tableEntry = ${tableEntry});

		AssertConfirm(value1 = "Are you sure you want to delete this item?");

		Alert.viewSuccessMessage();

		Testray.checkSuccessAlertAppearsAndDisappears();
	}

	@summary = "Default summary"
	macro deleteCategory(categoryName = null) {
		TestrayDropdown.selectOptionSidebar(
			buttonOption = "Manage",
			menuItem = "Categories");

		TestrayManage.selectTableRowOption(
			rowOption = "Delete",
			tableEntry = ${categoryName});

		AssertConfirm(value1 = "Are you sure you want to delete this item?");

		Alert.viewSuccessMessage();

		Testray.checkSuccessAlertAppearsAndDisappears();
	}

	@summary = "Default summary"
	macro editCaseType(newName = null, tableEntry = null) {
		TestrayManage.selectTableRowOption(
			rowOption = "Edit",
			tableEntry = ${tableEntry});

		if (isSet(newName)) {
			PortletEntry.inputName(name = ${newName});
		}

		Button.clickSave();

		Testray.checkSuccessAlertAppearsAndDisappears();
	}

	@summary = "Default summary"
	macro editCategory(newName = null, tableEntry = null) {
		TestrayManage.selectTableRowOption(
			rowOption = "Edit",
			tableEntry = ${tableEntry});

		PortletEntry.inputName(name = ${newName});

		Button.clickSave();
	}

	@summary = "Default summary"
	macro editComponent(newComponentName = null, tableEntry = null, newTeamName = null) {
		TestrayManage.selectTableRowOption(
			rowOption = "Edit",
			tableEntry = ${tableEntry});

		if (isSet(newComponentName)) {
			PortletEntry.inputName(name = ${newComponentName});
		}

		if (isSet(newTeamName)) {
			Select(
				key_fieldLabel = "Team",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = ${newTeamName});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro editOption(newName = null, tableEntry = null, category = null) {
		TestrayManage.selectTableRowOption(
			rowOption = "Edit",
			tableEntry = ${tableEntry});

		PortletEntry.inputName(name = ${newName});

		if (isSet(category)) {
			Select(
				locator1 = "Select#SELECT_ID",
				selectFieldId = "factorCategoryId",
				value1 = ${category});
		}

		Button.clickSave();

		Testray.checkSuccessAlertAppearsAndDisappears();
	}

	@summary = "Default summary"
	macro editProductVersion(newName = null, tableEntry = null) {
		TestrayManage.selectTableRowOption(
			rowOption = "Edit",
			tableEntry = ${tableEntry});

		PortletEntry.inputName(name = ${newName});

		Button.clickSave();
	}

	@summary = "Default summary"
	macro editTeam(newName = null, tableEntry = null) {
		TestrayManage.selectTableRowOption(
			rowOption = "Edit",
			tableEntry = ${tableEntry});

		if (isSet(newName)) {
			PortletEntry.inputName(name = ${newName});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro selectTableRowOption(tableEntry = null, rowOption = null) {
		WaitForElementPresent(
			key_tableEntry = ${tableEntry},
			locator1 = "Testray#TABLE_ENTRY");

		RightClick.rightClick(
			key_tableEntry = ${tableEntry},
			locator1 = "Testray#TABLE_ENTRY");

		MenuItem.clickNoError(menuItem = ${rowOption});
	}

}