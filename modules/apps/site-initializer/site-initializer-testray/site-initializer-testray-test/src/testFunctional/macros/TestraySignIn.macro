definition {

	@summary = "Default summary"
	macro assertTitleFailed(key_title = null) {
		AssertElementPresent(
			key_fieldName = ${key_title},
			locator1 = "TestrayUser#TITLE_FAILED");
	}

	@summary = "Default summary"
	macro assertTitleSucess(key_title = null) {
		AssertElementPresent(
			key_fieldName = ${key_title},
			locator1 = "TestrayUser#TITLE_SUCCESS");
	}

	@summary = "Default summary"
	macro changePassword(newPassword = null, confirmPassword = null, currentPassword = null) {
		if (isSet(currentPassword)) {
			Type(
				locator1 = "TextInput#CURRENT_PASSWORD",
				value1 = ${currentPassword});
		}

		if (isSet(newPassword)) {
			Type(
				locator1 = "TextInput#NEW_PASSWORD",
				value1 = ${newPassword});
		}

		if (isSet(confirmPassword)) {
			Type(
				locator1 = "TestrayUser#CONFIRM_PASSWORD",
				value1 = ${confirmPassword});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro loginUserTestrayPG(emailAddress = null, password = null) {
		if (isSet(emailAddress)) {
			Type(
				locator1 = "TextInput#TEXT",
				value1 = ${emailAddress});
		}

		if (isSet(password)) {
			Type(
				locator1 = "TextInput#PASSWORD_TYPE",
				value1 = ${password});
		}

		if (isSet(rememberMe)) {
			Check(locator1 = "Checkbox#REMEMBER_ME");
		}

		Button.click(button = "Sign In");
	}

}