definition {

	@summary = "Default summary"
	macro assertGraphValue(number = null) {
		AssertElementPresent(
			locator1 = "TestrayResults#TOTAL_TEST",
			value1 = ${number});
	}

	@summary = "Default summary"
	macro assertIssue(issue = null, label = null) {
		AssertElementPresent(
			key_issue = ${issue},
			key_label = ${label},
			locator1 = "TestrayResults#ISSUE_WITH_LABEL");
	}

}