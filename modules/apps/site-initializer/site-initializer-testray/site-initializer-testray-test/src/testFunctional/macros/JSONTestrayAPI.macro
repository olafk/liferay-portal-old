	@summary = "Default summary"
	macro createRunAPI(runName = null, buildId = null) {
		Variables.assertDefined(parameterList = "${runName},${buildId}");

		if (!(isSet(runNumber))) {
			var runNumber = 01;
		}

		var portalURL = JSONCompany.getPortalURL();

		var curl = '''
			${portalURL}/o/c/runs \
				-u test@liferay.com:test \
				-H 'accept: application/json' \
				-H 'Content-Type: application/json' \
				-d '{
					"name": "${runName}",
					"r_buildToRuns_c_buildId": "${buildId}"
				}'
		''';

		var response = JSONCurlUtil.post(${curl}, "$.id");

		echo(${response});

		return ${response};
	}

	@summary = "Default summary"
	macro createSubtaskAPI(subtaskName = null, statusSubtask = null, key = null, taskId = null) {
		Variables.assertDefined(parameterList = ${subtaskName});

		var portalURL = JSONCompany.getPortalURL();

		if (!(isSet(subtaskNumber))) {
			var subtaskNumber = "";
		}

		if (!(isSet(score))) {
			var score = "";
		}

		if (!(isSet(messageError))) {
			var messageError = "";
		}

		var curl = '''
			${portalURL}/o/c/subtasks \
				-u test@liferay.com:test \
				-H 'accept: application/json' \
				-H 'Content-Type: application/json' \
				-d '{
					"dueStatus": {
						"key": "${key}",
						"name": "${statusSubtask}"
					},
					"errors": "${messageError}",
					"number": "${subtaskNumber}",
					"score": "${score}",
					"name": "${subtaskName}",
					"r_taskToSubtasks_c_taskId": "${taskId}"
				}'
		''';

		var response = JSONCurlUtil.post(${curl}, "$.id");

		echo(${response});

		return ${response};
	}

	@summary = "Default summary"
	macro createSuiteAPI(projectId = null, suiteName = null) {
