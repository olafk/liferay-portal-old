definition {

	@summary = "Default summary"
	macro assertMergedSubtasks(listSubtaskName = null) {
		for (var subtaskName : list ${listSubtaskName}) {
			AssertElementPresent(
				key_subtaskName = ${subtaskName},
				locator1 = "TestraySubtask#SUBTASK_MERGED");
		}
	}

	@summary = "Default summary"
	macro assertNotMergedSubtasks(subtaskName = null) {
		AssertElementNotPresent(
			key_subtaskName = ${subtaskName},
			locator1 = "TestraySubtask#SUBTASK_MERGED");
	}

	@summary = "Default summary"
	macro mergeSubtasks(listSubtaskName = null) {
		for (var subtaskName : list ${listSubtaskName}) {
			Check.checkToggleSwitch(
				key_checkboxOption = ${subtaskName},
				locator1 = "Checkbox#SPECIFIC_CHECKBOX_IN_TABLE");
		}

		if (isSet(buttonClear)) {
			Click(
				key_indexNumber = 2,
				key_text = "Clear",
				locator1 = "Button#ANY_N");
		}

		Button.click(button = "Merge Subtasks");
	}

	@summary = "Default summary"
	macro verifySubtaskDetails(score = null, comment = null, userName = null, issues = null, updated = null, status = null) {
		AssertElementPresent(
			key_comment = ${comment},
			key_issues = ${issues},
			key_score = ${score},
			key_status = ${status},
			key_updated = ${updated},
			key_userName = ${userName},
			locator1 = "TestraySubtask#SUBTASK_DETAILS");
	}

	@summary = "Default summary"
	macro viewSubtaskSidebar(listsubtaskName = null) {
		for (var subtaskName : list ${listsubtaskName}) {
			AssertElementPresent(
				key_subtaskName = ${subtaskName},
				locator1 = "TestraySubtask#SUBTASK_SIDEBAR");
		}
	}

}