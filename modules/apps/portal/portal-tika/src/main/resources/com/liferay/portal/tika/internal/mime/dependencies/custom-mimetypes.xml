<?xml version="1.0"?>

<mime-info>
	<mime-type type="application/gpx+xml">
		<glob pattern="*.gpx" />
	</mime-type>
	<mime-type type="application/javascript">
		<glob pattern="*.js" />
	</mime-type>
	<mime-type type="application/zip">
		<glob pattern="*.lar" />
	</mime-type>
	<mime-type type="text/calendar">
		<glob pattern="*.ics" />
	</mime-type>
</mime-info>