			JSONAccountEntry.addAccountEntry(
				accountEntryName = "B Chocolate Factory",
				accountEntryType = "Business");

			Account.openAccountsAdmin();

			LexiconEntry.gotoEntry(rowEntry = "B Chocolate Factory");

			Account.addOwnedAccountRole(accountRoleTitle = "Account Specific Role");
		}

		task ("When a user searches for an account role in the Roles tab of an account") {
			Account.openAccountsAdmin();

			LexiconEntry.gotoEntry(rowEntry = "B Chocolate Factory");

			Navigator.gotoNavTab(navTab = "Roles");

			Search.searchCP(searchTerm = "Account Specific Role");
