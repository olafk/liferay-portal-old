	@description = "This test replaces user in Person Account with another existing user. It asserts that first user was replaced by the second user and isn't assigned to the account anymore."
	@priority = 4
	test SelectingUserWillReplaceExistingUserInPersonAccount {
		property portal.acceptance = "true";

		JSONAccountEntry.addAccountEntry(
			accountEntryName = "Business Account",
			accountEntryType = "Business");

		JSONAccountEntry.addAccountEntry(
			accountEntryName = "Person Account",
			accountEntryType = "Person");

		for (var accountUser : list "1,2") {
			AccountUsers.openAccountUsersAdmin();

			AccountUsers.addUser(
				accountName = "Business Account",
				userEmailAddress = "userea${accountUser}@liferay.com",
				userFirstName = "userfn${accountUser}",
				userLastName = "userln${accountUser}",
				userScreenName = "usersn${accountUser}");
		}

		Account.openAccountsAdmin();

		Account.gotoEdit(accountName = "Person Account");

		for (var navTab : list "Details,Organizations,Roles") {
			Account.viewAssigneeTab(navTab = ${navTab});
		}

		Account.viewNoAssigneeTab(navTab = "Users");

		Account.assignExistingUserToPersonAccount(accountUserName = "userfn1");

		Account.openAccountsAdmin();

		Account.gotoEdit(accountName = "Person Account");

		Account.assignExistingUserToPersonAccount(accountUserName = "userfn2");

		AssertElementNotPresent(
			key_userName = "userfn1",
			locator1 = "Account#USER_TABLE_NAME");
	}

	@description = "This is a use case for LPS-177878. TC-1: Verify Service Accounts portlet in CP, no password section,screen name cannot change,roles can assigned removed."
	@priority = 4
	test ServiceAccountsSmoke {
		task ("Given go to service accounts in control panel assert all section except password") {
			ApplicationsMenu.gotoPortlet(
				category = "Users",
				panel = "Control Panel",
				portlet = "Service Accounts");

			UserNavigator.gotoEdit(rowEntry = "default-service-account default-service-account");

			User.assertSection(sectionName = "Information,Organizations,Memberships,Roles,Profile and Dashboard,Apps");

			AssertElementNotPresent(
				key_assetTitle = "Password",
				locator1 = "NavBar#ASSET_TITLE");
		}

		task ("And screen name cannot be changed") {
			User.assertScreenNameDisabled();
		}

		task ("When assigned or removed roles") {
			ApplicationsMenu.gotoPortlet(
				category = "Users",
				panel = "Control Panel",
				portlet = "Service Accounts");

			User.assignRegularRoleCP(
				roleTitle = "Portal Content Reviewer",
				userScreenName = "default-service-account");
		}

		task ("Then roles can be assigned or removed from the default service account") {
			ApplicationsMenu.gotoPortlet(
				category = "Users",
				panel = "Control Panel",
				portlet = "Service Accounts");

			User.unassignRegularRoleCP(
				regularRoleName = "Portal Content Reviewer",
				userScreenName = "default-service-account");
		}
	}

