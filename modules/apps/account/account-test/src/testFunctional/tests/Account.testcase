			LexiconEntry.viewNoEntry(rowEntry = "userfn2 userln2");
		}
	}

	@description = "This test asserts accurate results when searching for available organizations in Assign Organizations to account modal"
	@priority = 4
	test CanSearchInAssignOrganizationsToAccountModal {
