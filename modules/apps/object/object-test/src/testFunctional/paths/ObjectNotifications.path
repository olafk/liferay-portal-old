<html>
<head>
<title>ObjectNotifications</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">ObjectNotifications</td></tr>
</thead>

<tbody>
	<tr>
		<td>NOTIFICATION_STATUS</td>
		<td>//div[@class='dnd-td']//strong[contains(.,'${key_statusName}')]</td>
		<td></td>
	</tr>
	<tr>
		<td>DELETE_NOTIFICATION_IN_QUEUE</td>
		<td>//div[@class='dnd-td'][contains(.,'${key_text}')]//following-sibling::div//*[contains(@class, 'icon-trash')]</td>
		<td></td>
	</tr>
	<tr>
		<td>DATA_SOURCE_ATTACHMENTS</td>
		<td>//div[@tabindex='0']//span[contains(.,'${key_dataSource}')]</td>
		<td></td>
	</tr>
	<tr>
		<td>FIELD_ATTACHMENTS_OBJECT</td>
		<td>//div[@class='input-group-item']//div[@class="form-control form-control-tag-group input-group"]</td>
		<td></td>
	</tr>
	<tr>
		<td>FIELD_ATTACHMENTS_OBJECT_SELECT_FIELD</td>
		<td>//span[@class='custom-control-label']//span[@class="custom-control-label-text"]</td>
		<td></td>
	</tr>
	<tr>
		<td>DELETE_ATTACHMENT_BUTTON</td>
		<td>//*[@class='lexicon-icon lexicon-icon-times-small']</td>
		<td></td>
	</tr>
	<tr>
		<td>VIEW_NOTIFICATION_ENTRIES</td>
		<td>//div[contains(@class,'dnd-tbody')]//*[contains(text(),'${key_entryLabel}')]/ancestor::div//*[contains(@class,'dnd-tbody')]//*[contains(text(),'${key_entryStatus}')]</td>
		<td></td>
	</tr>
	<tr>
		<td>ENTITY_TERMS</td>
		<td>//div[contains(@class,'dnd-td') and contains(text(),'${key_termName}')]</td>
		<td></td>
	</tr>
	<tr>
		<td>RECIPIENT_TYPE</td>
		<td>//div[contains(@class,'autocomplete-dropdown-menu')]//div[contains(text(),'${key_recipientType}')]</td>
		<td></td>
	</tr>
</tbody>
</table>
</body>
</html>