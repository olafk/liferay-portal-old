{
	"$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
	"appliesTo": [
		"bpmn:IntermediateCatchEvent",
		"bpmn:IntermediateThrowEvent"
	],
	"category": {
		"id": "connectors",
		"name": "Connectors"
	},
	"description": "Receive events from Liferay.",
	"elementType": {
		"eventDefinition": "bpmn:MessageEventDefinition",
		"value": "bpmn:IntermediateCatchEvent"
	},
	"engines": {
		"camunda": "^8.3"
	},
	"groups": [
		{
			"id": "endpoint",
			"label": "Webhook Configuration"
		},
		{
			"id": "authentication",
			"label": "Authentication"
		},
		{
			"id": "authorization",
			"label": "Authorization"
		},
		{
			"id": "webhookResponse",
			"label": "Webhook response"
		},
		{
			"id": "activation",
			"label": "Activation"
		},
		{
			"id": "correlation",
			"label": "Correlation",
			"tooltip": "Learn more about message correlation in the <a href=\"https://docs.camunda.io/docs/components/concepts/messages/#message-correlation-overview\">in the Camunda documentation</a>."
		},
		{
			"id": "output",
			"label": "Output Mapping"
		}
	],
	"icon": {
		"contents": "data:image/svg+xml;base64,"
	},
	"id": "io.camunda.connectors.webhook.WebhookConnectorIntermediate.v1",
	"metadata": {
		"keywords": [
		]
	},
	"name": "Webhook Intermediate Event Connector",
	"properties": [
		{
			"binding": {
				"name": "inbound.type",
				"type": "zeebe:property"
			},
			"type": "Hidden",
			"value": "io.camunda:webhook:1"
		},
		{
			"binding": {
				"name": "inbound.method",
				"type": "zeebe:property"
			},
			"description": "Select an HTTP method.",
			"group": "endpoint",
			"id": "inbound.method",
			"label": "Webhook Method",
			"optional": false,
			"type": "Hidden",
			"value": "any"
		},
		{
			"binding": {
				"name": "inbound.context",
				"type": "zeebe:property"
			},
			"constraints": {
				"notEmpty": true,
				"pattern": {
					"message": "can only contain letters, numbers, or single underscores/hyphens and cannot begin or end with an underscore/hyphen",
					"value": "^[a-zA-Z0-9]+([-_][a-zA-Z0-9]+)*$"
				}
			},
			"description": "The webhook ID is part of the URL.",
			"group": "endpoint",
			"id": "inbound.context",
			"label": "Webhook ID",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "inbound.auth.type",
				"type": "zeebe:property"
			},
			"choices": [
				{
					"name": "None",
					"value": "NONE"
				},
				{
					"name": "Secret",
					"value": "APIKEY"
				}
			],
			"description": "Choose the authorization type.",
			"group": "authorization",
			"id": "inbound.auth.type",
			"label": "Authorization Type",
			"type": "Dropdown",
			"value": "NONE"
		},
		{
			"binding": {
				"name": "inbound.auth.apiKey",
				"type": "zeebe:property"
			},
			"condition": {
				"equals": "APIKEY",
				"property": "inbound.auth.type",
				"type": "simple"
			},
			"description": "Enter the expected secret.",
			"feel": "optional",
			"group": "authorization",
			"id": "inbound.auth.apiKey",
			"label": "Secret",
			"optional": false,
			"type": "String"
		},
		{
			"binding": {
				"name": "inbound.auth.apiKeyLocator",
				"type": "zeebe:property"
			},
			"condition": {
				"equals": "APIKEY",
				"property": "inbound.auth.type",
				"type": "simple"
			},
			"constraints": {
				"notEmpty": true
			},
			"description": "Enter a FEEL expression that extracts a secret (e.g., API key or token) from the request body or headers.",
			"feel": "required",
			"group": "authorization",
			"id": "inbound.auth.apiKeyLocator",
			"label": "Secret Locator",
			"optional": false,
			"type": "String",
			"value": "=get value(request.headers, \"x-api-key\")"
		},
		{
			"binding": {
				"name": "inbound.responseExpression",
				"type": "zeebe:property"
			},
			"description": "Enter the expression used to generate the HTTP response.",
			"feel": "required",
			"group": "webhookResponse",
			"id": "inbound.responseExpression",
			"label": "Response Expression",
			"optional": true,
			"type": "Text"
		},
		{
			"binding": {
				"name": "activationCondition",
				"type": "zeebe:property"
			},
			"description": "Enter the condition to trigger the connector. Leave this empty to catch all events. triggers. Leave empty to catch all events.",
			"feel": "required",
			"group": "activation",
			"id": "activationCondition",
			"label": "Activation Condition",
			"optional": true,
			"type": "String"
		},
		{
			"binding": {
				"name": "consumeUnmatchedEvents",
				"type": "zeebe:property"
			},
			"group": "activation",
			"id": "consumeUnmatchedEvents",
			"label": "Consume Unmatched Events",
			"tooltip": "Unmatched events are rejected by default, allowing the upstream service to handle the error. Check this box to consume unmatched events and return a success response.",
			"type": "Boolean",
			"value": true
		},
		{
			"binding": {
				"name": "correlationKey",
				"type": "bpmn:Message#zeebe:subscription#property"
			},
			"constraints": {
				"notEmpty": true
			},
			"description": "Use process variables to set the correlation key expression.",
			"feel": "required",
			"group": "correlation",
			"id": "correlationKeyProcess",
			"label": "Correlation Key (Process)",
			"type": "String"
		},
		{
			"binding": {
				"name": "correlationKeyExpression",
				"type": "zeebe:property"
			},
			"constraints": {
				"notEmpty": true
			},
			"description": "Extracts the correlation key from the incoming message payload.",
			"feel": "required",
			"group": "correlation",
			"id": "correlationKeyPayload",
			"label": "Correlation Key (Payload)",
			"type": "String"
		},
		{
			"binding": {
				"name": "messageIdExpression",
				"type": "zeebe:property"
			},
			"description": "EEnter an expression to extract the unique identifier of a message. message.",
			"feel": "required",
			"group": "correlation",
			"id": "messageIdExpression",
			"label": "Message ID Expression",
			"optional": true,
			"type": "String"
		},
		{
			"binding": {
				"name": "messageTtl",
				"type": "zeebe:property"
			},
			"constraints": {
				"notEmpty": false,
				"pattern": {
					"message": "must be an ISO-8601 duration",
					"value": "^(PT.*|)$"
				}
			},
			"description": "Set the lifespan (time-to-live) of the broker message as an ISO-8601 duration.-8601 duration).",
			"feel": "optional",
			"group": "correlation",
			"id": "messageTtl",
			"label": "Message Lifespan (Time-To-Live)",
			"optional": true,
			"type": "String"
		},
		{
			"binding": {
				"name": "name",
				"type": "bpmn:Message#property"
			},
			"generatedValue": {
				"type": "uuid"
			},
			"group": "correlation",
			"id": "messageNameUuid",
			"type": "Hidden"
		},
		{
			"binding": {
				"name": "resultVariable",
				"type": "zeebe:property"
			},
			"description": "Set the name of the variable that stores the response.",
			"group": "output",
			"id": "resultVariable",
			"label": "Result Variable",
			"type": "String"
		},
		{
			"binding": {
				"name": "resultExpression",
				"type": "zeebe:property"
			},
			"description": "Enter an expression to map the response into process variables.bles.",
			"feel": "required",
			"group": "output",
			"id": "resultExpression",
			"label": "Result Expression",
			"type": "Text"
		}
	],
	"version": 1
}